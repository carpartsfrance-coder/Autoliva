<%- include('../partials/head') %>
<%- include('../partials/promo-banner') %>

<%- include('../partials/header') %>

<div id="readingProgress" class="fixed top-0 left-0 h-0.5 bg-primary z-50 transition-all duration-150" style="width:0%"></div>

<main class="flex-1 bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 transition-colors duration-300">
  <div class="container mx-auto px-4 lg:px-8 py-4">

    <nav class="flex items-center gap-2 text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-4">
      <a class="hover:text-primary transition-colors" href="/">Accueil</a>
      <span class="material-symbols-outlined text-[12px]">chevron_right</span>
      <a class="hover:text-primary transition-colors" href="/blog">Blog</a>
      <% if (post && post.category && post.category.label) { %>
        <span class="material-symbols-outlined text-[12px]">chevron_right</span>
        <span class="text-slate-600 dark:text-slate-200"><%= post.category.label %></span>
      <% } %>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      <div class="lg:col-span-8">
        <article class="bg-white dark:bg-surface-dark rounded-xl shadow-sm border border-slate-100 dark:border-slate-800 overflow-hidden">
          <% if (post && post.coverImageUrl) { %>
            <img alt="<%= post.title %>" class="w-full h-72 object-cover" src="<%= post.coverImageUrl %>" loading="eager" width="1200" height="288" fetchpriority="high"/>
          <% } %>

          <div class="p-6 lg:p-8">
            <div class="flex items-center flex-wrap gap-4 text-[11px] text-slate-400 font-bold uppercase tracking-wider mb-3">
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-sm text-primary">person</span>
                Par <%= post && post.authorName ? post.authorName : brand.NAME_SHORT %>
              </span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-sm text-primary">calendar_today</span>
                <%= post && post.dateLabel ? post.dateLabel : '' %>
              </span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-sm text-primary">schedule</span>
                <%= post && post.readingTimeLabel ? post.readingTimeLabel : '' %>
              </span>
            </div>

            <h1 class="text-3xl lg:text-4xl font-display font-bold text-slate-900 dark:text-white mb-6 leading-tight"><%= post && post.title ? post.title : '' %></h1>

            <% if (post && post.excerpt) { %>
              <div class="bg-slate-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl p-4 mb-6">
                <p class="text-sm text-slate-700 dark:text-slate-200 leading-relaxed font-medium"><%= post.excerpt %></p>
              </div>
            <% } %>

            <div class="prose dark:prose-invert max-w-none article-content">
              <%- post && post.contentHtml ? post.contentHtml : '' %>
            </div>

            <!-- Gros CTA fin d'article : capture lead avec contexte produit/sujet -->
            <% var _ctaTopic = post && post.category && post.category.label ? post.category.label : (post && post.seo && post.seo.primaryKeyword ? post.seo.primaryKeyword : ''); %>
            <div id="blog-end-cta" class="mt-10 rounded-2xl border-2 border-red-100 bg-gradient-to-br from-red-50 via-white to-red-50/50 p-6 lg:p-8 relative overflow-hidden">
              <div class="absolute -right-8 -top-8 w-40 h-40 bg-red-100/40 rounded-full"></div>
              <div class="absolute -left-10 -bottom-10 w-48 h-48 bg-amber-50/50 rounded-full"></div>

              <div class="relative z-10">
                <div class="inline-flex items-center gap-1.5 bg-red-100 text-red-700 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest mb-3">
                  <span class="material-symbols-outlined" style="font-size:14px">verified</span>
                  Aide technique offerte
                </div>

                <h2 class="text-2xl lg:text-3xl font-display font-black text-slate-900 leading-tight">
                  <% if (_ctaTopic) { %>
                    Besoin d'aide concernant <%= _ctaTopic %> ?
                  <% } else { %>
                    Besoin d'un avis technique sur votre véhicule ?
                  <% } %>
                </h2>

                <p class="mt-2 text-slate-600 text-sm lg:text-base leading-relaxed max-w-2xl">
                  Notre équipe technique vérifie gratuitement la compatibilité avec votre véhicule (VIN/immatriculation), vous envoie un devis personnalisé sous 24h et vous accompagne jusqu'au remontage. Garantie jusqu'à 2&nbsp;ans*.
                </p>

                <div class="mt-5 grid grid-cols-2 sm:grid-cols-4 gap-3">
                  <div class="bg-white rounded-lg border border-slate-100 p-3">
                    <span class="material-symbols-outlined text-green-600" style="font-size:20px">check_circle</span>
                    <div class="text-[11px] font-bold text-slate-700 mt-1 leading-tight">Vérification VIN</div>
                  </div>
                  <div class="bg-white rounded-lg border border-slate-100 p-3">
                    <span class="material-symbols-outlined text-green-600" style="font-size:20px">schedule</span>
                    <div class="text-[11px] font-bold text-slate-700 mt-1 leading-tight">Devis 24h</div>
                  </div>
                  <div class="bg-white rounded-lg border border-slate-100 p-3">
                    <span class="material-symbols-outlined text-green-600" style="font-size:20px">shield</span>
                    <div class="text-[11px] font-bold text-slate-700 mt-1 leading-tight">Garantie 2 ans*</div>
                  </div>
                  <div class="bg-white rounded-lg border border-slate-100 p-3">
                    <span class="material-symbols-outlined text-green-600" style="font-size:20px">local_shipping</span>
                    <div class="text-[11px] font-bold text-slate-700 mt-1 leading-tight">Livraison 24/48h</div>
                  </div>
                </div>

                <form id="blog-end-cta-form" class="mt-6 space-y-3">
                  <input type="hidden" name="articleSlug" value="<%= post && post.slug ? post.slug : '' %>" />
                  <input type="hidden" name="articleTitle" value="<%= post && post.title ? post.title : '' %>" />
                  <% if (relatedProducts && relatedProducts.length === 1) { %>
                    <input type="hidden" name="productId" value="<%= relatedProducts[0].id || '' %>" />
                  <% } %>

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <input type="text" name="firstName" placeholder="Prénom (optionnel)" maxlength="80"
                           class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-500 transition" />
                    <input type="tel" name="phone" placeholder="Téléphone (optionnel)" maxlength="24"
                           class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-500 transition" />
                  </div>
                  <input type="email" name="email" required placeholder="votre@email.com *"
                         class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-500 transition" />
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <input type="text" name="vin" placeholder="VIN (optionnel)" maxlength="32"
                           class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-sm font-mono uppercase focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-500 transition" />
                    <input type="text" name="vehicle" placeholder="Marque + modèle + année" maxlength="200"
                           class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-500 transition" />
                  </div>
                  <textarea name="message" rows="2" maxlength="500" placeholder="Décrivez votre symptôme ou question (codes défaut, bruit, kilométrage…)"
                            class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-500 transition resize-none"></textarea>

                  <button type="submit" class="w-full bg-red-600 hover:bg-red-700 active:bg-red-800 text-white py-4 rounded-xl font-black text-base transition shadow-md hover:shadow-lg flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined" style="font-size:20px">send</span>
                    Demander mon devis personnalisé
                  </button>

                  <p class="text-[11px] text-slate-500 text-center">Sans engagement · Réponse sous 24h ouvrées · <a href="/legal/politique-de-confidentialite" target="_blank" class="underline hover:text-slate-700">Confidentialité</a></p>
                </form>

                <div id="blog-end-cta-result" class="mt-4 text-sm"></div>
              </div>
            </div>

            <script>
            (function () {
              var form = document.getElementById('blog-end-cta-form');
              var result = document.getElementById('blog-end-cta-result');
              if (!form) return;
              form.addEventListener('submit', function (e) {
                e.preventDefault();
                var data = {};
                new FormData(form).forEach(function (v, k) { data[k] = v; });
                result.innerHTML = '<div class="text-slate-500 text-center">Envoi de votre demande…</div>';
                fetch('/api/lead/blog-cta', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(data),
                })
                  .then(function (r) { return r.json(); })
                  .then(function (d) {
                    if (d && d.ok) {
                      result.innerHTML = ''
                        + '<div class="rounded-xl bg-green-50 border-2 border-green-200 p-5 text-center">'
                        + '  <div class="w-14 h-14 mx-auto rounded-full bg-green-500 flex items-center justify-center mb-3">'
                        + '    <span class="material-symbols-outlined text-white" style="font-size:30px">check</span>'
                        + '  </div>'
                        + '  <div class="text-green-800 font-black text-lg">Demande reçue !</div>'
                        + '  <div class="text-sm text-slate-600 mt-1">Notre équipe vous contacte par email sous 24h ouvrées.</div>'
                        + '  <div class="text-xs text-slate-500 mt-2">📧 Confirmation envoyée à <strong>' + (data.email || '').replace(/[<>&"]/g, '') + '</strong></div>'
                        + '</div>';
                      form.style.display = 'none';
                      if (window.dataLayer) window.dataLayer.push({ event: 'lead_blog_cta_end', email: data.email, article: data.articleSlug });
                      setTimeout(function () {
                        result.scrollIntoView({ behavior: 'smooth', block: 'center' });
                      }, 200);
                    } else {
                      result.innerHTML = '<div class="text-red-700 text-center font-semibold">Erreur. Vérifiez votre email ou réessayez.</div>';
                    }
                  })
                  .catch(function () { result.innerHTML = '<div class="text-red-700 text-center font-semibold">Erreur réseau. Réessayez.</div>'; });
              });
            })();
            </script>
          </div>
        </article>
      </div>

      <aside class="lg:col-span-4 space-y-6 lg:sticky lg:top-24 lg:max-h-[calc(100vh-6rem)] lg:overflow-auto lg:pr-1">
        <!-- CTA expert : en TOP sidebar pour être visible sans scroll -->
        <div class="bg-gradient-to-br from-red-600 to-red-700 text-white p-5 rounded-xl relative overflow-hidden shadow-lg">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/5 rounded-full"></div>
          <div class="absolute -left-6 -bottom-6 w-32 h-32 bg-white/5 rounded-full"></div>
          <div class="relative z-10">
            <div class="inline-flex items-center gap-1 bg-amber-300 text-red-900 text-[9px] font-black px-2 py-0.5 rounded-full uppercase tracking-wider mb-2">
              <span class="material-symbols-outlined" style="font-size:12px">support_agent</span>
              Conseil expert offert
            </div>
            <h3 class="text-base font-bold mb-1.5 leading-tight">Une question sur cet article&nbsp;?</h3>
            <p class="text-[11px] text-white/80 mb-3 leading-snug">Notre équipe technique répond gratuitement avec des conseils adaptés à votre véhicule.</p>
            <form id="blog-sidebar-cta" class="space-y-2">
              <input type="hidden" name="articleSlug" value="<%= post && post.slug ? post.slug : '' %>" />
              <input type="hidden" name="articleTitle" value="<%= post && post.title ? post.title : '' %>" />
              <input class="w-full bg-white/15 backdrop-blur border border-white/20 rounded-lg py-2 px-3 text-xs text-white placeholder-white/60 focus:ring-2 focus:ring-amber-300/50 focus:border-amber-300 focus:outline-none"
                     placeholder="votre@email.com" name="email" type="email" required />
              <button class="w-full bg-amber-400 hover:bg-amber-300 text-red-900 font-black py-2 rounded-lg text-xs transition flex items-center justify-center gap-1" type="submit">
                Recevoir un conseil
                <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
              </button>
            </form>
            <div id="blog-sidebar-cta-result" class="mt-2 text-[11px]"></div>
          </div>
        </div>

        <script>
        (function () {
          var form = document.getElementById('blog-sidebar-cta');
          var result = document.getElementById('blog-sidebar-cta-result');
          if (!form) return;
          form.addEventListener('submit', function (e) {
            e.preventDefault();
            var data = {};
            new FormData(form).forEach(function (v, k) { data[k] = v; });
            result.innerHTML = '<span class="text-white/70">Envoi…</span>';
            fetch('/api/lead/blog-cta', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            })
              .then(function (r) { return r.json(); })
              .then(function (d) {
                if (d && d.ok) {
                  result.innerHTML = '<span class="text-amber-200 font-bold">✓ Demande reçue. Vérifiez votre email pour la suite.</span>';
                  if (window.dataLayer) window.dataLayer.push({ event: 'lead_blog_cta_sidebar', email: data.email });
                  setTimeout(function () { form.style.display = 'none'; }, 1500);
                } else {
                  result.innerHTML = '<span class="text-amber-200">Erreur. Réessayez.</span>';
                }
              })
              .catch(function () { result.innerHTML = '<span class="text-amber-200">Erreur réseau.</span>'; });
          });
        })();
        </script>

        <div id="tocCard" class="hidden bg-white dark:bg-surface-dark p-4 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800">
          <h3 class="font-display font-bold text-sm uppercase tracking-widest text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Sommaire
          </h3>
          <div id="tocList" class="space-y-0.5 text-[11px]"></div>
        </div>

        <% if (relatedProducts && relatedProducts.length) { %>
          <div class="bg-white dark:bg-surface-dark p-4 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800">
            <h3 class="font-display font-bold text-sm uppercase tracking-widest text-slate-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Produits Liés
            </h3>

            <div class="space-y-4">
              <% relatedProducts.forEach((p) => { %>
                <div class="flex gap-3 group">
                  <a class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0 border border-slate-100 dark:border-slate-800" href="<%= p.url %>">
                    <% if (p.imageUrl) { %>
                      <img alt="<%= p.name %>" class="w-full h-full object-cover" loading="lazy" decoding="async" width="80" height="80" src="<%= p.imageUrl %>"/>
                    <% } else { %>
                      <div class="w-full h-full bg-slate-100 dark:bg-slate-800"></div>
                    <% } %>
                  </a>

                  <div class="flex flex-col justify-between py-0.5">
                    <div>
                      <a class="text-[11px] font-bold line-clamp-2 leading-tight group-hover:text-primary transition-colors" href="<%= p.url %>"><%= p.name %></a>
                      <% if (p.priceLabel) { %>
                        <p class="text-[13px] font-display font-bold text-slate-900 dark:text-white mt-1"><%= p.priceLabel %></p>
                      <% } %>
                    </div>

                    <form action="/panier/ajouter/<%= p.id %>" method="POST">
                      <button class="bg-slate-900 text-white text-[9px] font-bold px-3 py-1 rounded hover:bg-primary transition-colors uppercase w-fit" type="submit">Ajouter</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <% if (similarPosts && similarPosts.length) { %>
          <div class="bg-white dark:bg-surface-dark p-4 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800">
            <h3 class="font-display font-bold text-sm uppercase tracking-widest text-slate-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-primary rounded-full"></span> <%= t('blog.similarArticles') %>
            </h3>

            <div class="space-y-4">
              <% similarPosts.slice(0, 4).forEach((s) => { %>
                <a class="flex gap-3 group" href="<%= s.url %>">
                  <div class="w-16 h-12 rounded overflow-hidden flex-shrink-0">
                    <% if (s.imageUrl) { %>
                      <img alt="<%= s.title %>" class="w-full h-full object-cover" loading="lazy" decoding="async" width="64" height="48" src="<%= s.imageUrl %>"/>
                    <% } else { %>
                      <div class="w-full h-full bg-slate-100 dark:bg-slate-800"></div>
                    <% } %>
                  </div>
                  <p class="text-[11px] font-semibold leading-snug group-hover:text-primary transition-colors"><%= s.title %></p>
                </a>
              <% }) %>
            </div>
          </div>
        <% } %>

      </aside>
    </div>
  </div>
</main>

<script>
(function() {
  var bar = document.getElementById('readingProgress');
  var article = document.querySelector('article');
  if (!bar || !article) return;
  window.addEventListener('scroll', function() {
    var rect = article.getBoundingClientRect();
    var total = article.offsetHeight - window.innerHeight;
    if (total <= 0) { bar.style.width = '100%'; return; }
    var current = -rect.top;
    var pct = Math.min(100, Math.max(0, (current / total) * 100));
    bar.style.width = pct + '%';
  });
})();
</script>

<script>
  (function () {
    function slugify(value) {
      var input = String(value || '').trim().toLowerCase();
      if (!input) return '';
      try {
        input = input.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      } catch (e) {
      }
      input = input.replace(/[^a-z0-9\s-]/g, ' ');
      input = input.replace(/\s+/g, '-');
      input = input.replace(/-+/g, '-');
      input = input.replace(/^-|-$/g, '');
      return input;
    }

    if (!window.matchMedia || !window.matchMedia('(min-width: 1024px)').matches) return;

    var content = document.querySelector('.prose');
    var card = document.getElementById('tocCard');
    var list = document.getElementById('tocList');
    if (!content || !card || !list) return;

    var headings = Array.prototype.slice.call(content.querySelectorAll('h2, h3'));
    if (!headings.length) return;

    var items = [];
    for (var i = 0; i < headings.length; i += 1) {
      var h = headings[i];
      var text = String(h.textContent || '').trim();
      if (!text) continue;

      if (text.toLowerCase() === 'sommaire') continue;

      if (!h.id) {
        var base = slugify(text) || ('section-' + (i + 1));
        var id = base;
        var n = 2;
        while (document.getElementById(id)) {
          id = base + '-' + n;
          n += 1;
        }
        h.id = id;
      }

      var level = h.tagName === 'H2' ? 0 : 1;
      items.push({ id: h.id, text: text, level: level });
    }

    if (items.length < 2) return;

    if (items.length > 12) {
      items = items.filter(function(it) { return it.level === 0; });
    }

    list.innerHTML = items.map(function (it) {
      var pad = it.level === 0 ? '' : it.level === 1 ? 'padding-left:12px;' : 'padding-left:22px;';
      return '<a href="#' + it.id + '" style="' + pad + '" class="block py-1 leading-snug break-words text-slate-600 dark:text-slate-200 hover:text-primary transition-colors">' + it.text + '</a>';
    }).join('');

    card.classList.remove('hidden');
  })();
</script>

<%/* Maillage interne article blog : si l'article mentionne une marque/modèle,
     on propose des liens vers les landing pages dédiées (signal SEO fort). */%>
<%- include('../partials/internal-linking-blocks', {
  vehicleLinking: null,
  categoryLinking: null,
  blogLinking: (typeof blogLinking !== 'undefined' && blogLinking) ? blogLinking : null,
}) %>

<%/* Sticky bar mobile : produit principal lié à l'article. Pattern e-commerce
     classique pour transformer le trafic SEO d'un article en clic produit.
     Visible uniquement sur mobile (md:hidden) — sur desktop l'aside sticky
     du sidebar gère déjà la conversion. */%>
<% const _stickyProduct = (typeof relatedProducts !== 'undefined' && Array.isArray(relatedProducts) && relatedProducts.length > 0) ? relatedProducts[0] : null; %>
<% if (_stickyProduct && _stickyProduct.url) { %>
  <div class="fixed bottom-[85px] left-0 right-0 z-40 md:hidden" data-blog-sticky-product>
    <div class="mx-3 mb-2 flex items-center gap-3 rounded-2xl border border-slate-200 bg-white/95 backdrop-blur-sm px-3 py-2.5 shadow-xl">
      <a class="shrink-0" href="<%= _stickyProduct.url %>">
        <% if (_stickyProduct.imageUrl) { %>
          <img alt="<%= _stickyProduct.name %>" src="<%= _stickyProduct.imageUrl %>" class="w-12 h-12 rounded-xl object-cover border border-slate-100" width="48" height="48" loading="lazy" decoding="async" />
        <% } else { %>
          <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-400">
            <span class="material-symbols-outlined text-xl">inventory_2</span>
          </div>
        <% } %>
      </a>
      <a class="flex flex-col min-w-0 flex-1" href="<%= _stickyProduct.url %>">
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Pièce de l'article</span>
        <span class="text-xs font-bold text-slate-900 truncate leading-tight"><%= _stickyProduct.name %></span>
        <% if (_stickyProduct.priceLabel) { %>
          <span class="text-primary font-black text-sm"><%= _stickyProduct.priceLabel %></span>
        <% } %>
      </a>
      <a class="shrink-0 bg-primary hover:bg-primary/90 text-white px-4 py-3 rounded-xl font-black text-xs uppercase tracking-wider flex items-center gap-1.5 shadow-lg shadow-primary/20 transition-all" href="<%= _stickyProduct.url %>">
        Voir
        <span class="material-symbols-outlined text-base">arrow_forward</span>
      </a>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>
