        .pp-link.white .ic { background: #E0212812; } .pp-link.white .ic .material-symbols-outlined { color: #E02128; }
        .pp-link .ic { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .pp-link .tt { display: block; font-size: 15.5px; font-weight: 700; margin-bottom: 3px; }
        .pp-link .sb { display: block; font-size: 13px; }
        /* Barres sticky : accent design */
        [data-sticky-atc-btn], [data-sticky-atc-desktop-btn] { background: #E02128 !important; }
        /* Responsive */
        @media (max-width: 1024px) {
          .pp-hero { grid-template-columns: 1fr; gap: 28px; }
          .pp-desc-grid, .pp-faq-grid { grid-template-columns: 1fr; gap: 28px; }
