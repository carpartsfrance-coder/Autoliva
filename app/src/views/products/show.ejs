<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-1 bg-white dark:bg-background-dark text-slate-800 dark:text-slate-200 transition-colors duration-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
    <% if (!dbConnected) { %>
      <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5 text-amber-900 mb-10">
        <div class="font-bold">Mode démo activé</div>
        <div class="mt-1 text-sm">Le site fonctionne sans base de données, avec des produits d'exemple.</div>
      </div>
    <% } %>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="rounded-2xl border border-red-200 bg-red-50 p-5 text-red-900 mb-10">
        <div class="font-bold">Erreur</div>
        <div class="mt-1 text-sm"><%= errorMessage %></div>
      </div>
    <% } %>

    <% if (!product) { %>
      <div class="bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-3xl p-8 refined-shadow">
        <div class="font-bold text-slate-900 dark:text-white">Produit indisponible</div>
        <div class="mt-1 text-sm text-slate-500">Ce produit ne peut pas être affiché pour le moment.</div>
      </div>
    <% } else { %>
      <% const ref = product.sku || String(product._id).slice(-10).toUpperCase(); %>
      <% const rawMedia = []; %>
      <% if (product.imageUrl) rawMedia.push({ url: product.imageUrl, type: 'image' }); %>
      <% (product.galleryUrls || []).forEach((u, i) => {
        if (!u) return;
        const gt = Array.isArray(product.galleryTypes) ? product.galleryTypes[i] : '';
        const t = (gt === 'video') ? 'video' : 'image';
        rawMedia.push({ url: u, type: t });
      }); %>
      <% const seenMediaUrls = new Set(); %>
      <% const mediaItems = rawMedia.filter((m) => {
        if (!m || !m.url || seenMediaUrls.has(m.url)) return false;
        seenMediaUrls.add(m.url);
        return true;
      }); %>
      <%# Vidéo YouTube/Vimeo (product.media.videoUrl) ajoutée comme DERNIER élément
          de la galerie : vignette cliquable → lecteur intégré dans le visualiseur
          principal. La vidéo reste hébergée chez YouTube/Vimeo (rien en base). %>
      <% const _galleryVideoEmbed = (product.sections && product.sections.showVideo && product.media && product.media.videoUrl && typeof parseVideoEmbed === 'function')
           ? parseVideoEmbed(product.media.videoUrl) : null; %>
      <% if (_galleryVideoEmbed && !seenMediaUrls.has(product.media.videoUrl)) {
           seenMediaUrls.add(product.media.videoUrl);
           mediaItems.push({ url: product.media.videoUrl, type: 'embed', embedUrl: _galleryVideoEmbed.embedUrl, poster: _galleryVideoEmbed.poster, provider: _galleryVideoEmbed.provider });
         } %>
      <% const images = mediaItems.map((m) => m.url); %>
      <% const mainImage = images[0] || ''; %>
      <% const mainMediaItem = mediaItems[0] || null; %>
      <% const thumbImages = images; %>
      <% const thumbMediaItems = mediaItems; %>
      <% const hasVideo = !!(product.sections && product.sections.showVideo && product.media && product.media.videoUrl); %>
      <% const topLeftBadge = product.badges && product.badges.topLeft ? product.badges.topLeft : ''; %>
      <% const conditionBadge = product.badges && product.badges.condition ? product.badges.condition : ''; %>
      <% const compareAt = product.compareAtPriceCents; %>
      <% const makes = Array.isArray(product.compatibility)
        ? Array.from(new Set(product.compatibility.map((c) => (c && c.make ? String(c.make).trim() : '')).filter(Boolean)))
        : []; %>
      <% /* GA4 item_brand : fallback sur la 1ère make des compatibilités si brand vide. */ %>
      <% const _ga4Brand = ((product.brand && String(product.brand).trim()) || makes[0] || ''); %>
      <% const formatMoney = (cents) => new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format((Number(cents) || 0) / 100); %>
      <% const findSpec = (label) => {
        const target = String(label || '').toLowerCase();
        const list = Array.isArray(product.specs) ? product.specs : [];
        for (const s of list) {
          if (!s || !s.label) continue;
          if (String(s.label).toLowerCase() === target) return s.value || '';
        }
        return '';
      }; %>
      <% const keyType = findSpec('type') || product.category || ''; %>
      <% const keyEtat = findSpec('état') || findSpec('etat') || conditionBadge || ''; %>
      <% const keyProgrammation = findSpec('programmation') || ''; %>
      <% const keyGarantie = (product.warranty && Number(product.warranty.months) > 0)
        ? (product.warranty.months + ' ' + t('product.monthsWord') + (product.warranty.text ? ' — ' + product.warranty.text : ''))
        : (findSpec('garantie') || topLeftBadge || ''); %>
      <%# Garantie « jusqu'à N mois » (formulation conforme, design Autoparts) %>
      <% const _wm = (product.warranty && Number(product.warranty.months) > 0) ? Number(product.warranty.months) : 0; %>
      <% const _garLabel = _wm ? t('product.warrantyUpTo', { months: _wm }) : (keyGarantie || t('product.warranty24')); %>
      <% const _garValue = _wm ? (t('product.upToMonths', { months: _wm }) + ' — ' + t('product.partsLabor')) : (keyGarantie || t('product.warranty24')); %>
      <% const optionGroups = Array.isArray(product.displayOptions) ? product.displayOptions : []; %>
      <% const compGrouped = {}; %>
      <% (Array.isArray(product.compatibility) ? product.compatibility : []).forEach((c) => {
        const make = c && c.make ? String(c.make).trim() : '';
        if (!make) return;
        if (!compGrouped[make]) compGrouped[make] = { models: new Set(), engines: new Set() };
        const model = c && c.model ? String(c.model).trim() : '';
        const years = c && c.years ? String(c.years).trim() : '';
        const engine = c && c.engine ? String(c.engine).trim() : '';
        const modelText = [model, years].filter(Boolean).join(' ');
        if (modelText) compGrouped[make].models.add(modelText);
        if (engine) compGrouped[make].engines.add(engine);
      }); %>
      <% const compMakes = Object.keys(compGrouped); %>
      <%# Liste DÉTAILLÉE par véhicule (1 ligne = 1 véhicule) pour l'onglet dédié. %>
      <% const compatVehicles = (Array.isArray(product.compatibility) ? product.compatibility : []).map((c) => {
           const make = c && c.make ? String(c.make).trim() : '';
           const model = c && c.model ? String(c.model).trim() : '';
           const years = c && c.years ? String(c.years).trim() : '';
           const engine = c && c.engine ? String(c.engine).trim() : '';
           const kw = c && Number(c.kw) > 0 ? Number(c.kw) : 0;
           const ch = c && Number(c.ch) > 0 ? Number(c.ch) : 0;
           let power = '';
           if (kw && ch) power = kw + ' kW / ' + ch + ' ch';
           else if (ch) power = ch + ' ch';
           else if (kw) power = kw + ' kW';
           return { make, model, years, engine, power };
         }).filter((v) => v.make || v.model || v.engine); %>
      <% compatVehicles.sort((a, b) => (a.make + a.model + a.engine).localeCompare(b.make + b.model + b.engine, 'fr')); %>
      <% const vehicleCount = compatVehicles.length; %>
      <% const compatibleReferences = Array.isArray(product.compatibleReferences)
        ? product.compatibleReferences.map((v) => String(v || '').trim()).filter(Boolean)
        : []; %>
      <% const keyPointsList = Array.isArray(product.keyPoints)
        ? product.keyPoints.map((v) => String(v || '').trim()).filter(Boolean)
        : []; %>
      <% const inclusionsList = Array.isArray(product.inclusions)
        ? product.inclusions.map((v) => String(v || '').trim()).filter(Boolean)
        : []; %>
      <% const exclusionsList = Array.isArray(product.exclusions)
        ? product.exclusions.map((v) => String(v || '').trim()).filter(Boolean)
        : []; %>
      <%# Blocs d'information groupés par position (chargés côté contrôleur). %>
      <% var _ib = (product && product.infoBlocksByPosition) ? product.infoBlocksByPosition : { description_end: [], after_inclusions: [], dedicated_tab: [] }; %>
      <% const summaryPoints = keyPointsList.length
        ? keyPointsList.slice(0, 3)
        : [
          keyType ? (t('product.specType') + ' : ' + keyType) : '',
          keyProgrammation ? (t('product.specProg') + ' : ' + keyProgrammation) : '',
          keyGarantie ? (t('product.guarantee') + ' : ' + keyGarantie) : '',
        ].filter(Boolean); %>
      <% const normalizeLoose = (value) => String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, ''); %>
      <% const basePriceCents = Number(product.priceCents) || 0; %>
      <% const installmentCount = 3; %>
      <% const installmentMinPriceCents = 10000; %>
      <% const installmentMaxPriceCents = 200000; %>
      <% const installmentEligible = basePriceCents >= installmentMinPriceCents && basePriceCents <= installmentMaxPriceCents; %>
      <% const installmentAmountCents = installmentEligible ? Math.round(basePriceCents / installmentCount) : 0; %>
      <%# ── Design Autoparts v3 : prix HT (TVA 20 %), échéance 4×, réfs alternatives, nb rapports ── %>
      <% const priceHTcents = Math.round(basePriceCents / 1.2); %>
      <% const installment4Cents = installmentEligible ? Math.round(basePriceCents / 4) : 0; %>
      <% const refsAlternatives = Array.isArray(product.compatibleReferences) ? product.compatibleReferences.filter(Boolean) : []; %>
      <% const gearsVal = (findSpec('rapports') || findSpec('vitesses') || '').replace(/[^0-9]/g, ''); %>
      <% const shippingDelayText = product && product.shippingDelayText ? String(product.shippingDelayText).trim() : ''; %>
      <% const hasConsigne = product && product.consigne && product.consigne.enabled && product.consigne.amountCents > 0; %>
      <% const consigneUpfront = hasConsigne && product.consigne.chargeUpfront === true; %>
      <% const consigneAmountEuro = hasConsigne ? (product.consigne.amountCents / 100).toFixed(2).replace('.', ',') : ''; %>
      <% const consigneDelayDays = hasConsigne ? (product.consigne.delayDays || 30) : 30; %>
      <% const stockLabel = product.inStock ? t('product.stockIn') : t('product.stockOrder'); %>
      <%# Code moteur/boîte (ex: CLHA, DQR) — info n°1 recherchée par le client. %>
      <% const engineCodeVal = (product.engineCode && String(product.engineCode).trim()) ? String(product.engineCode).trim() : ''; %>
      <%# Label du code adapté au genre : « Code boîte » pour les transmissions, « Code moteur » sinon. %>
      <% const _isGearbox = /bo[iî]te|vitesse|transmission|\bdsg\b|s-?tronic|\bdq\d/i.test(String(product.category || '') + ' ' + String(product.name || '')); %>
      <% const _codeLabel = _isGearbox ? t('product.codeBoite') : t('product.codeMoteur'); %>
      <% let productSubtitle; %>
      <% if (engineCodeVal) {
           // Sous-titre prioritaire : code moteur/boîte + référence (les marques sont déjà dans le titre H1).
           const _st = [_codeLabel + ' : ' + engineCodeVal];
           if (ref) _st.push(t('product.refPrefix') + ' ' + ref);
           productSubtitle = _st.join(' · ');
         } else {
           const subtitleParts = [];
           if (makes.length) { subtitleParts.push(t('product.forVehicles') + ' ' + makes.slice(0, 4).join(', ')); }
           else if (product.brand) { subtitleParts.push(t('product.forVehicles') + ' ' + String(product.brand).trim()); }
           if (ref) subtitleParts.push(t('product.seriesPrefix') + ' ' + ref);
           productSubtitle = subtitleParts.join(' - ');
         } %>
      <% const isService = product && product.serviceType === 'standalone_cloning'; %>
      <%# ISO 9001 : mis en avant UNIQUEMENT sur les pièces reconditionnées (pas occasion / neuf / service). %>
      <% const _isoHay = (String(product.category || '') + ' ' + String(conditionBadge || '') + ' ' + String(keyEtat || '')).toLowerCase(); %>
      <% const _showIso = !isService && !/occasion|\bneuf\b/.test(_isoHay); %>
      <% const heroBadge = isService
        ? (topLeftBadge || t('product.serviceRemote'))
        : (keyEtat || conditionBadge || topLeftBadge || t('product.reconditioningPro')); %>
      <% const visibleThumbImages = thumbImages.slice(0, 4); %>
      <% const hiddenThumbImages = thumbImages.slice(4); %>
      <%# La vignette vidéo (embed) est épinglée parmi les vignettes VISIBLES, même
          s'il y a déjà 4 images ou plus : sinon, en 5e position, elle serait
          masquée (invisible sur mobile). On réserve donc la dernière tuile à la
          vidéo (jusqu'à 3 images + la vidéo) ; les images en trop passent en « +N ». %>
      <% const _embedThumb = thumbMediaItems.find((m) => m.type === 'embed') || null; %>
      <% const _imgThumbs = _embedThumb ? thumbMediaItems.filter((m) => m !== _embedThumb) : thumbMediaItems; %>
      <% const _maxImgThumbs = _embedThumb ? 3 : 4; %>
      <% const visibleThumbItems = _imgThumbs.slice(0, _maxImgThumbs).concat(_embedThumb ? [_embedThumb] : []); %>
      <% const hiddenThumbItems = _imgThumbs.slice(_maxImgThumbs); %>
      <% const _hiddenThumbCount = hiddenThumbItems.length; %>
      <% const _lastImageThumbIdx = visibleThumbItems.length - 1 - (_embedThumb ? 1 : 0); %>
      <% const compatibilityPrefillMessage = [
        'Bonjour,',
        '',
        'Je souhaite vérifier la compatibilité de la pièce "' + product.name + '"' + (ref ? ' (référence ' + ref + ')' : '') + ' avec mon véhicule.',
        '',
        'Nos experts vérifient la compatibilité et vous répondent sous 24h.',
        '',
        'Merci.',
      ].join('\n'); %>
      <% const compatibilityContactUrl = '/contact?subject=compatibilite&partRef=' + encodeURIComponent(ref) + '&message=' + encodeURIComponent(compatibilityPrefillMessage); %>
      <%# Badges MANUELS (4 textes libres saisis en admin) — affichés tels quels.
          Si aucun n'est rempli → fallback sur les badges auto (rétrocompat). %>
      <% const manualBadgeCards = (product.badges && Array.isArray(product.badges.cards))
        ? product.badges.cards.map((s) => String(s || '').trim()).filter(Boolean).slice(0, 4)
        : []; %>
      <% const autoHighlights = isService
        ? [
            { icon: 'euro', label: t('product.svcFixedPrice') },
            { icon: 'bolt', label: t('product.svcCloning24') },
            { icon: 'local_shipping', label: t('product.svcRoundTrip') },
            { icon: 'verified', label: t('product.svcWarranty30') },
          ]
        : [
            { icon: 'verified', label: keyGarantie || t('product.warranty24') },
            { icon: 'terminal', label: keyProgrammation || t('product.progIncluded') },
            { icon: 'analytics', label: t('product.benchTested') },
            consigneUpfront ? { icon: 'verified_user', label: t('product.consigneRefundable') } : { icon: 'lock_open', label: t('product.noDeposit') },
          ]; %>
      <% const qualityHighlights = manualBadgeCards.length
        ? manualBadgeCards.map((label) => ({ icon: 'check_circle', label, manual: true }))
        : autoHighlights; %>
      <% const faqCount = Array.isArray(product.faqs) ? product.faqs.length : 0; %>
      <% const faqPreviewCards = Array.isArray(product.faqs)
        ? product.faqs.filter((f) => f && f.question && f.answer).slice(0, 3)
        : []; %>
      <% const technicalSpecs = []; %>
      <% const pushTechnicalSpec = (label, value) => {
        const safeLabel = String(label || '').trim();
        const safeValue = String(value || '').trim();
        if (!safeLabel || !safeValue) return;
        const alreadyExists = technicalSpecs.some((entry) => String(entry.label || '').toLowerCase() === safeLabel.toLowerCase());
        if (alreadyExists) return;
        technicalSpecs.push({ label: safeLabel, value: safeValue });
      }; %>
      <% (Array.isArray(product.specs) ? product.specs : []).forEach((spec) => {
        if (!spec || technicalSpecs.length >= 6) return;
        pushTechnicalSpec(spec.label, spec.value);
      }); %>
      <% if (technicalSpecs.length < 6 && engineCodeVal) {
           var _compatCodes = Array.isArray(product.compatibleReferences) ? product.compatibleReferences.filter(Boolean).slice(0, 2) : [];
           pushTechnicalSpec(_codeLabel, engineCodeVal + (_compatCodes.length ? ' (compatible ' + _compatCodes.join(', ') + ')' : ''));
         } %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.specRef'), ref); %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.specType'), keyType); %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.specState'), keyEtat); %>
      <% if (technicalSpecs.length < 6 && keyProgrammation) pushTechnicalSpec(t('product.specProg'), keyProgrammation); %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.guarantee'), (product.warranty && Number(product.warranty.months) > 0) ? (Number(product.warranty.months) + ' ' + t('product.monthsWord')) : (keyGarantie || t('product.specIncluded'))); %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.shippingLabel'), shippingDelayText || t('product.specShipping2448')); %>

      <%# ══════════════════════════ REFONTE DESIGN — AUTOPARTS v3 ══════════════════════════
          Fiche produit portée au pixel depuis le handoff « Page Produit Autoparts v3 ».
          Header/footer du site conservés (marque Autoliva). Styles inline = fidélité exacte.
          Hooks JS réels préservés : data-add-to-cart-*, data-price-display(-ht),
          data-installment-*, data-main-image/thumb/gallery-*, lightbox. %>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,700;1,800&display=swap" rel="stylesheet" />
      <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,300..700,0..1,0" rel="stylesheet" />
      <style>
        .ap-page { font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif; color: #0F1626; }
        .ap-page * { box-sizing: border-box; }
        .ap-page .material-symbols-outlined { font-family: 'Material Symbols Outlined'; font-weight: normal; font-style: normal; line-height: 1; letter-spacing: normal; text-transform: none; display: inline-block; white-space: nowrap; word-wrap: normal; direction: ltr; -webkit-font-feature-settings: 'liga'; -webkit-font-smoothing: antialiased; }
        .ap-page input::placeholder { color: #9AA1AF; opacity: 1; }
        .ap-fill { font-variation-settings: 'FILL' 1; }
        @keyframes apStickyIn { from { transform: translateY(100%); } to { transform: translateY(0); } }
        @keyframes apToastIn { from { transform: translate(-50%, 14px); opacity: 0; } to { transform: translate(-50%, 0); opacity: 1; } }
        @keyframes apImgFade { from { opacity: 0.4; } to { opacity: 1; } }
        @keyframes apLogoMarquee { to { transform: translateX(-50%); } }
        .ap-marquee-track { display: flex; width: max-content; animation: apLogoMarquee 30s linear infinite; }
        .ap-marquee-track:hover { animation-play-state: paused; }
        .ap-marquee-track img { transition: filter 0.2s; }
        .ap-marquee-track img:hover { filter: grayscale(0) opacity(1) !important; }
        @media (prefers-reduced-motion: reduce) { .ap-marquee-track { animation: none !important; } }
        .ap-hover-red:hover { color: #ED1C24 !important; }
        .ap-cta:hover { background: #D31118 !important; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(237,28,36,0.28); }
        .ap-cta:active { transform: translateY(0) scale(0.985); }
        .ap-navy:hover { background: #1E2C4E !important; transform: translateY(-1px); }
        .ap-navy:active { transform: translateY(0) scale(0.98); }
        .ap-iconbtn:hover { background: #F4F5F8; }
        .ap-iconbtn:active { transform: scale(0.9); }
        .ap-blogcard { transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; }
        .ap-blogcard:hover { border-color: #D5DAE2 !important; transform: translateY(-2px); box-shadow: 0 10px 24px rgba(15,22,38,0.08); }
        .ap-photocard img { transition: transform 0.45s ease; }
        .ap-photocard:hover img { transform: scale(1.04); }
        .ap-faq-row { cursor: pointer; border-radius: 10px; margin: 0 -10px; transition: background 0.15s; }
        .ap-faq-row:hover { background: #FAFBFC; }
        /* Sous-ensemble pp-* conservé pour la section maillage interne SEO (part_links) */
        .pp-page { font-family: 'Plus Jakarta Sans', sans-serif; }
        .pp-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: #ED1C24; margin-bottom: 10px; }
        .pp-h2 { font-size: 19px; font-weight: 800; letter-spacing: -0.01em; margin: 0; color: #0F1626; }
        .pp-links { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
        .pp-link { display: flex; align-items: center; gap: 14px; text-decoration: none; border-radius: 14px; padding: 18px 20px; border: 1px solid #E5E8EE; transition: transform 0.15s, box-shadow 0.15s; }
        .pp-link:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(15,22,38,0.08); }
        .pp-link.navy { background: #15213B; color: #fff; border-color: #15213B; }
        .pp-link.white { background: #fff; color: #0F1626; }
        .pp-link .ic { width: 42px; height: 42px; border-radius: 12px; background: rgba(237,28,36,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .pp-link.navy .ic { background: rgba(255,255,255,0.1); }
        .pp-link .tt { display: block; font-size: 14px; font-weight: 800; }
        .pp-link .sb { display: block; font-size: 12px; opacity: 0.7; margin-top: 2px; }
        .pp-link.navy .material-symbols-outlined, .pp-link.navy .ic .material-symbols-outlined { color: #fff; }
        .pp-link.white .material-symbols-outlined { color: #ED1C24; }
        @media (max-width: 760px) {
          .ap-hero-grid { grid-template-columns: 1fr !important; }
          .ap-two-col { grid-template-columns: 1fr !important; gap: 32px !important; }
          .ap-recond-grid { grid-template-columns: 1fr !important; }
          .ap-compare { grid-template-columns: 1fr !important; }
          .ap-4col { grid-template-columns: repeat(2, 1fr) !important; }
          .ap-3col { grid-template-columns: 1fr !important; }
          .pp-links { grid-template-columns: 1fr; }
          .ap-buypanel { width: auto !important; }
        }
      </style>

      <div class="ap-page">

      <%# ═══ Barre sticky d'achat (apparaît après 780px de scroll — JS) ═══ %>
      <div data-ap-sticky style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 100; background: #FFFFFF; border-top: 1px solid #E9ECF1; box-shadow: 0 -6px 24px rgba(15,22,38,0.08); display: none;">
        <div style="max-width: 1264px; margin: 0 auto; padding: 0 32px; height: 66px; display: flex; align-items: center; gap: 14px;">
          <% if (mainImage) { %><img src="<%= mainImage %>" alt="" style="width: 42px; height: 42px; border-radius: 8px; object-fit: cover; flex-shrink: 0;" /><% } %>
          <div style="min-width: 0;">
            <div style="font-size: 13px; font-weight: 800; color: #0F1626; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 420px;"><%= product.name %></div>
            <div style="font-size: 11px; font-weight: 600; color: #8A93A4; margin-top: 1px;">Réf. <%= ref %> · <%= t('product.shippingLabel') %> <%= shippingDelayText || '24/48h' %><% if (_garLabel) { %> · <%= _garLabel %><% } %></div>
          </div>
          <span data-ap-sticky-checkok style="display: none; align-items: center; gap: 6px; background: #E4F5EC; color: #128A52; font-size: 11.5px; font-weight: 800; padding: 5px 10px; border-radius: 999px; white-space: nowrap; flex-shrink: 0;"><span class="material-symbols-outlined ap-fill" style="font-size: 14px;">check_circle</span>Vérification expert en cours</span>
          <div style="margin-left: auto; text-align: right; flex-shrink: 0;">
            <div style="font-size: 17px; font-weight: 800; color: #0F1626;"><%= formatMoney(basePriceCents) %> €</div>
            <% if (installmentEligible) { %><div style="font-size: 10.5px; font-weight: 600; color: #6B7482;">3x / 4x sans frais avec Scalapay</div><% } %>
          </div>
          <button type="button" data-ap-sticky-add style="height: 44px; padding: 0 20px; border: none; border-radius: 10px; background: #ED1C24; color: #FFFFFF; font-family: inherit; font-size: 13.5px; font-weight: 800; cursor: pointer; display: flex; align-items: center; gap: 8px; flex-shrink: 0;" class="ap-cta">
            <span class="material-symbols-outlined" style="font-size: 17px;">shopping_cart</span><%= t('product.addToCart') %>
          </button>
        </div>
      </div>

      <%# ═══ Toast confirmation (JS) ═══ %>
      <div data-ap-toast style="position: fixed; left: 50%; bottom: 30px; transform: translateX(-50%); z-index: 130; background: #10151F; color: #FFFFFF; border-radius: 999px; padding: 13px 22px; display: none; align-items: center; gap: 10px; box-shadow: 0 12px 32px rgba(15,22,38,0.3); font-size: 13px; font-weight: 700; white-space: nowrap;">
        <span class="material-symbols-outlined ap-fill" style="font-size: 18px; color: #4ADE80;">check_circle</span>
        <span data-ap-toast-msg></span>
      </div>

      <%# ═══ Fil d'ariane ═══ %>
      <nav style="display: flex; align-items: center; gap: 10px; font-size: 12.5px; color: #8A93A4; padding: 22px 0 28px 0; flex-wrap: wrap;" aria-label="Fil d'Ariane">
        <a href="/" style="color: #6B7482; text-decoration: none;" class="ap-hover-red"><%= t('breadcrumb.home') %></a>
        <span class="material-symbols-outlined" style="font-size: 14px; color: #C3C9D3;">chevron_right</span>
        <a href="/produits" style="color: #6B7482; text-decoration: none;" class="ap-hover-red"><%= t('breadcrumb.catalog') %></a>
        <% if (typeof categoryUrl !== 'undefined' && categoryUrl && typeof categoryName !== 'undefined' && categoryName) { %>
          <% categoryName.split(/\s*>\s*/).forEach((part) => { %>
            <span class="material-symbols-outlined" style="font-size: 14px; color: #C3C9D3;">chevron_right</span>
            <a href="<%= categoryUrl %>" style="color: #6B7482; text-decoration: none;" class="ap-hover-red"><%= part %></a>
          <% }) %>
        <% } %>
        <span class="material-symbols-outlined" style="font-size: 14px; color: #C3C9D3;">chevron_right</span>
        <span style="color: #0F1626; font-weight: 700;"><%= (engineCodeVal || ref || product.name) %></span>
      </nav>

      <%# ═══ Hero : galerie + panneau d'achat ═══ %>
      <div class="ap-hero-grid" style="display: grid; grid-template-columns: minmax(0, 1fr) 520px; gap: 48px; align-items: start;">

        <%# ── Galerie (hooks réels : data-main-image / data-thumb / data-gallery-*) ── %>
        <div style="display: flex; flex-direction: column; gap: 14px;">
          <div style="position: relative; border: 1px solid #E9ECF1; border-radius: 16px; overflow: hidden; background: #FFFFFF; aspect-ratio: 1 / 0.885;">
            <% if (mainMediaItem) { %>
              <% const _isMainVideo = mainMediaItem.type === 'video'; const _isMainEmbed = mainMediaItem.type === 'embed'; %>
              <img alt="<%= product.name %>" data-main-image decoding="async" loading="eager" fetchpriority="high" class="<%= (_isMainVideo || _isMainEmbed) ? 'hidden' : '' %>" <% if (!_isMainVideo && !_isMainEmbed) { %>src="<%= mainImage %>"<% } %> style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; cursor: zoom-in; animation: apImgFade 0.28s ease;" />
              <video class="<%= _isMainVideo ? '' : 'hidden' %>" data-main-video controls preload="metadata" playsinline style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"<% if (_isMainVideo) { %> src="<%= mainImage %>"<% } %>></video>
              <iframe class="<%= _isMainEmbed ? '' : 'hidden' %>" style="position:absolute;inset:0;width:100%;height:100%;" data-main-embed title="<%= product.name %>" loading="lazy" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen<% if (_isMainEmbed) { %> src="<%= mainMediaItem.embedUrl %>"<% } %>></iframe>
            <% } else { %>
              <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#A6ACBB;"><span class="material-symbols-outlined" style="font-size:56px;">inventory_2</span></div>
            <% } %>
            <div style="position: absolute; top: 16px; left: 16px; background: #10151F; color: #FFFFFF; font-size: 12px; font-weight: 700; padding: 8px 13px; border-radius: 8px; z-index: 3;"><%= (heroBadge || t('product.reconditioned')) %></div>
            <% if (images.length > 1) { %>
              <button type="button" data-gallery-prev aria-label="Image précédente" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 999px; border: 1px solid #E9ECF1; background: #FFFFFF; box-shadow: 0 4px 12px rgba(15,22,38,0.08); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 3;" class="ap-iconbtn"><span class="material-symbols-outlined" style="font-size: 20px; color: #0F1626;">chevron_left</span></button>
              <button type="button" data-gallery-next aria-label="Image suivante" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 999px; border: 1px solid #E9ECF1; background: #FFFFFF; box-shadow: 0 4px 12px rgba(15,22,38,0.08); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 3;" class="ap-iconbtn"><span class="material-symbols-outlined" style="font-size: 20px; color: #0F1626;">chevron_right</span></button>
            <% } %>
            <% if (mainMediaItem && mainMediaItem.type === 'image') { %>
              <button type="button" data-pp-zoom aria-label="Agrandir" style="position:absolute;bottom:16px;right:16px;width:40px;height:40px;border-radius:999px;border:1px solid #E9ECF1;background:#FFFFFF;box-shadow:0 4px 12px rgba(15,22,38,0.08);cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:3;" class="ap-iconbtn"><span class="material-symbols-outlined" style="font-size: 20px; color: #0F1626;">zoom_in</span></button>
            <% } %>
          </div>
          <% if (visibleThumbItems.length > 1) { %>
            <div style="display: flex; gap: 14px; flex-wrap: wrap;">
              <% visibleThumbItems.forEach((item, idx) => { %>
                <% const _isThumbVideo = item.type === 'video'; const _isThumbEmbed = item.type === 'embed'; %>
                <button type="button" data-thumb data-index="<%= idx %>" data-src="<%= item.url %>" data-type="<%= item.type %>"<% if (_isThumbEmbed) { %> data-embed-src="<%= item.embedUrl %>"<% } %> aria-label="Vue <%= idx + 1 %>" style="width: 92px; height: 92px; padding: 5px; border: <%= idx === 0 ? '2px solid #ED1C24' : '2px solid #EDF0F4' %>; border-radius: 12px; background: #FFFFFF; cursor: pointer; overflow: hidden; position: relative; flex-shrink: 0;">
                  <% if (_isThumbEmbed && item.poster) { %>
                    <img alt="" decoding="async" loading="lazy" src="<%= item.poster %>" style="width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 7px;" />
                  <% } else if (_isThumbVideo) { %>
                    <video muted playsinline preload="metadata" style="width:100%;height:100%;object-fit:cover;border-radius:7px;"><source src="<%= item.url %>" /></video>
                  <% } else { %>
                    <img alt="Vue <%= idx + 1 %>" decoding="async" loading="lazy" src="<%= item.url %>" style="width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 7px;" />
                  <% } %>
                </button>
              <% }) %>
            </div>
          <% } %>
          <% hiddenThumbItems.forEach((item, idx) => { %>
            <button class="hidden" data-thumb data-index="<%= idx + 4 %>" data-src="<%= item.url %>" data-type="<%= item.type %>"<% if (item.type === 'embed') { %> data-embed-src="<%= item.embedUrl %>"<% } %> type="button"></button>
          <% }) %>
        </div>

        <%# ── Panneau d'achat (largeur 520 ; hooks cart/prix réels) ── %>
        <form action="/panier/ajouter/<%= product._id %>" data-add-to-cart-form data-product-id="<%= product._id %>" data-product-sku="<%= product.sku || product._id %>" data-product-image="<%= mainImage %>" data-product-name="<%= product.name %>" data-product-category="<%= product.category || '' %>" data-product-brand="<%= _ga4Brand %>" data-product-price-cents="<%= basePriceCents %>" method="POST" class="ap-buypanel" style="margin: 0;">
          <input type="hidden" name="qty" value="1" data-qty-input />
          <h1 style="font-size: 30px; font-weight: 800; line-height: 1.22; letter-spacing: -0.015em; margin: 0 0 10px 0; color: #0F1626; text-wrap: pretty;"><%= product.name %></h1>

          <% if (_showIso) { %>
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
            <div style="display: flex; gap: 2.5px;">
              <% for (var _s = 0; _s < 5; _s++) { %><span style="width: 18px; height: 18px; background: #00B67A; display: flex; align-items: center; justify-content: center;"><span class="material-symbols-outlined ap-fill" style="font-size: 12.5px; color: #FFFFFF;">star</span></span><% } %>
            </div>
            <span style="font-size: 12.5px; font-weight: 800; color: #0F1626;"><%= t('product.qualityPremiumIso') %></span>
          </div>
          <% } %>

          <div style="font-size: 12.5px; font-weight: 600; color: #6B7482; margin-bottom: 22px;">
            <% var _specBits = []; %>
            <% if (engineCodeVal) _specBits.push(_codeLabel + ' ' + engineCodeVal); %>
            <% if (keyType) _specBits.push(keyType); %>
            <% if (gearsVal) _specBits.push(gearsVal + ' ' + t('product.gearsWord')); %>
            <% if (_showIso) _specBits.push(t('product.exchangeStandardWord')); %>
            <% if (_garLabel) _specBits.push(_garLabel); %>
            <%= _specBits.join(' · ') %><% if (_showIso) { %> · <%= t('product.isoFactories') %><% } %>
          </div>

          <div style="background: #F5F6F8; border-radius: 14px; padding: 22px;">
            <div style="display: flex; align-items: flex-start;">
              <div>
                <div style="display: flex; align-items: flex-end; flex-wrap: wrap;">
                  <span style="font-size: 32px; font-weight: 800; letter-spacing: -0.01em; color: #0F1626; line-height: 1;" data-price-display data-base-price-cents="<%= basePriceCents %>" data-installment-count="4" data-installment-min-cents="<%= installmentMinPriceCents %>" data-installment-max-cents="<%= installmentMaxPriceCents %>"><%= formatMoney(basePriceCents) %> €</span>
                  <span style="font-size: 12px; font-weight: 700; color: #8A93A4; margin-left: 8px; padding-bottom: 2px;"><%= t('product.ttc') %></span>
                  <span style="font-size: 12.5px; font-weight: 700; color: #99A1B0; margin-left: 12px; padding-bottom: 2px;"><span data-price-display-ht><%= formatMoney(priceHTcents) %></span> <%= t('product.ht') %></span>
                </div>
                <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px;">
                  <% if (installmentEligible) { %>
                  <span data-installment-wrapper style="display: inline-flex; align-items: center; gap: 7px; background: #FFFFFF; border: 1px solid #E1E5EB; border-radius: 999px; padding: 5px 12px; font-size: 11.5px; font-weight: 700; color: #2A3242;">4 × <span data-installment-amount><%= formatMoney(installment4Cents) %> €</span> <%= t('product.noFees') %><img src="/design/autoparts/scalapay.png" alt="Scalapay" style="height: 11px; display: block;" /></span>
                  <% } %>
                  <span style="display: inline-flex; align-items: center; background: #E4F5EC; border-radius: 999px; padding: 5px 12px; font-size: 11.5px; font-weight: 800; color: #128A52;"><%= t('product.cheaperThanNew') %></span>
                </div>
              </div>
              <div style="margin-left: auto; text-align: right;">
                <% if (product.inStock) { %>
                  <span style="display: inline-flex; align-items: center; gap: 6px; background: #E4F5EC; color: #128A52; font-size: 12px; font-weight: 800; padding: 6px 11px; border-radius: 999px; white-space: nowrap;"><span style="width: 6px; height: 6px; border-radius: 50%; background: #128A52;"></span><%= t('product.inStockWord') %></span>
                  <div style="font-size: 11.5px; font-weight: 700; color: #3E4657; margin-top: 7px; white-space: nowrap;"><%= t('product.shipUnder') %> <%= shippingDelayText || '24/48h' %></div>
                <% } else { %>
                  <span style="display: inline-flex; align-items: center; gap: 6px; background: #FDF0E0; color: #B45309; font-size: 12px; font-weight: 800; padding: 6px 11px; border-radius: 999px; white-space: nowrap;"><span style="width: 6px; height: 6px; border-radius: 50%; background: #B45309;"></span><%= t('product.onOrderWord') %></span>
                  <div style="font-size: 11.5px; font-weight: 700; color: #3E4657; margin-top: 7px; white-space: nowrap;"><%= t('product.delayConfirmed') %></div>
                <% } %>
              </div>
            </div>
            <div style="height: 1px; background: #E5E8EE; margin: 18px 0 16px 0;"></div>

            <%# ── Vérif compatibilité par un expert (POST /api/lead/product-quote) ── %>
            <div style="font-size: 12px; font-weight: 800; color: #0F1626; margin-bottom: 8px;"><%= t('product.checkCompatExpert') %></div>
            <div style="display: flex; gap: 8px;">
              <div style="display: flex; height: 48px; flex: 0 0 148px; border: 1px solid #DEE2E9; border-radius: 10px; overflow: hidden; background: #FFFFFF;">
                <div style="width: 30px; background: #2653C6; color: #FFFFFF; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; flex-shrink: 0;"><span style="font-size: 7px; letter-spacing: 1px; opacity: 0.9;">★</span><span style="font-size: 11px; font-weight: 800;">F</span></div>
                <input type="text" data-ap-plate placeholder="AA-123-AA" style="flex: 1; min-width: 0; border: none; outline: none; font-family: inherit; font-size: 13.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #0F1626; padding: 0 10px; background: transparent;" />
              </div>
              <input type="text" data-ap-contact placeholder="<%= t('product.phoneOrEmail') %>" style="flex: 1; min-width: 0; height: 48px; border: 1px solid #DEE2E9; border-radius: 10px; outline: none; font-family: inherit; font-size: 12.5px; font-weight: 500; color: #0F1626; padding: 0 12px; background: #FFFFFF;" />
              <button type="button" data-ap-check-btn style="height: 48px; padding: 0 16px; border: none; border-radius: 10px; background: #15213B; color: #FFFFFF; font-family: inherit; font-size: 13px; font-weight: 800; cursor: pointer; white-space: nowrap; flex-shrink: 0;" class="ap-navy"><%= t('product.checkCta') %></button>
            </div>
            <div data-ap-check-idle style="font-size: 11.5px; font-weight: 500; color: #8A93A4; margin-top: 9px;"><%= t('product.expertConfirms') %></div>
            <div data-ap-check-loading style="display: none; align-items: center; gap: 8px; margin-top: 10px; font-size: 12px; font-weight: 600; color: #6B7482;"><span class="material-symbols-outlined" style="font-size: 15px;">progress_activity</span><%= t('product.sendingRequest') %></div>
            <div data-ap-check-ok style="display: none; align-items: center; gap: 9px; margin-top: 10px; background: #E4F5EC; border-radius: 10px; padding: 11px 13px;"><span class="material-symbols-outlined ap-fill" style="font-size: 17px; color: #128A52;">check_circle</span><span style="font-size: 12.5px; font-weight: 700; color: #128A52;"><%= t('product.requestSentExpert') %></span></div>
            <div data-ap-check-err style="display: none; align-items: center; gap: 8px; margin-top: 10px; font-size: 12px; font-weight: 600; color: #B42318;"><span class="material-symbols-outlined" style="font-size: 15px;">error</span><%= t('product.errPlate') %></div>
            <div data-ap-check-errcontact style="display: none; align-items: center; gap: 8px; margin-top: 10px; font-size: 12px; font-weight: 600; color: #B42318;"><span class="material-symbols-outlined" style="font-size: 15px;">error</span><%= t('product.errContact') %></div>

            <div style="display: flex; gap: 10px; margin-top: 18px;">
              <button type="submit" data-add-to-cart-submit <%= product.inStock ? '' : 'disabled' %> style="flex: 1; height: 52px; border: none; border-radius: 10px; background: #ED1C24; color: #FFFFFF; font-family: inherit; font-size: 15px; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;<%= product.inStock ? '' : 'opacity:0.5;cursor:not-allowed;' %>" class="ap-cta">
                <span class="material-symbols-outlined" style="font-size: 20px;" data-add-to-cart-icon>shopping_cart</span><span data-add-to-cart-label><%= t('product.addToCart') %></span>
              </button>
              <button type="button" data-ap-fav title="<%= t('product.addFavorite') %>" style="width: 52px; height: 52px; border: 1px solid #E1E5EB; border-radius: 10px; background: #FFFFFF; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <span class="material-symbols-outlined" data-ap-fav-icon style="font-size: 21px; color: #0F1626;">favorite</span>
              </button>
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 9px; margin-top: 16px; padding: 0 2px;">
            <span style="display: flex; align-items: center; gap: 9px; font-size: 12px; font-weight: 600; color: #5B6474;"><span class="material-symbols-outlined" style="font-size: 16px; color: #128A52;">local_shipping</span><%= t('product.trustDelivery') %></span>
            <span style="display: flex; align-items: center; gap: 9px; font-size: 12px; font-weight: 600; color: #5B6474;"><span class="material-symbols-outlined" style="font-size: 16px; color: #128A52;">assignment_return</span><%= t('product.trustExchange') %></span>
            <span style="display: flex; align-items: center; gap: 9px; font-size: 12px; font-weight: 600; color: #5B6474;"><span class="material-symbols-outlined" style="font-size: 16px; color: #128A52;">verified_user</span><%= t('product.trustPayment') %></span>
          </div>
        </form>
      </div>

      <%# ═══ Lightbox (hooks du script principal) ═══ %>
      <div aria-hidden="true" class="hidden" style="position:fixed;inset:0;z-index:100;background:rgba(11,15,26,0.85);backdrop-filter:blur(8px);padding:32px;align-items:center;justify-content:center;" data-lightbox role="dialog" tabindex="-1">
        <button aria-label="Fermer" style="position:absolute;top:18px;right:18px;z-index:10;width:44px;height:44px;border-radius:999px;border:none;background:rgba(255,255,255,0.14);cursor:pointer;display:flex;align-items:center;justify-content:center;" data-lightbox-close type="button"><span class="material-symbols-outlined" style="color:#fff;font-size:22px;">close</span></button>
        <button aria-label="Précédente" class="hidden" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);z-index:10;width:44px;height:44px;border-radius:999px;border:none;background:rgba(255,255,255,0.14);cursor:pointer;align-items:center;justify-content:center;display:flex;" data-lightbox-prev type="button"><span class="material-symbols-outlined" style="color:#fff;">chevron_left</span></button>
        <button aria-label="Suivante" class="hidden" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);z-index:10;width:44px;height:44px;border-radius:999px;border:none;background:rgba(255,255,255,0.14);cursor:pointer;align-items:center;justify-content:center;display:flex;" data-lightbox-next type="button"><span class="material-symbols-outlined" style="color:#fff;">chevron_right</span></button>
        <img alt="<%= product.name %>" style="max-width:100%;max-height:100%;object-fit:contain;border-radius:18px;box-shadow:0 30px 80px rgba(0,0,0,0.45);" data-lightbox-img />
        <div class="hidden" style="position:absolute;bottom:16px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.8);font-size:12px;font-weight:600;" data-lightbox-counter></div>
      </div>

      <%# ═══ Véhicules compatibles + Caractéristiques ═══ %>
      <div class="ap-two-col" style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 56px; margin-top: 72px;">
        <div id="compat">
          <div style="font-size: 19px; font-weight: 800; color: #0F1626; margin-bottom: 14px;"><%= t('product.compatibleVehicles') %></div>
          <% if (compatVehicles.length) { %>
            <div style="display: grid; grid-template-columns: 1fr 1.1fr 0.8fr 1fr; padding: 8px 0;">
              <span style="font-size: 10.5px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #7A8394;"><%= t('product.model') %></span>
              <span style="font-size: 10.5px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #7A8394;"><%= t('product.engine') %></span>
              <span style="font-size: 10.5px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #7A8394;"><%= t('product.years') %></span>
              <span style="font-size: 10.5px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #7A8394;"><%= t('product.references') %></span>
            </div>
            <% compatVehicles.forEach((v, i) => { %>
              <% var _rowRef = refsAlternatives[i] || ref || engineCodeVal || '—'; %>
              <div style="display: grid; grid-template-columns: 1fr 1.1fr 0.8fr 1fr; align-items: center; padding: 13px 0; border-top: 1px solid #F0F2F6;">
                <span style="font-size: 13px; font-weight: 800; color: #0F1626;"><%= [v.make, v.model].filter(Boolean).join(' ') || '—' %></span>
                <span style="font-size: 13px; font-weight: 600; color: #3E4657;"><%= v.engine || '—' %></span>
                <span style="font-size: 13px; font-weight: 600; color: #3E4657;"><%= v.years || '—' %></span>
                <span style="font-size: 13px; font-weight: 800; color: #0F1626;"><%= _rowRef %></span>
              </div>
            <% }) %>
          <% } %>
          <div style="display: flex; align-items: center; gap: 14px; margin-top: 20px; background: #F5F6F8; border-radius: 12px; padding: 14px 16px; flex-wrap: wrap;">
            <span style="width: 46px; height: 46px; border-radius: 999px; background: rgba(237,28,36,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;"><span class="material-symbols-outlined" style="font-size: 24px; color: #ED1C24;">support_agent</span></span>
            <div style="flex: 1; min-width: 160px;">
              <div style="font-size: 13px; font-weight: 800; color: #0F1626;"><%= t('product.notSureConseiller') %></div>
              <div style="font-size: 11.5px; font-weight: 500; color: #6B7482; margin-top: 2px;"><%= t('product.techTeamCallback') %></div>
            </div>
            <div data-ap-callback-idle style="display: flex; gap: 8px; flex-shrink: 0;">
              <input type="text" data-ap-callback-contact placeholder="<%= t('product.phoneOrEmail') %>" style="height: 42px; width: 200px; border: 1px solid #DEE2E9; border-radius: 10px; outline: none; font-family: inherit; font-size: 12.5px; font-weight: 500; color: #0F1626; padding: 0 13px; background: #FFFFFF;" />
              <button type="button" data-ap-callback-btn style="height: 42px; padding: 0 16px; border: none; border-radius: 10px; background: #15213B; color: #FFFFFF; font-family: inherit; font-size: 12.5px; font-weight: 800; cursor: pointer; white-space: nowrap;" class="ap-navy"><%= t('product.callbackCta') %></button>
            </div>
            <div data-ap-callback-ok style="display: none; align-items: center; gap: 8px; flex-shrink: 0; background: #E4F5EC; border-radius: 10px; padding: 10px 14px;"><span class="material-symbols-outlined ap-fill" style="font-size: 16px; color: #128A52;">check_circle</span><span style="font-size: 12px; font-weight: 700; color: #128A52;"><%= t('product.callbackOk') %></span></div>
          </div>
        </div>

        <div>
          <div style="font-size: 19px; font-weight: 800; color: #0F1626; margin-bottom: 14px;"><%= t('product.characteristics') %></div>
          <% var _carac = []; %>
          <% if (keyType) _carac.push({ k: t('product.specType'), v: keyType }); %>
          <% if (gearsVal) _carac.push({ k: t('product.gearsCount'), v: gearsVal }); %>
          <% if (ref) _carac.push({ k: t('product.specRef'), v: ref }); %>
          <% if (engineCodeVal) _carac.push({ k: _codeLabel, v: engineCodeVal }); %>
          <% if (keyEtat) _carac.push({ k: t('product.specState'), v: keyEtat }); %>
          <% if (_garValue) _carac.push({ k: t('product.guarantee'), v: _garValue }); %>
          <% _carac.forEach((row, i) => { %>
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 12px 0; border-top: 1px solid #F0F2F6;<%= i === _carac.length - 1 ? ' border-bottom: 1px solid #F0F2F6;' : '' %>">
              <span style="font-size: 13px; font-weight: 600; color: #6B7482;<%= /altern/i.test(row.k) ? ' white-space: nowrap;' : '' %>"><%= row.k %></span>
              <span style="font-size: 13px; font-weight: 800; color: #0F1626; text-align: right; line-height: 1.55;"><%= row.v %></span>
            </div>
          <% }) %>
          <% if (refsAlternatives.length) { %>
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 12px 0; border-bottom: 1px solid #F0F2F6;">
              <span style="font-size: 13px; font-weight: 600; color: #6B7482; white-space: nowrap;"><%= t('product.altRefs') %></span>
              <span style="font-size: 12.5px; font-weight: 800; color: #0F1626; text-align: right; line-height: 1.55;"><%= refsAlternatives.join(', ') %></span>
            </div>
          <% } %>
        </div>
      </div>

      <%# ═══ Comment nous reconditionnons (bande navy) ═══ %>
      <% if (_showIso) { %>
      <div class="ap-recond-grid" style="background: #15213B; border-radius: 20px; padding: 40px 44px; margin-top: 72px; color: #FFFFFF; display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 44px; align-items: center;">
        <div>
          <div style="display: flex; align-items: center; gap: 11px; margin-bottom: 16px;">
            <div style="display: flex; gap: 3px;"><% for (var _s2 = 0; _s2 < 5; _s2++) { %><span style="width: 20px; height: 20px; background: #00B67A; display: flex; align-items: center; justify-content: center;"><span class="material-symbols-outlined ap-fill" style="font-size: 14px; color: #FFFFFF;">star</span></span><% } %></div>
            <span style="font-size: 12.5px; font-weight: 800; letter-spacing: 0.02em; color: #FFFFFF;"><%= t('product.qualityPremiumIso') %></span>
          </div>
          <div style="font-size: 22px; font-weight: 800; line-height: 1.3; margin-bottom: 12px; text-wrap: pretty;"><%= t('product.howWeRecond') %></div>
          <p style="font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.72); line-height: 1.7; margin: 0 0 26px 0; max-width: 480px;"><%= t('product.recondIntro') %></p>
          <div style="display: flex; flex-direction: column; gap: 18px;">
            <% var _recSteps = [ {t: t('product.recStep1Title'), d: t('product.recStep1Text')}, {t: t('product.recStep2Title'), d: t('product.recStep2Text')}, {t: t('product.recStep3Title'), d: t('product.recStep3Text')} ]; %>
            <% _recSteps.forEach((st, i) => { %>
              <div style="display: flex; align-items: flex-start; gap: 14px;">
                <span style="width: 30px; height: 30px; border-radius: 999px; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; flex-shrink: 0;"><%= i + 1 %></span>
                <div><div style="font-size: 13.5px; font-weight: 800;"><%= st.t %></div><div style="font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.65); margin-top: 2px;"><%= st.d %></div></div>
              </div>
            <% }) %>
          </div>
        </div>
        <%# Vidéo de présentation du reconditionnement (Short YouTube vertical, commune
            à toutes les fiches reconditionnées). youtube-nocookie = pas de cookie tant
            que l'utilisateur ne lance pas la lecture. %>
        <div style="display: flex; align-items: center; justify-content: center;">
          <div style="position: relative; width: 100%; max-width: 250px; aspect-ratio: 9 / 16; border-radius: 16px; overflow: hidden; background: #1A2233; box-shadow: 0 14px 36px rgba(0,0,0,0.30);">
            <iframe src="https://www.youtube-nocookie.com/embed/EyZbdJosmr0?rel=0" title="<%= t('product.howWeRecond') %>" style="position: absolute; inset: 0; width: 100%; height: 100%; border: 0;" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
          </div>
        </div>
      </div>
      <% } %>

      <%# ═══ Occasion / Reconditionné / Neuf (comparatif) ═══ %>
      <% if (_showIso) { %>
      <div style="margin-top: 72px;">
        <div style="text-align: center; max-width: 600px; margin: 0 auto 26px auto;">
          <div style="font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: #ED1C24; margin-bottom: 8px;"><%= t('product.chooseWell') %></div>
          <div style="font-size: 22px; font-weight: 800; color: #0F1626;"><%= t('product.compareTitle') %></div>
          <div style="font-size: 12.5px; font-weight: 500; color: #6B7482; margin-top: 7px; line-height: 1.6;"><%= t('product.compareSub') %></div>
        </div>
        <div class="ap-compare" style="display: grid; grid-template-columns: 1.15fr 1fr 1.25fr 1fr; border: 1px solid #E5E8EE; border-radius: 16px; overflow: hidden;">
          <div style="padding: 16px 20px; background: #FFFFFF;"></div>
          <div style="padding: 16px; font-size: 11px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; background: #F7F8FA; color: #6B7482; display: flex; align-items: center; justify-content: center;"><%= t('product.usedWord') %></div>
          <div style="padding: 16px; font-size: 11px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; background: #15213B; color: #FFFFFF; display: flex; align-items: center; justify-content: center;"><%= t('product.recondWord') %></div>
          <div style="padding: 16px; font-size: 11px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; background: #F7F8FA; color: #6B7482; display: flex; align-items: center; justify-content: center;"><%= t('product.newWord') %></div>
          <% var _cmpRows = [
               { c: t('product.cmpPrice'), u: t('product.cmpPriceUsed'), r: t('product.cmpPriceRecond'), n: t('product.cmpPriceNew'), weak: [true, false, false] },
               { c: t('product.cmpWarranty'), u: t('product.cmpNone'), r: t('product.cmpWarrantyRecond'), n: t('product.cmpWarrantyNew'), weak: [true, false, false] },
               { c: t('product.cmpHistory'), u: t('product.cmpUnknown'), r: t('product.cmpHistoryRecond'), n: t('product.cmpNew2'), weak: [true, false, false] },
               { c: t('product.cmpAvail'), u: t('product.cmpRandom'), r: t('product.cmpAvailRecond'), n: t('product.cmpAvailNew'), weak: [true, false, false] },
               { c: t('product.cmpBreakdown'), u: t('product.cmpNoRecourse'), r: t('product.cmpBreakdownRecond'), n: t('product.cmpBreakdownNew'), weak: [true, false, false] }
             ]; %>
          <% _cmpRows.forEach((rw) => { %>
            <div style="padding: 15px 20px; font-size: 12.5px; font-weight: 700; color: #6B7482; border-top: 1px solid #F0F2F6; display: flex; align-items: center;"><%= rw.c %></div>
            <div style="padding: 15px 16px; font-size: 13px; font-weight: 600; color: <%= rw.weak[0] ? '#99A1B0' : '#3E4657' %>; border-top: 1px solid #F0F2F6; display: flex; align-items: center; justify-content: center; text-align: center;"><%= rw.u %></div>
            <div style="padding: 15px 16px; font-size: 13px; font-weight: 800; color: #0F1626; background: #F5F7FB; border-top: 1px solid #E8ECF3; display: flex; align-items: center; justify-content: center; text-align: center;"><%= rw.r %></div>
            <div style="padding: 15px 16px; font-size: 13px; font-weight: 600; color: #3E4657; border-top: 1px solid #F0F2F6; display: flex; align-items: center; justify-content: center; text-align: center;"><%= rw.n %></div>
          <% }) %>
          <div style="padding: 15px 20px; font-size: 12.5px; font-weight: 700; color: #6B7482; border-top: 1px solid #F0F2F6; display: flex; align-items: center; gap: 7px;"><span class="material-symbols-outlined" style="font-size: 15px; color: #128A52;">eco</span><%= t('product.cmpEnv') %></div>
          <div style="padding: 15px 16px; font-size: 13px; font-weight: 600; color: #3E4657; border-top: 1px solid #F0F2F6; display: flex; align-items: center; justify-content: center; text-align: center;"><%= t('product.cmpReuse') %></div>
          <div style="padding: 15px 16px; font-size: 13px; font-weight: 800; color: #0F1626; background: #F5F7FB; border-top: 1px solid #E8ECF3; display: flex; align-items: center; justify-content: center; text-align: center; gap: 7px;"><span class="material-symbols-outlined ap-fill" style="font-size: 15px; color: #128A52;">check_circle</span><%= t('product.cmpReuseRecond') %></div>
          <div style="padding: 15px 16px; font-size: 13px; font-weight: 600; color: #99A1B0; border-top: 1px solid #F0F2F6; display: flex; align-items: center; justify-content: center; text-align: center;"><%= t('product.cmpNewProd') %></div>
        </div>
        <div style="font-size: 11px; font-weight: 500; color: #99A1B0; margin-top: 10px; text-align: center;"><%= t('product.compareLegal') %></div>
      </div>
      <% } %>

      <%# ═══ L'échange standard, comment ça marche ═══ %>
      <% if (_showIso) { %>
      <div id="echange-standard" style="margin-top: 72px; background: #F7F8FA; border-radius: 20px; padding: 36px 44px;">
        <div style="margin-bottom: 24px;">
          <div style="font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: #ED1C24; margin-bottom: 8px;"><%= t('product.noDepositWord') %></div>
          <div style="font-size: 19px; font-weight: 800; color: #0F1626;"><%= t('product.exchangeHowTitle') %></div>
          <div style="font-size: 12.5px; font-weight: 500; color: #6B7482; margin-top: 4px;"><%= t('product.exchangeHowSub') %></div>
        </div>
        <div class="ap-4col" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px;">
          <% var _exSteps = [ {t: t('product.exStep1Title'), d: t('product.exStep1Text')}, {t: t('product.exStep2Title'), d: t('product.exStep2Text')}, {t: t('product.exStep3Title'), d: t('product.exStep3Text')}, {t: t('product.exStep4Title'), d: t('product.exStep4Text')} ]; %>
          <% _exSteps.forEach((st, i) => { %>
            <div style="display: flex; align-items: flex-start; gap: 13px;">
              <span style="width: 32px; height: 32px; border-radius: 999px; background: #15213B; color: #FFFFFF; font-size: 13px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"><%= i + 1 %></span>
              <div><div style="font-size: 13.5px; font-weight: 800; color: #0F1626;"><%= st.t %></div><div style="font-size: 12px; font-weight: 500; color: #6B7482; line-height: 1.55; margin-top: 3px;"><%= st.d %></div></div>
            </div>
          <% }) %>
        </div>
        <div style="display: inline-flex; align-items: center; gap: 8px; margin-top: 20px; background: #E4F5EC; border-radius: 10px; padding: 10px 14px;">
          <span class="material-symbols-outlined ap-fill" style="font-size: 16px; color: #128A52;">check_circle</span>
          <span style="font-size: 12.5px; font-weight: 700; color: #128A52;"><%= t('product.noDepositNote') %></span>
        </div>
      </div>
      <% } %>

      <%# ═══ Ils nous font confiance (preuves + logos) — TOGGLEABLE, accord écrit requis ═══ %>
      <% var _showTrust = (typeof showTrustProof !== 'undefined') ? showTrustProof : true; %>
      <% if (_showTrust) { %>
      <div id="avis" style="margin-top: 72px;">
        <div style="display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 16px; flex-wrap: wrap;">
          <div>
            <div style="font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: #ED1C24; margin-bottom: 8px;"><%= t('product.proofImages') %></div>
            <div style="font-size: 19px; font-weight: 800; color: #0F1626;"><%= t('product.theyTrust') %></div>
            <div style="font-size: 12.5px; font-weight: 500; color: #6B7482; margin-top: 4px;"><%= t('product.realDeliveries') %></div>
          </div>
          <a href="tel:<%= brand.PHONE_INTL %>" style="border: 1px solid #DEE2E9; border-radius: 10px; padding: 10px 16px; background: #FFFFFF; font-family: inherit; font-size: 12.5px; font-weight: 800; color: #0F1626; text-decoration: none; white-space: nowrap;" class="ap-iconbtn"><%= t('product.areYouGarage') %></a>
        </div>
        <div class="ap-3col" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;">
          <% var _proofs = [ {img:'/design/autoparts/photo-porsche.jpg', t: t('product.proof1Title'), s: t('product.proof1Sub')}, {img:'/design/autoparts/photo-sun-motors.jpg', t: t('product.proof2Title'), s: t('product.proof2Sub')}, {img:'/design/autoparts/photo-chargement.jpg', t: t('product.proof3Title'), s: t('product.proof3Sub')} ]; %>
          <% _proofs.forEach((pf) => { %>
            <div class="ap-photocard" style="position: relative; border-radius: 14px; overflow: hidden; aspect-ratio: 16 / 10; background: #1A2233;">
              <img src="<%= pf.img %>" alt="<%= pf.t %>" loading="lazy" decoding="async" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;" />
              <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,14,24,0.78), rgba(10,14,24,0.03) 52%); pointer-events: none;"></div>
              <div style="position: absolute; left: 16px; right: 16px; bottom: 14px; pointer-events: none;">
                <div style="font-size: 13px; font-weight: 800; color: #FFFFFF;"><%= pf.t %></div>
                <div style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.8); margin-top: 2px;"><%= pf.s %></div>
              </div>
            </div>
          <% }) %>
        </div>
        <div style="text-align: center; margin-top: 28px;">
          <div style="font-size: 11px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: #99A1B0; margin-bottom: 18px;"><%= t('product.garagesTrust') %></div>
          <div style="overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent); mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);">
            <div class="ap-marquee-track">
              <% for (var _dup = 0; _dup < 2; _dup++) { %>
                <div style="display: flex; align-items: center; gap: 64px; padding-right: 64px;"<%= _dup === 1 ? ' aria-hidden="true"' : '' %>>
                  <img src="/design/autoparts/logo-porsche.webp" alt="Porsche" style="height: 44px; filter: grayscale(1) opacity(0.7);" />
                  <img src="/design/autoparts/chassay-automobiles.png" alt="Chassay Automobiles" style="height: 20px; filter: grayscale(1) opacity(0.7);" />
                  <img src="/design/autoparts/sun-motors.webp" alt="Sun Motors" style="height: 42px; filter: grayscale(1) opacity(0.75);" />
                  <img src="/design/autoparts/mougins-autosport.webp" alt="Mougins Auto Sport" style="height: 32px; filter: grayscale(1) opacity(0.7);" />
                  <img src="/design/autoparts/Logo-FLAT44-contact.png" alt="FLAT44" style="height: 24px; filter: invert(0.75) grayscale(1) opacity(0.85);" />
                  <img src="/design/autoparts/LOGO-SIMPLICI-CAR-NOIR-copie.png" alt="SimpliciCar" style="height: 44px; filter: grayscale(1) opacity(0.75);" />
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% } %>

      <%# ═══ FAQ ═══ %>
      <% var _faqItems = (product.sections && product.sections.showFaq && Array.isArray(product.faqs) && product.faqs.length)
           ? product.faqs.map((f) => ({ q: f.question, a: f.answer }))
           : [ {q: t('product.faqQ1'), a: t('product.faqA1')}, {q: t('product.faqQ2'), a: t('product.faqA2')}, {q: t('product.faqQ3'), a: t('product.faqA3')}, {q: t('product.faqQ4'), a: t('product.faqA4')} ]; %>
      <% if (_faqItems.length) { %>
      <div style="max-width: 780px; margin: 72px auto 0 auto;">
        <div style="font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: #ED1C24; margin-bottom: 8px;"><%= t('product.weAnswer') %></div>
        <div style="font-size: 19px; font-weight: 800; color: #0F1626; margin-bottom: 14px;"><%= t('product.freqQuestions') %></div>
        <% _faqItems.forEach((f, i) => { %>
          <div data-ap-faq style="border-top: 1px solid #F0F2F6;<%= i === _faqItems.length - 1 ? ' border-bottom: 1px solid #F0F2F6;' : '' %> padding: 15px 10px;" class="ap-faq-row">
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px;">
              <span style="font-size: 13.5px; font-weight: 700; color: #0F1626;"><%= f.q %></span>
              <span class="material-symbols-outlined" data-ap-faq-chev style="font-size: 19px; color: #6B7482; transition: transform 0.18s;">expand_more</span>
            </div>
            <p data-ap-faq-ans style="display: none; font-size: 12.5px; font-weight: 500; color: #6B7482; line-height: 1.65; margin: 9px 0 0 0; max-width: 560px;"><%= f.a %></p>
          </div>
        <% }) %>
      </div>
      <% } %>

      <%# ═══ Complétez votre montage (accessoires réels liés — ajout panier AJAX) ═══ %>
      <% if (Array.isArray(productAccessories) && productAccessories.length) { %>
      <div style="margin-top: 72px;">
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 20px; margin-bottom: 16px; flex-wrap: wrap;">
          <div>
            <div style="font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: #ED1C24; margin-bottom: 8px;"><%= t('product.recommendedAccessories') %></div>
            <div style="font-size: 19px; font-weight: 800; color: #0F1626;"><%= t('product.completeMounting') %></div>
            <div style="font-size: 12.5px; font-weight: 500; color: #6B7482; margin-top: 4px;"><%= t('product.accessoriesSub') %></div>
          </div>
          <a href="/produits" style="display: flex; align-items: center; gap: 4px; font-size: 12.5px; font-weight: 800; color: #ED1C24; text-decoration: none; white-space: nowrap;"><%= t('product.seeAllCatalog') %><span class="material-symbols-outlined" style="font-size: 16px;">chevron_right</span></a>
        </div>
        <div class="ap-4col" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;">
          <% productAccessories.slice(0, 4).forEach((ac) => { %>
            <div style="border: 1px solid #E5E8EE; border-radius: 12px; padding: 12px; display: flex; gap: 12px; align-items: center;">
              <a href="<%= ac.publicPath %>" style="width: 62px; height: 62px; border-radius: 8px; background: #F4F5F8; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; text-decoration: none;">
                <% if (ac.imageUrl) { %>
                  <img src="<%= ac.imageUrl %>" alt="<%= ac.name %>" loading="lazy" decoding="async" style="width: 100%; height: 100%; object-fit: cover;" />
                <% } else { %>
                  <span class="material-symbols-outlined" style="font-size: 28px; color: #99A1B0;">handyman</span>
                <% } %>
              </a>
              <div style="flex: 1; min-width: 0;">
                <a href="<%= ac.publicPath %>" style="display: block; font-size: 12px; font-weight: 700; color: #0F1626; line-height: 1.35; text-decoration: none; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= ac.name %></a>
                <div style="font-size: 11px; font-weight: 600; color: #6B7482; margin-top: 2px;"><% if (ac.sku) { %>Réf. <%= ac.sku %><% } %><% if (ac.condition) { %> · <%= ac.condition %><% } %></div>
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: 7px;">
                  <span style="font-size: 13.5px; font-weight: 800; color: #0F1626;"><%= formatMoney(ac.priceCents) %> €</span>
                  <button type="button" data-ap-acc-add data-acc-id="<%= ac._id %>" data-acc-name="<%= ac.name %>" <%= ac.inStock ? '' : 'disabled' %> style="width: 32px; height: 32px; border: 1px solid #E1E5EB; border-radius: 8px; background: #FFFFFF; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0;<%= ac.inStock ? '' : 'opacity:0.45;cursor:not-allowed;' %>" class="ap-iconbtn" aria-label="Ajouter au panier"><span class="material-symbols-outlined" style="font-size: 16px; color: #0F1626;">add_shopping_cart</span></button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <%# ═══ Pour aller plus loin (blog) ═══ %>
      <%# Articles de blog liés depuis le back-office : choisis dans le picker de la
          fiche produit (relatedBlogPostIds) OU articles qui pointent vers ce produit
          (relatedProductIds). Aucun contenu d'exemple : section masquée si rien de lié. %>
      <% var _blog = (Array.isArray(relatedBlogPosts) && relatedBlogPosts.length)
           ? relatedBlogPosts.slice(0, 3).map((a) => ({ url: a.url, img: a.imageUrl, tag: (a.categoryLabel || t('product.blogGuide')), read: (a.readTimeLabel || ''), title: a.title, excerpt: a.excerpt }))
           : []; %>
      <% if (_blog.length) { %>
      <div style="margin-top: 72px;">
        <div style="display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 16px; flex-wrap: wrap;">
          <div>
            <div style="font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: #ED1C24; margin-bottom: 8px;"><%= t('product.tipsWord') %></div>
            <div style="font-size: 19px; font-weight: 800; color: #0F1626;"><%= t('product.goFurther') %></div>
            <div style="font-size: 12.5px; font-weight: 500; color: #6B7482; margin-top: 4px;"><%= t('product.blogSub') %></div>
          </div>
          <a href="/blog" style="display: flex; align-items: center; gap: 4px; font-size: 12.5px; font-weight: 800; color: #ED1C24; text-decoration: none; white-space: nowrap;"><%= t('product.seeAllBlog') %><span class="material-symbols-outlined" style="font-size: 16px;">chevron_right</span></a>
        </div>
        <div class="ap-3col" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;">
          <% _blog.forEach((a) => { %>
            <a href="<%= a.url %>" class="ap-blogcard" style="display: block; border: 1px solid #E5E8EE; border-radius: 14px; overflow: hidden; background: #FFFFFF; text-decoration: none; color: inherit;">
              <div style="position: relative; aspect-ratio: 16 / 10; background: #F4F5F8;">
                <% if (a.img) { %><img src="<%= a.img %>" alt="<%= a.title %>" loading="lazy" decoding="async" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;" /><% } else { %><div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#C3C9D3;"><span class="material-symbols-outlined" style="font-size:40px;">article</span></div><% } %>
              </div>
              <div style="padding: 16px 18px 18px 18px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 9px;">
                  <span style="background: #F4F5F8; border-radius: 6px; padding: 4px 8px; font-size: 10.5px; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #2A3242;"><%= a.tag %></span>
                  <% if (a.read) { %><span style="font-size: 11.5px; font-weight: 600; color: #99A1B0;"><%= a.read %></span><% } %>
                </div>
                <div style="font-size: 15px; font-weight: 800; color: #0F1626; line-height: 1.4; text-wrap: pretty;"><%= a.title %></div>
                <% if (a.excerpt) { %><p style="font-size: 12.5px; font-weight: 500; color: #6B7482; line-height: 1.6; margin: 7px 0 12px 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= a.excerpt %></p><% } %>
                <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 12.5px; font-weight: 800; color: #ED1C24; margin-top: 8px;"><%= t('product.readArticle') %><span class="material-symbols-outlined" style="font-size: 15px;">arrow_forward</span></span>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <%# ═══ Bandeau réassurance (4 items) ═══ %>
      <div class="ap-4col" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; margin-top: 72px; padding: 32px 0 38px 0; border-top: 1px solid #F0F2F6;">
        <% var _reass = [ {icon:'verified_user', t: t('product.reassure1Title'), s: t('product.reassure1Sub')}, {icon:'credit_card', t: t('product.reassure2Title'), s: t('product.reassure2Sub')}, {icon:'local_shipping', t: t('product.reassure3Title'), s: t('product.reassure3Sub')}, {icon:'support_agent', t: t('product.reassure4Title'), s: t('product.reassure4Sub')} ]; %>
        <% _reass.forEach((it) => { %>
          <div style="display: flex; align-items: center; gap: 13px;">
            <span class="material-symbols-outlined" style="font-size: 27px; color: #1A2233; font-variation-settings: 'wght' 300; flex-shrink: 0;"><%= it.icon %></span>
            <div><div style="font-size: 13px; font-weight: 800; color: #0F1626;"><%= it.t %></div><div style="font-size: 11.5px; font-weight: 500; color: #6B7482; margin-top: 2px;"><%= it.s %></div></div>
          </div>
        <% }) %>
      </div>

      </div><%# /ap-page %>


      <script>
        (function () {
          var mainImg = document.querySelector('[data-main-image]');
          var mainVid = document.querySelector('[data-main-video]');
          var mainEmbed = document.querySelector('[data-main-embed]'); // iframe YouTube/Vimeo
          var thumbs = Array.prototype.slice.call(document.querySelectorAll('[data-thumb]') || []);
          var prevBtn = document.querySelector('[data-gallery-prev]');
          var nextBtn = document.querySelector('[data-gallery-next]');
          var currentIndex = 0;

          var qtyInput = document.querySelector('[data-qty-input]');
          var qtyDisplay = document.querySelector('[data-qty-display]');
          var minus = document.querySelector('[data-qty-minus]');
          var plus = document.querySelector('[data-qty-plus]');
          var addToCartForm = document.querySelector('[data-add-to-cart-form]');
          var addToCartSubmit = addToCartForm ? addToCartForm.querySelector('[data-add-to-cart-submit]') : null;
          var addToCartIcon = addToCartForm ? addToCartForm.querySelector('[data-add-to-cart-icon]') : null;
          var addToCartLabel = addToCartForm ? addToCartForm.querySelector('[data-add-to-cart-label]') : null;
          var addToCartPending = false;
          var addToCartResetTimer = null;
          var originalSubmitIcon = addToCartIcon ? addToCartIcon.textContent : 'add_shopping_cart';
          var originalSubmitLabel = addToCartLabel ? addToCartLabel.textContent : '<%= t('product.addToCart') %>';
          var originalSubmitDisabled = !!(addToCartSubmit && addToCartSubmit.disabled);

          var priceEl = document.querySelector('[data-price-display]');
          var priceHtEl = document.querySelector('[data-price-display-ht]'); // prix HT (TVA récupérable)
          var installmentWrapper = document.querySelector('[data-installment-wrapper]');
          var installmentAmountEl = document.querySelector('[data-installment-amount]');
          var optionInputs = Array.prototype.slice.call(document.querySelectorAll('[data-option-input]') || []);
          var exchangeStandardPanel = document.querySelector('[data-exchange-standard-panel]');
          var supplyModeInputs = Array.prototype.slice.call(document.querySelectorAll('[data-supply-mode-choice]') || []);

          function formatMoney(cents) {
            try {
              return new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format((Number(cents) || 0) / 100);
            } catch (e) {
              return ((Number(cents) || 0) / 100).toFixed(2).replace('.', ',');
            }
          }

          function computeOptionPricing() {
            var total = 0;
            var absolute = null;
            optionInputs.forEach(function (el) {
              if (!el) return;
              var type = el.getAttribute('data-option-type') || '';
              var delta = Number(el.getAttribute('data-price-delta-cents') || '0');
              var absoluteRaw = el.getAttribute('data-absolute-price-cents');
              var absolutePrice = absoluteRaw === '' || absoluteRaw === null ? null : Number(absoluteRaw);
              if (!Number.isFinite(delta)) delta = 0;

              if (type === 'choice') {
                if (el.checked) {
                  if (Number.isFinite(absolutePrice) && absolutePrice >= 0) absolute = absolutePrice;
                  else total += delta;
                }
              } else if (type === 'text') {
                var v = (el.value || '').trim();
                if (v) total += delta;
              }
            });
            return { delta: total, absolute: absolute };
          }

          function syncDisplayedPrice() {
            if (!priceEl) return;
            var base = Number(priceEl.getAttribute('data-base-price-cents') || '0');
            if (!Number.isFinite(base)) base = 0;
            var pricing = computeOptionPricing();
            var next = (pricing.absolute !== null ? pricing.absolute : base) + pricing.delta;
            priceEl.textContent = formatMoney(next) + ' €';
            if (priceHtEl) priceHtEl.textContent = formatMoney(Math.round(next / 1.2)); // HT = TTC / 1,20
            syncInstallmentDisplay(next);
          }

          function syncInstallmentDisplay(totalCents) {
            if (!installmentWrapper || !priceEl) return;
            var count = Number(priceEl.getAttribute('data-installment-count') || '3');
            var min = Number(priceEl.getAttribute('data-installment-min-cents') || '0');
            var max = Number(priceEl.getAttribute('data-installment-max-cents') || '0');
            if (!Number.isFinite(count) || count <= 0) count = 3;
            if (!Number.isFinite(min) || min < 0) min = 0;
            if (!Number.isFinite(max) || max < min) max = Number.MAX_SAFE_INTEGER;
            var eligible = Number.isFinite(totalCents) && totalCents >= min && totalCents <= max;
            installmentWrapper.classList.toggle('hidden', !eligible);
            if (eligible && installmentAmountEl) {
              installmentAmountEl.textContent = formatMoney(Math.round(totalCents / count)) + ' €';
            }
          }

          function syncExchangeStandardPanel() {
            if (!exchangeStandardPanel) return;
            var selectedInput = null;
            supplyModeInputs.forEach(function (el) {
              if (el && el.checked) selectedInput = el;
            });
            var selectedMode = selectedInput ? String(selectedInput.getAttribute('data-supply-mode-choice') || '') : '';
            var showPanel = selectedMode.indexOf('echange-standard') !== -1;
            exchangeStandardPanel.classList.toggle('hidden', !showPanel);
          }

          function clamp(v) {
            if (!Number.isFinite(v)) return 1;
            if (v < 1) return 1;
            if (v > 99) return 99;
            return v;
          }

          function getQty() {
            if (!qtyInput) return 1;
            var n = parseInt(qtyInput.value, 10);
            if (!Number.isFinite(n)) return 1;
            return clamp(n);
          }

          function setQty(nextQty) {
            var v = clamp(nextQty);
            if (qtyInput) qtyInput.value = String(v);
            if (qtyDisplay) qtyDisplay.textContent = String(v);
          }

          function resetAddToCartButton() {
            if (addToCartResetTimer) {
              window.clearTimeout(addToCartResetTimer);
              addToCartResetTimer = null;
            }
            if (!addToCartSubmit) return;
            addToCartSubmit.classList.remove('cart-submit-success');
            addToCartSubmit.disabled = originalSubmitDisabled;
            if (addToCartIcon) addToCartIcon.textContent = originalSubmitIcon;
            if (addToCartLabel) addToCartLabel.textContent = originalSubmitLabel;
          }

          function setAddToCartSuccessState() {
            if (!addToCartSubmit) return;
            addToCartSubmit.classList.add('cart-submit-success');
            addToCartSubmit.disabled = true;
            if (addToCartIcon) addToCartIcon.textContent = 'check';
            if (addToCartLabel) addToCartLabel.textContent = 'Ajouté';
          }

          function scheduleAddToCartReset(delayMs) {
            if (addToCartResetTimer) {
              window.clearTimeout(addToCartResetTimer);
            }
            addToCartResetTimer = window.setTimeout(function () {
              resetAddToCartButton();
              addToCartPending = false;
            }, delayMs);
          }

          function setActiveThumb(index) {
            if (!thumbs || !thumbs.length) return;

            thumbs.forEach(function (b, idx) {
              b.classList.remove('ring-2', 'ring-primary', 'border-primary/20', 'border-slate-200', 'dark:border-slate-700');
              b.classList.add('border');
              if (idx === index) {
                b.classList.add('border-primary/20', 'ring-2', 'ring-primary');
              } else {
                b.classList.add('border-slate-200', 'dark:border-slate-700');
              }
            });

            var btn = thumbs[index];
            if (!btn) return;
            try {
              btn.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
            } catch (e) {
              btn.scrollIntoView(true);
            }
          }

          function setIndex(nextIndex) {
            if ((!mainImg && !mainVid) || !thumbs || !thumbs.length) return;
            var max = thumbs.length;
            var idx = nextIndex % max;
            if (idx < 0) idx = max + idx;

            var btn = thumbs[idx];
            if (!btn) return;
            var src = btn.getAttribute('data-src');
            var type = btn.getAttribute('data-type') || 'image';
            if (!src) return;

            if (type === 'embed') {
              // Vidéo YouTube/Vimeo : on affiche l'iframe (autoplay au clic) et on
              // masque image + vidéo fichier.
              if (mainImg) { mainImg.classList.add('hidden'); mainImg.removeAttribute('src'); }
              if (mainVid) { try { mainVid.pause(); } catch (e) {} mainVid.classList.add('hidden'); mainVid.removeAttribute('src'); }
              if (mainEmbed) {
                var embedSrc = btn.getAttribute('data-embed-src') || src;
                mainEmbed.classList.remove('hidden');
                mainEmbed.setAttribute('src', embedSrc + (embedSrc.indexOf('?') === -1 ? '?' : '&') + 'autoplay=1');
              }
            } else if (type === 'video') {
              if (mainEmbed) { mainEmbed.classList.add('hidden'); mainEmbed.removeAttribute('src'); }
              if (mainImg) {
                mainImg.classList.add('hidden');
                mainImg.removeAttribute('src');
              }
              if (mainVid) {
                mainVid.classList.remove('hidden');
                try { mainVid.pause(); } catch (e) {}
                mainVid.setAttribute('src', src);
                try { mainVid.load(); } catch (e) {}
              }
            } else {
              if (mainEmbed) { mainEmbed.classList.add('hidden'); mainEmbed.removeAttribute('src'); }
              if (mainVid) {
                try { mainVid.pause(); } catch (e) {}
                mainVid.classList.add('hidden');
                mainVid.removeAttribute('src');
              }
              if (mainImg) {
                mainImg.classList.remove('hidden');
                mainImg.setAttribute('src', src);
              }
            }

            currentIndex = idx;
            setActiveThumb(currentIndex);
          }

          if (minus) {
            minus.addEventListener('click', function () {
              setQty(getQty() - 1);
            });
          }
          if (plus) {
            plus.addEventListener('click', function () {
              setQty(getQty() + 1);
            });
          }

          if (thumbs && thumbs.length && mainImg) {
            thumbs.forEach(function (btn, idx) {
              btn.addEventListener('click', function () {
                setIndex(idx);
              });
            });

            if (prevBtn) {
              prevBtn.addEventListener('click', function () {
                setIndex(currentIndex - 1);
              });
            }
            if (nextBtn) {
              nextBtn.addEventListener('click', function () {
                setIndex(currentIndex + 1);
              });
            }

            /* ── Lightbox : ouvrir au clic sur l'image principale ─────── */
            var lightbox = document.querySelector('[data-lightbox]');
            var lightboxImg = lightbox ? lightbox.querySelector('[data-lightbox-img]') : null;
            var lightboxPrev = lightbox ? lightbox.querySelector('[data-lightbox-prev]') : null;
            var lightboxNext = lightbox ? lightbox.querySelector('[data-lightbox-next]') : null;
            var lightboxClose = lightbox ? lightbox.querySelector('[data-lightbox-close]') : null;
            var lightboxCounter = lightbox ? lightbox.querySelector('[data-lightbox-counter]') : null;

            /* Indices des images (vidéos exclues) pour la nav lightbox */
            var imageThumbIndices = thumbs.reduce(function (acc, t, i) {
              var _ty = t.getAttribute('data-type') || 'image';
              if (_ty !== 'video' && _ty !== 'embed') acc.push(i);
              return acc;
            }, []);
            var lightboxImageIdx = 0; // position dans imageThumbIndices

            function updateLightboxCounter() {
              if (!lightboxCounter) return;
              if (imageThumbIndices.length <= 1) {
                lightboxCounter.classList.add('hidden');
                return;
              }
              lightboxCounter.classList.remove('hidden');
              lightboxCounter.textContent = (lightboxImageIdx + 1) + ' / ' + imageThumbIndices.length;
            }

            function showLightboxAt(imageIdx) {
              if (!lightbox || !lightboxImg) return;
              if (!imageThumbIndices.length) return;
              if (imageIdx < 0) imageIdx = imageThumbIndices.length - 1;
              if (imageIdx >= imageThumbIndices.length) imageIdx = 0;
              lightboxImageIdx = imageIdx;
              var thumb = thumbs[imageThumbIndices[imageIdx]];
              var src = thumb && thumb.getAttribute('data-src');
              if (!src) return;
              lightboxImg.setAttribute('src', src);
              lightboxImg.setAttribute('alt', (mainImg && mainImg.getAttribute('alt')) || '');
              updateLightboxCounter();
              /* Sync également l'image principale + thumb actif */
              setIndex(imageThumbIndices[imageIdx]);
            }

            function openLightbox() {
              if (!lightbox || !mainImg || mainImg.classList.contains('hidden')) return;
              /* Trouver l'index image courant dans imageThumbIndices */
              var pos = imageThumbIndices.indexOf(currentIndex);
              if (pos < 0) pos = 0;
              showLightboxAt(pos);
              lightbox.classList.remove('hidden');
              lightbox.classList.add('flex');
              lightbox.setAttribute('aria-hidden', 'false');
              document.body.style.overflow = 'hidden';
              if (lightboxPrev) lightboxPrev.classList.toggle('hidden', imageThumbIndices.length <= 1);
              if (lightboxNext) lightboxNext.classList.toggle('hidden', imageThumbIndices.length <= 1);
              try { lightbox.focus(); } catch (e) {}
            }

            function closeLightbox() {
              if (!lightbox) return;
              lightbox.classList.add('hidden');
              lightbox.classList.remove('flex');
              lightbox.setAttribute('aria-hidden', 'true');
              document.body.style.overflow = '';
            }

            if (lightbox && mainImg) {
              mainImg.addEventListener('click', openLightbox);

              if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
              if (lightboxPrev) lightboxPrev.addEventListener('click', function () { showLightboxAt(lightboxImageIdx - 1); });
              if (lightboxNext) lightboxNext.addEventListener('click', function () { showLightboxAt(lightboxImageIdx + 1); });

              /* Clic sur l'overlay (pas sur l'image ou les boutons) → fermer */
              lightbox.addEventListener('click', function (e) {
                if (e.target === lightbox) closeLightbox();
              });
            }

            document.addEventListener('keydown', function (e) {
              if (!e) return;
              if (e.altKey || e.ctrlKey || e.metaKey) return;
              var lightboxOpen = lightbox && !lightbox.classList.contains('hidden');

              if (lightboxOpen) {
                if (e.key === 'Escape') { e.preventDefault(); closeLightbox(); return; }
                if (e.key === 'ArrowLeft') { e.preventDefault(); showLightboxAt(lightboxImageIdx - 1); return; }
                if (e.key === 'ArrowRight') { e.preventDefault(); showLightboxAt(lightboxImageIdx + 1); return; }
                return;
              }

              var tag = (e.target && e.target.tagName) ? String(e.target.tagName).toLowerCase() : '';
              if (tag === 'input' || tag === 'textarea' || tag === 'select') return;

              if (e.key === 'ArrowLeft') {
                setIndex(currentIndex - 1);
              }
              if (e.key === 'ArrowRight') {
                setIndex(currentIndex + 1);
              }
            });

            setIndex(0);
          }

          if (optionInputs && optionInputs.length) {
            optionInputs.forEach(function (el) {
              el.addEventListener('change', syncDisplayedPrice);
              el.addEventListener('input', syncDisplayedPrice);
              el.addEventListener('change', syncExchangeStandardPanel);
              el.addEventListener('input', syncExchangeStandardPanel);
            });
          }

          /* On retire window.CPFCartFeedback du gate : il est défini dans
             footer.ejs qui est inclus APRÈS ce script, donc undefined au
             parse-time → le listener ne s'attachait pas → form submit natif
             → reload de page → add_to_cart perdu. CPFCartFeedback est
             utilisé seulement DANS le handler, lazily. */
          if (addToCartForm && addToCartSubmit && window.fetch && window.FormData) {
            addToCartForm.addEventListener('submit', function (event) {
              if (addToCartPending) {
                event.preventDefault();
                return;
              }

              event.preventDefault();
              addToCartPending = true;
              addToCartSubmit.disabled = true;

              var startedAt = Date.now();
              var formData = new URLSearchParams(new FormData(addToCartForm));

              fetch(addToCartForm.getAttribute('action'), {
                method: 'POST',
                body: formData,
                credentials: 'same-origin',
                headers: {
                  'Accept': 'application/json',
                  'X-Requested-With': 'XMLHttpRequest',
                  'Content-Type': 'application/x-www-form-urlencoded'
                }
              })
                .then(function (response) {
                  return response.json().catch(function () {
                    return null;
                  }).then(function (data) {
                    if (!response.ok || !data || data.ok !== true) {
                      throw new Error(data && data.error ? data.error : 'Impossible d’ajouter le produit au panier pour le moment.');
                    }
                    return data;
                  });
                })
                .then(function (data) {
                  var payload = data && typeof data === 'object' ? data : {};
                  var productData = payload.product && typeof payload.product === 'object' ? payload.product : {};

                  /* GA4 add_to_cart : déléguer à window.GA4Ecommerce.trackAddToCart()
                     qui dédup en interne. Le click capture-phase l'a déjà appelé,
                     donc cet appel sera no-op (dédup 1500ms). On l'appelle quand
                     même comme filet de sécurité au cas où le click serait raté. */
                  if (window.GA4Ecommerce && typeof window.GA4Ecommerce.trackAddToCart === 'function') {
                    try { window.GA4Ecommerce.trackAddToCart(addToCartForm); } catch (e) {}
                  }

                  if (window.CPFCartFeedback && typeof window.CPFCartFeedback.notifyAdded === 'function') {
                    window.CPFCartFeedback.notifyAdded({
                      cartItemCount: payload.cartItemCount,
                      productName: productData.name || addToCartForm.getAttribute('data-product-name') || 'Produit',
                      imageUrl: productData.imageUrl || addToCartForm.getAttribute('data-product-image') || ''
                    });
                  }

                  setAddToCartSuccessState();

                  var minDisableRemaining = Math.max(0, 1000 - (Date.now() - startedAt));
                  window.setTimeout(function () {
                    scheduleAddToCartReset(2000);
                  }, minDisableRemaining);
                })
                .catch(function (err) {
                  var minDisableRemaining = Math.max(0, 1000 - (Date.now() - startedAt));
                  if (window.CPFCartFeedback && typeof window.CPFCartFeedback.notifyError === 'function') {
                    window.CPFCartFeedback.notifyError(err && err.message ? err.message : 'Impossible d’ajouter le produit au panier pour le moment.');
                  }
                  window.setTimeout(function () {
                    resetAddToCartButton();
                    addToCartPending = false;
                  }, minDisableRemaining);
                });
            });
          }

          setQty(getQty());
          syncDisplayedPrice();
          syncExchangeStandardPanel();
        })();
      </script>
    <% } %>
  </div>

  <!-- Sticky Add-to-Cart bar (mobile only) — populated by JS -->
      <%# ═══ Interactions design Autoparts (sticky, favori, FAQ, vérif plaque, toast) ═══ %>
      <script>
        (function () {
          var root = document.querySelector('.ap-page');
          if (!root) return;

          /* ── Toast ── */
          var toast = document.querySelector('[data-ap-toast]');
          var toastMsg = document.querySelector('[data-ap-toast-msg]');
          var toastTimer = null;
          function showToast(msg) {
            if (!toast) return;
            if (toastMsg) toastMsg.textContent = msg;
            toast.style.display = 'flex';
            toast.style.animation = 'apToastIn 0.22s ease';
            if (toastTimer) clearTimeout(toastTimer);
            toastTimer = setTimeout(function () { toast.style.display = 'none'; }, 2200);
          }

          /* ── Barre sticky (scroll > 780) ── */
          var sticky = document.querySelector('[data-ap-sticky]');
          var stickyAdd = document.querySelector('[data-ap-sticky-add]');
          var mainSubmit = document.querySelector('[data-add-to-cart-submit]');
          if (sticky) {
            var onScroll = function () {
              sticky.style.display = (window.scrollY > 780) ? 'block' : 'none';
            };
            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
          }
          if (stickyAdd && mainSubmit) {
            stickyAdd.addEventListener('click', function () { mainSubmit.click(); });
          }

          /* ── Favori (visuel) ── */
          var favBtn = document.querySelector('[data-ap-fav]');
          var favIcon = document.querySelector('[data-ap-fav-icon]');
          if (favBtn && favIcon) {
            favBtn.addEventListener('click', function () {
              var on = favIcon.style.color === 'rgb(237, 28, 36)' || favIcon.classList.contains('ap-fill');
              if (on) { favIcon.classList.remove('ap-fill'); favIcon.style.color = '#0F1626'; }
              else { favIcon.classList.add('ap-fill'); favIcon.style.color = '#ED1C24'; showToast('<%= t('product.addedToFavorites') %>'); }
            });
          }

          /* ── FAQ accordéon (exclusif) ── */
          var faqRows = Array.prototype.slice.call(document.querySelectorAll('[data-ap-faq]') || []);
          faqRows.forEach(function (row) {
            row.addEventListener('click', function () {
              var ans = row.querySelector('[data-ap-faq-ans]');
              var chev = row.querySelector('[data-ap-faq-chev]');
              var isOpen = ans && ans.style.display === 'block';
              faqRows.forEach(function (r) {
                var a = r.querySelector('[data-ap-faq-ans]'); var c = r.querySelector('[data-ap-faq-chev]');
                if (a) a.style.display = 'none'; if (c) c.style.transform = 'rotate(0deg)';
              });
              if (!isOpen && ans) { ans.style.display = 'block'; if (chev) chev.style.transform = 'rotate(180deg)'; }
            });
          });

          /* ── Accessoires : ajout panier réel (AJAX urlencoded, comme l'ATC principal) ── */
          Array.prototype.slice.call(document.querySelectorAll('[data-ap-acc-add]') || []).forEach(function (b) {
            b.addEventListener('click', function () {
              var id = b.getAttribute('data-acc-id');
              var name = b.getAttribute('data-acc-name') || 'Accessoire';
              if (!id || b.disabled) return;
              b.disabled = true;
              fetch('/panier/ajouter/' + encodeURIComponent(id), {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'qty=1'
              }).then(function (r) { return r.json().catch(function () { return { ok: r.ok }; }); })
                .then(function (data) {
                  if (data && data.ok !== false) {
                    if (window.CPFCartFeedback && typeof window.CPFCartFeedback.notifyAdded === 'function') {
                      try { window.CPFCartFeedback.notifyAdded({ cartItemCount: data.cartItemCount, productName: name }); } catch (e) {}
                    }
                    showToast(name + ' <%= t('product.addedToCartShort') %>');
                  } else { showToast('<%= t('cart.addError') %>'); }
                }).catch(function () { showToast('<%= t('cart.addError') %>'); })
                .then(function () { b.disabled = false; });
            });
          });

          /* ── Encart conseiller : demande de rappel → CRM (/api/lead/product-quote) ── */
          var cbBtn = document.querySelector('[data-ap-callback-btn]');
          var cbInput = document.querySelector('[data-ap-callback-contact]');
          var cbIdle = document.querySelector('[data-ap-callback-idle]');
          var cbOk = document.querySelector('[data-ap-callback-ok]');
          function sendCallback() {
            if (!cbInput) return;
            var c = (cbInput.value || '').trim();
            var looksMail = c.indexOf('@') !== -1 && c.indexOf('.') !== -1;
            var digits = c.replace(/\D/g, '');
            if (!looksMail && digits.length < 8) { cbInput.style.borderColor = '#B42318'; cbInput.focus(); return; }
            cbInput.style.borderColor = '#DEE2E9';
            var body = { productId: '<%= product._id %>', message: '<%= t('product.callbackMsg') %>' };
            if (looksMail) body.email = c; else body.phone = c;
            fetch('/api/lead/product-quote', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
              .then(function (r) { return r.json().catch(function () { return { ok: r.ok }; }); })
              .then(function (res) { if (res && res.ok) { if (cbIdle) cbIdle.style.display = 'none'; if (cbOk) cbOk.style.display = 'flex'; } else { cbInput.style.borderColor = '#B42318'; } })
              .catch(function () { cbInput.style.borderColor = '#B42318'; });
          }
          if (cbBtn) cbBtn.addEventListener('click', sendCallback);
          if (cbInput) cbInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); sendCallback(); } });

          /* ── Vérification plaque par un expert → CRM (/api/lead/product-quote) ── */
          var plateInput = document.querySelector('[data-ap-plate]');
          var contactInput = document.querySelector('[data-ap-contact]');
          var checkBtn = document.querySelector('[data-ap-check-btn]');
          var stIdle = document.querySelector('[data-ap-check-idle]');
          var stLoading = document.querySelector('[data-ap-check-loading]');
          var stOk = document.querySelector('[data-ap-check-ok]');
          var stErr = document.querySelector('[data-ap-check-err]');
          var stErrContact = document.querySelector('[data-ap-check-errcontact]');
          var stickyCheckOk = document.querySelector('[data-ap-sticky-checkok]');
          var productId = '<%= product._id %>';

          function fmtPlate(raw) {
            var c = (raw || '').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 7);
            var out = c.slice(0, 2);
            if (c.length > 2) out += '-' + c.slice(2, 5);
            if (c.length > 5) out += '-' + c.slice(5, 7);
            return out;
          }
          function setState(name) {
            [stIdle, stLoading, stOk, stErr, stErrContact].forEach(function (el) { if (el) el.style.display = 'none'; });
            var map = { idle: stIdle, loading: stLoading, ok: stOk, err: stErr, errContact: stErrContact };
            var el = map[name];
            if (el) el.style.display = (name === 'ok' || name === 'loading' || name === 'err' || name === 'errContact') ? 'flex' : 'block';
          }
          if (plateInput) {
            plateInput.addEventListener('input', function () { plateInput.value = fmtPlate(plateInput.value); setState('idle'); });
          }
          if (contactInput) contactInput.addEventListener('input', function () { setState('idle'); });

          function doCheck() {
            var plate = (plateInput ? plateInput.value : '').replace(/[^A-Z0-9]/gi, '');
            if (plate.length < 6) { setState('err'); return; }
            var c = (contactInput ? contactInput.value : '').trim();
            var looksMail = c.indexOf('@') !== -1 && c.indexOf('.') !== -1;
            var digits = c.replace(/\D/g, '');
            if (!looksMail && digits.length < 8) { setState('errContact'); return; }
            setState('loading');
            var body = { productId: productId, plate: (plateInput ? plateInput.value : ''), message: '<%= t('product.compatCheckMsg') %>' };
            if (looksMail) body.email = c; else body.phone = c;
            fetch('/api/lead/product-quote', {
              method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
            }).then(function (r) { return r.json().catch(function () { return { ok: r.ok }; }); })
              .then(function (res) {
                if (res && res.ok) { setState('ok'); if (stickyCheckOk) stickyCheckOk.style.display = 'inline-flex'; }
                else { setState(res && res.error === 'no_contact' ? 'errContact' : 'err'); }
              }).catch(function () { setState('err'); });
          }
          if (checkBtn) checkBtn.addEventListener('click', doCheck);
          [plateInput, contactInput].forEach(function (el) {
            if (el) el.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); doCheck(); } });
          });
        })();
      </script>


  <script>
    (function() {
      var wrapper = document.querySelector('[data-desc-collapse]');
      if (!wrapper) return;
      var inner = wrapper.querySelector('[data-desc-collapse-inner]');
      var fade = wrapper.querySelector('[data-desc-fade]');
      var toggleBtn = wrapper.querySelector('[data-desc-toggle]');
      var toggleLabel = wrapper.querySelector('[data-desc-toggle-label]');
      var toggleIcon = wrapper.querySelector('[data-desc-toggle-icon]');
      if (!inner || !fade || !toggleBtn) return;

      var THRESHOLD = 250; /* px - only collapse if taller than this */
      var expanded = false;
      var userToggled = false; /* true once user clicks — prevents resize from re-collapsing */

      function checkSize() {
        if (userToggled) return; /* respect user's explicit choice */
        var isMobile = window.innerWidth < 768;
        var naturalHeight = inner.scrollHeight;

        if (isMobile && naturalHeight > THRESHOLD) {
          inner.classList.add('is-collapsed');
          inner.classList.remove('is-expanded');
          fade.classList.remove('hidden');
          expanded = false;
          if (toggleLabel) toggleLabel.textContent = 'Lire la suite';
          if (toggleIcon) toggleIcon.style.transform = '';
        } else {
          inner.classList.remove('is-collapsed');
          inner.classList.add('is-expanded');
          fade.classList.add('hidden');
        }
      }

      toggleBtn.addEventListener('click', function() {
        expanded = !expanded;
        userToggled = true;
        if (expanded) {
          inner.classList.remove('is-collapsed');
          inner.classList.add('is-expanded');
          fade.classList.add('hidden');
          if (toggleLabel) toggleLabel.textContent = 'Réduire';
          if (toggleIcon) toggleIcon.style.transform = 'rotate(180deg)';
        } else {
          inner.classList.add('is-collapsed');
          inner.classList.remove('is-expanded');
          fade.classList.remove('hidden');
          if (toggleLabel) toggleLabel.textContent = 'Lire la suite';
          if (toggleIcon) toggleIcon.style.transform = '';
          wrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      checkSize();
      window.addEventListener('resize', checkSize);
    })();
  </script>

  <%/* Maillage interne fiche produit : parentVehicleLandings + parentCategory.
       Donne à Google des signaux clairs sur la place du produit dans la taxonomie.
       Restylé au design v3 (blocs navy / blanc). */%>
  <% if (typeof productLinking !== 'undefined' && productLinking
        && (
          (Array.isArray(productLinking.parentVehicleLandings) && productLinking.parentVehicleLandings.length > 0)
          || productLinking.parentCategory
        )) { %>
    <section class="seo-internal-linking pp-page" style="background:#fff;border-top:1px solid #E8EAEF;">
      <div class="max-w-7xl mx-auto px-4 lg:px-8" style="padding-top:56px;padding-bottom:64px;">
        <div class="pp-eyebrow"><%= t('product.seeAllCompat') %></div>
        <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;margin-bottom:22px;flex-wrap:wrap;">
          <h2 class="pp-h2"><%= t('product.specificParts') %></h2>
          <% var _vlWm = (product.warranty && Number(product.warranty.months) > 0) ? Number(product.warranty.months) : 0; %>
          <% if (_vlWm) { %><span style="font-size:13px;color:#8A909E;"><%= t('product.warrantyMonths', { months: _vlWm }) %></span><% } %>
        </div>
        <div class="pp-links">
          <% var _linkIdx = 0; %>
          <% if (Array.isArray(productLinking.parentVehicleLandings)) { %>
            <% for (const v of productLinking.parentVehicleLandings) { %>
              <a href="<%= v.url %>" class="pp-link <%= _linkIdx === 0 ? 'navy' : 'white' %>">
                <span class="ic"><span class="material-symbols-outlined" style="font-size:24px;">directions_car</span></span>
                <span style="flex:1;min-width:0;">
                  <span class="tt"><%= t('product.allPartsFor', { make: (v.makeName + (v.modelName ? ' ' + v.modelName : '')) }) %></span>
                  <span class="sb"><%= t('product.fullCatalog').replace(' →', '') %></span>
                </span>
                <span class="material-symbols-outlined" style="font-size:22px;">arrow_forward</span>
              </a>
              <% _linkIdx++; %>
            <% } %>
          <% } %>
          <% if (productLinking.parentCategory) { %>
            <a href="<%= productLinking.parentCategory.url %>" class="pp-link <%= _linkIdx === 0 ? 'navy' : 'white' %>">
              <span class="ic"><span class="material-symbols-outlined" style="font-size:24px;">manufacturing</span></span>
              <span style="flex:1;min-width:0;">
                <span class="tt"><%= productLinking.parentCategory.name %></span>
                <span class="sb"><%= t('product.allCategoryParts') %></span>
              </span>
              <span class="material-symbols-outlined" style="font-size:22px;">arrow_forward</span>
            </a>
          <% } %>
        </div>
      </div>
    </section>
  <% } %>
</main>

<% if (product) { %>
<% /* _ga4Brand est défini dans le else-block plus haut, donc hors-scope ici. On
     recompose localement pour éviter ReferenceError. */ %>
<% const _ga4BrandFooter = ((product.brand && String(product.brand).trim())
  || (Array.isArray(product.compatibility) && product.compatibility[0] && product.compatibility[0].make)
  || ''); %>
<% const _ga4ViewItem = JSON.stringify({
  event: 'view_item',
  ecommerce: {
    currency: 'EUR',
    value: Math.round(Number(product.priceCents) || 0) / 100,
    items: [{
      item_id: String(product.sku || product._id || ''),
      item_name: String(product.name || ''),
      item_category: String(product.category || ''),
      item_brand: String(_ga4BrandFooter),
      price: Math.round(Number(product.priceCents) || 0) / 100,
      quantity: 1,
    }],
  },
}).replace(/</g, '\\u003c'); %>
<script>
(function () {
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ ecommerce: null });
  window.dataLayer.push(<%- _ga4ViewItem %>);
})();
</script>
<% } %>

