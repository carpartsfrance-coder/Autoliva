<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-1 bg-white dark:bg-background-dark text-slate-800 dark:text-slate-200 transition-colors duration-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
    <% if (!dbConnected) { %>
      <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5 text-amber-900 mb-10">
        <div class="font-bold">Mode démo activé</div>
        <div class="mt-1 text-sm">Le site fonctionne sans base de données, avec des produits d'exemple.</div>
      </div>
    <% } %>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="rounded-2xl border border-red-200 bg-red-50 p-5 text-red-900 mb-10">
        <div class="font-bold">Erreur</div>
        <div class="mt-1 text-sm"><%= errorMessage %></div>
      </div>
    <% } %>

    <% if (!product) { %>
      <div class="bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-3xl p-8 refined-shadow">
        <div class="font-bold text-slate-900 dark:text-white">Produit indisponible</div>
        <div class="mt-1 text-sm text-slate-500">Ce produit ne peut pas être affiché pour le moment.</div>
      </div>
    <% } else { %>
      <% const ref = product.sku || String(product._id).slice(-10).toUpperCase(); %>
      <% const rawMedia = []; %>
      <% if (product.imageUrl) rawMedia.push({ url: product.imageUrl, type: 'image' }); %>
      <% (product.galleryUrls || []).forEach((u, i) => {
        if (!u) return;
        const gt = Array.isArray(product.galleryTypes) ? product.galleryTypes[i] : '';
        const t = (gt === 'video') ? 'video' : 'image';
        rawMedia.push({ url: u, type: t });
      }); %>
      <% const seenMediaUrls = new Set(); %>
      <% const mediaItems = rawMedia.filter((m) => {
        if (!m || !m.url || seenMediaUrls.has(m.url)) return false;
        seenMediaUrls.add(m.url);
        return true;
      }); %>
      <%# Vidéo YouTube/Vimeo (product.media.videoUrl) ajoutée comme DERNIER élément
          de la galerie : vignette cliquable → lecteur intégré dans le visualiseur
          principal. La vidéo reste hébergée chez YouTube/Vimeo (rien en base). %>
      <% const _galleryVideoEmbed = (product.sections && product.sections.showVideo && product.media && product.media.videoUrl && typeof parseVideoEmbed === 'function')
           ? parseVideoEmbed(product.media.videoUrl) : null; %>
      <% if (_galleryVideoEmbed && !seenMediaUrls.has(product.media.videoUrl)) {
           seenMediaUrls.add(product.media.videoUrl);
           mediaItems.push({ url: product.media.videoUrl, type: 'embed', embedUrl: _galleryVideoEmbed.embedUrl, poster: _galleryVideoEmbed.poster, provider: _galleryVideoEmbed.provider });
         } %>
      <% const images = mediaItems.map((m) => m.url); %>
      <% const mainImage = images[0] || ''; %>
      <% const mainMediaItem = mediaItems[0] || null; %>
      <% const thumbImages = images; %>
      <% const thumbMediaItems = mediaItems; %>
      <% const hasVideo = !!(product.sections && product.sections.showVideo && product.media && product.media.videoUrl); %>
      <% const topLeftBadge = product.badges && product.badges.topLeft ? product.badges.topLeft : ''; %>
      <% const conditionBadge = product.badges && product.badges.condition ? product.badges.condition : ''; %>
      <% const compareAt = product.compareAtPriceCents; %>
      <% const makes = Array.isArray(product.compatibility)
        ? Array.from(new Set(product.compatibility.map((c) => (c && c.make ? String(c.make).trim() : '')).filter(Boolean)))
        : []; %>
      <% /* GA4 item_brand : fallback sur la 1ère make des compatibilités si brand vide. */ %>
      <% const _ga4Brand = ((product.brand && String(product.brand).trim()) || makes[0] || ''); %>
      <% const formatMoney = (cents) => new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format((Number(cents) || 0) / 100); %>
      <% const findSpec = (label) => {
        const target = String(label || '').toLowerCase();
        const list = Array.isArray(product.specs) ? product.specs : [];
        for (const s of list) {
          if (!s || !s.label) continue;
          if (String(s.label).toLowerCase() === target) return s.value || '';
        }
        return '';
      }; %>
      <% const keyType = findSpec('type') || product.category || ''; %>
      <% const keyEtat = findSpec('état') || findSpec('etat') || conditionBadge || ''; %>
      <% const keyProgrammation = findSpec('programmation') || ''; %>
      <% const keyGarantie = (product.warranty && Number(product.warranty.months) > 0)
        ? (product.warranty.months + ' ' + t('product.monthsWord') + (product.warranty.text ? ' — ' + product.warranty.text : ''))
        : (findSpec('garantie') || topLeftBadge || ''); %>
      <% const optionGroups = Array.isArray(product.displayOptions) ? product.displayOptions : []; %>
      <% const compGrouped = {}; %>
      <% (Array.isArray(product.compatibility) ? product.compatibility : []).forEach((c) => {
        const make = c && c.make ? String(c.make).trim() : '';
        if (!make) return;
        if (!compGrouped[make]) compGrouped[make] = { models: new Set(), engines: new Set() };
        const model = c && c.model ? String(c.model).trim() : '';
        const years = c && c.years ? String(c.years).trim() : '';
        const engine = c && c.engine ? String(c.engine).trim() : '';
        const modelText = [model, years].filter(Boolean).join(' ');
        if (modelText) compGrouped[make].models.add(modelText);
        if (engine) compGrouped[make].engines.add(engine);
      }); %>
      <% const compMakes = Object.keys(compGrouped); %>
      <%# Liste DÉTAILLÉE par véhicule (1 ligne = 1 véhicule) pour l'onglet dédié. %>
      <% const compatVehicles = (Array.isArray(product.compatibility) ? product.compatibility : []).map((c) => {
           const make = c && c.make ? String(c.make).trim() : '';
           const model = c && c.model ? String(c.model).trim() : '';
           const years = c && c.years ? String(c.years).trim() : '';
           const engine = c && c.engine ? String(c.engine).trim() : '';
           const kw = c && Number(c.kw) > 0 ? Number(c.kw) : 0;
           const ch = c && Number(c.ch) > 0 ? Number(c.ch) : 0;
           let power = '';
           if (kw && ch) power = kw + ' kW / ' + ch + ' ch';
           else if (ch) power = ch + ' ch';
           else if (kw) power = kw + ' kW';
           return { make, model, years, engine, power };
         }).filter((v) => v.make || v.model || v.engine); %>
      <% compatVehicles.sort((a, b) => (a.make + a.model + a.engine).localeCompare(b.make + b.model + b.engine, 'fr')); %>
      <% const vehicleCount = compatVehicles.length; %>
      <% const compatibleReferences = Array.isArray(product.compatibleReferences)
        ? product.compatibleReferences.map((v) => String(v || '').trim()).filter(Boolean)
        : []; %>
      <% const keyPointsList = Array.isArray(product.keyPoints)
        ? product.keyPoints.map((v) => String(v || '').trim()).filter(Boolean)
        : []; %>
      <% const inclusionsList = Array.isArray(product.inclusions)
        ? product.inclusions.map((v) => String(v || '').trim()).filter(Boolean)
        : []; %>
      <% const exclusionsList = Array.isArray(product.exclusions)
        ? product.exclusions.map((v) => String(v || '').trim()).filter(Boolean)
        : []; %>
      <%# Blocs d'information groupés par position (chargés côté contrôleur). %>
      <% var _ib = (product && product.infoBlocksByPosition) ? product.infoBlocksByPosition : { description_end: [], after_inclusions: [], dedicated_tab: [] }; %>
      <% const summaryPoints = keyPointsList.length
        ? keyPointsList.slice(0, 3)
        : [
          keyType ? (t('product.specType') + ' : ' + keyType) : '',
          keyProgrammation ? (t('product.specProg') + ' : ' + keyProgrammation) : '',
          keyGarantie ? (t('product.guarantee') + ' : ' + keyGarantie) : '',
        ].filter(Boolean); %>
      <% const normalizeLoose = (value) => String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, ''); %>
      <% const basePriceCents = Number(product.priceCents) || 0; %>
      <% const installmentCount = 3; %>
      <% const installmentMinPriceCents = 10000; %>
      <% const installmentMaxPriceCents = 200000; %>
      <% const installmentEligible = basePriceCents >= installmentMinPriceCents && basePriceCents <= installmentMaxPriceCents; %>
      <% const installmentAmountCents = installmentEligible ? Math.round(basePriceCents / installmentCount) : 0; %>
      <% const shippingDelayText = product && product.shippingDelayText ? String(product.shippingDelayText).trim() : ''; %>
      <% const hasConsigne = product && product.consigne && product.consigne.enabled && product.consigne.amountCents > 0; %>
      <% const consigneUpfront = hasConsigne && product.consigne.chargeUpfront === true; %>
      <% const consigneAmountEuro = hasConsigne ? (product.consigne.amountCents / 100).toFixed(2).replace('.', ',') : ''; %>
      <% const consigneDelayDays = hasConsigne ? (product.consigne.delayDays || 30) : 30; %>
      <% const stockLabel = product.inStock ? t('product.stockIn') : t('product.stockOrder'); %>
      <%# Code moteur (ex: CLHA) — info n°1 recherchée par le client. %>
      <% const engineCodeVal = (product.engineCode && String(product.engineCode).trim()) ? String(product.engineCode).trim() : ''; %>
      <% let productSubtitle; %>
      <% if (engineCodeVal) {
           // Sous-titre prioritaire : code moteur + référence (les marques sont déjà dans le titre H1).
           const _st = [t('product.codeMoteur') + ' : ' + engineCodeVal];
           if (ref) _st.push(t('product.refPrefix') + ' ' + ref);
           productSubtitle = _st.join(' · ');
         } else {
           const subtitleParts = [];
           if (makes.length) { subtitleParts.push(t('product.forVehicles') + ' ' + makes.slice(0, 4).join(', ')); }
           else if (product.brand) { subtitleParts.push(t('product.forVehicles') + ' ' + String(product.brand).trim()); }
           if (ref) subtitleParts.push(t('product.seriesPrefix') + ' ' + ref);
           productSubtitle = subtitleParts.join(' - ');
         } %>
      <% const isService = product && product.serviceType === 'standalone_cloning'; %>
      <%# ISO 9001 : mis en avant UNIQUEMENT sur les pièces reconditionnées (pas occasion / neuf / service). %>
      <% const _isoHay = (String(product.category || '') + ' ' + String(conditionBadge || '') + ' ' + String(keyEtat || '')).toLowerCase(); %>
      <% const _showIso = !isService && !/occasion|\bneuf\b/.test(_isoHay); %>
      <% const heroBadge = isService
        ? (topLeftBadge || t('product.serviceRemote'))
        : (keyEtat || conditionBadge || topLeftBadge || t('product.reconditioningPro')); %>
      <% const visibleThumbImages = thumbImages.slice(0, 4); %>
      <% const hiddenThumbImages = thumbImages.slice(4); %>
      <%# La vignette vidéo (embed) est épinglée parmi les vignettes VISIBLES, même
          s'il y a déjà 4 images ou plus : sinon, en 5e position, elle serait
          masquée (invisible sur mobile). On réserve donc la dernière tuile à la
          vidéo (jusqu'à 3 images + la vidéo) ; les images en trop passent en « +N ». %>
      <% const _embedThumb = thumbMediaItems.find((m) => m.type === 'embed') || null; %>
      <% const _imgThumbs = _embedThumb ? thumbMediaItems.filter((m) => m !== _embedThumb) : thumbMediaItems; %>
      <% const _maxImgThumbs = _embedThumb ? 3 : 4; %>
      <% const visibleThumbItems = _imgThumbs.slice(0, _maxImgThumbs).concat(_embedThumb ? [_embedThumb] : []); %>
      <% const hiddenThumbItems = _imgThumbs.slice(_maxImgThumbs); %>
      <% const _hiddenThumbCount = hiddenThumbItems.length; %>
      <% const _lastImageThumbIdx = visibleThumbItems.length - 1 - (_embedThumb ? 1 : 0); %>
      <% const compatibilityPrefillMessage = [
        'Bonjour,',
        '',
        'Je souhaite vérifier la compatibilité de la pièce "' + product.name + '"' + (ref ? ' (référence ' + ref + ')' : '') + ' avec mon véhicule.',
        '',
        'Nos experts vérifient la compatibilité et vous répondent sous 24h.',
        '',
        'Merci.',
      ].join('\n'); %>
      <% const compatibilityContactUrl = '/contact?subject=compatibilite&partRef=' + encodeURIComponent(ref) + '&message=' + encodeURIComponent(compatibilityPrefillMessage); %>
      <%# Badges MANUELS (4 textes libres saisis en admin) — affichés tels quels.
          Si aucun n'est rempli → fallback sur les badges auto (rétrocompat). %>
      <% const manualBadgeCards = (product.badges && Array.isArray(product.badges.cards))
        ? product.badges.cards.map((s) => String(s || '').trim()).filter(Boolean).slice(0, 4)
        : []; %>
      <% const autoHighlights = isService
        ? [
            { icon: 'euro', label: t('product.svcFixedPrice') },
            { icon: 'bolt', label: t('product.svcCloning24') },
            { icon: 'local_shipping', label: t('product.svcRoundTrip') },
            { icon: 'verified', label: t('product.svcWarranty30') },
          ]
        : [
            { icon: 'verified', label: keyGarantie || t('product.warranty24') },
            { icon: 'terminal', label: keyProgrammation || t('product.progIncluded') },
            { icon: 'analytics', label: t('product.benchTested') },
            consigneUpfront ? { icon: 'verified_user', label: t('product.consigneRefundable') } : { icon: 'lock_open', label: t('product.noDeposit') },
          ]; %>
      <% const qualityHighlights = manualBadgeCards.length
        ? manualBadgeCards.map((label) => ({ icon: 'check_circle', label, manual: true }))
        : autoHighlights; %>
      <% const faqCount = Array.isArray(product.faqs) ? product.faqs.length : 0; %>
      <% const faqPreviewCards = Array.isArray(product.faqs)
        ? product.faqs.filter((f) => f && f.question && f.answer).slice(0, 3)
        : []; %>
      <% const technicalSpecs = []; %>
      <% const pushTechnicalSpec = (label, value) => {
        const safeLabel = String(label || '').trim();
        const safeValue = String(value || '').trim();
        if (!safeLabel || !safeValue) return;
        const alreadyExists = technicalSpecs.some((entry) => String(entry.label || '').toLowerCase() === safeLabel.toLowerCase());
        if (alreadyExists) return;
        technicalSpecs.push({ label: safeLabel, value: safeValue });
      }; %>
      <% (Array.isArray(product.specs) ? product.specs : []).forEach((spec) => {
        if (!spec || technicalSpecs.length >= 6) return;
        pushTechnicalSpec(spec.label, spec.value);
      }); %>
      <% if (technicalSpecs.length < 6 && engineCodeVal) {
           var _compatCodes = Array.isArray(product.compatibleReferences) ? product.compatibleReferences.filter(Boolean).slice(0, 2) : [];
           pushTechnicalSpec(t('product.codeMoteur'), engineCodeVal + (_compatCodes.length ? ' (compatible ' + _compatCodes.join(', ') + ')' : ''));
         } %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.specRef'), ref); %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.specType'), keyType); %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.specState'), keyEtat); %>
      <% if (technicalSpecs.length < 6 && keyProgrammation) pushTechnicalSpec(t('product.specProg'), keyProgrammation); %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.guarantee'), keyGarantie || t('product.specIncluded')); %>
      <% if (technicalSpecs.length < 6) pushTechnicalSpec(t('product.shippingLabel'), shippingDelayText || t('product.specShipping2448')); %>

      <nav class="flex items-center gap-1.5 sm:gap-2 mb-6 text-xs sm:text-sm overflow-x-auto no-scrollbar whitespace-nowrap pb-1" aria-label="Fil d'Ariane">
        <a class="text-slate-500 hover:text-primary transition-colors shrink-0" href="/"><%= t('breadcrumb.home') %></a>
        <span class="text-slate-300 shrink-0">/</span>
        <a class="text-slate-500 hover:text-primary transition-colors shrink-0" href="/produits"><%= t('breadcrumb.catalog') %></a>
        <% if (typeof categoryUrl !== 'undefined' && categoryUrl && typeof categoryName !== 'undefined' && categoryName) { %>
          <% const catParts = categoryName.split(/\s*>\s*/); %>
          <% catParts.forEach((part, i) => { %>
            <span class="text-slate-300 shrink-0">/</span>
            <% if (i === catParts.length - 1) { %>
              <a class="text-slate-500 hover:text-primary transition-colors shrink-0" href="<%= categoryUrl %>"><%= part %></a>
            <% } else { %>
              <span class="text-slate-500 shrink-0"><%= part %></span>
            <% } %>
          <% }) %>
        <% } %>
        <span class="text-slate-300 shrink-0">/</span>
        <span class="text-slate-400 dark:text-slate-500 font-normal truncate"><%= product.name %></span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start lg:items-stretch">
        <div class="lg:col-span-7 flex flex-col gap-4 h-full">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:gap-4">
            <% if (visibleThumbItems.length) { %>
              <div class="grid grid-cols-4 gap-4 order-2 lg:order-1 lg:grid-cols-1 lg:gap-3 lg:w-20 xl:w-24 lg:flex-shrink-0">
                <% visibleThumbItems.forEach((item, idx) => { %>
                  <% const _isThumbVideo = item.type === 'video'; %>
                  <% const _isThumbEmbed = item.type === 'embed'; %>
                  <button aria-label="Voir <%= (_isThumbVideo || _isThumbEmbed) ? 'la vidéo' : 'l\'image' %> <%= idx + 1 %>" class="relative aspect-square rounded-lg overflow-hidden cursor-pointer border bg-white dark:bg-slate-900 refined-shadow transition-all <%= idx === 0 ? 'border-primary/20 ring-2 ring-primary' : 'border-slate-200 dark:border-slate-700 hover:border-primary' %>" data-thumb data-index="<%= idx %>" data-src="<%= item.url %>" data-type="<%= item.type %>"<% if (_isThumbEmbed) { %> data-embed-src="<%= item.embedUrl %>"<% } %> type="button">
                    <% if (_isThumbEmbed) { %>
                      <% if (item.poster) { %>
                        <img alt="<%= product.name %> — vidéo" class="w-full h-full object-cover" decoding="async" loading="lazy" width="200" height="200" src="<%= item.poster %>" />
                      <% } else { %>
                        <span class="w-full h-full flex items-center justify-center bg-slate-900"><span class="material-symbols-outlined text-white/80 text-2xl leading-none">smart_display</span></span>
                      <% } %>
                      <span class="absolute inset-0 flex items-center justify-center">
                        <span class="bg-black/60 text-white rounded-full p-1.5 flex items-center justify-center"><span class="material-symbols-outlined text-base leading-none">play_arrow</span></span>
                      </span>
                    <% } else if (_isThumbVideo) { %>
                      <video class="w-full h-full object-cover" muted playsinline preload="metadata">
                        <source src="<%= item.url %>" />
                      </video>
                      <span class="absolute bottom-1 left-1 bg-black/70 text-white rounded-full p-1 flex items-center justify-center">
                        <span class="material-symbols-outlined text-sm leading-none">play_arrow</span>
                      </span>
                    <% } else { %>
                      <img alt="<%= product.name %> — vue <%= idx + 1 %>" class="w-full h-full object-cover" decoding="async" loading="lazy" width="200" height="200" src="<%= item.url %>" />
                    <% } %>
                    <% if (!_isThumbEmbed && idx === _lastImageThumbIdx && _hiddenThumbCount > 0) { %>
                      <span class="absolute inset-0 bg-slate-900/60 flex items-center justify-center text-white text-xs font-bold uppercase tracking-wider"><%= t('product.moreImages', { count: _hiddenThumbCount }) %></span>
                    <% } %>
                  </button>
                <% }) %>
              </div>
            <% } %>

            <div class="relative w-full aspect-video lg:aspect-square lg:w-auto lg:flex-1 order-1 lg:order-2 rounded-xl bg-slate-100 dark:bg-slate-900 overflow-hidden border border-slate-200 dark:border-slate-800 refined-shadow">
              <% if (mainMediaItem) { %>
                <% const _isMainVideo = mainMediaItem.type === 'video'; %>
                <% const _isMainEmbed = mainMediaItem.type === 'embed'; %>
                <img alt="<%= product.name %> — photo principale" class="w-full h-full object-cover cursor-zoom-in<%= (_isMainVideo || _isMainEmbed) ? ' hidden' : '' %>" data-main-image decoding="async" loading="eager" fetchpriority="high" width="800" height="450" <% if (!_isMainVideo && !_isMainEmbed) { %>src="<%= mainImage %>"<% } %> />
                <video class="w-full h-full object-cover<%= _isMainVideo ? '' : ' hidden' %>" data-main-video controls preload="metadata" playsinline<% if (_isMainVideo) { %> src="<%= mainImage %>"<% } %>></video>
                <iframe class="absolute inset-0 w-full h-full<%= _isMainEmbed ? '' : ' hidden' %>" data-main-embed title="<%= product.name %> — vidéo" loading="lazy" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen<% if (_isMainEmbed) { %> src="<%= mainMediaItem.embedUrl %>"<% } %>></iframe>
              <% } else if (isService) { %>
                <div class="w-full h-full flex flex-col items-center justify-center gap-3 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-950">
                  <span class="material-symbols-outlined text-7xl text-primary/70">memory</span>
                  <span class="text-xs font-bold uppercase tracking-widest text-slate-500"><%= t('product.serviceRemote') %></span>
                  <span class="text-sm font-bold text-slate-700 dark:text-slate-300 text-center px-4 max-w-md"><%= t('product.cloningService') %><br/><%= t('product.dsgChrono') %></span>
                </div>
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center text-slate-400">
                  <span class="material-symbols-outlined text-6xl">inventory_2</span>
                </div>
              <% } %>

              <% if (images.length > 1) { %>
                <button aria-label="Image précédente" class="absolute left-4 top-1/2 -translate-y-1/2 h-10 w-10 rounded-full bg-white/90 text-slate-700 flex items-center justify-center refined-shadow hover:bg-white transition-all" data-gallery-prev type="button">
                  <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <button aria-label="Image suivante" class="absolute right-4 top-1/2 -translate-y-1/2 h-10 w-10 rounded-full bg-white/90 text-slate-700 flex items-center justify-center refined-shadow hover:bg-white transition-all" data-gallery-next type="button">
                  <span class="material-symbols-outlined">chevron_right</span>
                </button>
              <% } %>
            </div>
          </div>

          <%# Lightbox — agrandir l'image au clic %>
          <div aria-hidden="true" aria-label="Image agrandie" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm p-4 sm:p-8" data-lightbox role="dialog" tabindex="-1">
            <button aria-label="Fermer" class="absolute top-4 right-4 z-10 h-11 w-11 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition" data-lightbox-close type="button">
              <span class="material-symbols-outlined">close</span>
            </button>
            <button aria-label="Image précédente" class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-10 h-11 w-11 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition hidden" data-lightbox-prev type="button">
              <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button aria-label="Image suivante" class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-10 h-11 w-11 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition hidden" data-lightbox-next type="button">
              <span class="material-symbols-outlined">chevron_right</span>
            </button>
            <img alt="<%= product.name %>" class="max-w-full max-h-full object-contain select-none" data-lightbox-img />
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/80 text-xs font-semibold tracking-wider hidden" data-lightbox-counter></div>
          </div>

          <% hiddenThumbItems.forEach((item, idx) => { %>
            <button class="hidden" data-thumb data-index="<%= idx + 4 %>" data-src="<%= item.url %>" data-type="<%= item.type %>"<% if (item.type === 'embed') { %> data-embed-src="<%= item.embedUrl %>"<% } %> type="button"></button>
          <% }) %>

          <% if (qualityHighlights.length) { %>
          <div class="grid grid-cols-2 xl:grid-cols-4 gap-2 sm:gap-4 mt-1">
            <% qualityHighlights.forEach((item) => { %>
              <div class="flex flex-col items-center justify-center p-2 sm:p-4 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 text-center refined-shadow">
                <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl mb-1 sm:mb-2"><%= item.icon %></span>
                <span class="text-[10px] sm:text-xs font-bold <%= item.manual ? 'normal-case leading-tight' : 'uppercase tracking-tight' %> text-slate-900 dark:text-white"><%= item.label %></span>
              </div>
            <% }) %>
          </div>
          <% } %>

          <%# Vidéo YouTube/Vimeo : intégrée dans la galerie ci-dessus (dernière
              vignette). Ici on ne garde qu'un lien de secours si l'URL vidéo n'est
              PAS embarquable (ni YouTube ni Vimeo). %>
          <% if (hasVideo && !_galleryVideoEmbed) { %>
            <div class="flex justify-start">
              <a class="inline-flex items-center gap-2 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-4 py-3 text-sm font-semibold hover:border-primary hover:text-primary transition-colors" href="<%= product.media.videoUrl %>" rel="noreferrer" target="_blank">
                <span class="material-symbols-outlined">play_circle</span>
                <%= t('product.watchVideo') %>
              </a>
            </div>
          <% } %>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-6 h-full">
          <div>
            <span class="inline-block px-2 py-1 rounded bg-primary text-white text-[10px] font-black uppercase mb-3 tracking-widest"><%= heroBadge %></span>
            <h1 class="text-[22px] sm:text-3xl md:text-4xl font-black text-slate-900 dark:text-white leading-tight mb-2 sm:uppercase tracking-tighter"><%= product.name %></h1>
            <p class="text-slate-500 dark:text-slate-300 text-lg"><%= productSubtitle || ('Série ' + ref) %></p>
          </div>

          <div class="p-5 bg-white dark:bg-slate-900 rounded-xl border border-slate-300 dark:border-slate-700 border-l-4 border-l-primary refined-shadow">
            <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-1 md:gap-4 mb-1">
              <div class="hidden md:block">
                <span class="text-slate-500 text-sm font-medium"><%= t('product.publicPrice') %></span>
                <% if (compareAt && compareAt > product.priceCents) { %>
                  <div class="mt-1 text-sm text-slate-400 line-through"><%= formatMoney(compareAt) %> €</div>
                <% } %>
              </div>
              <% if (compareAt && compareAt > product.priceCents) { %>
                <div class="md:hidden text-sm text-slate-400 line-through"><%= formatMoney(compareAt) %> €</div>
              <% } %>
              <div class="text-left md:text-right">
                <% if (product.vatRecoverable) { %>
                  <%# Clientèle pro : prix HT mis en avant, TTC en rappel discret %>
                  <span class="text-4xl font-black text-primary"><span data-price-display-ht><%= formatMoney(Math.round(product.priceCents / 1.2)) %></span> € <%= t('product.ht') %></span>
                  <div class="mt-1 flex flex-wrap items-center md:justify-end gap-2">
                    <span class="text-sm font-medium text-slate-500 dark:text-slate-400"><span data-price-display data-base-price-cents="<%= basePriceCents %>" data-installment-count="<%= installmentCount %>" data-installment-min-cents="<%= installmentMinPriceCents %>" data-installment-max-cents="<%= installmentMaxPriceCents %>"><%= formatMoney(product.priceCents) %> €</span> <%= t('product.ttc') %></span>
                    <span class="inline-flex items-center rounded-full bg-emerald-50 text-emerald-700 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide"><%= t('product.vatRecoverable') %></span>
                  </div>
                <% } else { %>
                  <%# Régime de la marge / particuliers : prix net (TTC) affiché seul %>
                  <span class="text-4xl font-black text-primary" data-price-display data-base-price-cents="<%= basePriceCents %>" data-installment-count="<%= installmentCount %>" data-installment-min-cents="<%= installmentMinPriceCents %>" data-installment-max-cents="<%= installmentMaxPriceCents %>"><%= formatMoney(product.priceCents) %> €</span>
                  <div class="text-[11px] uppercase tracking-wide text-slate-400"><%= t('product.ttc') %></div>
                <% } %>
                <div class="mt-1 flex items-center md:justify-end gap-1 text-xs text-slate-500 <%= installmentEligible ? '' : 'hidden' %>" data-installment-wrapper>
                  <span class="material-symbols-outlined text-sm text-slate-400">credit_card</span>
                  <span><%= t('product.installmentPrefix') %> <span data-installment-amount><%= formatMoney(installmentAmountCents) %> €</span> <%= t('product.installmentSuffix') %></span>
                </div>
              </div>
            </div>
            <p class="text-left md:text-right text-xs italic <%= hasConsigne ? 'text-emerald-600 font-semibold' : 'text-slate-400' %>"><%= hasConsigne ? (consigneUpfront ? (t('product.consigneRefundShort', { amount: consigneAmountEuro, days: consigneDelayDays })) : (t('product.exchangeNoDeposit', { days: consigneDelayDays }))) : (shippingDelayText || (product.inStock ? t('product.fastDeliveryFr') : t('product.onOrderAvailable'))) %></p>
          </div>

          <form action="/panier/ajouter/<%= product._id %>" class="flex flex-col gap-4 lg:flex-1" data-add-to-cart-form data-product-id="<%= product._id %>" data-product-sku="<%= product.sku || product._id %>" data-product-image="<%= mainImage %>" data-product-name="<%= product.name %>" data-product-category="<%= product.category || '' %>" data-product-brand="<%= _ga4Brand %>" data-product-price-cents="<%= basePriceCents %>" method="POST">
            <input name="returnTo" type="hidden" value="<%= typeof returnTo !== 'undefined' ? returnTo : '/panier' %>" />
            <input data-qty-input name="qty" type="hidden" value="1" />

            <% if (optionGroups && optionGroups.length) { %>
              <div class="flex flex-col gap-3">
                <% optionGroups.forEach((g) => { %>
                  <% const gKey = g && g.key ? String(g.key) : ''; %>
                  <% if (!gKey) return; %>
                  <% const fieldName = 'opt_' + gKey; %>
                  <% const groupLabel = g && g.label ? g.label : gKey; %>
                  <% const isSupplyModeGroup = normalizeLoose(groupLabel).includes('mode-de-fourniture'); %>
                  <% const choices = Array.isArray(g && g.choices) ? g.choices : []; %>

                  <div class="p-5 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-300 dark:border-slate-700 refined-shadow">
                    <div class="flex items-center justify-between gap-4">
                      <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-lg">tune</span>
                        <div class="flex flex-col">
                          <span class="text-slate-900 dark:text-white font-bold text-sm uppercase tracking-tight"><%= groupLabel %></span>
                          <span class="text-slate-500 text-[11px] uppercase tracking-wider font-semibold mt-0.5"><%= g && g.helpText ? g.helpText : (g && g.required ? t('product.selectOption') : t('product.productOption')) %></span>
                        </div>
                      </div>
                      <% if (g && g.required) { %>
                        <span class="text-[10px] font-black uppercase tracking-widest text-white bg-primary px-2 py-1 rounded-md"><%= t('product.required') %></span>
                      <% } %>
                    </div>

                    <% if (g && String(g.type) === 'text') { %>
                      <input
                        class="mt-4 w-full rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-950 px-4 py-3 text-sm font-semibold focus:ring-primary"
                        type="text"
                        name="<%= fieldName %>"
                        placeholder="<%= g && g.placeholder ? g.placeholder : '' %>"
                        <%= g && g.required ? 'required' : '' %>
                        data-option-input
                        data-option-type="text"
                        data-price-delta-cents="<%= Number(g.priceDeltaCents) || 0 %>"
                      />
                    <% } else if (choices.length && choices.length <= 3) { %>
                      <div class="mt-4 flex bg-slate-200 dark:bg-slate-800 p-1 rounded-lg border border-slate-300 dark:border-slate-700 gap-1 flex-wrap">
                        <% choices.forEach((c) => { %>
                          <% const cKey = c && c.key ? String(c.key) : ''; %>
                          <% const cAbsoluteRaw = c && c.absolutePriceCents !== null && typeof c.absolutePriceCents !== 'undefined' ? String(c.absolutePriceCents).trim() : ''; %>
                          <% const hasAbsolutePrice = cAbsoluteRaw !== '' && Number.isFinite(Number(cAbsoluteRaw)) && Number(cAbsoluteRaw) >= 0; %>
                          <% if (!cKey) return; %>
                          <label class="choice-toggle relative flex-1 min-w-[120px] cursor-pointer">
                            <input
                              type="radio"
                              name="<%= fieldName %>"
                              value="<%= cKey %>"
                              class="text-primary focus:ring-primary"
                              <%= g && g.required ? 'required' : '' %>
                              data-option-input
                              data-option-type="choice"
                              data-absolute-price-cents="<%= hasAbsolutePrice ? Number(cAbsoluteRaw) : '' %>"
                              data-price-delta-cents="<%= Number(c.priceDeltaCents) || 0 %>"
                              <%- isSupplyModeGroup ? (' data-supply-mode-choice="' + normalizeLoose(c && c.label ? c.label : cKey) + '"') : '' %>
                            />
                            <span class="flex items-center justify-center rounded-md border border-transparent px-4 py-2 text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-300 transition-all text-center min-h-[44px]">
                              <span>
                                <%= c && c.label ? c.label : cKey %>
                                <% if (hasAbsolutePrice) { %>
                                  <span class="block normal-case text-[11px] mt-0.5"><%= formatMoney(c.absolutePriceCents) %> €</span>
                                <% } else if (Number(c && c.priceDeltaCents) > 0) { %>
                                  <span class="block normal-case text-[11px] mt-0.5">+<%= formatMoney(c.priceDeltaCents) %> €</span>
                                <% } %>
                              </span>
                            </span>
                          </label>
                        <% }) %>
                      </div>
                    <% } else if (choices.length) { %>
                      <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <% choices.forEach((c) => { %>
                          <% const cKey = c && c.key ? String(c.key) : ''; %>
                          <% const cAbsoluteRaw = c && c.absolutePriceCents !== null && typeof c.absolutePriceCents !== 'undefined' ? String(c.absolutePriceCents).trim() : ''; %>
                          <% const hasAbsolutePrice = cAbsoluteRaw !== '' && Number.isFinite(Number(cAbsoluteRaw)) && Number(cAbsoluteRaw) >= 0; %>
                          <% if (!cKey) return; %>
                          <label class="option-card group flex items-center gap-3 rounded-xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-950 px-4 py-3.5 cursor-pointer hover:border-primary/50 hover:shadow-md transition-all">
                            <input
                              type="radio"
                              name="<%= fieldName %>"
                              value="<%= cKey %>"
                              class="text-primary focus:ring-primary w-4 h-4 shrink-0"
                              <%= g && g.required ? 'required' : '' %>
                              data-option-input
                              data-option-type="choice"
                              data-absolute-price-cents="<%= hasAbsolutePrice ? Number(cAbsoluteRaw) : '' %>"
                              data-price-delta-cents="<%= Number(c.priceDeltaCents) || 0 %>"
                              <%- isSupplyModeGroup ? (' data-supply-mode-choice="' + normalizeLoose(c && c.label ? c.label : cKey) + '"') : '' %>
                            />
                            <span class="flex-1 min-w-0 normal-case text-sm font-semibold tracking-normal"><%= c && c.label ? c.label : cKey %></span>
                            <% if (hasAbsolutePrice) { %>
                              <span class="text-primary font-black normal-case text-sm"><%= formatMoney(c.absolutePriceCents) %> €</span>
                            <% } else if (Number(c && c.priceDeltaCents) > 0) { %>
                              <span class="text-primary font-black normal-case text-sm">+<%= formatMoney(c.priceDeltaCents) %> €</span>
                            <% } %>
                          </label>
                        <% }) %>
                      </div>
                    <% } %>

                    <% if (isSupplyModeGroup) { %>
                      <div class="mt-4 hidden rounded-xl border border-slate-200 bg-slate-50 p-5" data-exchange-standard-panel>
                        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                          <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary">inventory_2</span>
                            <div>
                              <div class="text-xs font-black uppercase tracking-widest text-slate-900"><%= t('product.step') %> 1</div>
                              <div class="mt-1 text-sm text-slate-600"><%= t('product.exchangeStep1') %></div>
                            </div>
                          </div>
                          <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary">build</span>
                            <div>
                              <div class="text-xs font-black uppercase tracking-widest text-slate-900"><%= t('product.step') %> 2</div>
                              <div class="mt-1 text-sm text-slate-600"><%= t('product.exchangeStep2') %></div>
                            </div>
                          </div>
                          <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary">local_shipping</span>
                            <div>
                              <div class="text-xs font-black uppercase tracking-widest text-slate-900"><%= t('product.step') %> 3</div>
                              <div class="mt-1 text-sm text-slate-600"><%= t('product.exchangeStep3') %></div>
                            </div>
                          </div>
                        </div>
                        <div class="mt-4 text-xs text-slate-500"><% if (consigneUpfront) { %><%- t('product.consigneUpfront', { amount: consigneAmountEuro, days: consigneDelayDays }) %><% } else { %><%- t('product.consigneOnReturn', { days: consigneDelayDays }) %><% } %></div>
                      </div>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            <% } %>

            <div class="flex flex-col gap-3 lg:mt-auto">
              <div class="flex flex-row items-stretch gap-2">
                <div class="flex items-center justify-center rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-1 shrink-0">
                  <button class="w-9 h-11 flex items-center justify-center hover:text-primary transition-colors text-sm" data-qty-minus type="button">—</button>
                  <span class="w-8 text-center font-bold text-sm" data-qty-display>1</span>
                  <button class="w-9 h-11 flex items-center justify-center hover:text-primary transition-colors text-sm" data-qty-plus type="button">+</button>
                </div>
                <button class="flex-1 lg:flex-none lg:min-w-[320px] lg:max-w-[420px] bg-primary hover:bg-primary/90 text-white py-3.5 px-4 rounded-xl font-black uppercase tracking-wide text-sm flex items-center justify-center gap-2 transition-all shadow-lg shadow-primary/20 disabled:opacity-60" data-add-to-cart-submit <%= product.inStock ? '' : 'disabled' %> type="submit">
                  <span class="material-symbols-outlined text-xl" data-add-to-cart-icon>add_shopping_cart</span>
                  <span data-add-to-cart-label><%= t('product.addToCart') %></span>
                </button>
              </div>
              <div class="flex items-center justify-center gap-6 text-xs text-slate-500 font-medium">
                <div class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">lock</span> <%= t('product.securePay') %></div>
                <div class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">local_shipping</span> <%= shippingDelayText || t('product.fastDelivery') %></div>
                <a class="flex items-center gap-1 transition hover:text-primary" href="<%= compatibilityContactUrl %>"><span class="material-symbols-outlined text-sm">search</span> <%= t('product.checkCompat') %></a>
              </div>

              <% if (_showIso) { %>
                <%# Réassurance ISO 9001 au point de conversion (reconditionnés uniquement) %>
                <div class="flex items-center justify-center gap-2 rounded-xl bg-primary/5 border border-primary/15 px-3 py-2 text-xs font-bold text-primary">
                  <span class="material-symbols-outlined text-base">workspace_premium</span>
                  <%= t('product.isoBadge') %>
                </div>
              <% } %>

              <!-- Bouton secondaire : devis par email (capture lead) -->
              <button type="button" id="quote-by-email-btn" class="mt-2 flex items-center justify-center gap-2 w-full text-sm font-medium text-slate-600 hover:text-primary border-t border-slate-100 pt-4 transition">
                <span class="material-symbols-outlined text-base">mail</span>
                <%= t('product.quoteByEmail') %>
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Modal: devis par email -->
      <div id="quote-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50">
        <div class="bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl">
          <div class="flex items-start justify-between mb-3">
            <div>
              <div class="font-bold text-slate-900 text-lg"><%= t('product.receiveQuote') %></div>
              <div class="text-sm text-slate-500 mt-0.5"><%= t('product.teamReplies') %></div>
            </div>
            <button type="button" id="quote-modal-close" class="w-8 h-8 rounded-lg hover:bg-slate-100 flex items-center justify-center -mr-2">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>

          <div class="rounded-xl bg-slate-50 p-3 flex items-center gap-3 mb-4">
            <% if (mainImage) { %>
              <img src="<%= mainImage %>" alt="<%= product.name %>" class="w-12 h-12 rounded-lg object-cover flex-shrink-0" />
            <% } %>
            <div class="text-sm font-medium text-slate-700 truncate"><%= product.name %></div>
          </div>

          <form id="quote-form" class="space-y-3">
            <input type="hidden" name="productId" value="<%= product._id %>" />
            <div class="grid grid-cols-2 gap-2">
              <input type="text" name="firstName" placeholder="<%= t('product.phFirstNameOpt') %>" maxlength="80" class="rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20" />
              <input type="tel" name="phone" placeholder="<%= t('product.phPhoneOpt') %>" maxlength="24" class="rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </div>
            <input type="email" name="email" required placeholder="<%= t('product.phEmailReq') %>" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20" />
            <div class="grid grid-cols-2 gap-2">
              <input type="text" name="vin" placeholder="<%= t('product.phVinOpt') %>" maxlength="32" class="rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:ring-2 focus:ring-primary/20" />
              <input type="text" name="plate" placeholder="<%= t('product.phPlateOpt') %>" maxlength="16" class="rounded-lg border border-slate-200 px-3 py-2 text-sm uppercase focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </div>
            <textarea name="message" rows="2" maxlength="500" placeholder="<%= t('product.phQuestion') %>" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20"></textarea>
            <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white py-2.5 rounded-lg font-bold text-sm transition">
              <%= t('product.requestMyQuote') %>
            </button>
            <p class="text-[11px] text-slate-400 text-center"><%= t('product.consentRecontact') %></p>
          </form>
          <div id="quote-result" class="mt-3 text-sm text-center"></div>
        </div>
      </div>

      <script>
      (function () {
        var btn = document.getElementById('quote-by-email-btn');
        var modal = document.getElementById('quote-modal');
        var closeBtn = document.getElementById('quote-modal-close');
        var form = document.getElementById('quote-form');
        var result = document.getElementById('quote-result');
        if (!btn || !modal || !form) return;

        function open() {
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          if (window.dataLayer) window.dataLayer.push({ event: 'quote_modal_open', product_id: form.querySelector('[name="productId"]').value });
        }
        function close() {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          result.innerHTML = '';
        }
        btn.addEventListener('click', open);
        closeBtn.addEventListener('click', close);
        modal.addEventListener('click', function (e) { if (e.target === modal) close(); });

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var data = {};
          new FormData(form).forEach(function (v, k) { data[k] = v; });
          result.innerHTML = '<span class="text-slate-500">' + <%- JSON.stringify(t('product.sending')) %> + '</span>';
          fetch('/api/lead/product-quote', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          })
            .then(function (r) { return r.json(); })
            .then(function (d) {
              if (d && d.ok) {
                result.innerHTML = '<span class="text-green-700 font-semibold">' + <%- JSON.stringify(t('product.quoteSent')) %> + '</span>';
                form.reset();
                if (window.dataLayer) window.dataLayer.push({ event: 'lead_product_quote', product_id: data.productId, email: data.email });
                setTimeout(close, 2500);
              } else {
                result.innerHTML = '<span class="text-red-700">' + <%- JSON.stringify(t('product.quoteError')) %> + '</span>';
              }
            })
            .catch(function () { result.innerHTML = '<span class="text-red-700">' + <%- JSON.stringify(t('product.networkError')) %> + '</span>'; });
        });
      })();
      </script>

      <div class="mt-16">
        <input checked class="hidden" id="tab-description" name="product-tabs" type="radio" />
        <input class="hidden" id="tab-tech" name="product-tabs" type="radio" />
        <% if (vehicleCount > 0) { %><input class="hidden" id="tab-vehicles" name="product-tabs" type="radio" /><% } %>
        <input class="hidden" id="tab-process" name="product-tabs" type="radio" />
        <% if (_ib.dedicated_tab && _ib.dedicated_tab.length) { %><input class="hidden" id="tab-info" name="product-tabs" type="radio" /><% } %>
        <input class="hidden" id="tab-faq" name="product-tabs" type="radio" />

        <div class="tabs-nav flex border-b-2 border-slate-200 dark:border-slate-800 overflow-x-auto whitespace-nowrap no-scrollbar">
          <label class="px-8 py-4 border-b-4 border-transparent text-slate-500 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white font-bold uppercase text-sm transition-all -mb-[2px] cursor-pointer" for="tab-description"><%= t('product.description') %></label>
          <label class="px-8 py-4 border-b-4 border-transparent text-slate-500 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white font-bold uppercase text-sm transition-all -mb-[2px] cursor-pointer" for="tab-tech"><%= t('product.techSheet') %></label>
          <% if (vehicleCount > 0) { %><label class="px-8 py-4 border-b-4 border-transparent text-slate-500 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white font-bold uppercase text-sm transition-all -mb-[2px] cursor-pointer" for="tab-vehicles"><%= t('product.compatibleVehicles') %> (<%= vehicleCount %>)</label><% } %>
          <label class="px-8 py-4 border-b-4 border-transparent text-slate-500 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white font-bold uppercase text-sm transition-all -mb-[2px] cursor-pointer" for="tab-process"><%= t('product.qualityProcess') %></label>
          <% if (_ib.dedicated_tab && _ib.dedicated_tab.length) { %><label class="px-8 py-4 border-b-4 border-transparent text-slate-500 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white font-bold uppercase text-sm transition-all -mb-[2px] cursor-pointer" for="tab-info"><%= t('product.goodToKnow') %></label><% } %>
          <label class="px-8 py-4 border-b-4 border-transparent text-slate-500 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white font-bold uppercase text-sm transition-all -mb-[2px] cursor-pointer" for="tab-faq"><%= t('product.faq') %> (<%= faqCount %>)</label>
        </div>

        <div class="tab-content-container">
          <div class="tab-content" id="content-description">
            <div class="py-10 grid grid-cols-1 md:grid-cols-2 gap-12">
              <div class="flex flex-col gap-6">
                <h2 class="text-2xl font-black uppercase tracking-tight text-slate-900 dark:text-white"><%= keyType || product.name %></h2>
                <div class="desc-collapse-wrapper relative" data-desc-collapse>
                  <div class="desc-collapse-inner" data-desc-collapse-inner>
                    <% const hasSafeHtml = product && typeof product.descriptionHtmlSafe === 'string' && product.descriptionHtmlSafe.trim(); %>
                    <% if (hasSafeHtml) { %>
                      <div class="text-slate-700 dark:text-slate-300 leading-relaxed product-html"><%- product.descriptionHtmlSafe %></div>
                    <% } else { %>
                      <p class="text-slate-700 dark:text-slate-300 leading-relaxed whitespace-pre-line"><%= product.descriptionText || product.description || product.shortDescription || '' %></p>
                    <% } %>

                    <% if (summaryPoints.length) { %>
                      <ul class="space-y-3 mt-4">
                        <% summaryPoints.forEach((point) => { %>
                          <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary">check_circle</span>
                            <span class="text-slate-700 dark:text-slate-300"><%= point %></span>
                          </li>
                        <% }) %>
                      </ul>
                    <% } %>
                  </div>
                  <div class="desc-collapse-fade hidden" data-desc-fade>
                    <button class="w-full pt-10 pb-2 text-center text-sm font-bold text-primary flex items-center justify-center gap-1" data-desc-toggle type="button">
                      <span data-desc-toggle-label><%= t('product.readMore') %></span>
                      <span class="material-symbols-outlined text-base transition-transform" data-desc-toggle-icon>expand_more</span>
                    </button>
                  </div>
                </div>
              </div>

              <div class="bg-slate-50 dark:bg-slate-900 rounded-2xl p-8 border border-slate-300 dark:border-slate-700 refined-shadow">
                <h4 class="text-lg font-bold uppercase text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                  <span class="material-symbols-outlined text-primary">build</span>
                  <%= t('product.technicalPoints') %>
                </h4>
                <div class="space-y-4">
                  <% technicalSpecs.slice(0, 6).forEach((entry) => { %>
                    <div class="flex justify-between gap-4 border-b border-slate-200 dark:border-slate-800 pb-2">
                      <span class="text-slate-500 text-sm"><%= entry.label %></span>
                      <span class="font-bold text-sm text-right text-slate-900 dark:text-white"><%= entry.value %></span>
                    </div>
                  <% }) %>
                </div>
              </div>

              <% if (inclusionsList.length || exclusionsList.length) { %>
                <div class="mt-6 bg-slate-50 dark:bg-slate-900 rounded-2xl p-8 border border-slate-300 dark:border-slate-700 refined-shadow">
                  <h4 class="text-lg font-bold uppercase text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">checklist</span>
                    <%= t('product.offerContent') %>
                  </h4>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <% if (inclusionsList.length) { %>
                      <div>
                        <p class="text-xs font-bold uppercase tracking-wider text-emerald-600 mb-3"><%= t('product.included') %></p>
                        <ul class="space-y-2">
                          <% inclusionsList.forEach((it) => { %>
                            <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-200"><span class="material-symbols-outlined text-emerald-600 text-base leading-5">check_circle</span><span><%= it %></span></li>
                          <% }) %>
                        </ul>
                      </div>
                    <% } %>
                    <% if (exclusionsList.length) { %>
                      <div>
                        <p class="text-xs font-bold uppercase tracking-wider text-rose-600 mb-3"><%= t('product.notIncluded') %></p>
                        <ul class="space-y-2">
                          <% exclusionsList.forEach((it) => { %>
                            <li class="flex items-start gap-2 text-sm text-slate-500"><span class="material-symbols-outlined text-rose-500 text-base leading-5">cancel</span><span><%= it %></span></li>
                          <% }) %>
                        </ul>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% } %>

              <%# Documents techniques fournis — titres seuls (réassurance). Le
                   téléchargement est réservé à l'acheteur (email + page commande). %>
              <% var _techDocs = Array.isArray(product.technicalDocs) ? product.technicalDocs : []; %>
              <% if (_techDocs.length) { %>
                <div class="mt-6 bg-slate-50 dark:bg-slate-900 rounded-2xl p-8 border border-slate-300 dark:border-slate-700 refined-shadow">
                  <h4 class="text-lg font-bold uppercase text-slate-900 dark:text-white mb-2 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">description</span>
                    Documents techniques fournis
                  </h4>
                  <p class="text-xs text-slate-500 mb-5">Transmis <strong>avec votre commande</strong> (manuel de montage, prérequis, conditions). Accès dans l'email de confirmation et l'espace de votre commande.</p>
                  <ul class="space-y-2">
                    <% _techDocs.forEach((doc) => { %>
                      <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-200">
                        <span class="material-symbols-outlined text-red-600 text-base leading-5">picture_as_pdf</span>
                        <span><%= (doc.title && String(doc.title).trim()) ? doc.title : (doc.filename || 'Document technique') %></span>
                      </li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>
            </div>
            <%# Blocs d'information : fin de description, puis après inclus/non-inclus %>
            <%- include('./partials/info-blocks', { blocks: _ib.description_end }) %>
            <%- include('./partials/info-blocks', { blocks: _ib.after_inclusions }) %>
          </div>

          <% if (_ib.dedicated_tab && _ib.dedicated_tab.length) { %>
          <div class="tab-content" id="content-info">
            <div class="py-10 max-w-3xl">
              <%- include('./partials/info-blocks', { blocks: _ib.dedicated_tab }) %>
            </div>
          </div>
          <% } %>

          <div class="tab-content" id="content-tech">
            <div class="py-10 grid grid-cols-1 xl:grid-cols-[minmax(0,0.92fr)_minmax(340px,1.08fr)] gap-10">
              <div class="space-y-8">
                <div class="bg-slate-50 dark:bg-slate-900 rounded-2xl p-8 border border-slate-300 dark:border-slate-700 refined-shadow">
                  <h4 class="text-lg font-bold uppercase text-slate-900 dark:text-white mb-6"><%= t('product.productSheet') %></h4>
                  <div class="space-y-4">
                    <% technicalSpecs.forEach((entry) => { %>
                      <div class="flex justify-between gap-4 border-b border-slate-200 dark:border-slate-800 pb-2">
                        <span class="text-slate-500 text-sm"><%= entry.label %></span>
                        <span class="font-bold text-sm text-right text-slate-900 dark:text-white"><%= entry.value %></span>
                      </div>
                    <% }) %>
                  </div>
                </div>

                <% if (compatibleReferences.length) { %>
                  <div>
                    <h2 class="text-sm font-black uppercase tracking-widest text-slate-400 mb-4"><%= t('product.oemRefs') %></h2>
                    <div class="flex flex-wrap gap-2">
                      <% compatibleReferences.forEach((r) => { %>
                        <span class="px-3 py-1.5 rounded-full border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-xs font-bold text-slate-700 dark:text-slate-200"><%= r %></span>
                      <% }) %>
                    </div>
                  </div>
                <% } %>

                <% if (product.sections && product.sections.showSupportBox) { %>
                  <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-6 refined-shadow">
                    <div class="flex items-start gap-4">
                      <div class="h-12 w-12 rounded-full bg-primary/10 text-primary flex items-center justify-center">
                        <span class="material-symbols-outlined">support_agent</span>
                      </div>
                      <div>
                        <h4 class="text-base font-bold text-slate-900 dark:text-white"><%= t('product.needValidation') %></h4>
                        <p class="mt-2 text-sm text-slate-500"><%= t('product.techCanConfirm') %></p>
                        <div class="mt-4 flex flex-wrap gap-3">
                          <a class="inline-flex items-center justify-center rounded-lg bg-primary text-white px-4 py-2 text-xs font-black uppercase tracking-wider hover:bg-primary/90 transition-colors" href="/devis"><%= t('product.contactTech') %></a>
                          <a class="inline-flex items-center justify-center rounded-lg border border-slate-300 dark:border-slate-700 px-4 py-2 text-xs font-black uppercase tracking-wider hover:border-primary hover:text-primary transition-colors" href="/compte"><%= t('product.requestVerif') %></a>
                        </div>
                      </div>
                    </div>
                  </div>
                <% } %>
              </div>

              <div>
                <% /* Helper de slug pour les liens vers landing pages véhicule */ %>
                <% function slugifyVeh(v) { return String(v||'').normalize('NFD').replace(/[̀-ͯ]/g,'').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,''); } %>
                <% if (compMakes.length) { %>
                  <%/* Bloc "Voir aussi" avec liens vers landing pages — boost l'internal
                       linking SEO entre fiches produits et pages véhicule, et améliore
                       l'expérience client (parcours rapide vers d'autres pièces compatibles). */%>
                  <div class="mb-6 rounded-2xl border border-primary/20 bg-primary/5 p-5">
                    <div class="text-xs font-bold uppercase tracking-widest text-primary mb-3"><%= t('product.seeAlsoCompat') %></div>
                    <div class="flex flex-wrap gap-2">
                      <% compMakes.slice(0, 4).forEach((mk) => { %>
                        <% const mkSlug = slugifyVeh(mk); %>
                        <a class="inline-flex items-center gap-1 bg-white border border-slate-200 hover:border-primary hover:text-primary text-xs font-bold text-slate-700 px-3 py-1.5 rounded-full transition-colors" href="/pieces-auto/<%= mkSlug %>">
                          <span class="material-symbols-outlined text-[14px]">directions_car</span>
                          <%= t('product.allPartsFor', { make: mk }) %>
                        </a>
                        <% const row = compGrouped[mk]; %>
                        <% const modelsArr = row ? Array.from(row.models).slice(0, 2) : []; %>
                        <% modelsArr.forEach((md) => { %>
                          <% const mdSlug = slugifyVeh(md); %>
                          <a class="inline-flex items-center gap-1 bg-white border border-slate-200 hover:border-primary hover:text-primary text-xs font-bold text-slate-700 px-3 py-1.5 rounded-full transition-colors" href="/pieces-auto/<%= mkSlug %>/<%= mdSlug %>">
                            <span class="material-symbols-outlined text-[14px]">car_repair</span>
                            <%= mk %> <%= md %>
                          </a>
                        <% }) %>
                      <% }) %>
                    </div>
                  </div>
                  <div class="overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 refined-shadow">
                    <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/70">
                      <h2 class="text-lg font-bold uppercase text-slate-900 dark:text-white"><%= t('product.compatibleVehicles') %></h2>
                      <p class="mt-1 text-sm text-slate-500"><%= t('product.compatWarning') %></p>
                    </div>
                    <table class="w-full text-left border-collapse compatibility-table">
                      <thead class="bg-white dark:bg-slate-950 text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                        <tr>
                          <th class="px-5 sm:px-6 py-4"><%= t('product.make') %></th>
                          <th class="px-5 sm:px-6 py-4"><%= t('product.models') %></th>
                          <th class="px-5 sm:px-6 py-4"><%= t('product.engines') %></th>
                        </tr>
                      </thead>
                      <tbody class="text-[13px]">
                        <% compMakes.forEach((mk) => { %>
                          <% const row = compGrouped[mk]; %>
                          <% const models = row ? Array.from(row.models) : []; %>
                          <% const engines = row ? Array.from(row.engines) : []; %>
                          <% const mkSlug = slugifyVeh(mk); %>
                          <tr class="border-t border-slate-100 dark:border-slate-700/50">
                            <td class="px-5 sm:px-6 py-4 font-bold align-top">
                              <a class="hover:text-primary transition-colors" href="/pieces-auto/<%= mkSlug %>"><%= mk %></a>
                            </td>
                            <td class="px-5 sm:px-6 py-4 text-slate-500 align-top">
                              <% models.forEach((md, idx) => { %><a class="hover:text-primary transition-colors" href="/pieces-auto/<%= mkSlug %>/<%= slugifyVeh(md) %>"><%= md %></a><%= idx < models.length - 1 ? ', ' : '' %><% }) %>
                            </td>
                            <td class="px-5 sm:px-6 py-4 text-slate-400 italic align-top"><%= engines.join(' / ') %></td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <div class="bg-slate-50 dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-8 text-center text-sm text-slate-500 refined-shadow"><%= t('product.noCompat') %></div>
                <% } %>
              </div>
            </div>

            <div class="mt-10 bg-slate-50 dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-8 refined-shadow">
              <h2 class="text-lg font-bold uppercase text-slate-900 dark:text-white mb-4">
                <%= t('product.mountingWarranty') %>
              </h2>
              <p class="text-slate-700 dark:text-slate-300 leading-relaxed mb-4">
                <%# Occasion ≠ reconditionné : texte adapté pour ne pas prétendre un reconditionnement/banc d'essai sur une pièce d'occasion. %>
                <% var _isOccasion = /occasion/i.test(String(product.category || '') + ' ' + String((product.badges && product.badges.condition) || '')); %>
                <%- t(_isOccasion ? 'product.mountingParaOccasion' : 'product.mountingPara', { warranty: (typeof keyGarantie !== 'undefined' && keyGarantie ? keyGarantie : t('product.warrantyOf')) }) %>
              </p>
              <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
                <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-base mt-0.5">check</span> <%= t('product.mount1') %></li>
                <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-base mt-0.5">check</span> <%= t('product.mount2') %></li>
                <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-base mt-0.5">check</span> <%= t('product.mount3') %></li>
                <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-base mt-0.5">check</span> <%= t('product.mount4') %></li>
              </ul>
            </div>
          </div>

          <div class="tab-content" id="content-vehicles">
            <div class="overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 refined-shadow">
              <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/70 flex items-center justify-between gap-4">
                <div>
                  <h2 class="text-lg font-bold uppercase text-slate-900 dark:text-white"><%= t('product.compatibleVehicles') %></h2>
                  <p class="mt-1 text-sm text-slate-500"><%= t('product.checkVinModel', { count: vehicleCount }) %></p>
                </div>
                <span class="shrink-0 inline-flex items-center rounded-full bg-emerald-50 text-emerald-700 px-3 py-1.5 text-xs font-bold"><%= vehicleCount %></span>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead class="bg-white dark:bg-slate-950 text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                    <tr>
                      <th class="px-5 sm:px-6 py-4"><%= t('product.make') %></th>
                      <th class="px-5 sm:px-6 py-4"><%= t('product.model') %></th>
                      <th class="px-5 sm:px-6 py-4"><%= t('product.years') %></th>
                      <th class="px-5 sm:px-6 py-4"><%= t('product.engine') %></th>
                      <th class="px-5 sm:px-6 py-4"><%= t('product.power') %></th>
                    </tr>
                  </thead>
                  <tbody class="text-[13px]">
                    <% compatVehicles.forEach((v) => { %>
                      <tr class="border-t border-slate-100 dark:border-slate-700/50">
                        <td class="px-5 sm:px-6 py-3 font-bold text-slate-900 dark:text-white whitespace-nowrap"><%= v.make %></td>
                        <td class="px-5 sm:px-6 py-3 text-slate-600 dark:text-slate-300"><%= v.model %></td>
                        <td class="px-5 sm:px-6 py-3 text-slate-500 whitespace-nowrap"><%= v.years || '—' %></td>
                        <td class="px-5 sm:px-6 py-3 text-slate-500"><%= v.engine || '—' %></td>
                        <td class="px-5 sm:px-6 py-3 text-slate-400 italic whitespace-nowrap"><%= v.power || '—' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
            <p class="mt-4 text-xs text-slate-400"><%= t('product.indicativeList') %></p>
          </div>

          <div class="tab-content" id="content-process">
            <% if (product.sections && product.sections.showReconditioning && Array.isArray(product.reconditioningSteps) && product.reconditioningSteps.length) { %>
              <div class="py-10">
                <div class="mb-8">
                  <h2 class="text-2xl font-black uppercase tracking-tight text-slate-900 dark:text-white"><%= isService ? t('product.howItWorks') : t('product.qualityProcessTitle') %></h3>
                  <p class="mt-2 text-sm text-slate-500"><%= isService ? t('product.howItWorksDesc') : t('product.qualityProcessDesc') %></p>
                  <% if (_showIso) { %>
                    <div class="mt-3 inline-flex items-center gap-2 rounded-lg bg-primary/5 border border-primary/15 px-3 py-1.5 text-xs font-semibold text-primary">
                      <span class="material-symbols-outlined text-sm">workspace_premium</span>
                      <%= t('product.isoProcessNote') %>
                    </div>
                  <% } %>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
                  <% product.reconditioningSteps.slice(0, 4).forEach((st, idx) => { %>
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 refined-shadow space-y-3">
                      <div class="text-3xl font-black text-slate-200 dark:text-slate-700"><%= String(idx + 1).padStart(2, '0') %></div>
                      <h4 class="text-sm font-bold uppercase tracking-wider text-slate-900 dark:text-white"><%= st.title %></h4>
                      <p class="text-sm text-slate-500 leading-relaxed"><%= st.description %></p>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } else { %>
              <div class="py-10 text-center text-slate-500 text-sm"><%= t('product.noReconditioning') %></div>
            <% } %>
          </div>

          <div class="tab-content" id="content-faq">
            <% if (product.sections && product.sections.showFaq && Array.isArray(product.faqs) && product.faqs.length) { %>
              <div class="py-10 max-w-5xl space-y-4">
                <% product.faqs.forEach((f) => { %>
                  <details class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl refined-shadow group">
                    <summary class="p-5 flex justify-between items-center cursor-pointer">
                      <span class="font-bold text-sm text-slate-900 dark:text-white"><%= f.question %></span>
                      <span class="material-symbols-outlined text-slate-300 group-hover:text-primary transition-colors">add</span>
                    </summary>
                    <div class="px-5 pb-5">
                      <p class="text-sm text-slate-500 leading-relaxed whitespace-pre-line"><%= f.answer %></p>
                    </div>
                  </details>
                <% }) %>
              </div>
            <% } else { %>
              <div class="py-10 text-center text-slate-500 text-sm"><%= t('product.noFaq') %></div>
            <% } %>
          </div>
        </div>
      </div>

      <%/* Preuve sociale : logos des garages qui montent nos pièces (titre générique).
           CSS marquee inline (non global). Repris de la landing moteur-occasion. */%>
      <% if (!isService) { %>
        <% var _montLabel = 'Nos pièces ont été montées par';
           var _montBrands = [
             ['Porsche', '/images/partenaires/logo-porsche.webp'],
             ['Simplici Car', '/images/partenaires/LOGO-SIMPLICI-CAR-NOIR-copie.png'],
             ['Flat 44', '/images/partenaires/Logo-FLAT44-contact.png'],
             ['Mougins Autosport', '/images/partenaires/mougins-autosport.webp'],
             ['Sun Motors', '/images/partenaires/sun-motors.webp'],
             ['Chassay Automobiles', '/images/partenaires/chassay-automobiles.png']
           ]; %>
        <style>
          @keyframes brand-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
          .brand-marquee-track { animation: brand-marquee 28s linear infinite; will-change: transform; }
          .brand-marquee:hover .brand-marquee-track { animation-play-state: paused; }
          @media (prefers-reduced-motion: reduce) { .brand-marquee-track { animation: none; } }
        </style>
        <section class="mt-16 border-t border-slate-100 dark:border-slate-800 pt-10">
          <p class="text-center text-xs font-bold text-slate-400 uppercase tracking-widest mb-8"><%= _montLabel %></p>
          <div class="brand-marquee relative overflow-hidden" style="-webkit-mask-image:linear-gradient(to right,transparent,#000 8%,#000 92%,transparent);mask-image:linear-gradient(to right,transparent,#000 8%,#000 92%,transparent);">
            <div class="brand-marquee-track flex items-center gap-12 w-max">
              <% for (var _d = 0; _d < 2; _d++) { %>
                <% _montBrands.forEach(function (b) { %>
                  <div class="h-12 w-28 md:h-14 md:w-32 flex items-center justify-center shrink-0 grayscale hover:grayscale-0 opacity-70 hover:opacity-100 transition duration-300">
                    <img alt="<%= b[0] %>" class="max-h-full max-w-full object-contain" src="<%= b[1] %>" loading="lazy" <%= _d === 1 ? 'aria-hidden="true"' : '' %> />
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>
        </section>
      <% } %>

      <% if (product.sections && product.sections.showRelatedProducts && Array.isArray(relatedProducts) && relatedProducts.length) { %>
        <section class="mt-16">
          <h2 class="text-xl font-black uppercase mb-8 tracking-wider text-slate-900 dark:text-white border-b-2 border-slate-200 dark:border-slate-800 pb-4"><%= t('product.boughtTogether') %></h3>
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            <% relatedProducts.slice(0, 3).forEach((p) => { %>
              <% const productUrl = (p && p.publicPath) ? p.publicPath : ('/produits/' + p._id); %>
              <% const relatedBadge = p && p.category ? String(p.category).trim() : 'Pièce liée'; %>
              <article class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex gap-4 group hover:border-primary hover:shadow-md transition-all">
                <a class="w-24 h-24 bg-slate-100 dark:bg-slate-950 rounded-lg overflow-hidden flex-shrink-0" href="<%= productUrl %>">
                  <% if (p.imageUrl) { %>
                    <img alt="<%= p.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform" decoding="async" loading="lazy" width="96" height="96" src="<%= p.imageUrl %>" />
                  <% } else { %>
                    <span class="w-full h-full flex items-center justify-center text-slate-400">
                      <span class="material-symbols-outlined text-4xl">inventory_2</span>
                    </span>
                  <% } %>
                </a>
                <div class="flex flex-col justify-between py-1 flex-1 min-w-0">
                  <div>
                    <h4 class="text-xs font-bold uppercase text-slate-400"><%= relatedBadge %></h4>
                    <a class="text-sm font-bold text-slate-900 dark:text-white line-clamp-2 hover:text-primary transition-colors" href="<%= productUrl %>"><%= p.name %></a>
                  </div>
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-primary font-black"><%= formatMoney(p.priceCents) %> €</span>
                    <form action="/panier/ajouter/<%= p._id %>" method="POST">
                      <input name="returnTo" type="hidden" value="<%= typeof returnTo !== 'undefined' ? returnTo : '/produits' %>" />
                      <input name="qty" type="hidden" value="1" />
                      <button class="text-primary hover:bg-primary hover:text-white rounded-full p-1 transition-all disabled:opacity-60" <%= p.inStock ? '' : 'disabled' %> type="submit">
                        <span class="material-symbols-outlined">add_circle</span>
                      </button>
                    </form>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <% if (faqPreviewCards.length) { %>
        <section class="mt-20">
          <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 border-b-2 border-slate-200 dark:border-slate-800 pb-4 gap-4">
            <div class="flex items-center gap-4">
              <h2 class="text-xl font-black uppercase tracking-wider text-slate-900 dark:text-white"><%= t('product.freqQuestions') %></h3>
              <div class="flex items-center gap-1.5 bg-primary/10 px-2.5 py-1 rounded-md border border-primary/20">
                <span class="font-black text-[10px] text-primary tracking-tighter uppercase italic"><%= t('product.productBadge') %></span>
                <div class="w-4 h-4 bg-primary rounded-full flex items-center justify-center">
                  <span class="text-[8px] font-black text-white">FAQ</span>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="flex text-primary">
                <span class="material-symbols-outlined fill-1">check_circle</span>
                <span class="material-symbols-outlined fill-1">check_circle</span>
                <span class="material-symbols-outlined fill-1">check_circle</span>
              </div>
              <span class="text-lg font-black text-slate-900 dark:text-white"><%= faqPreviewCards.length %></span>
              <span class="text-slate-400 text-sm font-medium"><%= t('product.usefulAnswers') %></span>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% faqPreviewCards.forEach((f) => { %>
              <% const initials = String(f.question || 'FAQ').replace(/[^A-Za-zÀ-ÿ0-9 ]/g, ' ').trim().split(/\s+/).slice(0, 2).map((part) => part.charAt(0).toUpperCase()).join('') || 'FAQ'; %>
              <article class="bg-slate-50 dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 refined-shadow">
                <div class="flex text-primary mb-3 scale-75 -ml-3">
                  <span class="material-symbols-outlined fill-1">star</span>
                  <span class="material-symbols-outlined fill-1">star</span>
                  <span class="material-symbols-outlined fill-1">star</span>
                </div>
                <p class="text-slate-700 dark:text-slate-300 italic text-sm leading-relaxed mb-4 line-clamp-5"><%= f.answer %></p>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-xs font-bold text-slate-500 dark:text-slate-200"><%= initials %></div>
                  <div>
                    <p class="text-xs font-bold text-slate-900 dark:text-white uppercase"><%= f.question %></p>
                    <div class="flex items-center gap-1.5">
                      <p class="text-[10px] text-slate-400 uppercase"><%= t('product.usefulInfo') %></p>
                      <div class="flex items-center gap-1 bg-primary/10 border border-primary/20 px-1 rounded-sm">
                        <span class="text-[8px] font-bold text-primary uppercase"><%= brand.NAME_SHORT %></span>
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <% if (Array.isArray(relatedBlogPosts) && relatedBlogPosts.length) { %>
        <section class="mt-24 border-t-2 border-slate-200 dark:border-slate-800 pt-16">
          <div class="flex items-center justify-between mb-8 gap-4">
            <h2 class="text-xl font-black uppercase tracking-wider text-slate-900 dark:text-white"><%= t('product.blogArticles') %></h3>
            <a class="text-xs font-black uppercase text-primary hover:underline flex items-center gap-1" href="/blog"><%= t('product.viewAllArticles') %> <span class="material-symbols-outlined text-sm">chevron_right</span></a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
            <% relatedBlogPosts.slice(0, 4).forEach((a) => { %>
              <article class="group cursor-pointer">
                <a class="block" href="<%= a.url %>">
                  <div class="aspect-[16/10] bg-slate-100 dark:bg-slate-900 rounded-lg overflow-hidden mb-4 border border-slate-200 dark:border-slate-800">
                    <% if (a.imageUrl) { %>
                      <img alt="<%= a.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" width="400" height="250" src="<%= a.imageUrl %>" />
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center text-slate-400">
                        <span class="material-symbols-outlined text-5xl">article</span>
                      </div>
                    <% } %>
                  </div>
                  <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-2 leading-tight group-hover:text-primary transition-colors"><%= a.title %></h4>
                  <p class="text-xs text-slate-500 line-clamp-2 leading-relaxed"><%= a.excerpt %></p>
                </a>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <script>
        (function () {
          var mainImg = document.querySelector('[data-main-image]');
          var mainVid = document.querySelector('[data-main-video]');
          var mainEmbed = document.querySelector('[data-main-embed]'); // iframe YouTube/Vimeo
          var thumbs = Array.prototype.slice.call(document.querySelectorAll('[data-thumb]') || []);
          var prevBtn = document.querySelector('[data-gallery-prev]');
          var nextBtn = document.querySelector('[data-gallery-next]');
          var currentIndex = 0;

          var qtyInput = document.querySelector('[data-qty-input]');
          var qtyDisplay = document.querySelector('[data-qty-display]');
          var minus = document.querySelector('[data-qty-minus]');
          var plus = document.querySelector('[data-qty-plus]');
          var addToCartForm = document.querySelector('[data-add-to-cart-form]');
          var addToCartSubmit = addToCartForm ? addToCartForm.querySelector('[data-add-to-cart-submit]') : null;
          var addToCartIcon = addToCartForm ? addToCartForm.querySelector('[data-add-to-cart-icon]') : null;
          var addToCartLabel = addToCartForm ? addToCartForm.querySelector('[data-add-to-cart-label]') : null;
          var addToCartPending = false;
          var addToCartResetTimer = null;
          var originalSubmitIcon = addToCartIcon ? addToCartIcon.textContent : 'add_shopping_cart';
          var originalSubmitLabel = addToCartLabel ? addToCartLabel.textContent : '<%= t('product.addToCart') %>';
          var originalSubmitDisabled = !!(addToCartSubmit && addToCartSubmit.disabled);

          var priceEl = document.querySelector('[data-price-display]');
          var priceHtEl = document.querySelector('[data-price-display-ht]'); // prix HT (TVA récupérable)
          var installmentWrapper = document.querySelector('[data-installment-wrapper]');
          var installmentAmountEl = document.querySelector('[data-installment-amount]');
          var optionInputs = Array.prototype.slice.call(document.querySelectorAll('[data-option-input]') || []);
          var exchangeStandardPanel = document.querySelector('[data-exchange-standard-panel]');
          var supplyModeInputs = Array.prototype.slice.call(document.querySelectorAll('[data-supply-mode-choice]') || []);

          function formatMoney(cents) {
            try {
              return new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format((Number(cents) || 0) / 100);
            } catch (e) {
              return ((Number(cents) || 0) / 100).toFixed(2).replace('.', ',');
            }
          }

          function computeOptionPricing() {
            var total = 0;
            var absolute = null;
            optionInputs.forEach(function (el) {
              if (!el) return;
              var type = el.getAttribute('data-option-type') || '';
              var delta = Number(el.getAttribute('data-price-delta-cents') || '0');
              var absoluteRaw = el.getAttribute('data-absolute-price-cents');
              var absolutePrice = absoluteRaw === '' || absoluteRaw === null ? null : Number(absoluteRaw);
              if (!Number.isFinite(delta)) delta = 0;

              if (type === 'choice') {
                if (el.checked) {
                  if (Number.isFinite(absolutePrice) && absolutePrice >= 0) absolute = absolutePrice;
                  else total += delta;
                }
              } else if (type === 'text') {
                var v = (el.value || '').trim();
                if (v) total += delta;
              }
            });
            return { delta: total, absolute: absolute };
          }

          function syncDisplayedPrice() {
            if (!priceEl) return;
            var base = Number(priceEl.getAttribute('data-base-price-cents') || '0');
            if (!Number.isFinite(base)) base = 0;
            var pricing = computeOptionPricing();
            var next = (pricing.absolute !== null ? pricing.absolute : base) + pricing.delta;
            priceEl.textContent = formatMoney(next) + ' €';
            if (priceHtEl) priceHtEl.textContent = formatMoney(Math.round(next / 1.2)); // HT = TTC / 1,20
            syncInstallmentDisplay(next);
          }

          function syncInstallmentDisplay(totalCents) {
            if (!installmentWrapper || !priceEl) return;
            var count = Number(priceEl.getAttribute('data-installment-count') || '3');
            var min = Number(priceEl.getAttribute('data-installment-min-cents') || '0');
            var max = Number(priceEl.getAttribute('data-installment-max-cents') || '0');
            if (!Number.isFinite(count) || count <= 0) count = 3;
            if (!Number.isFinite(min) || min < 0) min = 0;
            if (!Number.isFinite(max) || max < min) max = Number.MAX_SAFE_INTEGER;
            var eligible = Number.isFinite(totalCents) && totalCents >= min && totalCents <= max;
            installmentWrapper.classList.toggle('hidden', !eligible);
            if (eligible && installmentAmountEl) {
              installmentAmountEl.textContent = formatMoney(Math.round(totalCents / count)) + ' €';
            }
          }

          function syncExchangeStandardPanel() {
            if (!exchangeStandardPanel) return;
            var selectedInput = null;
            supplyModeInputs.forEach(function (el) {
              if (el && el.checked) selectedInput = el;
            });
            var selectedMode = selectedInput ? String(selectedInput.getAttribute('data-supply-mode-choice') || '') : '';
            var showPanel = selectedMode.indexOf('echange-standard') !== -1;
            exchangeStandardPanel.classList.toggle('hidden', !showPanel);
          }

          function clamp(v) {
            if (!Number.isFinite(v)) return 1;
            if (v < 1) return 1;
            if (v > 99) return 99;
            return v;
          }

          function getQty() {
            if (!qtyInput) return 1;
            var n = parseInt(qtyInput.value, 10);
            if (!Number.isFinite(n)) return 1;
            return clamp(n);
          }

          function setQty(nextQty) {
            var v = clamp(nextQty);
            if (qtyInput) qtyInput.value = String(v);
            if (qtyDisplay) qtyDisplay.textContent = String(v);
          }

          function resetAddToCartButton() {
            if (addToCartResetTimer) {
              window.clearTimeout(addToCartResetTimer);
              addToCartResetTimer = null;
            }
            if (!addToCartSubmit) return;
            addToCartSubmit.classList.remove('cart-submit-success');
            addToCartSubmit.disabled = originalSubmitDisabled;
            if (addToCartIcon) addToCartIcon.textContent = originalSubmitIcon;
            if (addToCartLabel) addToCartLabel.textContent = originalSubmitLabel;
          }

          function setAddToCartSuccessState() {
            if (!addToCartSubmit) return;
            addToCartSubmit.classList.add('cart-submit-success');
            addToCartSubmit.disabled = true;
            if (addToCartIcon) addToCartIcon.textContent = 'check';
            if (addToCartLabel) addToCartLabel.textContent = 'Ajouté';
          }

          function scheduleAddToCartReset(delayMs) {
            if (addToCartResetTimer) {
              window.clearTimeout(addToCartResetTimer);
            }
            addToCartResetTimer = window.setTimeout(function () {
              resetAddToCartButton();
              addToCartPending = false;
            }, delayMs);
          }

          function setActiveThumb(index) {
            if (!thumbs || !thumbs.length) return;

            thumbs.forEach(function (b, idx) {
              b.classList.remove('ring-2', 'ring-primary', 'border-primary/20', 'border-slate-200', 'dark:border-slate-700');
              b.classList.add('border');
              if (idx === index) {
                b.classList.add('border-primary/20', 'ring-2', 'ring-primary');
              } else {
                b.classList.add('border-slate-200', 'dark:border-slate-700');
              }
            });

            var btn = thumbs[index];
            if (!btn) return;
            try {
              btn.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
            } catch (e) {
              btn.scrollIntoView(true);
            }
          }

          function setIndex(nextIndex) {
            if ((!mainImg && !mainVid) || !thumbs || !thumbs.length) return;
            var max = thumbs.length;
            var idx = nextIndex % max;
            if (idx < 0) idx = max + idx;

            var btn = thumbs[idx];
            if (!btn) return;
            var src = btn.getAttribute('data-src');
            var type = btn.getAttribute('data-type') || 'image';
            if (!src) return;

            if (type === 'embed') {
              // Vidéo YouTube/Vimeo : on affiche l'iframe (autoplay au clic) et on
              // masque image + vidéo fichier.
              if (mainImg) { mainImg.classList.add('hidden'); mainImg.removeAttribute('src'); }
              if (mainVid) { try { mainVid.pause(); } catch (e) {} mainVid.classList.add('hidden'); mainVid.removeAttribute('src'); }
              if (mainEmbed) {
                var embedSrc = btn.getAttribute('data-embed-src') || src;
                mainEmbed.classList.remove('hidden');
                mainEmbed.setAttribute('src', embedSrc + (embedSrc.indexOf('?') === -1 ? '?' : '&') + 'autoplay=1');
              }
            } else if (type === 'video') {
              if (mainEmbed) { mainEmbed.classList.add('hidden'); mainEmbed.removeAttribute('src'); }
              if (mainImg) {
                mainImg.classList.add('hidden');
                mainImg.removeAttribute('src');
              }
              if (mainVid) {
                mainVid.classList.remove('hidden');
                try { mainVid.pause(); } catch (e) {}
                mainVid.setAttribute('src', src);
                try { mainVid.load(); } catch (e) {}
              }
            } else {
              if (mainEmbed) { mainEmbed.classList.add('hidden'); mainEmbed.removeAttribute('src'); }
              if (mainVid) {
                try { mainVid.pause(); } catch (e) {}
                mainVid.classList.add('hidden');
                mainVid.removeAttribute('src');
              }
              if (mainImg) {
                mainImg.classList.remove('hidden');
                mainImg.setAttribute('src', src);
              }
            }

            currentIndex = idx;
            setActiveThumb(currentIndex);
          }

          if (minus) {
            minus.addEventListener('click', function () {
              setQty(getQty() - 1);
            });
          }
          if (plus) {
            plus.addEventListener('click', function () {
              setQty(getQty() + 1);
            });
          }

          if (thumbs && thumbs.length && mainImg) {
            thumbs.forEach(function (btn, idx) {
              btn.addEventListener('click', function () {
                setIndex(idx);
              });
            });

            if (prevBtn) {
              prevBtn.addEventListener('click', function () {
                setIndex(currentIndex - 1);
              });
            }
            if (nextBtn) {
              nextBtn.addEventListener('click', function () {
                setIndex(currentIndex + 1);
              });
            }

            /* ── Lightbox : ouvrir au clic sur l'image principale ─────── */
            var lightbox = document.querySelector('[data-lightbox]');
            var lightboxImg = lightbox ? lightbox.querySelector('[data-lightbox-img]') : null;
            var lightboxPrev = lightbox ? lightbox.querySelector('[data-lightbox-prev]') : null;
            var lightboxNext = lightbox ? lightbox.querySelector('[data-lightbox-next]') : null;
            var lightboxClose = lightbox ? lightbox.querySelector('[data-lightbox-close]') : null;
            var lightboxCounter = lightbox ? lightbox.querySelector('[data-lightbox-counter]') : null;

            /* Indices des images (vidéos exclues) pour la nav lightbox */
            var imageThumbIndices = thumbs.reduce(function (acc, t, i) {
              var _ty = t.getAttribute('data-type') || 'image';
              if (_ty !== 'video' && _ty !== 'embed') acc.push(i);
              return acc;
            }, []);
            var lightboxImageIdx = 0; // position dans imageThumbIndices

            function updateLightboxCounter() {
              if (!lightboxCounter) return;
              if (imageThumbIndices.length <= 1) {
                lightboxCounter.classList.add('hidden');
                return;
              }
              lightboxCounter.classList.remove('hidden');
              lightboxCounter.textContent = (lightboxImageIdx + 1) + ' / ' + imageThumbIndices.length;
            }

            function showLightboxAt(imageIdx) {
              if (!lightbox || !lightboxImg) return;
              if (!imageThumbIndices.length) return;
              if (imageIdx < 0) imageIdx = imageThumbIndices.length - 1;
              if (imageIdx >= imageThumbIndices.length) imageIdx = 0;
              lightboxImageIdx = imageIdx;
              var thumb = thumbs[imageThumbIndices[imageIdx]];
              var src = thumb && thumb.getAttribute('data-src');
              if (!src) return;
              lightboxImg.setAttribute('src', src);
              lightboxImg.setAttribute('alt', (mainImg && mainImg.getAttribute('alt')) || '');
              updateLightboxCounter();
              /* Sync également l'image principale + thumb actif */
              setIndex(imageThumbIndices[imageIdx]);
            }

            function openLightbox() {
              if (!lightbox || !mainImg || mainImg.classList.contains('hidden')) return;
              /* Trouver l'index image courant dans imageThumbIndices */
              var pos = imageThumbIndices.indexOf(currentIndex);
              if (pos < 0) pos = 0;
              showLightboxAt(pos);
              lightbox.classList.remove('hidden');
              lightbox.classList.add('flex');
              lightbox.setAttribute('aria-hidden', 'false');
              document.body.style.overflow = 'hidden';
              if (lightboxPrev) lightboxPrev.classList.toggle('hidden', imageThumbIndices.length <= 1);
              if (lightboxNext) lightboxNext.classList.toggle('hidden', imageThumbIndices.length <= 1);
              try { lightbox.focus(); } catch (e) {}
            }

            function closeLightbox() {
              if (!lightbox) return;
              lightbox.classList.add('hidden');
              lightbox.classList.remove('flex');
              lightbox.setAttribute('aria-hidden', 'true');
              document.body.style.overflow = '';
            }

            if (lightbox && mainImg) {
              mainImg.addEventListener('click', openLightbox);

              if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
              if (lightboxPrev) lightboxPrev.addEventListener('click', function () { showLightboxAt(lightboxImageIdx - 1); });
              if (lightboxNext) lightboxNext.addEventListener('click', function () { showLightboxAt(lightboxImageIdx + 1); });

              /* Clic sur l'overlay (pas sur l'image ou les boutons) → fermer */
              lightbox.addEventListener('click', function (e) {
                if (e.target === lightbox) closeLightbox();
              });
            }

            document.addEventListener('keydown', function (e) {
              if (!e) return;
              if (e.altKey || e.ctrlKey || e.metaKey) return;
              var lightboxOpen = lightbox && !lightbox.classList.contains('hidden');

              if (lightboxOpen) {
                if (e.key === 'Escape') { e.preventDefault(); closeLightbox(); return; }
                if (e.key === 'ArrowLeft') { e.preventDefault(); showLightboxAt(lightboxImageIdx - 1); return; }
                if (e.key === 'ArrowRight') { e.preventDefault(); showLightboxAt(lightboxImageIdx + 1); return; }
                return;
              }

              var tag = (e.target && e.target.tagName) ? String(e.target.tagName).toLowerCase() : '';
              if (tag === 'input' || tag === 'textarea' || tag === 'select') return;

              if (e.key === 'ArrowLeft') {
                setIndex(currentIndex - 1);
              }
              if (e.key === 'ArrowRight') {
                setIndex(currentIndex + 1);
              }
            });

            setIndex(0);
          }

          if (optionInputs && optionInputs.length) {
            optionInputs.forEach(function (el) {
              el.addEventListener('change', syncDisplayedPrice);
              el.addEventListener('input', syncDisplayedPrice);
              el.addEventListener('change', syncExchangeStandardPanel);
              el.addEventListener('input', syncExchangeStandardPanel);
            });
          }

          /* On retire window.CPFCartFeedback du gate : il est défini dans
             footer.ejs qui est inclus APRÈS ce script, donc undefined au
             parse-time → le listener ne s'attachait pas → form submit natif
             → reload de page → add_to_cart perdu. CPFCartFeedback est
             utilisé seulement DANS le handler, lazily. */
          if (addToCartForm && addToCartSubmit && window.fetch && window.FormData) {
            addToCartForm.addEventListener('submit', function (event) {
              if (addToCartPending) {
                event.preventDefault();
                return;
              }

              event.preventDefault();
              addToCartPending = true;
              addToCartSubmit.disabled = true;

              var startedAt = Date.now();
              var formData = new URLSearchParams(new FormData(addToCartForm));

              fetch(addToCartForm.getAttribute('action'), {
                method: 'POST',
                body: formData,
                credentials: 'same-origin',
                headers: {
                  'Accept': 'application/json',
                  'X-Requested-With': 'XMLHttpRequest',
                  'Content-Type': 'application/x-www-form-urlencoded'
                }
              })
                .then(function (response) {
                  return response.json().catch(function () {
                    return null;
                  }).then(function (data) {
                    if (!response.ok || !data || data.ok !== true) {
                      throw new Error(data && data.error ? data.error : 'Impossible d’ajouter le produit au panier pour le moment.');
                    }
                    return data;
                  });
                })
                .then(function (data) {
                  var payload = data && typeof data === 'object' ? data : {};
                  var productData = payload.product && typeof payload.product === 'object' ? payload.product : {};

                  /* GA4 add_to_cart : déléguer à window.GA4Ecommerce.trackAddToCart()
                     qui dédup en interne. Le click capture-phase l'a déjà appelé,
                     donc cet appel sera no-op (dédup 1500ms). On l'appelle quand
                     même comme filet de sécurité au cas où le click serait raté. */
                  if (window.GA4Ecommerce && typeof window.GA4Ecommerce.trackAddToCart === 'function') {
                    try { window.GA4Ecommerce.trackAddToCart(addToCartForm); } catch (e) {}
                  }

                  if (window.CPFCartFeedback && typeof window.CPFCartFeedback.notifyAdded === 'function') {
                    window.CPFCartFeedback.notifyAdded({
                      cartItemCount: payload.cartItemCount,
                      productName: productData.name || addToCartForm.getAttribute('data-product-name') || 'Produit',
                      imageUrl: productData.imageUrl || addToCartForm.getAttribute('data-product-image') || ''
                    });
                  }

                  setAddToCartSuccessState();

                  var minDisableRemaining = Math.max(0, 1000 - (Date.now() - startedAt));
                  window.setTimeout(function () {
                    scheduleAddToCartReset(2000);
                  }, minDisableRemaining);
                })
                .catch(function (err) {
                  var minDisableRemaining = Math.max(0, 1000 - (Date.now() - startedAt));
                  if (window.CPFCartFeedback && typeof window.CPFCartFeedback.notifyError === 'function') {
                    window.CPFCartFeedback.notifyError(err && err.message ? err.message : 'Impossible d’ajouter le produit au panier pour le moment.');
                  }
                  window.setTimeout(function () {
                    resetAddToCartButton();
                    addToCartPending = false;
                  }, minDisableRemaining);
                });
            });
          }

          setQty(getQty());
          syncDisplayedPrice();
          syncExchangeStandardPanel();
        })();
      </script>
    <% } %>
  </div>

  <!-- Sticky Add-to-Cart bar (mobile only) — populated by JS -->
  <div class="fixed bottom-[85px] left-0 right-0 z-40 md:hidden transition-all duration-300 opacity-0 pointer-events-none" data-sticky-atc id="stickyAtcBar" style="display:none">
    <div class="mx-3 mb-2 flex items-center gap-3 rounded-2xl border border-slate-200 bg-white/95 backdrop-blur-sm px-4 py-3 shadow-xl">
      <div class="flex flex-col min-w-0 flex-1">
        <span class="text-xs font-bold text-slate-900 truncate" data-sticky-atc-name></span>
        <span class="text-primary font-black text-sm" data-sticky-atc-price></span>
      </div>
      <button class="shrink-0 bg-primary hover:bg-primary/90 text-white px-5 py-3 rounded-xl font-black text-xs uppercase tracking-wider flex items-center gap-2 shadow-lg shadow-primary/20 transition-all" data-sticky-atc-btn type="button">
        <span class="material-symbols-outlined text-lg">add_shopping_cart</span>
        <%= t('product.addShort') %>
      </button>
    </div>
  </div>

  <!-- Sticky Add-to-Cart bar (desktop only, ≥ md) — slides down from top sous le header -->
  <div class="hidden md:block fixed top-[64px] left-0 right-0 z-40 -translate-y-[calc(100%+64px)] transition-transform duration-300 ease-out" data-sticky-atc-desktop id="stickyAtcBarDesktop">
    <div class="bg-white/98 backdrop-blur-md border-b border-slate-200 shadow-lg shadow-slate-900/5">
      <div class="mx-auto max-w-[1440px] px-4 md:px-10 py-3 flex items-center gap-4">
        <!-- Image produit miniature -->
        <div class="h-14 w-14 rounded-lg overflow-hidden bg-slate-100 shrink-0 ring-1 ring-slate-200">
          <img alt="" class="h-full w-full object-cover" data-sticky-atc-desktop-img loading="lazy" />
        </div>

        <!-- Nom + prix -->
        <div class="flex flex-col min-w-0 flex-1">
          <span class="text-[13px] md:text-sm font-bold text-slate-900 truncate leading-tight" data-sticky-atc-desktop-name></span>
          <div class="flex items-baseline gap-2 mt-0.5">
            <span class="text-primary font-black text-lg" data-sticky-atc-desktop-price></span>
          </div>
        </div>

        <!-- Indicateurs de réassurance (lg+) -->
        <div class="hidden xl:flex items-center gap-5 text-xs font-semibold text-slate-600 shrink-0 mr-2">
          <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-base text-emerald-600">local_shipping</span>
            <%= (product && product.shippingDelayText && String(product.shippingDelayText).trim()) ? String(product.shippingDelayText).trim() : t('product.fastDeliveryShort') %>
          </span>
          <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-base text-emerald-600">verified</span>
            <%# Calculé inline depuis product.warranty (local de rendu accessible ici,
                contrairement à keyGarantie qui est hors portée dans cette barre). %>
            <% var _stickyWm = (product.warranty && Number(product.warranty.months) > 0) ? Number(product.warranty.months) : 0; %>
            <%= _stickyWm ? t('product.warrantyMonths', { months: _stickyWm }) : t('product.warrantyIncl') %>
          </span>
          <%# Badge 3× : affiché seulement si éligible (≤ 2000€). Variables du haut hors portée dans cette barre → recalcul inline depuis product. %>
          <% var _stickyPrice = Number(product.priceCents) || 0; %>
          <% if (_stickyPrice >= 10000 && _stickyPrice <= 200000) { %>
          <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-base text-emerald-600">payments</span>
            3× sans frais
          </span>
          <% } %>
        </div>

        <!-- CTA -->
        <button class="shrink-0 bg-primary hover:bg-primary/90 active:bg-primary/95 text-white px-6 py-3 rounded-xl font-black text-sm uppercase tracking-wider flex items-center gap-2 shadow-lg shadow-primary/30 transition-all hover:shadow-xl hover:shadow-primary/40 hover:scale-[1.02]" data-sticky-atc-desktop-btn type="button">
          <span class="material-symbols-outlined text-lg">add_shopping_cart</span>
          <%= t('product.addToCart') %>
        </button>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var stickyBar = document.querySelector('[data-sticky-atc]');
      var stickyBarDesktop = document.querySelector('[data-sticky-atc-desktop]');
      var realBtn = document.querySelector('[data-add-to-cart-submit]');
      var stickyBtn = document.querySelector('[data-sticky-atc-btn]');
      var stickyBtnDesktop = document.querySelector('[data-sticky-atc-desktop-btn]');
      if (!stickyBar || !realBtn) return;

      /* Populate name & price from existing DOM (les 2 barres partagent les sources) */
      var h1 = document.querySelector('h1');
      var priceEl = document.querySelector('[data-price-display]');
      var priceHtEl = document.querySelector('[data-price-display-ht]'); // si présent → prix HT mis en avant
      // Prix affiché dans la barre sticky : HT en avant si TVA récupérable, sinon TTC.
      // L'unité (HT / TTC) est portée par la chaîne elle-même → pas de label statique.
      function currentStickyPrice() {
        if (priceHtEl) return priceHtEl.textContent.trim() + ' € HT';
        var ttc = (priceEl && priceEl.textContent.trim()) || '';
        return ttc ? (ttc + ' TTC') : '';
      }
      var addToCartForm = document.querySelector('[data-add-to-cart-form]');
      var productName = (h1 && h1.textContent.trim())
        || (addToCartForm && addToCartForm.getAttribute('data-product-name'))
        || '';
      var productImage = (addToCartForm && addToCartForm.getAttribute('data-product-image'))
        || (function () {
            var m = document.querySelector('[data-main-image]');
            return m && m.src ? m.src : '';
          })();
      var productPrice = currentStickyPrice();

      var nameSpan = stickyBar.querySelector('[data-sticky-atc-name]');
      var priceSpan = stickyBar.querySelector('[data-sticky-atc-price]');
      if (nameSpan) nameSpan.textContent = productName;
      if (priceSpan) priceSpan.textContent = productPrice;

      stickyBar.style.display = '';

      /* Populate desktop sticky bar */
      if (stickyBarDesktop) {
        var nameSpanD = stickyBarDesktop.querySelector('[data-sticky-atc-desktop-name]');
        var priceSpanD = stickyBarDesktop.querySelector('[data-sticky-atc-desktop-price]');
        var imgD = stickyBarDesktop.querySelector('[data-sticky-atc-desktop-img]');
        if (nameSpanD) nameSpanD.textContent = productName;
        if (priceSpanD) priceSpanD.textContent = productPrice;
        if (imgD && productImage) {
          imgD.src = productImage;
          imgD.alt = productName;
        }

        /* Sync prix dynamique : si l'utilisateur change une option qui modifie le prix,
         * le bouton sticky desktop reflète la nouvelle valeur. */
        var priceObserved = priceHtEl || priceEl;
        if (priceObserved && typeof MutationObserver !== 'undefined') {
          var priceMo = new MutationObserver(function () {
            var newPrice = currentStickyPrice();
            if (priceSpan) priceSpan.textContent = newPrice;
            if (priceSpanD) priceSpanD.textContent = newPrice;
          });
          priceMo.observe(priceObserved, { childList: true, characterData: true, subtree: true });
        }
      }

      /* Show custom validation error for missing required options */
      function showOptionError(form) {
        var firstInvalid = form.querySelector(':invalid');
        if (!firstInvalid) return false;

        /* Find the parent option group */
        var group = firstInvalid.closest('.refined-shadow') || firstInvalid.closest('.rounded-xl');
        if (!group) { form.reportValidity(); return true; }

        /* Scroll to the group */
        group.scrollIntoView({ behavior: 'smooth', block: 'center' });

        /* Add error ring */
        group.classList.add('ring-2', 'ring-red-500', 'ring-offset-2');

        /* Remove any existing error message in this group */
        var existing = group.querySelector('[data-option-error]');
        if (existing) existing.remove();

        /* Get option label */
        var labelEl = group.querySelector('.uppercase.tracking-tight');
        var optionName = labelEl ? labelEl.textContent.trim() : 'une option';

        /* Insert custom error message */
        var errorDiv = document.createElement('div');
        errorDiv.setAttribute('data-option-error', '');
        errorDiv.className = 'mt-3 flex items-center gap-2 rounded-lg bg-red-50 border border-red-200 px-3 py-2.5 text-red-700 text-sm font-semibold animate-pulse';
        errorDiv.innerHTML = '<span class="material-symbols-outlined text-base">error</span> Veuillez sélectionner : ' + optionName;
        group.appendChild(errorDiv);

        /* Auto-cleanup after 4s */
        setTimeout(function() {
          group.classList.remove('ring-2', 'ring-red-500', 'ring-offset-2');
          if (errorDiv.parentNode) {
            errorDiv.style.transition = 'opacity 0.3s';
            errorDiv.style.opacity = '0';
            setTimeout(function() { errorDiv.remove(); }, 300);
          }
        }, 4000);

        /* Remove error on selection */
        var inputs = group.querySelectorAll('input, select');
        inputs.forEach(function(input) {
          input.addEventListener('change', function handler() {
            group.classList.remove('ring-2', 'ring-red-500', 'ring-offset-2');
            if (errorDiv.parentNode) errorDiv.remove();
            input.removeEventListener('change', handler);
          });
        });

        return true;
      }

      /* Click on sticky → check options then submit or scroll to options.
       * Même comportement pour mobile et desktop. */
      function handleStickyClick() {
        var form = realBtn.closest('form');
        if (form && !form.checkValidity()) {
          showOptionError(form);
          return;
        }
        realBtn.click();
      }

      if (stickyBtn) stickyBtn.addEventListener('click', handleStickyClick);
      if (stickyBtnDesktop) stickyBtnDesktop.addEventListener('click', handleStickyClick);

      /* Also intercept the real submit button for consistent error UX */
      realBtn.addEventListener('click', function(e) {
        var form = realBtn.closest('form');
        if (form && !form.checkValidity()) {
          e.preventDefault();
          showOptionError(form);
        }
      });

      /* Show/hide sticky bars (mobile + desktop) based on real button visibility */
      var visible = false;
      var observer = new IntersectionObserver(function(entries) {
        var isInView = entries[0].isIntersecting;
        if (!isInView && !visible) {
          // Mobile : fade in
          stickyBar.classList.remove('opacity-0', 'pointer-events-none');
          stickyBar.classList.add('opacity-100', 'pointer-events-auto');
          // Desktop : slide down
          if (stickyBarDesktop) {
            stickyBarDesktop.classList.remove('-translate-y-[calc(100%+64px)]');
            stickyBarDesktop.classList.add('translate-y-0');
          }
          visible = true;
        } else if (isInView && visible) {
          stickyBar.classList.remove('opacity-100', 'pointer-events-auto');
          stickyBar.classList.add('opacity-0', 'pointer-events-none');
          if (stickyBarDesktop) {
            stickyBarDesktop.classList.remove('translate-y-0');
            stickyBarDesktop.classList.add('-translate-y-[calc(100%+64px)]');
          }
          visible = false;
        }
      }, { threshold: 0 });

      observer.observe(realBtn);
    })();
  </script>

  <!-- Description read-more collapse (mobile only) -->
  <script>
    (function() {
      var wrapper = document.querySelector('[data-desc-collapse]');
      if (!wrapper) return;
      var inner = wrapper.querySelector('[data-desc-collapse-inner]');
      var fade = wrapper.querySelector('[data-desc-fade]');
      var toggleBtn = wrapper.querySelector('[data-desc-toggle]');
      var toggleLabel = wrapper.querySelector('[data-desc-toggle-label]');
      var toggleIcon = wrapper.querySelector('[data-desc-toggle-icon]');
      if (!inner || !fade || !toggleBtn) return;

      var THRESHOLD = 250; /* px - only collapse if taller than this */
      var expanded = false;
      var userToggled = false; /* true once user clicks — prevents resize from re-collapsing */

      function checkSize() {
        if (userToggled) return; /* respect user's explicit choice */
        var isMobile = window.innerWidth < 768;
        var naturalHeight = inner.scrollHeight;

        if (isMobile && naturalHeight > THRESHOLD) {
          inner.classList.add('is-collapsed');
          inner.classList.remove('is-expanded');
          fade.classList.remove('hidden');
          expanded = false;
          if (toggleLabel) toggleLabel.textContent = 'Lire la suite';
          if (toggleIcon) toggleIcon.style.transform = '';
        } else {
          inner.classList.remove('is-collapsed');
          inner.classList.add('is-expanded');
          fade.classList.add('hidden');
        }
      }

      toggleBtn.addEventListener('click', function() {
        expanded = !expanded;
        userToggled = true;
        if (expanded) {
          inner.classList.remove('is-collapsed');
          inner.classList.add('is-expanded');
          fade.classList.add('hidden');
          if (toggleLabel) toggleLabel.textContent = 'Réduire';
          if (toggleIcon) toggleIcon.style.transform = 'rotate(180deg)';
        } else {
          inner.classList.add('is-collapsed');
          inner.classList.remove('is-expanded');
          fade.classList.remove('hidden');
          if (toggleLabel) toggleLabel.textContent = 'Lire la suite';
          if (toggleIcon) toggleIcon.style.transform = '';
          wrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      checkSize();
      window.addEventListener('resize', checkSize);
    })();
  </script>

  <%/* Maillage interne fiche produit : parentVehicleLandings + parentCategory.
       Donne à Google des signaux clairs sur la place du produit dans la taxonomie. */%>
  <% if (typeof productLinking !== 'undefined' && productLinking
        && (
          (Array.isArray(productLinking.parentVehicleLandings) && productLinking.parentVehicleLandings.length > 0)
          || productLinking.parentCategory
        )) { %>
    <section class="seo-internal-linking" style="background:#fff;border-top:1px solid #e9ecef;">
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-10 sm:py-14 space-y-12 sm:space-y-16">

        <% if (Array.isArray(productLinking.parentVehicleLandings) && productLinking.parentVehicleLandings.length > 0) { %>
          <div>
            <div class="mb-4 sm:mb-6">
              <h2 class="text-xl sm:text-3xl home-display font-bold"><%= t('product.seeAllCompat') %></h2>
              <% var _vlWm = (product.warranty && Number(product.warranty.months) > 0) ? Number(product.warranty.months) : 0; %>
              <p class="text-slate-500 text-sm mt-1"><%= t('product.specificParts') %><%= _vlWm ? t('product.specificPartsWarranty', { months: _vlWm }) : '' %></p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
              <% for (const v of productLinking.parentVehicleLandings) { %>
                <a href="<%= v.url %>"
                   class="group flex items-center justify-between gap-3 px-5 py-5 bg-gradient-to-br from-primary/5 to-primary/10 rounded-2xl border-2 border-primary/20 hover:border-primary hover:shadow-md hover:shadow-red-500/20 transition-all">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="shrink-0 w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                      <span class="material-symbols-rounded text-2xl">directions_car</span>
                    </span>
                    <div class="flex flex-col min-w-0">
                      <span class="text-base font-black text-primary truncate">
                        <%= v.makeName %><% if (v.modelName) { %> <%= v.modelName %><% } %>
                      </span>
                      <span class="text-xs text-slate-500"><%= t('product.fullCatalog') %></span>
                    </div>
                  </div>
                  <span class="shrink-0 material-symbols-rounded text-primary group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </a>
              <% } %>
            </div>
          </div>
        <% } %>

        <% if (productLinking.parentCategory) { %>
          <div>
            <div class="mb-4 sm:mb-6">
              <h2 class="text-xl sm:text-3xl home-display font-bold"><%= t('product.exploreCategory') %></h2>
              <p class="text-slate-500 text-sm mt-1"><%= t('product.allCategoryParts') %></p>
            </div>
            <a href="<%= productLinking.parentCategory.url %>"
               class="group inline-flex items-center gap-3 px-5 py-4 bg-white rounded-2xl border border-slate-200/80 hover:border-primary hover:shadow-md hover:shadow-red-500/10 transition-all">
              <span class="shrink-0 w-10 h-10 rounded-xl bg-slate-100 text-slate-500 group-hover:bg-primary/10 group-hover:text-primary flex items-center justify-center transition-colors">
                <span class="material-symbols-rounded text-xl">category</span>
              </span>
              <span class="text-sm font-bold text-slate-800 group-hover:text-primary"><%= productLinking.parentCategory.name %></span>
              <span class="material-symbols-rounded text-base text-slate-300 group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_forward</span>
            </a>
          </div>
        <% } %>

      </div>
    </section>
  <% } %>
</main>

<% if (product) { %>
<% /* _ga4Brand est défini dans le else-block plus haut, donc hors-scope ici. On
     recompose localement pour éviter ReferenceError. */ %>
<% const _ga4BrandFooter = ((product.brand && String(product.brand).trim())
  || (Array.isArray(product.compatibility) && product.compatibility[0] && product.compatibility[0].make)
  || ''); %>
<% const _ga4ViewItem = JSON.stringify({
  event: 'view_item',
  ecommerce: {
    currency: 'EUR',
    value: Math.round(Number(product.priceCents) || 0) / 100,
    items: [{
      item_id: String(product.sku || product._id || ''),
      item_name: String(product.name || ''),
      item_category: String(product.category || ''),
      item_brand: String(_ga4BrandFooter),
      price: Math.round(Number(product.priceCents) || 0) / 100,
      quantity: 1,
    }],
  },
}).replace(/</g, '\\u003c'); %>
<script>
(function () {
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ ecommerce: null });
  window.dataLayer.push(<%- _ga4ViewItem %>);
})();
</script>
<% } %>

<%- include('../partials/footer') %>
