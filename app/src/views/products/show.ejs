          .pp-scene { aspect-ratio: 4 / 3.4; border-radius: 18px; }
          .pp-reassure, .pp-steps, .pp-related, .pp-blog, .pp-links { grid-template-columns: 1fr; }
          .pp-optcards { grid-template-columns: 1fr; }
          .pp-meta { gap: 14px; }
