      </style>

      <div class="pp-page">

      <nav class="pp-crumb" aria-label="Fil d'Ariane">
        <a href="/"><%= t('breadcrumb.home') %></a>
        <span class="sep">›</span>
        <a href="/produits"><%= t('breadcrumb.catalog') %></a>
        <% if (typeof categoryUrl !== 'undefined' && categoryUrl && typeof categoryName !== 'undefined' && categoryName) { %>
          <% const catParts = categoryName.split(/\s*>\s*/); %>
          <% catParts.forEach((part, i) => { %>
            <span class="sep">›</span>
            <% if (i === catParts.length - 1) { %>
              <a href="<%= categoryUrl %>"><%= part %></a>
            <% } else { %>
              <span><%= part %></span>
            <% } %>
          <% }) %>
        <% } %>
        <span class="sep">›</span>
        <span class="cur"><%= product.name %></span>
      </nav>

      <div class="pp-hero">

        <%# ═══ Colonne galerie ═══ %>
        <div>
          <div class="pp-scene">
            <% if (mainMediaItem) { %>
              <% const _isMainVideo = mainMediaItem.type === 'video'; %>
              <% const _isMainEmbed = mainMediaItem.type === 'embed'; %>
              <img alt="<%= product.name %> — photo principale" class="cursor-zoom-in<%= (_isMainVideo || _isMainEmbed) ? ' hidden' : '' %>" data-main-image decoding="async" loading="eager" fetchpriority="high" width="800" height="768" <% if (!_isMainVideo && !_isMainEmbed) { %>src="<%= mainImage %>"<% } %> style="cursor: zoom-in;" />
              <video class="<%= _isMainVideo ? '' : 'hidden' %>" data-main-video controls preload="metadata" playsinline<% if (_isMainVideo) { %> src="<%= mainImage %>"<% } %>></video>
              <iframe class="absolute inset-0 w-full h-full<%= _isMainEmbed ? '' : ' hidden' %>" style="position:absolute;inset:0;width:100%;height:100%;" data-main-embed title="<%= product.name %> — vidéo" loading="lazy" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen<% if (_isMainEmbed) { %> src="<%= mainMediaItem.embedUrl %>"<% } %>></iframe>
            <% } else if (isService) { %>
              <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;background:linear-gradient(135deg,#F7F8FA,#EEF0F4);">
                <span class="material-symbols-outlined" style="font-size:64px;color:#E02128B0;">memory</span>
                <span style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#8A909E;"><%= t('product.serviceRemote') %></span>
                <span style="font-size:14px;font-weight:700;color:#3C4354;text-align:center;padding:0 24px;max-width:420px;"><%= t('product.cloningService') %><br/><%= t('product.dsgChrono') %></span>
              </div>
            <% } else { %>
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#A6ACBB;">
                <span class="material-symbols-outlined" style="font-size:56px;">inventory_2</span>
              </div>
            <% } %>

            <div class="pp-scene-grad"></div>

            <% if (_showIso && mainMediaItem) { %>
              <div class="pp-scene-badge">
                <span class="material-symbols-outlined" style="font-size:15px;color:#7EE2A8;">verified</span>
                <%= t('product.benchTested') %>
              </div>
            <% } %>

            <% if (visibleThumbItems.length > 1) { %>
              <div class="pp-thumbs">
                <% visibleThumbItems.forEach((item, idx) => { %>
                  <% const _isThumbVideo = item.type === 'video'; %>
                  <% const _isThumbEmbed = item.type === 'embed'; %>
                  <button aria-label="Voir <%= (_isThumbVideo || _isThumbEmbed) ? 'la vidéo' : 'l\'image' %> <%= idx + 1 %>" class="pp-thumb border <%= idx === 0 ? 'border-primary/20 ring-2 ring-primary' : 'border-slate-200 dark:border-slate-700' %>" data-thumb data-index="<%= idx %>" data-src="<%= item.url %>" data-type="<%= item.type %>"<% if (_isThumbEmbed) { %> data-embed-src="<%= item.embedUrl %>"<% } %> type="button">
                    <% if (_isThumbEmbed) { %>
                      <% if (item.poster) { %>
                        <img alt="<%= product.name %> — vidéo" decoding="async" loading="lazy" width="120" height="120" src="<%= item.poster %>" />
                      <% } else { %>
                        <span style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#131B2E;border-radius:9px;"><span class="material-symbols-outlined" style="color:#fff;font-size:20px;">smart_display</span></span>
                      <% } %>
                      <span style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;"><span style="background:rgba(0,0,0,0.6);color:#fff;border-radius:999px;padding:4px;display:flex;"><span class="material-symbols-outlined" style="font-size:14px;">play_arrow</span></span></span>
                    <% } else if (_isThumbVideo) { %>
                      <video muted playsinline preload="metadata"><source src="<%= item.url %>" /></video>
                      <span style="position:absolute;bottom:4px;left:4px;background:rgba(0,0,0,0.7);color:#fff;border-radius:999px;padding:3px;display:flex;"><span class="material-symbols-outlined" style="font-size:12px;">play_arrow</span></span>
                    <% } else { %>
                      <img alt="<%= product.name %> — vue <%= idx + 1 %>" decoding="async" loading="lazy" width="120" height="120" src="<%= item.url %>" />
                    <% } %>
                    <% if (!_isThumbEmbed && idx === _lastImageThumbIdx && _hiddenThumbCount > 0) { %>
                      <span style="position:absolute;inset:2px;border-radius:9px;background:rgba(19,27,46,0.6);display:flex;align-items:center;justify-content:center;color:#fff;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.05em;"><%= t('product.moreImages', { count: _hiddenThumbCount }) %></span>
                    <% } %>
                  </button>
                <% }) %>
              </div>
            <% } %>

            <% if (images.length > 1) { %>
              <button aria-label="Image précédente" class="pp-navbtn prev" data-gallery-prev type="button"><span class="material-symbols-outlined" style="font-size:20px;color:#131B2E;">chevron_left</span></button>
              <button aria-label="Image suivante" class="pp-navbtn next" data-gallery-next type="button"><span class="material-symbols-outlined" style="font-size:20px;color:#131B2E;">chevron_right</span></button>
            <% } %>

            <% if (mainMediaItem && mainMediaItem.type === 'image') { %>
              <button aria-label="Agrandir l'image" class="pp-zoombtn" data-pp-zoom type="button"><span class="material-symbols-outlined" style="font-size:21px;color:#131B2E;">zoom_in</span></button>
            <% } %>
          </div>

          <% if (mediaItems.length) { %>
            <div class="pp-caption">
              <span class="material-symbols-outlined" style="font-size:16px;">photo_camera</span>
              <%= t('product.realPhotos') %>
              <span class="pp-mono" style="margin-left:auto;font-size:12px;color:#A6ACBB;flex-shrink:0;">1 / <%= mediaItems.length %></span>
            </div>
          <% } %>

          <%# Lightbox — hooks identiques (script principal inchangé) %>
          <div aria-hidden="true" aria-label="Image agrandie" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm p-4 sm:p-8" style="position:fixed;inset:0;z-index:100;background:rgba(11,15,26,0.85);backdrop-filter:blur(8px);padding:32px;" data-lightbox role="dialog" tabindex="-1">
            <button aria-label="Fermer" class="absolute top-4 right-4 z-10" style="position:absolute;top:18px;right:18px;z-index:10;width:44px;height:44px;border-radius:999px;border:none;background:rgba(255,255,255,0.14);cursor:pointer;display:flex;align-items:center;justify-content:center;" data-lightbox-close type="button">
              <span class="material-symbols-outlined" style="color:#fff;font-size:22px;">close</span>
            </button>
            <button aria-label="Image précédente" class="hidden" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);z-index:10;width:44px;height:44px;border-radius:999px;border:none;background:rgba(255,255,255,0.14);cursor:pointer;align-items:center;justify-content:center;display:flex;" data-lightbox-prev type="button">
              <span class="material-symbols-outlined" style="color:#fff;">chevron_left</span>
            </button>
            <button aria-label="Image suivante" class="hidden" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);z-index:10;width:44px;height:44px;border-radius:999px;border:none;background:rgba(255,255,255,0.14);cursor:pointer;align-items:center;justify-content:center;display:flex;" data-lightbox-next type="button">
              <span class="material-symbols-outlined" style="color:#fff;">chevron_right</span>
            </button>
            <img alt="<%= product.name %>" style="max-width:100%;max-height:100%;object-fit:contain;border-radius:18px;box-shadow:0 30px 80px rgba(0,0,0,0.45);user-select:none;" data-lightbox-img />
            <div class="hidden" style="position:absolute;bottom:16px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.8);font-size:12px;font-weight:600;letter-spacing:0.05em;" data-lightbox-counter></div>
          </div>

          <% hiddenThumbItems.forEach((item, idx) => { %>
            <button class="hidden" data-thumb data-index="<%= idx + 4 %>" data-src="<%= item.url %>" data-type="<%= item.type %>"<% if (item.type === 'embed') { %> data-embed-src="<%= item.embedUrl %>"<% } %> type="button"></button>
          <% }) %>

          <% if (hasVideo && !_galleryVideoEmbed) { %>
            <div style="margin-top:12px;">
              <a class="pp-telbtn" href="<%= product.media.videoUrl %>" rel="noreferrer" target="_blank">
                <span class="material-symbols-outlined" style="font-size:18px;color:#E02128;">play_circle</span>
                <%= t('product.watchVideo') %>
              </a>
            </div>
          <% } %>
        </div>

        <%# ═══ Colonne panneau d'achat ═══ %>
        <div>
          <div class="pp-statebadge"><span class="dot"></span><%= heroBadge %></div>
          <h1 class="pp-h1"><%= product.name %></h1>

          <div class="pp-meta">
            <% if (engineCodeVal) { %>
              <div style="min-width:0;">
                <div class="pp-meta-k"><%= _codeLabel %></div>
                <div class="pp-meta-v pp-mono"><%= engineCodeVal %></div>
              </div>
              <div class="sep"></div>
            <% } %>
            <div style="min-width:0;overflow:hidden;">
              <div class="pp-meta-k"><%= t('product.specRef') %></div>
              <div class="pp-meta-v pp-mono" style="overflow:hidden;text-overflow:ellipsis;"><%= ref %></div>
            </div>
            <% if (vehicleCount > 0) { %>
              <div class="sep"></div>
              <div style="min-width:0;">
                <div class="pp-meta-k"><%= t('product.compatLabel') %></div>
                <a class="pp-meta-link" href="#compat"><%= vehicleCount %> <%= t('product.vehiclesWord') %><span class="material-symbols-outlined" style="font-size:14px;color:#E02128;">south</span></a>
              </div>
            <% } %>
          </div>

          <form action="/panier/ajouter/<%= product._id %>" data-add-to-cart-form data-product-id="<%= product._id %>" data-product-sku="<%= product.sku || product._id %>" data-product-image="<%= mainImage %>" data-product-name="<%= product.name %>" data-product-category="<%= product.category || '' %>" data-product-brand="<%= _ga4Brand %>" data-product-price-cents="<%= basePriceCents %>" method="POST">
            <input name="returnTo" type="hidden" value="<%= typeof returnTo !== 'undefined' ? returnTo : '/panier' %>" />
            <input data-qty-input name="qty" type="hidden" value="1" />

            <% if (optionGroups && optionGroups.length) { %>
              <% optionGroups.forEach((g) => { %>
                <% const gKey = g && g.key ? String(g.key) : ''; %>
                <% if (!gKey) return; %>
                <% const fieldName = 'opt_' + gKey; %>
                <% const groupLabel = g && g.label ? g.label : gKey; %>
                <% const isSupplyModeGroup = normalizeLoose(groupLabel).includes('mode-de-fourniture'); %>
                <% const choices = Array.isArray(g && g.choices) ? g.choices : []; %>

                <div class="pp-optgroup rounded-xl">
                  <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;">
                    <span class="pp-optlabel uppercase tracking-tight"><%= groupLabel %></span>
                    <% if (g && g.required) { %><span style="font-size:10px;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;color:#E02128;"><%= t('product.required') %></span><% } %>
                  </div>
                  <% if (g && g.helpText) { %><div style="font-size:12px;color:#8A909E;margin-top:2px;"><%= g.helpText %></div><% } %>

                  <% if (g && String(g.type) === 'text') { %>
                    <input
                      class="pp-opttext"
                      type="text"
                      name="<%= fieldName %>"
                      placeholder="<%= g && g.placeholder ? g.placeholder : '' %>"
                      <%= g && g.required ? 'required' : '' %>
                      data-option-input
                      data-option-type="text"
                      data-price-delta-cents="<%= Number(g.priceDeltaCents) || 0 %>"
                    />
                  <% } else if (choices.length) { %>
                    <div class="pp-optcards<%= choices.length === 1 ? ' single' : '' %>">
                      <% choices.forEach((c) => { %>
                        <% const cKey = c && c.key ? String(c.key) : ''; %>
                        <% const cAbsoluteRaw = c && c.absolutePriceCents !== null && typeof c.absolutePriceCents !== 'undefined' ? String(c.absolutePriceCents).trim() : ''; %>
                        <% const hasAbsolutePrice = cAbsoluteRaw !== '' && Number.isFinite(Number(cAbsoluteRaw)) && Number(cAbsoluteRaw) >= 0; %>
                        <% if (!cKey) return; %>
                        <label class="pp-optcard">
                          <input
                            type="radio"
                            name="<%= fieldName %>"
                            value="<%= cKey %>"
                            <%= g && g.required ? 'required' : '' %>
                            data-option-input
                            data-option-type="choice"
                            data-absolute-price-cents="<%= hasAbsolutePrice ? Number(cAbsoluteRaw) : '' %>"
                            data-price-delta-cents="<%= Number(c.priceDeltaCents) || 0 %>"
                            <%- isSupplyModeGroup ? (' data-supply-mode-choice="' + normalizeLoose(c && c.label ? c.label : cKey) + '"') : '' %>
                          />
                          <span class="chk"><span class="material-symbols-outlined">check</span></span>
                          <span class="ttl"><%= c && c.label ? c.label : cKey %></span>
                          <% if (hasAbsolutePrice) { %>
                            <span class="prc"><%= formatMoney(c.absolutePriceCents) %> €</span>
                          <% } else if (Number(c && c.priceDeltaCents) > 0) { %>
                            <span class="prc">+ <%= formatMoney(c.priceDeltaCents) %> €</span>
                          <% } else { %>
                            <span class="prc" style="color:#1E9E5A;"><%= t('product.included') %></span>
                          <% } %>
                        </label>
                      <% }) %>
                    </div>
                  <% } %>

                  <% if (isSupplyModeGroup) { %>
                    <div class="pp-exchange hidden" data-exchange-standard-panel>
                      <div style="display:grid;grid-template-columns:1fr;gap:12px;">
                        <div class="step"><span class="material-symbols-outlined" style="color:#E02128;font-size:20px;">inventory_2</span><div><div class="n"><%= t('product.step') %> 1</div><div class="d"><%= t('product.exchangeStep1') %></div></div></div>
                        <div class="step"><span class="material-symbols-outlined" style="color:#E02128;font-size:20px;">build</span><div><div class="n"><%= t('product.step') %> 2</div><div class="d"><%= t('product.exchangeStep2') %></div></div></div>
                        <div class="step"><span class="material-symbols-outlined" style="color:#E02128;font-size:20px;">local_shipping</span><div><div class="n"><%= t('product.step') %> 3</div><div class="d"><%= t('product.exchangeStep3') %></div></div></div>
                      </div>
                      <div style="margin-top:12px;font-size:12px;color:#8A909E;"><% if (consigneUpfront) { %><%- t('product.consigneUpfront', { amount: consigneAmountEuro, days: consigneDelayDays }) %><% } else { %><%- t('product.consigneOnReturn', { days: consigneDelayDays }) %><% } %></div>
                    </div>
                  <% } %>
                </div>
              <% }) %>
            <% } %>

            <div class="pp-pricebox">
              <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:12px;flex-wrap:wrap;">
                <div>
                  <% if (compareAt && compareAt > product.priceCents) { %>
                    <div style="font-size:13px;color:#A6ACBB;text-decoration:line-through;margin-bottom:2px;"><%= formatMoney(compareAt) %> €</div>
                  <% } %>
                  <% if (product.vatRecoverable) { %>
                    <div class="pp-price-main"><span data-price-display-ht><%= formatMoney(Math.round(product.priceCents / 1.2)) %></span>&nbsp;€ <span style="font-size:16px;font-weight:700;"><%= t('product.ht') %></span></div>
                    <div class="pp-price-ht-note" style="margin-top:4px;"><span data-price-display data-base-price-cents="<%= basePriceCents %>" data-installment-count="<%= installmentCount %>" data-installment-min-cents="<%= installmentMinPriceCents %>" data-installment-max-cents="<%= installmentMaxPriceCents %>"><%= formatMoney(product.priceCents) %> €</span> <%= t('product.ttc') %> · <span style="color:#1E9E5A;font-weight:700;"><%= t('product.vatRecoverable') %></span></div>
                  <% } else { %>
                    <div class="pp-price-main"><span data-price-display data-base-price-cents="<%= basePriceCents %>" data-installment-count="<%= installmentCount %>" data-installment-min-cents="<%= installmentMinPriceCents %>" data-installment-max-cents="<%= installmentMaxPriceCents %>"><%= formatMoney(product.priceCents) %> €</span></div>
                    <div class="pp-price-ht-note" style="margin-top:4px;"><%= t('product.publicPrice') %> <%= t('product.ttc') %></div>
                  <% } %>
                </div>
                <span class="pp-stock<%= product.inStock ? '' : ' off' %>"><span class="dot"></span><%= stockLabel %><% if (shippingDelayText) { %> · <%= shippingDelayText %><% } %></span>
              </div>

              <div class="pp-scalapay <%= installmentEligible ? '' : 'hidden' %>" data-installment-wrapper>
                <span class="pp-scalachip"><span class="s">s</span><span style="font-size:13px;font-weight:700;letter-spacing:-0.01em;color:#131B2E;">scalapay</span></span>
                <span style="font-size:12.5px;color:#5B6270;"><%= t('product.installmentPrefix') %> <strong style="color:#131B2E;"><span data-installment-amount><%= formatMoney(installmentAmountCents) %> €</span></strong> <%= t('product.installmentSuffix') %></span>
              </div>

              <div class="pp-qtyrow" style="<%= installmentEligible ? '' : 'margin-top:16px;' %>">
                <div class="pp-stepper">
                  <button data-qty-minus type="button">−</button>
                  <span class="val" data-qty-display>1</span>
                  <button data-qty-plus type="button">+</button>
                </div>
                <button class="pp-cta" data-add-to-cart-submit <%= product.inStock ? '' : 'disabled' %> type="submit">
                  <span class="material-symbols-outlined" style="font-size:20px;" data-add-to-cart-icon>shopping_cart</span>
                  <span data-add-to-cart-label><%= t('product.addToCart') %></span>
                </button>
              </div>

              <p class="pp-consigne<%= hasConsigne ? ' ok' : '' %>"><%= hasConsigne ? (consigneUpfront ? (t('product.consigneRefundShort', { amount: consigneAmountEuro, days: consigneDelayDays })) : (t('product.exchangeNoDeposit', { days: consigneDelayDays }))) : (shippingDelayText || (product.inStock ? t('product.fastDeliveryFr') : t('product.onOrderAvailable'))) %></p>
            </div>
          </form>

          <%# Vérification plaque INLINE (design v3) — poste sur le vrai endpoint lead %>
          <div class="pp-plate" id="pp-plate" data-product-id="<%= product._id %>">
            <button class="pp-plate-head" type="button" data-pp-plate-toggle>
              <span class="material-symbols-outlined" style="font-size:19px;color:#E02128;">verified</span>
              <span class="lbl"><%= t('product.plateVerifyTitle') %></span>
              <span class="free"><%= t('product.freeBadge') %></span>
              <span class="material-symbols-outlined chev">expand_more</span>
            </button>
            <div class="pp-plate-body">
              <div class="note"><%= t('product.plateVerifyNote') %></div>
              <div data-pp-plate-form>
                <div class="pp-plate-inputs">
                  <input class="plate" data-pp-plate placeholder="AA-123-BC" maxlength="16" />
                  <input class="email" type="email" data-pp-email placeholder="<%= t('product.phEmailReq') %>" />
                </div>
                <button class="pp-plate-send" type="button" data-pp-plate-send>
                  <span class="material-symbols-outlined" style="font-size:18px;"><%= 'send' %></span>
                  <%= t('product.plateVerifyCta') %>
                </button>
              </div>
              <div class="pp-plate-ok" data-pp-plate-ok style="display:none;">
                <span class="material-symbols-outlined" style="font-size:19px;color:#1E9E5A;">check_circle</span>
                <div><strong><%= t('product.plateSentTitle') %> <span data-pp-plate-shown></span>.</strong> <%= t('product.plateSentBody') %></div>
              </div>
            </div>
          </div>

          <div class="pp-tel">
            <span class="material-symbols-outlined" style="font-size:18px;color:#8A909E;">support_agent</span>
            <span><%= t('product.anyDoubt') %> <a href="tel:<%= brand.PHONE_INTL %>"><%= brand.PHONE %></a> · <%= t('product.workHours') %></span>
          </div>
        </div>
      </div>

      <script>
        (function () {
          var box = document.getElementById('pp-plate');
          if (!box) return;
          var head = box.querySelector('[data-pp-plate-toggle]');
          var plate = box.querySelector('[data-pp-plate]');
          var email = box.querySelector('[data-pp-email]');
          var send = box.querySelector('[data-pp-plate-send]');
          var form = box.querySelector('[data-pp-plate-form]');
          var ok = box.querySelector('[data-pp-plate-ok]');
          var shown = box.querySelector('[data-pp-plate-shown]');
          head.addEventListener('click', function () { box.classList.toggle('open'); });
          if (plate) plate.addEventListener('input', function () { this.value = this.value.toUpperCase(); });
          send.addEventListener('click', function () {
            var p = (plate.value || '').trim();
            if (p.length < 4) { plate.focus(); return; }
            var payload = { productId: box.getAttribute('data-product-id'), plate: p, email: (email.value || '').trim(), message: 'Vérification de compatibilité par plaque : ' + p };
            send.disabled = true;
            fetch('/api/lead/product-quote', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
              .then(function (r) { return r.json().catch(function () { return null; }); })
              .then(function (d) {
                if (d && d.ok) {
                  if (shown) shown.textContent = p;
                  form.style.display = 'none'; ok.style.display = 'flex';
                  if (window.dataLayer) window.dataLayer.push({ event: 'lead_product_quote', product_id: payload.productId, email: payload.email });
                } else { send.disabled = false; }
              })
              .catch(function () { send.disabled = false; });
          });
        })();
      </script>

      <script>
        (function () {
          var zb = document.querySelector('[data-pp-zoom]');
          var mi = document.querySelector('[data-main-image]');
          if (zb && mi) zb.addEventListener('click', function () { mi.click(); });
        })();
      </script>

      <!-- Modal: devis par email -->
      <div id="quote-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50">
        <div class="bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl">
          <div class="flex items-start justify-between mb-3">
            <div>
              <div class="font-bold text-slate-900 text-lg"><%= t('product.receiveQuote') %></div>
              <div class="text-sm text-slate-500 mt-0.5"><%= t('product.teamReplies') %></div>
            </div>
            <button type="button" id="quote-modal-close" class="w-8 h-8 rounded-lg hover:bg-slate-100 flex items-center justify-center -mr-2">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>

          <div class="rounded-xl bg-slate-50 p-3 flex items-center gap-3 mb-4">
            <% if (mainImage) { %>
              <img src="<%= mainImage %>" alt="<%= product.name %>" class="w-12 h-12 rounded-lg object-cover flex-shrink-0" />
            <% } %>
            <div class="text-sm font-medium text-slate-700 truncate"><%= product.name %></div>
          </div>

          <form id="quote-form" class="space-y-3">
            <input type="hidden" name="productId" value="<%= product._id %>" />
            <div class="grid grid-cols-2 gap-2">
              <input type="text" name="firstName" placeholder="<%= t('product.phFirstNameOpt') %>" maxlength="80" class="rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20" />
              <input type="tel" name="phone" placeholder="<%= t('product.phPhoneOpt') %>" maxlength="24" class="rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </div>
            <input type="email" name="email" required placeholder="<%= t('product.phEmailReq') %>" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20" />
            <div class="grid grid-cols-2 gap-2">
              <input type="text" name="vin" placeholder="<%= t('product.phVinOpt') %>" maxlength="32" class="rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:ring-2 focus:ring-primary/20" />
              <input type="text" name="plate" placeholder="<%= t('product.phPlateOpt') %>" maxlength="16" class="rounded-lg border border-slate-200 px-3 py-2 text-sm uppercase focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </div>
            <textarea name="message" rows="2" maxlength="500" placeholder="<%= t('product.phQuestion') %>" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20"></textarea>
            <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white py-2.5 rounded-lg font-bold text-sm transition">
              <%= t('product.requestMyQuote') %>
            </button>
            <p class="text-[11px] text-slate-400 text-center"><%= t('product.consentRecontact') %></p>
          </form>
          <div id="quote-result" class="mt-3 text-sm text-center"></div>
        </div>
      </div>

      <script>
      (function () {
        var btn = document.getElementById('quote-by-email-btn');
        var modal = document.getElementById('quote-modal');
        var closeBtn = document.getElementById('quote-modal-close');
        var form = document.getElementById('quote-form');
        var result = document.getElementById('quote-result');
        if (!btn || !modal || !form) return;

        function open() {
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          if (window.dataLayer) window.dataLayer.push({ event: 'quote_modal_open', product_id: form.querySelector('[name="productId"]').value });
        }
        function close() {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          result.innerHTML = '';
        }
        btn.addEventListener('click', open);
        closeBtn.addEventListener('click', close);
        modal.addEventListener('click', function (e) { if (e.target === modal) close(); });

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var data = {};
          new FormData(form).forEach(function (v, k) { data[k] = v; });
          result.innerHTML = '<span class="text-slate-500">' + <%- JSON.stringify(t('product.sending')) %> + '</span>';
          fetch('/api/lead/product-quote', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          })
            .then(function (r) { return r.json(); })
            .then(function (d) {
              if (d && d.ok) {
                result.innerHTML = '<span class="text-green-700 font-semibold">' + <%- JSON.stringify(t('product.quoteSent')) %> + '</span>';
                form.reset();
                if (window.dataLayer) window.dataLayer.push({ event: 'lead_product_quote', product_id: data.productId, email: data.email });
                setTimeout(close, 2500);
              } else {
                result.innerHTML = '<span class="text-red-700">' + <%- JSON.stringify(t('product.quoteError')) %> + '</span>';
              }
            })
            .catch(function () { result.innerHTML = '<span class="text-red-700">' + <%- JSON.stringify(t('product.networkError')) %> + '</span>'; });
        });
      })();
      </script>

