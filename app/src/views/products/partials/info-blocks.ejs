<%# Rend une liste de blocs d'information (style encadré discret « À savoir »). %>
<%# Attend `blocks` = [{ title, html }] ; `html` est déjà assaini (markdownToHtml). %>
<% (typeof blocks !== 'undefined' && blocks ? blocks : []).forEach(function (blk) { %>
  <div class="mt-6 rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/40 p-5">
    <div class="flex items-center gap-2 mb-2">
      <span class="material-symbols-outlined text-primary text-lg">info</span>
      <h3 class="text-sm font-bold uppercase tracking-wide text-slate-700 dark:text-slate-200"><%= blk.title %></h3>
    </div>
    <div class="product-html text-sm text-slate-600 dark:text-slate-300 leading-relaxed"><%- blk.html %></div>
  </div>
<% }); %>
