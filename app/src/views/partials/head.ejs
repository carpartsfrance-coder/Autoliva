<!DOCTYPE html>
<html class="light" lang="<%= typeof lang !== 'undefined' ? lang : 'fr' %>"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title><%= typeof title !== 'undefined' ? title : brand.NAME %></title>
<link rel="icon" type="image/png" href="<%= brand.FAVICON_URL %>" />
<!-- Consent Mode V2 default state (MUST be before GTM) -->
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('consent', 'default', {
  ad_storage: 'denied',
  ad_user_data: 'denied',
  ad_personalization: 'denied',
  analytics_storage: 'denied',
  functionality_storage: 'granted',
  security_storage: 'granted',
  wait_for_update: 500
});
(function(){
  try {
    var m = document.cookie.match(/(?:^|;\s*)cpf_consent=([^;]+)/);
    if (!m) return;
    var c = JSON.parse(decodeURIComponent(m[1]));
    if (!c || c.version !== 1) return;
    gtag('consent', 'update', {
      ad_storage: c.ads ? 'granted' : 'denied',
      ad_user_data: c.ads ? 'granted' : 'denied',
      ad_personalization: c.ads ? 'granted' : 'denied',
      analytics_storage: c.analytics ? 'granted' : 'denied'
    });
  } catch (e) {}
})();
</script>
<!-- End Consent Mode V2 default -->
<link rel="stylesheet" href="/css/consent-banner.css"/>
<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-NZDFRVCG');</script>
<!-- End Google Tag Manager -->
<!-- Google Ads (gtag) — suivi des conversions leads (déclenchées manuellement, ex: page de succès /moteurs) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=AW-16778404215"></script>
<script>
  gtag('js', new Date());
  gtag('config', 'AW-16778404215', { allow_enhanced_conversions: true });
</script>
<!-- End Google Ads gtag -->
<!-- Attribution capture (gclid + utm + GA4 client_id) -->
<script>
(function () {
  try {
    var KEYS = ['gclid','gbraid','wbraid','fbclid','msclkid','utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
    var KEY_LAST = 'cpf_attr';
    var KEY_FIRST = 'cpf_attr_first';

    var url = new URL(window.location.href);
    var found = {};
    var hasAny = false;
    for (var i = 0; i < KEYS.length; i++) {
      var v = url.searchParams.get(KEYS[i]);
      if (v) { found[KEYS[i]] = v; hasAny = true; }
    }

    if (hasAny) {
      var payload = {
        gclid: found.gclid || '',
        gbraid: found.gbraid || '',
        wbraid: found.wbraid || '',
        fbclid: found.fbclid || '',
        msclkid: found.msclkid || '',
        utmSource: found.utm_source || '',
        utmMedium: found.utm_medium || '',
        utmCampaign: found.utm_campaign || '',
        utmContent: found.utm_content || '',
        utmTerm: found.utm_term || '',
        landingPath: url.pathname + url.search,
        referrer: document.referrer || '',
        capturedAt: new Date().toISOString()
      };
      try {
        localStorage.setItem(KEY_LAST, JSON.stringify(payload));
        if (!localStorage.getItem(KEY_FIRST)) {
          localStorage.setItem(KEY_FIRST, JSON.stringify(payload));
        }
      } catch (e) {}
    }

    function readLs(k) {
      try { return JSON.parse(localStorage.getItem(k) || 'null'); } catch (e) { return null; }
    }
    function readGaClientId() {
      var m = document.cookie.match(/_ga=GA\d+\.\d+\.(\d+\.\d+)/);
      return m ? m[1] : '';
    }

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'attribution_ready',
      attribution_first_touch: readLs(KEY_FIRST),
      attribution_last_touch: readLs(KEY_LAST),
      ga_client_id: readGaClientId()
    });
  } catch (e) {}
})();
</script>
<!-- End Attribution capture -->
<script>
  (function () {
    document.documentElement.classList.add('js');
  })();
</script>
<style>
  html.js:not(.icons-ready) .material-symbols-outlined,
  html.js:not(.icons-ready) .material-symbols-rounded {
    visibility: hidden;
  }
</style>
<meta name="robots" content="<%= (typeof metaRobots !== 'undefined' && metaRobots) ? metaRobots : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' %>"/>
<% if (typeof metaDescription !== 'undefined' && metaDescription) { %>
<meta name="description" content="<%= metaDescription %>"/>
<% } %>
<% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %>
<link rel="canonical" href="<%= canonicalUrl %>"/>
<% } %>
<% if (typeof hreflangTags !== 'undefined' && Array.isArray(hreflangTags) && hreflangTags.length > 0) { %>
<% hreflangTags.forEach(function(tag) { %>
<link rel="alternate" hreflang="<%= tag.lang %>" href="<%= tag.href %>"/>
<% }); %>
<% } else { %>
<% if (typeof hreflangFr !== 'undefined' && hreflangFr) { %>
<link rel="alternate" hreflang="fr" href="<%= hreflangFr %>"/>
<% } %>
<% if (typeof hreflangEn !== 'undefined' && hreflangEn) { %>
<link rel="alternate" hreflang="en" href="<%= hreflangEn %>"/>
<% } %>
<% if (typeof hreflangDefault !== 'undefined' && hreflangDefault) { %>
<link rel="alternate" hreflang="x-default" href="<%= hreflangDefault %>"/>
<% } %>
<% } %>
<% if (typeof ogTitle !== 'undefined' && ogTitle) { %>
<meta property="og:title" content="<%= ogTitle %>"/>
<% } %>
<% if (typeof ogDescription !== 'undefined' && ogDescription) { %>
<meta property="og:description" content="<%= ogDescription %>"/>
<% } %>
<% if (typeof ogUrl !== 'undefined' && ogUrl) { %>
<meta property="og:url" content="<%= ogUrl %>"/>
<% } %>
<% if (typeof ogSiteName !== 'undefined' && ogSiteName) { %>
<meta property="og:site_name" content="<%= ogSiteName %>"/>
<% } %>
<% if (typeof ogImage !== 'undefined' && ogImage) { %>
<meta property="og:image" content="<%= ogImage %>"/>
<% } %>
<meta property="og:type" content="<%= (typeof ogType !== 'undefined' && ogType) ? ogType : 'website' %>"/>
<% if (typeof ogLocale !== 'undefined' && ogLocale) { %>
<meta property="og:locale" content="<%= ogLocale %>"/>
<% } else { %>
<meta property="og:locale" content="<%= (typeof lang !== 'undefined' && lang === 'de') ? 'de_DE' : (typeof lang !== 'undefined' && lang === 'en') ? 'en_US' : 'fr_FR' %>"/>
<% } %>
<% if (typeof ogLocaleAlternate !== 'undefined' && ogLocaleAlternate) { %>
<meta property="og:locale:alternate" content="<%= ogLocaleAlternate %>"/>
<% } %>
<% if (typeof ogArticlePublishedTime !== 'undefined' && ogArticlePublishedTime) { %>
<meta property="article:published_time" content="<%= ogArticlePublishedTime %>"/>
<% } %>
<% if (typeof ogArticleModifiedTime !== 'undefined' && ogArticleModifiedTime) { %>
<meta property="article:modified_time" content="<%= ogArticleModifiedTime %>"/>
<% } %>
<meta name="twitter:card" content="summary_large_image"/>
<% if (typeof ogTitle !== 'undefined' && ogTitle) { %>
<meta name="twitter:title" content="<%= ogTitle %>"/>
<% } %>
<% if (typeof ogDescription !== 'undefined' && ogDescription) { %>
<meta name="twitter:description" content="<%= ogDescription %>"/>
<% } %>
<% if (typeof ogImage !== 'undefined' && ogImage) { %>
<meta name="twitter:image" content="<%= ogImage %>"/>
<% } %>
<% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
<script type="application/ld+json"><%- jsonLd %></script>
<% } %>
<!-- Preload critical CSS for faster FCP -->
<% var _cssV = (typeof assetVersions !== 'undefined' && assetVersions.mainCss) || Date.now(); %>
<link rel="preload" href="/css/styles.css?v=<%= _cssV %>" as="style"/>
<link rel="stylesheet" href="/css/styles.css?v=<%= _cssV %>"/>
<!-- Preconnect to Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<!-- Critical fonts: Inter (body) + Outfit (headings) loaded with display=swap -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700&amp;display=swap" rel="stylesheet"/>
<!-- Icon fonts -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&amp;display=swap" rel="stylesheet"/>
<script>
  (function () {
    var el = document.documentElement;
    if (!el.classList.contains('js')) el.classList.add('js');
    if (!document.fonts || typeof document.fonts.load !== 'function') {
      el.classList.add('icons-ready');
      return;
    }

    var done = false;
    function markReady() {
      if (done) return;
      done = true;
      el.classList.add('icons-ready');
    }

    Promise.all([
      document.fonts.load('1em "Material Symbols Outlined"'),
      document.fonts.load('1em "Material Symbols Rounded"'),
    ])
      .then(markReady)
      .catch(markReady);

    setTimeout(markReady, 2000);
  })();
</script>
</head>
<body class="bg-[#f6f7fb] font-display text-slate-900 transition-colors duration-200 antialiased overflow-x-hidden">
