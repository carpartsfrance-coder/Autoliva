    <div class="cat-nav__card">
      <div class="cat-nav__head">
        <span class="cat-nav__label"><%= t('header.allCategories') %></span>
        <a class="cat-nav__seeall" href="<%= _lp %>/produits"><%= t('header.viewCatalog') %> <span class="material-symbols-outlined" style="font-size:15px;">arrow_forward</span></a>
