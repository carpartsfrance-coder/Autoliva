<% const _lp = typeof langPrefix !== 'undefined' ? langPrefix : ''; %>
<% const _hp = typeof currentPathWithoutLang !== 'undefined' ? currentPathWithoutLang : (typeof currentPath === 'string' ? currentPath : ''); %>
<% const _hpPathOnly = _hp.split('?')[0].split('#')[0]; %>
<% const _navActive = (href) => {
  if (!href) return false;
  if (href === '/') return _hpPathOnly === '/';
  return _hpPathOnly === href || _hpPathOnly.startsWith(href + '/');
}; %>
<%/* Calculs langue (FR/DE) — remontés ici car utilisés par la barre utilitaire
     ET par le menu mobile. */%>
<% const _curPathClean = (_hp || '/').split('?')[0].split('#')[0]; %>
<% const _isDe = typeof lang !== 'undefined' && lang === 'de'; %>
<% var _htSw = (typeof hreflangTags !== 'undefined' && Array.isArray(hreflangTags)) ? hreflangTags : []; %>
<% var _frTag = null, _deTag = null; %>
<% for (var _s = 0; _s < _htSw.length; _s++) { if (_htSw[_s] && _htSw[_s].lang === 'fr') _frTag = _htSw[_s]; if (_htSw[_s] && _htSw[_s].lang === 'de') _deTag = _htSw[_s]; } %>
<% const _frHref = (_frTag && _frTag.href) ? _frTag.href : (_curPathClean === '/' ? '/' : _curPathClean); %>
<% const _deHref = (_deTag && _deTag.href) ? _deTag.href : ('/de' + (_curPathClean === '/' ? '' : _curPathClean)); %>

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white">

<%/* Barre utilitaire (desktop md+) : téléphone + langue. Sortis de la rangée
     principale pour laisser toute la largeur à la recherche. */%>
<div class="hidden md:block bg-slate-50 border-b border-slate-100">
<div class="mx-auto max-w-[1440px] px-4 md:px-10 flex items-center justify-end gap-5 h-9">
<a class="flex items-center gap-1.5 text-sm font-bold text-slate-700 hover:text-primary transition-colors" href="tel:<%= brand.PHONE_INTL %>" aria-label="Appeler <%= brand.NAME %> au <%= brand.PHONE %>">
<span class="material-symbols-outlined text-base text-primary">call</span><%= brand.PHONE %>
</a>
<div class="flex items-center rounded-md border border-slate-200 overflow-hidden h-6" role="navigation" aria-label="Sprache / Langue">
<a class="flex items-center justify-center px-2 h-full text-[11px] font-black uppercase tracking-wider transition-colors <%= _isDe ? 'text-slate-400 hover:text-primary hover:bg-white' : 'bg-primary text-white' %>" href="<%= _frHref %>" hreflang="fr" <%= _isDe ? '' : 'aria-current="true"' %>>FR</a>
<a class="flex items-center justify-center px-2 h-full text-[11px] font-black uppercase tracking-wider transition-colors <%= _isDe ? 'bg-primary text-white' : 'text-slate-400 hover:text-primary hover:bg-white' %>" href="<%= _deHref %>" hreflang="de" <%= _isDe ? 'aria-current="true"' : '' %>>DE</a>
</div>
</div>
</div>

<%/* Rangée principale */%>
<div class="mx-auto flex max-w-[1440px] items-center gap-6 px-4 md:px-10 py-3">
<a class="flex items-center gap-2 text-primary shrink-0" href="<%= _lp %>/">
<img src="<%= brand.LOGO_URL %>" alt="<%= brand.NAME %>" class="h-10 md:h-11 w-auto" loading="eager" />
</a>

<nav class="hidden lg:flex items-center gap-6 text-sm font-semibold text-slate-600">
<a class="px-3 py-2 rounded-xl transition-colors <%= _navActive('/') ? 'bg-primary/10 text-primary' : 'text-slate-600 hover:text-primary hover:bg-slate-50' %>" href="<%= _lp %>/" <%= _navActive('/') ? 'aria-current="page"' : '' %>><%= t('nav.home') %></a>
<style>
  .cat-nav { position: relative; }
  .cat-nav__trigger { display: inline-flex; align-items: center; gap: 4px; }
  .cat-nav__caret { font-size: 18px; transition: transform .18s; }
  .cat-nav:hover .cat-nav__caret { transform: rotate(180deg); }
  .cat-nav__panel { position: absolute; left: 0; top: 100%; padding-top: 12px; opacity: 0; visibility: hidden; transform: translateY(6px); transition: opacity .16s ease, transform .16s ease, visibility .16s; z-index: 60; }
  .cat-nav:hover .cat-nav__panel, .cat-nav__panel:hover { opacity: 1; visibility: visible; transform: translateY(0); }
  .cat-nav__card { width: min(94vw, 840px); max-height: min(74vh, 560px); overflow-y: auto; background: #fff; border-radius: 20px; box-shadow: 0 26px 60px rgba(15,22,38,.18); border: 1px solid #EDF0F4; padding: 18px; }
  .cat-nav__head { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 2px 8px 14px; }
  .cat-nav__label { font-size: 11px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: #99A1B0; }
  .cat-nav__seeall { display: inline-flex; align-items: center; gap: 4px; font-size: 12.5px; font-weight: 800; color: #ED1C24; text-decoration: none; white-space: nowrap; }
  .cat-nav__seeall:hover { text-decoration: underline; }
  .cat-nav__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 6px; }
  .cat-nav__item { display: flex; align-items: center; gap: 11px; padding: 10px 11px; border-radius: 14px; text-decoration: none; transition: background .12s; }
  .cat-nav__item:hover { background: #F7F8FA; }
  .cat-nav__ic { width: 40px; height: 40px; border-radius: 12px; background: #F4F5F8; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background .12s; }
  .cat-nav__ic .material-symbols-outlined { font-size: 21px; color: #6B7482; transition: color .12s; }
  .cat-nav__item:hover .cat-nav__ic { background: #FEECEC; }
  .cat-nav__item:hover .cat-nav__ic .material-symbols-outlined { color: #ED1C24; }
  .cat-nav__nm { font-size: 13px; font-weight: 700; color: #1F2937; line-height: 1.25; }
  .cat-nav__item:hover .cat-nav__nm { color: #ED1C24; }
  @media (max-width: 1180px) { .cat-nav__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } .cat-nav__card { width: min(94vw, 640px); } }
</style>
<div class="cat-nav">
