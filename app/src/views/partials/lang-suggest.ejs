<%
  /* Bannière de SUGGESTION de langue (jamais de redirection — Google-safe).
   * Ne s'affiche QUE si la page a une vraie version dans l'autre langue
   * (présente dans hreflangTags) ET que le navigateur préfère cette langue
   * ET que l'utilisateur ne l'a pas déjà fermée (cookie hideLangSuggest). */
  var _ht = (typeof hreflangTags !== 'undefined' && Array.isArray(hreflangTags)) ? hreflangTags : [];
  var _deAlt = null, _frAlt = null;
  for (var _i = 0; _i < _ht.length; _i++) {
    if (_ht[_i] && _ht[_i].lang === 'de' && _ht[_i].href) _deAlt = _ht[_i];
    if (_ht[_i] && _ht[_i].lang === 'fr' && _ht[_i].href) _frAlt = _ht[_i];
  }
  var _curLang = (typeof lang !== 'undefined') ? lang : 'fr';
  var _pref = (typeof browserLangPref !== 'undefined') ? browserLangPref : '';
  var _hidden = (typeof langSuggestHidden !== 'undefined') ? langSuggestHidden : false;
  var _suggest = null;
  if (!_hidden) {
    if (_curLang === 'fr' && _pref === 'de' && _deAlt) {
      _suggest = { href: _deAlt.href, msg: 'Diese Seite ist auch auf Deutsch verfügbar.', cta: 'Auf Deutsch ansehen', flag: '🇩🇪', aria: 'Sprachvorschlag' };
    } else if (_curLang === 'de' && _pref && _pref !== 'de' && _frAlt) {
      _suggest = { href: _frAlt.href, msg: 'Cette page est aussi disponible en français.', cta: 'Voir en français', flag: '🇫🇷', aria: 'Suggestion de langue' };
    }
  }
%>
<% if (_suggest) { %>
<div id="lang-suggest" role="region" aria-label="<%= _suggest.aria %>" class="bg-slate-900 text-white text-sm border-b border-slate-700">
  <div class="container mx-auto px-4 lg:px-8 py-2.5 flex items-center justify-center gap-3 flex-wrap">
    <span class="opacity-90"><%= _suggest.flag %> <%= _suggest.msg %></span>
    <a id="lang-suggest-go" href="<%= _suggest.href %>" class="inline-flex items-center gap-1 rounded-lg bg-primary px-3 py-1.5 font-bold text-white hover:bg-red-700 transition">
      <%= _suggest.cta %>
      <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
    </a>
    <button id="lang-suggest-close" type="button" aria-label="Fermer / Schließen" class="ml-1 opacity-70 hover:opacity-100 transition">
      <span class="material-symbols-outlined text-[18px]">close</span>
    </button>
  </div>
</div>
<script>
  (function () {
    var bar = document.getElementById('lang-suggest');
    if (!bar) return;
    function remember() { document.cookie = 'hideLangSuggest=1; path=/; max-age=31536000; samesite=lax'; }
    var go = document.getElementById('lang-suggest-go');
    var close = document.getElementById('lang-suggest-close');
    if (go) go.addEventListener('click', remember);
    if (close) close.addEventListener('click', function () { remember(); bar.remove(); });
  })();
</script>
<% } %>
