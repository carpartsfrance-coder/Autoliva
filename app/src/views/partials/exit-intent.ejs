<%/*
  Popup d'intention de sortie : email contre code promo BIENVENUE5.
  - Ne s'affiche QUE :
    * sur les pages publiques (pas /admin, /commande, /panier, /compte)
    * pour les visiteurs anonymes (pas connectés)
    * une fois par 7 jours (cookie + sessionStorage)
    * après un délai minimum sur la page (5s) pour ne pas saouler
  - Triggers :
    * Desktop : mouseleave vers le haut du viewport
    * Mobile  : scroll-up rapide après scroll-down (proxy de "user about to leave")
*/%>
<% var _eiPath = (typeof currentPathWithoutLang !== 'undefined' ? currentPathWithoutLang : (typeof currentPath === 'string' ? currentPath : '')).split('?')[0].split('#')[0]; %>
<% var _showExitIntent = !/^\/(admin|commande|panier|compte|legal|sav)(\/|$)/.test(_eiPath) && !(typeof currentUser !== 'undefined' && currentUser); %>

<% if (_showExitIntent) { %>
<div id="exit-intent-popup" class="fixed inset-0 z-[60] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="ei-title">
  <div class="bg-white rounded-2xl max-w-md w-full shadow-2xl relative overflow-hidden animate-[ei-pop_280ms_ease-out]">
    <button type="button" id="ei-close" class="absolute top-3 right-3 z-10 w-9 h-9 rounded-full bg-white/80 hover:bg-slate-100 flex items-center justify-center shadow-sm" aria-label="Fermer">
      <span class="material-symbols-outlined text-slate-500">close</span>
    </button>

    <!-- Header avec gradient + badge promo -->
    <div class="relative bg-gradient-to-br from-red-600 via-red-700 to-red-800 px-6 pt-7 pb-16 text-white overflow-hidden">
      <!-- Badge -5% en coin -->
      <div class="absolute -right-6 top-4 rotate-12 bg-amber-400 text-red-900 font-black text-sm px-8 py-1 shadow-lg">
        − 5 % OFFERTS
      </div>

      <div class="flex items-center gap-2 text-white/80 text-[11px] font-bold uppercase tracking-widest mb-2">
        <span class="material-symbols-outlined" style="font-size:16px">support_agent</span>
        Aide à la commande
      </div>
      <h3 id="ei-title" class="text-2xl font-black leading-tight">Pas sûr de la<br/>compatibilité ?</h3>
      <p class="mt-2 text-white/90 text-sm">Notre équipe technique vérifie votre pièce <strong>gratuitement</strong> avant que vous commandiez.</p>
    </div>

    <!-- Body : value props -->
    <div class="px-6 -mt-10 relative z-[1]">
      <div class="bg-white rounded-xl border border-slate-200 shadow-md p-4">
        <ul class="space-y-2 text-sm text-slate-700">
          <li class="flex items-start gap-2">
            <span class="material-symbols-outlined text-green-600 flex-shrink-0" style="font-size:18px">check_circle</span>
            <span><strong>Vérification VIN gratuite</strong> par notre équipe</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="material-symbols-outlined text-green-600 flex-shrink-0" style="font-size:18px">check_circle</span>
            <span><strong>Devis personnalisé</strong> sous 24h ouvrées</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="material-symbols-outlined text-green-600 flex-shrink-0" style="font-size:18px">check_circle</span>
            <span><strong>Garantie 1 an</strong> pièce reconditionnée</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="material-symbols-outlined text-amber-600 flex-shrink-0" style="font-size:18px">redeem</span>
            <span><strong>−5 %</strong> sur votre 1ʳᵉ commande avec <code class="bg-amber-50 text-amber-800 px-1.5 py-0.5 rounded text-xs font-bold">BIENVENUE5</code></span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Form -->
    <div class="px-6 pt-4 pb-6">
      <form id="ei-form" class="space-y-2">
        <% if (typeof product !== 'undefined' && product && product._id) { %>
          <input type="hidden" name="productId" value="<%= product._id %>" />
        <% } %>
        <label class="block text-xs font-semibold text-slate-600">Recevez votre code + nos conseils experts</label>
        <input type="email" name="email" required placeholder="votre@email.com" autocomplete="email"
               class="w-full rounded-lg border border-slate-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-300 focus:border-red-300" />
        <button type="submit" class="w-full bg-red-600 hover:bg-red-700 active:bg-red-800 text-white py-3 rounded-lg font-bold text-sm transition shadow-sm">
          Recevoir mon code −5 %
        </button>
      </form>

      <!-- Trust + secondary action -->
      <div class="mt-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-1 text-xs text-slate-500">
          <span class="text-amber-500">★★★★★</span>
          <span class="font-semibold">4,8/5</span>
          <span class="text-slate-400">— clients satisfaits</span>
        </div>
        <button type="button" id="ei-decline" class="text-xs text-slate-400 hover:text-slate-600 underline-offset-2 hover:underline">
          Non merci
        </button>
      </div>

      <p class="mt-2 text-[10px] text-slate-400 text-center">Pas de spam. Désinscription en 1 clic. Données traitées selon notre <a href="/legal/politique-de-confidentialite" target="_blank" class="underline hover:text-slate-600">politique de confidentialité</a>.</p>

      <div id="ei-result" class="mt-3 text-sm text-center"></div>
    </div>
  </div>
</div>

<style>
  @keyframes ei-pop {
    from { opacity: 0; transform: scale(0.92) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>

<script>
(function () {
  // Bail si déjà vu / converti dans les 7 derniers jours
  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(?:^|;\\s*)' + name + '=([^;]+)'));
    return match ? match[1] : '';
  }
  function setCookie(name, value, days) {
    var d = new Date();
    d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
    document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
  }

  if (getCookie('cpf_ei_seen') === '1') return;
  try { if (sessionStorage.getItem('cpf_ei_dismissed') === '1') return; } catch (e) {}

  var modal = document.getElementById('exit-intent-popup');
  var closeBtn = document.getElementById('ei-close');
  var form = document.getElementById('ei-form');
  var result = document.getElementById('ei-result');
  if (!modal || !form) return;

  var triggered = false;
  var loadTime = Date.now();
  var MIN_TIME_ON_PAGE = 5000; // 5s minimum

  function show(reason) {
    if (triggered) return;
    if (Date.now() - loadTime < MIN_TIME_ON_PAGE) return;
    triggered = true;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    if (window.dataLayer) window.dataLayer.push({ event: 'exit_intent_shown', reason: reason });
  }

  function dismiss() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    try { sessionStorage.setItem('cpf_ei_dismissed', '1'); } catch (e) {}
  }

  // Desktop : souris sort par le haut du viewport
  document.addEventListener('mouseout', function (e) {
    if (e.toElement || e.relatedTarget) return; // sortie réelle uniquement
    if (e.clientY > 0) return; // par le haut
    show('mouse_leave_top');
  });

  // Mobile : proxy "back button intent" via scroll comportement
  var lastScrollY = window.scrollY;
  var scrollUpStart = 0;
  window.addEventListener('scroll', function () {
    var y = window.scrollY;
    if (y < lastScrollY && lastScrollY > 800) {
      // remontée rapide après avoir scrollé bas → intention de partir
      if (!scrollUpStart) scrollUpStart = Date.now();
      if (Date.now() - scrollUpStart < 300 && (lastScrollY - y) > 400) {
        show('mobile_scroll_up_fast');
      }
    } else {
      scrollUpStart = 0;
    }
    lastScrollY = y;
  }, { passive: true });

  // Fallback : 60s sur la page sans intéraction submit / navigation
  setTimeout(function () { show('time_60s'); }, 60000);

  closeBtn.addEventListener('click', dismiss);
  var declineBtn = document.getElementById('ei-decline');
  if (declineBtn) declineBtn.addEventListener('click', dismiss);
  modal.addEventListener('click', function (e) { if (e.target === modal) dismiss(); });

  // ESC ferme
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) dismiss();
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var data = {};
    new FormData(form).forEach(function (v, k) { data[k] = v; });
    result.innerHTML = '<span class="text-slate-500">Envoi…</span>';
    fetch('/api/lead/exit-intent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d && d.ok) {
          result.innerHTML = '<span class="text-green-700 font-semibold">✓ Code BIENVENUE5 envoyé sur ' + data.email + '</span>';
          setCookie('cpf_ei_seen', '1', 30);
          if (window.dataLayer) window.dataLayer.push({ event: 'lead_exit_intent', email: data.email });
          setTimeout(dismiss, 2500);
        } else {
          result.innerHTML = '<span class="text-red-700">Erreur. Réessayez.</span>';
        }
      })
      .catch(function () { result.innerHTML = '<span class="text-red-700">Erreur réseau.</span>'; });
  });
})();
</script>
<% } %>
