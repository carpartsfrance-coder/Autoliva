<%/*
  Popup d'intention de sortie : email contre code promo BIENVENUE5.
  - Ne s'affiche QUE :
    * sur les pages publiques (pas /admin, /commande, /panier, /compte)
    * pour les visiteurs anonymes (pas connectés)
    * une fois par 7 jours (cookie + sessionStorage)
    * après un délai minimum sur la page (5s) pour ne pas saouler
  - Triggers :
    * Desktop : mouseleave vers le haut du viewport
    * Mobile  : scroll-up rapide après scroll-down (proxy de "user about to leave")
*/%>
<% var _eiPath = (typeof currentPathWithoutLang !== 'undefined' ? currentPathWithoutLang : (typeof currentPath === 'string' ? currentPath : '')).split('?')[0].split('#')[0]; %>
<% var _showExitIntent = !/^\/(admin|commande|panier|compte|legal|sav)(\/|$)/.test(_eiPath) && !(typeof currentUser !== 'undefined' && currentUser); %>

<% if (_showExitIntent) { %>
<div id="exit-intent-popup" class="fixed inset-0 z-[60] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="ei-title">
  <div class="bg-white rounded-2xl max-w-md w-full shadow-2xl relative overflow-hidden animate-[ei-pop_280ms_ease-out]">
    <button type="button" id="ei-close" class="absolute top-3 right-3 z-20 w-9 h-9 rounded-full bg-white/90 hover:bg-white flex items-center justify-center shadow-md ring-1 ring-slate-200" aria-label="Fermer">
      <span class="material-symbols-outlined text-slate-600">close</span>
    </button>

    <!-- Header avec gradient + pill promo discret -->
    <div class="relative bg-gradient-to-br from-red-600 via-red-700 to-red-800 px-6 pt-6 pb-12 text-white overflow-hidden">
      <div class="flex items-center justify-between gap-2 mb-3">
        <div class="flex items-center gap-1.5 text-white/85 text-[10px] font-bold uppercase tracking-[0.18em]">
          <span class="material-symbols-outlined" style="font-size:14px">support_agent</span>
          Aide à la commande
        </div>
        <div class="inline-flex items-center gap-1 bg-amber-300 text-red-900 font-black text-[10px] px-2.5 py-1 rounded-full ring-1 ring-amber-500/40 shadow-sm whitespace-nowrap mr-12">
          🎁 −5 % OFFERTS
        </div>
      </div>
      <h3 id="ei-title" class="text-[22px] font-black leading-[1.15]">Pas sûr de la<br/>compatibilité ?</h3>
      <p class="mt-2 text-white/90 text-sm leading-snug">Notre équipe vérifie votre pièce <strong class="text-white">gratuitement</strong> avant commande.</p>
    </div>

    <!-- Body : value props (carte qui chevauche le header) -->
    <div class="px-5 -mt-8 relative z-[1]">
      <div class="bg-white rounded-xl border border-slate-200 shadow-lg p-4">
        <ul class="space-y-1.5 text-sm text-slate-700">
          <li class="flex items-start gap-2 leading-snug">
            <span class="material-symbols-outlined text-green-600 flex-shrink-0 mt-0.5" style="font-size:18px">check_circle</span>
            <span><strong>Vérification VIN gratuite</strong> par notre équipe</span>
          </li>
          <li class="flex items-start gap-2 leading-snug">
            <span class="material-symbols-outlined text-green-600 flex-shrink-0 mt-0.5" style="font-size:18px">check_circle</span>
            <span><strong>Devis personnalisé</strong> sous 24h ouvrées</span>
          </li>
          <li class="flex items-start gap-2 leading-snug">
            <span class="material-symbols-outlined text-green-600 flex-shrink-0 mt-0.5" style="font-size:18px">check_circle</span>
            <span><strong>Garantie 1 an</strong> pièce reconditionnée</span>
          </li>
          <li class="flex items-start gap-2 leading-snug">
            <span class="material-symbols-outlined text-amber-600 flex-shrink-0 mt-0.5" style="font-size:18px">redeem</span>
            <span><strong>−5 %</strong> sur votre 1ʳᵉ commande <span class="text-slate-500 text-xs">(code envoyé par email)</span></span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Form -->
    <div class="px-5 pt-4 pb-1">
      <form id="ei-form" class="space-y-2">
        <% if (typeof product !== 'undefined' && product && product._id) { %>
          <input type="hidden" name="productId" value="<%= product._id %>" />
        <% } %>
        <input type="email" name="email" required placeholder="votre@email.com" autocomplete="email"
               class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-500 transition" />
        <button type="submit" class="w-full bg-red-600 hover:bg-red-700 active:bg-red-800 text-white py-3.5 rounded-xl font-black text-[15px] transition shadow-md hover:shadow-lg flex items-center justify-center gap-2">
          Recevoir mon code −5 %
          <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
        </button>
      </form>
    </div>

    <!-- Trust strip : marques traitées -->
    <div class="px-5 pt-4 pb-3">
      <div class="text-[10px] uppercase tracking-[0.18em] text-slate-400 font-bold text-center">
        Choisis par les concessions et garages pros
      </div>
      <div class="mt-2.5 grid grid-cols-4 gap-3 items-center">
        <% var _eiBrands = [
          { name: 'Volkswagen', file: 'volkswagen-logo.webp' },
          { name: 'Audi',       file: 'audi-logo.webp' },
          { name: 'BMW',        file: 'bmw-logo.webp' },
          { name: 'Mercedes',   file: 'mercedes-benz-logo.webp' },
          { name: 'Renault',    file: 'renault-logo.webp' },
          { name: 'Peugeot',    file: 'peugeot-logo.png' },
          { name: 'Skoda',      file: 'skoda-logo.webp' },
          { name: 'Seat',       file: 'seat-logo.webp' },
        ]; %>
        <% _eiBrands.forEach(function (b) { %>
          <div class="flex items-center justify-center h-8 grayscale opacity-60 hover:opacity-100 hover:grayscale-0 transition" title="<%= b.name %>">
            <img src="/images/brands/<%= b.file %>" alt="<%= b.name %>" loading="lazy" class="max-h-7 max-w-[60px] object-contain" />
          </div>
        <% }); %>
      </div>
    </div>

    <!-- Bottom : opt-out + RGPD -->
    <div class="px-5 pb-5">
      <div class="flex items-center justify-center gap-3 pt-2 border-t border-slate-100">
        <button type="button" id="ei-decline" class="text-[11px] text-slate-400 hover:text-slate-600 underline-offset-2 hover:underline pt-2">
          Non merci, continuer ma visite
        </button>
      </div>
      <p class="mt-1 text-[10px] text-slate-400 text-center">Pas de spam. Désinscription en 1 clic. <a href="/legal/politique-de-confidentialite" target="_blank" class="underline hover:text-slate-600">Confidentialité</a>.</p>

      <div id="ei-result" class="mt-2 text-sm text-center"></div>
    </div>
  </div>
</div>

<style>
  @keyframes ei-pop {
    from { opacity: 0; transform: scale(0.92) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>

<script>
(function () {
  // Bail si déjà vu / converti dans les 7 derniers jours
  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(?:^|;\\s*)' + name + '=([^;]+)'));
    return match ? match[1] : '';
  }
  function setCookie(name, value, days) {
    var d = new Date();
    d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
    document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
  }

  if (getCookie('cpf_ei_seen') === '1') return;
  try { if (sessionStorage.getItem('cpf_ei_dismissed') === '1') return; } catch (e) {}

  var modal = document.getElementById('exit-intent-popup');
  var closeBtn = document.getElementById('ei-close');
  var form = document.getElementById('ei-form');
  var result = document.getElementById('ei-result');
  if (!modal || !form) return;

  var triggered = false;
  var loadTime = Date.now();
  var MIN_TIME_ON_PAGE = 5000; // 5s minimum

  function show(reason) {
    if (triggered) return;
    if (Date.now() - loadTime < MIN_TIME_ON_PAGE) return;
    triggered = true;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    if (window.dataLayer) window.dataLayer.push({ event: 'exit_intent_shown', reason: reason });
  }

  function dismiss() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    try { sessionStorage.setItem('cpf_ei_dismissed', '1'); } catch (e) {}
  }

  // Desktop : souris sort par le haut du viewport
  document.addEventListener('mouseout', function (e) {
    if (e.toElement || e.relatedTarget) return; // sortie réelle uniquement
    if (e.clientY > 0) return; // par le haut
    show('mouse_leave_top');
  });

  // Mobile : proxy "back button intent" via scroll comportement
  var lastScrollY = window.scrollY;
  var scrollUpStart = 0;
  window.addEventListener('scroll', function () {
    var y = window.scrollY;
    if (y < lastScrollY && lastScrollY > 800) {
      // remontée rapide après avoir scrollé bas → intention de partir
      if (!scrollUpStart) scrollUpStart = Date.now();
      if (Date.now() - scrollUpStart < 300 && (lastScrollY - y) > 400) {
        show('mobile_scroll_up_fast');
      }
    } else {
      scrollUpStart = 0;
    }
    lastScrollY = y;
  }, { passive: true });

  // Fallback : 60s sur la page sans intéraction submit / navigation
  setTimeout(function () { show('time_60s'); }, 60000);

  closeBtn.addEventListener('click', dismiss);
  var declineBtn = document.getElementById('ei-decline');
  if (declineBtn) declineBtn.addEventListener('click', dismiss);
  modal.addEventListener('click', function (e) { if (e.target === modal) dismiss(); });

  // ESC ferme
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) dismiss();
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var data = {};
    new FormData(form).forEach(function (v, k) { data[k] = v; });
    result.innerHTML = '<span class="text-slate-500">Envoi…</span>';
    fetch('/api/lead/exit-intent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d && d.ok) {
          var code = (d && d.code) || 'BIENVENUE5';
          result.innerHTML = ''
            + '<div class="rounded-xl bg-green-50 border border-green-200 p-4 text-center">'
            + '  <div class="text-green-700 font-bold text-sm">✓ Email envoyé sur ' + (data.email || '').replace(/[<>&"]/g, '') + '</div>'
            + '  <div class="mt-2 text-xs text-slate-500 uppercase tracking-widest font-semibold">Votre code promo</div>'
            + '  <div class="mt-1 inline-flex items-center gap-2 bg-amber-50 border border-amber-200 rounded-lg px-4 py-2 mt-2">'
            + '    <span class="text-amber-800 font-black text-lg tracking-widest" id="ei-code-value">' + code + '</span>'
            + '    <button type="button" id="ei-code-copy" class="text-amber-700 hover:text-amber-900 transition" title="Copier"><span class="material-symbols-outlined" style="font-size:18px">content_copy</span></button>'
            + '  </div>'
            + '  <div class="mt-2 text-[11px] text-slate-500">À saisir au moment du paiement. Valable 30 jours.</div>'
            + '</div>';
          setCookie('cpf_ei_seen', '1', 30);
          if (window.dataLayer) window.dataLayer.push({ event: 'lead_exit_intent', email: data.email });

          var copyBtn = document.getElementById('ei-code-copy');
          if (copyBtn) {
            copyBtn.addEventListener('click', function () {
              if (navigator.clipboard) {
                navigator.clipboard.writeText(code).then(function () {
                  copyBtn.innerHTML = '<span class="material-symbols-outlined text-green-600" style="font-size:18px">check</span>';
                  setTimeout(function () {
                    copyBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:18px">content_copy</span>';
                  }, 1500);
                });
              }
            });
          }

          setTimeout(dismiss, 6000);
        } else {
          result.innerHTML = '<span class="text-red-700">Erreur. Réessayez.</span>';
        }
      })
      .catch(function () { result.innerHTML = '<span class="text-red-700">Erreur réseau.</span>'; });
  });
})();
</script>
<% } %>
