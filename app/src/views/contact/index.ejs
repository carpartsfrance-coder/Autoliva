<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-1 bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 transition-colors duration-300">
  <div class="mx-auto max-w-[1440px] px-4 md:px-10 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <div class="lg:col-span-5">
        <div class="rounded-3xl bg-white/80 dark:bg-surface-dark/70 backdrop-blur border border-slate-100 dark:border-slate-800 p-6 sm:p-8 shadow-premium">
          <div class="flex items-center gap-3">
            <div class="h-12 w-12 rounded-2xl bg-primary/10 flex items-center justify-center">
              <span class="material-symbols-rounded text-primary text-3xl">support_agent</span>
            </div>
            <div>
              <div class="text-xs font-black uppercase tracking-widest text-slate-400"><%= brand.NAME %></div>
              <h1 class="text-2xl sm:text-3xl font-black tracking-tight">
                <%= mode === 'devis' ? t('contact.titleDevis') : t('contact.titleContact') %>
              </h1>
            </div>
          </div>

          <p class="mt-4 text-sm text-slate-600 dark:text-slate-300 leading-relaxed">
            <%= mode === 'devis' ? t('contact.introDevis') : t('contact.introContact') %>
          </p>

          <div class="mt-6 flex flex-col sm:flex-row flex-wrap gap-3">
            <a class="inline-flex items-center justify-center gap-2 rounded-2xl bg-white hover:bg-slate-50 dark:bg-slate-900 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 font-black text-xs sm:text-sm transition-colors" href="tel:<%= brand.PHONE_INTL %>">
              <span class="material-symbols-rounded text-primary">call</span>
              <%= brand.PHONE %>
            </a>
            <a class="inline-flex items-center justify-center gap-2 rounded-2xl bg-white hover:bg-slate-50 dark:bg-slate-900 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 font-black text-xs sm:text-sm transition-colors" href="mailto:<%= brand.EMAIL_CONTACT %>">
              <span class="material-symbols-rounded text-primary">alternate_email</span>
              <%= brand.EMAIL_CONTACT %>
            </a>
          </div>

          <div class="mt-8 rounded-3xl border border-slate-200/70 dark:border-slate-700 bg-gradient-to-br from-slate-50 to-white dark:from-slate-900 dark:to-slate-900/40 p-6">
            <div class="text-xs font-black uppercase tracking-widest text-slate-400"><%= t('contact.choose') %></div>
            <div class="mt-3 grid grid-cols-2 gap-3">
              <a class="rounded-2xl border px-4 py-3 text-sm font-black transition-colors <%= mode === 'contact' ? 'border-primary/40 bg-primary/10 text-primary' : 'border-slate-200 dark:border-slate-700 hover:bg-white/70 dark:hover:bg-slate-800' %>" href="<%= langPrefix %>/contact">
                <%= t('contact.titleContact') %>
              </a>
              <a class="rounded-2xl border px-4 py-3 text-sm font-black transition-colors <%= mode === 'devis' ? 'border-primary/40 bg-primary/10 text-primary' : 'border-slate-200 dark:border-slate-700 hover:bg-white/70 dark:hover:bg-slate-800' %>" href="<%= langPrefix %>/devis">
                <%= t('contact.tabDevis') %>
              </a>
            </div>

            <div class="mt-4 text-[11px] text-slate-500 dark:text-slate-400 leading-relaxed">
              <%= t('contact.tip') %>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-3xl bg-white dark:bg-surface-dark border border-slate-100 dark:border-slate-800 p-6 sm:p-10 shadow-premium">
          <% if (errorMessage) { %>
            <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 p-5 text-red-900">
              <div class="font-bold"><%= t('checkout.errorShort') %></div>
              <div class="mt-1 text-sm"><%= errorMessage %></div>
            </div>
          <% } %>

          <% if (successMessage) { %>
            <div class="mb-6 rounded-2xl border border-green-200 bg-green-50 p-5 text-green-900">
              <div class="font-bold">OK</div>
              <div class="mt-1 text-sm"><%= successMessage %></div>
            </div>
          <% } %>

          <form action="<%= langPrefix %><%= mode === 'devis' ? '/devis' : '/contact' %>" class="space-y-5" method="POST">
            <input name="mode" type="hidden" value="<%= mode %>" />
            <input name="website" type="text" value="<%= form && form.website ? form.website : '' %>" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="firstName"><%= t('contact.firstName') %></label>
                <input class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="firstName" name="firstName" placeholder="<%= t('contact.phFirstName') %>" type="text" value="<%= form && form.firstName ? form.firstName : '' %>" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="lastName"><%= t('contact.lastName') %></label>
                <input class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="lastName" name="lastName" placeholder="<%= t('contact.phLastName') %>" type="text" value="<%= form && form.lastName ? form.lastName : '' %>" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="email"><%= t('contact.email') %></label>
                <input class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="email" name="email" placeholder="<%= t('contact.phEmail') %>" required type="email" value="<%= form && form.email ? form.email : '' %>" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="phone"><%= t('contact.phoneOpt') %></label>
                <input class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="phone" name="phone" placeholder="<%= t('contact.phPhone') %>" type="tel" value="<%= form && form.phone ? form.phone : '' %>" />
              </div>
            </div>

            <% const subjectValue = form && form.subject ? form.subject : ''; %>
            <% const showQuoteFields = mode === 'devis'; %>
            <% const showCompatibilityFields = showQuoteFields || subjectValue === 'compatibilite'; %>

            <% if (showCompatibilityFields) { %>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="vin"><%= t('contact.vin') %></label>
                  <input class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="vin" name="vin" placeholder="<%= t('contact.vin') %>" type="text" value="<%= form && form.vin ? form.vin : '' %>" />
                  <div class="mt-1 text-[11px] text-slate-500"><%= t('contact.vinHint') %></div>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="plate"><%= t('contact.plate') %></label>
                  <input class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="plate" name="plate" placeholder="<%= t('contact.phPlate') %>" type="text" value="<%= form && form.plate ? form.plate : '' %>" />
                  <div class="mt-1 text-[11px] text-slate-500"><%= t('contact.plateHint') %></div>
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="partRef"><%= t('contact.partRef') %></label>
                <input class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="partRef" name="partRef" placeholder="<%= t('contact.phPartRef') %>" type="text" value="<%= form && form.partRef ? form.partRef : '' %>" />
              </div>

              <div>
                <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="vehicle"><%= t('contact.vehicle') %></label>
                <input class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="vehicle" name="vehicle" placeholder="<%= t('contact.phVehicle') %>" type="text" value="<%= form && form.vehicle ? form.vehicle : '' %>" />
              </div>

              <% if (showQuoteFields) { %>
                <input name="subject" type="hidden" value="devis" />
              <% } %>
            <% } %>

            <% if (!showQuoteFields) { %>
              <div>
                <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="subject"><%= t('contact.subject') %></label>
                <select id="subject" name="subject" class="w-full h-12 px-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium">
                  <option value="question" <%= (form && form.subject === 'question') ? 'selected' : '' %>><%= t('contact.subjQuestion') %></option>
                  <option value="compatibilite" <%= (form && form.subject === 'compatibilite') ? 'selected' : '' %>><%= t('contact.subjCompat') %></option>
                  <option value="commande" <%= (form && form.subject === 'commande') ? 'selected' : '' %>><%= t('contact.subjOrder') %></option>
                  <option value="autre" <%= (form && form.subject === 'autre') ? 'selected' : '' %>><%= t('contact.subjOther') %></option>
                </select>
              </div>
            <% } %>

            <div>
              <label class="block text-sm font-semibold text-slate-900 dark:text-slate-200 mb-2" for="message"><%= t('contact.message') %></label>
              <textarea class="w-full min-h-[160px] px-4 py-3 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary outline-none text-sm font-medium placeholder:text-slate-400" id="message" name="message" placeholder="<%= t('contact.phMessage') %>" required><%= form && form.message ? form.message : '' %></textarea>
              <div class="mt-2 text-[11px] text-slate-500"><%= t('contact.privacyNote') %></div>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
              <button class="inline-flex items-center justify-center rounded-2xl bg-primary hover:bg-primary/90 text-white py-3 px-6 font-black text-sm shadow-xl shadow-red-500/20 transition-all" type="submit">
                <%= t('contact.send') %>
                <span class="material-symbols-outlined ml-2">send</span>
              </button>
              <a class="inline-flex items-center justify-center rounded-2xl bg-white hover:bg-slate-50 dark:bg-slate-900 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-700 py-3 px-6 font-black text-sm transition-colors" href="<%= langPrefix %>/produits">
                <%= t('contact.viewCatalog') %>
                <span class="material-symbols-outlined ml-2">arrow_forward</span>
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
