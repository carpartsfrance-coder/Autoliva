<%- include('./partials/head', { pageTitle }) %>
<%- include('./partials/sidebar', { active: 'reconciliation', currentUser }) %>

<main class="p-4 sm:p-6 lg:p-10 max-w-7xl mx-auto">

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Réconciliation Mollie</h1>
      <p class="text-sm text-slate-500 mt-1">
        Virements Mollie ↔ ventes du mois. Pour chaque payout reçu sur ton compte bancaire, le détail des paiements qui le composent.
      </p>
    </div>
    <% if (period) { %>
      <div class="flex items-center gap-2 bg-white rounded-xl border border-slate-200 p-1">
        <a href="?period=<%= period.prevPeriod %>" class="px-3 py-2 text-sm rounded-lg hover:bg-slate-100 transition" title="Mois précédent">
          <span class="material-symbols-outlined text-base align-middle">chevron_left</span>
        </a>
        <div class="px-3 py-2 text-sm font-semibold text-slate-900 capitalize"><%= period.currentLabel %></div>
        <a href="?period=<%= period.nextPeriod %>" class="px-3 py-2 text-sm rounded-lg hover:bg-slate-100 transition" title="Mois suivant">
          <span class="material-symbols-outlined text-base align-middle">chevron_right</span>
        </a>
      </div>
    <% } %>
  </div>

  <% if (!data.configured) { %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-800">
      <div class="font-semibold mb-1">Réconciliation indisponible</div>
      <div><%= data.message || 'MOLLIE_API_KEY non configurée côté serveur.' %></div>
    </div>
  <% } else if (data.message) { %>
    <div class="bg-rose-50 border border-rose-200 rounded-xl p-6 text-sm text-rose-800">
      <div class="font-semibold mb-1">Erreur</div>
      <div><%= data.message %></div>
    </div>
  <% } else if (data.settlements.length === 0) { %>
    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center text-slate-500">
      <span class="material-symbols-outlined text-4xl text-slate-300">account_balance</span>
      <p class="mt-2">Aucun virement Mollie reçu sur cette période.</p>
      <p class="text-xs mt-1">Les settlements apparaissent une fois que Mollie a effectué le virement sur ton compte bancaire (typiquement 1-3 jours après la vente).</p>
    </div>
  <% } else { %>

    <% data.settlements.forEach(function (s) { %>
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-6">

        <!-- Bandeau récap -->
        <div class="px-6 py-4 bg-slate-50 border-b border-slate-100 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3">
          <div>
            <div class="flex items-center gap-2 flex-wrap">
              <div class="font-semibold text-slate-900">
                Virement du <%= s.settledAt ? new Date(s.settledAt).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' }) : '—' %>
              </div>
              <% if (s.reference) { %>
                <span class="text-xs font-mono bg-slate-100 text-slate-600 px-2 py-0.5 rounded"><%= s.reference %></span>
              <% } %>
              <% if (s.status === 'paidout') { %>
                <span class="text-xs bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full font-semibold">Versé</span>
              <% } else if (s.status === 'pending') { %>
                <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full font-semibold">En cours</span>
              <% } else { %>
                <span class="text-xs bg-slate-100 text-slate-700 px-2 py-0.5 rounded-full"><%= s.status %></span>
              <% } %>
            </div>
            <div class="text-xs text-slate-500 mt-1">
              <%= s.paymentsCount %> paiement(s) · <%= s.refundsCount %> remboursement(s)
              · Frais Mollie : <%= (s.feesCents / 100).toFixed(2) %> €
              <% if (s.diffCents !== 0) { %>
                · <span class="text-rose-600 font-semibold">Écart : <%= (s.diffCents / 100).toFixed(2) %> €</span>
              <% } %>
            </div>
          </div>
          <div class="text-right">
            <div class="text-2xl font-bold text-slate-900 tabular-nums"><%= (s.amountCents / 100).toFixed(2) %> €</div>
            <div class="text-xs text-slate-500">Montant net versé</div>
          </div>
        </div>

        <!-- Anomalies -->
        <% if (s.issues.length > 0) { %>
          <div class="px-6 py-3 bg-rose-50 border-b border-rose-100">
            <% s.issues.forEach(function (i) { %>
              <div class="flex items-start gap-2 text-sm">
                <span class="material-symbols-outlined text-base text-rose-600 flex-shrink-0 mt-0.5">warning</span>
                <span class="text-rose-800"><%= i.message %></span>
              </div>
            <% }) %>
          </div>
        <% } %>

        <!-- Détail paiements -->
        <% if (s.payments.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 text-xs uppercase tracking-wider text-slate-500">
                <tr>
                  <th class="px-4 py-2 text-left font-semibold">Commande</th>
                  <th class="px-4 py-2 text-left font-semibold">Facture</th>
                  <th class="px-4 py-2 text-left font-semibold">Client</th>
                  <th class="px-4 py-2 text-left font-semibold">Méthode</th>
                  <th class="px-4 py-2 text-right font-semibold">Brut</th>
                  <th class="px-4 py-2 text-right font-semibold">Frais</th>
                  <th class="px-4 py-2 text-right font-semibold">Net versé</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% s.payments.forEach(function (p) { %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-4 py-2">
                      <% if (p.order) { %>
                        <span class="font-mono text-xs text-slate-900"><%= p.order.number %></span>
                      <% } else { %>
                        <span class="text-rose-600 text-xs">⚠ aucune commande</span>
                      <% } %>
                    </td>
                    <td class="px-4 py-2 font-mono text-xs text-slate-500">
                      <% if (p.order && p.order.invoiceNumber) { %>
                        <a href="/comptable/factures/<%= p.order.id %>/pdf" target="_blank" class="text-amber-600 hover:underline"><%= p.order.invoiceNumber %></a>
                      <% } else if (p.order) { %>
                        <span class="text-rose-500" title="Paiement OK mais pas de facture émise">⚠ aucune</span>
                      <% } else { %>
                        —
                      <% } %>
                    </td>
                    <td class="px-4 py-2 text-slate-700 text-xs"><%= p.order ? p.order.customer : '—' %></td>
                    <td class="px-4 py-2 text-xs text-slate-500"><%= p.method %></td>
                    <td class="px-4 py-2 text-right tabular-nums text-slate-900"><%= (p.grossCents / 100).toFixed(2) %> €</td>
                    <td class="px-4 py-2 text-right tabular-nums text-slate-500">-<%= (p.feesCents / 100).toFixed(2) %> €</td>
                    <td class="px-4 py-2 text-right tabular-nums font-semibold text-slate-900"><%= (p.settledCents / 100).toFixed(2) %> €</td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <!-- Détail refunds (s'il y en a dans ce settlement) -->
        <% if (s.refunds.length > 0) { %>
          <div class="px-6 py-3 bg-rose-50/40 border-t border-slate-100">
            <div class="text-xs uppercase tracking-wider text-slate-500 font-semibold mb-2">
              Remboursements imputés sur ce virement (<%= s.refunds.length %>)
            </div>
            <ul class="text-sm space-y-1">
              <% s.refunds.forEach(function (r) { %>
                <li class="flex items-center justify-between">
                  <span class="text-slate-700">
                    <%= r.createdAt ? new Date(r.createdAt).toLocaleDateString('fr-FR') : '—' %>
                    · <span class="font-mono text-xs text-slate-500"><%= r.mollieId %></span>
                    · <%= r.description || 'remboursement' %>
                  </span>
                  <span class="text-rose-600 tabular-nums font-semibold">-<%= (r.grossCents / 100).toFixed(2) %> €</span>
                </li>
              <% }) %>
            </ul>
          </div>
        <% } %>

      </div>
    <% }); %>

  <% } %>

</main>

<%- include('./partials/footer') %>
