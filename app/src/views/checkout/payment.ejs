<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-1">
  <div class="mx-auto max-w-[1440px] px-4 md:px-10 py-8">
    <div class="flex items-center justify-center gap-4 text-xs font-black uppercase tracking-widest text-slate-400">
      <div class="flex items-center gap-3">
        <div class="w-7 h-7 rounded-full bg-slate-900 text-white flex items-center justify-center">1</div>
        <div class="text-slate-500"><%= t('checkout.stepCart') %></div>
      </div>
      <div class="h-px w-10 bg-slate-200"></div>
      <div class="flex items-center gap-3">
        <div class="w-7 h-7 rounded-full bg-slate-900 text-white flex items-center justify-center">2</div>
        <div class="text-slate-500"><%= t('checkout.stepShipping') %></div>
      </div>
      <div class="h-px w-10 bg-slate-200"></div>
      <div class="flex items-center gap-3">
        <div class="w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center">3</div>
        <div class="text-primary"><%= t('checkout.stepPayment') %></div>
      </div>
    </div>

    <% if (errorMessage) { %>
      <div class="mt-8 rounded-xl border border-red-200 bg-red-50 p-5 text-red-900">
        <div class="font-bold"><%= t('checkout.errorShort') %></div>
        <div class="mt-1 text-sm"><%= errorMessage %></div>
      </div>
    <% } %>

    <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
      <section class="lg:col-span-8 space-y-8">
        <div class="bg-white rounded-2xl border border-slate-200 p-6">
          <div class="text-lg font-black text-slate-900"><%= t('checkout.summary') %></div>
          <div class="mt-1 text-sm text-slate-600"><%= t('checkout.verifyInfo') %></div>

          <div class="mt-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="rounded-2xl border border-slate-200 p-5">
              <div class="text-xs font-black uppercase tracking-widest text-slate-400"><%= t('checkout.shippingMethod') %></div>
              <div class="mt-3 font-black text-slate-900"><%= shippingMethod.title %></div>
              <div class="mt-1 text-sm text-slate-600"><%= shippingMethod.description %></div>
              <div class="mt-3 font-black <%= shippingMethod.priceCents === 0 ? 'text-green-600' : 'text-primary' %>">
                <%= shippingMethod.priceCents === 0 ? t('checkout.free').toUpperCase() : (shippingMethod.priceCents / 100).toFixed(2).replace('.', ',') + ' €' %>
              </div>
            </div>

            <div class="rounded-2xl border border-slate-200 p-5">
              <div class="text-xs font-black uppercase tracking-widest text-slate-400"><%= t('checkout.shippingAddress') %></div>
              <div class="mt-3">
                <% if (address.fullName) { %><div class="font-black text-slate-900"><%= address.fullName %></div><% } %>
                <div class="text-sm text-slate-600"><%= address.line1 %></div>
                <% if (address.line2) { %><div class="text-sm text-slate-600"><%= address.line2 %></div><% } %>
                <div class="text-sm text-slate-600"><%= address.postalCode %> <%= address.city %> • <%= address.country || 'France' %></div>
                <% if (address.phone) { %><div class="mt-1 text-xs text-slate-500"><%= t('checkout.phoneColon') %> <%= address.phone %></div><% } %>
              </div>
            </div>

            <div class="rounded-2xl border border-slate-200 p-5">
              <div class="text-xs font-black uppercase tracking-widest text-slate-400"><%= t('checkout.billingAddress') %></div>
              <% if (billingSameAsShipping) { %>
                <div class="mt-3 text-sm text-slate-600"><%= t('checkout.sameAsShipping') %>.</div>
              <% } %>

              <% if (billingAddress) { %>
                <div class="mt-3">
                  <% if (billingAddress.fullName) { %><div class="font-black text-slate-900"><%= billingAddress.fullName %></div><% } %>
                  <div class="text-sm text-slate-600"><%= billingAddress.line1 %></div>
                  <% if (billingAddress.line2) { %><div class="text-sm text-slate-600"><%= billingAddress.line2 %></div><% } %>
                  <div class="text-sm text-slate-600"><%= billingAddress.postalCode %> <%= billingAddress.city %> • <%= billingAddress.country || 'France' %></div>
                  <% if (billingAddress.phone) { %><div class="mt-1 text-xs text-slate-500"><%= t('checkout.phoneColon') %> <%= billingAddress.phone %></div><% } %>
                </div>
              <% } %>
            </div>
          </div>

          <% if (guestCheckout) { %>
            <div class="mt-6 rounded-2xl border border-primary/20 bg-primary/5 p-5 text-sm text-slate-700">
              <%= t('checkout.guestAccountNote') %>
            </div>
          <% } %>

          <% if (localMolliePaymentSimulation || localScalapayPaymentSimulation) { %>
            <div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-5 text-sm text-amber-900">
              Mode test local activé : en l’absence de clé de paiement, la commande sera validée automatiquement pour vous permettre de tester le tunnel jusqu’au bout.
            </div>
          <% } %>

          <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-5">
            <div class="text-sm font-black text-slate-900"><%= t('checkout.stepPayment') %></div>
            <div class="mt-1 text-sm text-slate-600"><%= t('checkout.choosePayment') %></div>

            <form action="/commande/paiement" method="POST" class="mt-4 space-y-3">
              <label class="block">
                <input class="peer sr-only" type="radio" name="paymentMethod" value="mollie" checked />
                <div class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-slate-300 peer-checked:border-primary peer-checked:ring-2 peer-checked:ring-primary/20">
                  <div class="flex items-start gap-4">
                    <div class="w-11 h-11 rounded-xl bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined">credit_card</span>
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between gap-3">
                        <div class="font-black text-slate-900"><%= t('checkout.cardPayment') %></div>
                      </div>
                      <div class="mt-1 text-sm text-slate-600"><%= t('checkout.cardDesc') %></div>

                      <div class="mt-3 flex items-center gap-2">
                        <div class="h-7 w-11 rounded-lg border border-slate-200 bg-white flex items-center justify-center">
                          <div class="flex items-center">
                            <div class="w-3.5 h-3.5 rounded-full bg-red-500 -mr-1"></div>
                            <div class="w-3.5 h-3.5 rounded-full bg-amber-400 opacity-90"></div>
                          </div>
                        </div>
                        <div class="h-7 w-11 rounded-lg border border-slate-200 bg-white flex items-center justify-center">
                          <div class="text-[10px] font-black text-slate-700">VISA</div>
                        </div>
                        <div class="text-xs font-black text-slate-500"><%= t('checkout.moreMethods') %></div>
                      </div>
                    </div>
                  </div>
                </div>
              </label>

              <label class="block">
                <input class="peer sr-only" type="radio" name="paymentMethod" value="scalapay_pay_in_3" />
                <div class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-slate-300 peer-checked:border-primary peer-checked:ring-2 peer-checked:ring-primary/20">
                  <div class="flex items-start gap-4">
                    <div class="w-11 h-11 rounded-xl bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined">payments</span>
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between gap-3">
                        <div class="font-black text-slate-900">Scalapay</div>
                        <span class="inline-flex items-center rounded-full bg-slate-900 text-white text-xs font-black px-3 py-1">3x</span>
                      </div>
                      <div class="mt-1 text-sm text-slate-600"><%= t('checkout.pay3x') %></div>
                      <div class="mt-3 flex items-center gap-2 text-xs font-black text-slate-500">
                        <span class="material-symbols-outlined text-base text-slate-400">schedule</span>
                        <%= t('checkout.autoSchedule') %>
                      </div>
                    </div>
                  </div>
                </div>
              </label>

              <label class="block">
                <input class="peer sr-only" type="radio" name="paymentMethod" value="scalapay_pay_in_4" />
                <div class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-slate-300 peer-checked:border-primary peer-checked:ring-2 peer-checked:ring-primary/20">
                  <div class="flex items-start gap-4">
                    <div class="w-11 h-11 rounded-xl bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined">request_quote</span>
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between gap-3">
                        <div class="font-black text-slate-900">Scalapay</div>
                        <span class="inline-flex items-center rounded-full bg-slate-900 text-white text-xs font-black px-3 py-1">4x</span>
                      </div>
                      <div class="mt-1 text-sm text-slate-600"><%= t('checkout.pay4x') %></div>
                      <div class="mt-3 flex items-center gap-2 text-xs font-black text-slate-500">
                        <span class="material-symbols-outlined text-base text-slate-400">shield_lock</span>
                        <%= t('checkout.protectedPayment') %>
                      </div>
                    </div>
                  </div>
                </div>
              </label>

              <% const _veh = (typeof vehicle !== 'undefined' && vehicle) ? vehicle : null; %>
              <% const _vehType = _veh && _veh.identifierType === 'vin' ? 'vin' : 'plate'; %>
              <% const _vehPlate = _veh && _veh.plate ? _veh.plate : ''; %>
              <% const _vehVin = _veh && _veh.vin ? _veh.vin : ''; %>
              <% const _vehConsentChecked = Boolean(_veh && _veh.consentAt); %>

              <div class="mt-2 rounded-2xl border border-slate-200 bg-white p-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <div class="font-black text-slate-900"><%= t('checkout.vehicleTitle') %> <span class="text-rose-600">*</span></div>
                    <div class="mt-1 text-xs text-slate-600"><span class="font-semibold text-slate-700"><%= t('checkout.required') %></span><%= t('checkout.compatCheckText') %></div>
                  </div>
                  <div class="w-10 h-10 rounded-xl bg-slate-900/5 text-slate-700 flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined">directions_car</span>
                  </div>
                </div>

                <input name="vehicleIdentifierType" type="hidden" value="<%= _vehType %>" data-vehicle-type />

                <div class="mt-4 <%= _vehType === 'plate' ? '' : 'hidden' %>" data-vehicle-panel="plate">
                  <label class="block text-xs font-black uppercase tracking-widest text-slate-400" for="vehiclePlate"><%= t('checkout.plate') %></label>
                  <input class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" id="vehiclePlate" name="vehiclePlate" placeholder="Ex : AB-123-CD" type="text" value="<%= _vehPlate %>" data-vehicle-input="plate" <%= _vehType === 'plate' ? 'required' : '' %> />
                  <button class="mt-2 text-xs font-black text-primary hover:underline" data-vehicle-switch="vin" type="button"><%= t('checkout.useVin') %></button>
                </div>

                <div class="mt-4 <%= _vehType === 'vin' ? '' : 'hidden' %>" data-vehicle-panel="vin">
                  <label class="block text-xs font-black uppercase tracking-widest text-slate-400" for="vehicleVin"><%= t('checkout.vin') %></label>
                  <input class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" id="vehicleVin" name="vehicleVin" placeholder="Ex : VF1..." type="text" value="<%= _vehVin %>" data-vehicle-input="vin" <%= _vehType === 'vin' ? 'required' : '' %> />
                  <button class="mt-2 text-xs font-black text-primary hover:underline" data-vehicle-switch="plate" type="button"><%= t('checkout.backToPlate') %></button>
                </div>

                <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-3">
                  <p class="text-[11px] text-slate-500 leading-normal flex items-start gap-1.5">
                    <span class="material-symbols-outlined" style="font-size:14px">lock</span>
                    <span><%- t('checkout.plateUsage') %></span>
                  </p>
                </div>
              </div>

              <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <label class="flex items-start gap-3">
                  <input class="mt-1 rounded border-slate-300 text-primary focus:ring-primary" name="acceptCgv" required type="checkbox" value="true" />
                  <span class="text-xs text-slate-600 leading-normal">
                    <%= t('checkout.acceptCgvPre') %> <a class="text-primary font-black hover:underline" href="/legal/cgv" target="_blank" rel="noreferrer"><%= t('checkout.cgvLink') %></a>.
                  </span>
                </label>
              </div>

              <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <label class="flex items-start gap-3">
                  <input class="mt-1 rounded border-slate-300 text-primary focus:ring-primary" name="smsOptIn" type="checkbox" value="true" />
                  <span class="text-xs text-slate-600 leading-normal">
                    <%= t('checkout.smsOptIn') %>
                    <span class="block mt-1 text-[11px] text-slate-500"><%= t('checkout.unsubscribeAnytime') %></span>
                  </span>
                </label>
              </div>

              <button class="w-full mt-3 inline-flex items-center justify-center rounded-xl bg-primary text-white px-6 py-3 font-black hover:bg-red-700 transition" type="submit">
                <%= t('checkout.continue') %>
              </button>
            </form>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
            <a class="inline-flex items-center justify-center rounded-xl bg-slate-100 text-slate-700 px-5 py-3 font-black hover:bg-slate-200 transition" href="/commande/livraison"><%= t('checkout.backToShipping') %></a>
          </div>
        </div>
      </section>

      <aside class="lg:col-span-4">
        <div class="bg-white rounded-2xl border border-slate-200 p-6 sticky top-6">
          <div class="font-black text-slate-900"><%= t('checkout.orderSummary') %></div>

          <div class="mt-5 space-y-4">
            <% items.forEach((it) => { %>
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl overflow-hidden bg-slate-50 flex items-center justify-center flex-shrink-0">
                  <% if (it.product.imageUrl) { %>
                    <img alt="<%= it.product.name %>" class="w-full h-full object-cover" src="<%= it.product.imageUrl %>" />
                  <% } else { %>
                    <span class="material-symbols-outlined text-slate-400">inventory_2</span>
                  <% } %>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-black text-slate-900"><%= it.product.name %></div>
                  <% if (it.optionsSummary) { %>
                    <div class="text-xs text-slate-500"><%= it.optionsSummary %></div>
                  <% } %>
                  <div class="text-xs text-slate-500"><%= t('checkout.qty') %> <%= it.quantity %></div>
                </div>
                <div class="text-sm font-black text-slate-900"><%= (it.lineTotalCents / 100).toFixed(2).replace('.', ',') %> €</div>
              </div>
            <% }) %>
          </div>

          <div class="mt-6 pt-6 border-t border-slate-200 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <div class="text-slate-600"><%= t('cart.subtotal') %></div>
              <div class="font-black text-slate-900"><%= ((typeof itemsSubtotalCents !== 'undefined' ? itemsSubtotalCents : itemsTotalCents) / 100).toFixed(2).replace('.', ',') %> €</div>
            </div>

            <% if (typeof clientDiscountCents !== 'undefined' && clientDiscountCents > 0) { %>
              <div class="flex items-center justify-between">
                <div class="text-slate-600"><%= t('cart.accountDiscount', { pct: (typeof clientDiscountPercent !== 'undefined' ? String(clientDiscountPercent).replace('.', ',') : '') }) %></div>
                <div class="font-black text-slate-900">- <%= (clientDiscountCents / 100).toFixed(2).replace('.', ',') %> €</div>
              </div>
            <% } %>

            <% if (typeof promoDiscountCents !== 'undefined' && promoDiscountCents > 0) { %>
              <div class="flex items-center justify-between">
                <div class="text-slate-600"><%= t('cart.promoCodeLabel') %> <%= typeof promoCode !== 'undefined' && promoCode ? '(' + promoCode + ')' : '' %></div>
                <div class="font-black text-slate-900">- <%= (promoDiscountCents / 100).toFixed(2).replace('.', ',') %> €</div>
              </div>
            <% } %>

            <% if ((typeof clientDiscountCents !== 'undefined' && clientDiscountCents > 0) || (typeof promoDiscountCents !== 'undefined' && promoDiscountCents > 0)) { %>
              <div class="flex items-center justify-between">
                <div class="text-slate-600"><%= t('cart.subtotalAfter') %></div>
                <div class="font-black text-slate-900"><%= ((typeof itemsTotalAfterDiscountCents !== 'undefined' ? itemsTotalAfterDiscountCents : itemsTotalCents) / 100).toFixed(2).replace('.', ',') %> €</div>
              </div>
            <% } %>

            <div class="flex items-center justify-between">
              <div class="text-slate-600"><%= t('product.shipping') %></div>
              <div class="font-black text-slate-900"><%= shippingCostCents === 0 ? t('checkout.free').toUpperCase() : (shippingCostCents / 100).toFixed(2).replace('.', ',') + ' €' %></div>
            </div>
            <% if (typeof consigneChargeCents !== 'undefined' && consigneChargeCents > 0) { %>
              <div class="flex items-start justify-between gap-3">
                <div class="text-slate-600"><%= t('cart.consigne') %> <span class="text-slate-400 font-normal"><%= t('cart.consigneTax') %></span> <span class="block text-[11px] text-emerald-600 font-medium"><%= t('cart.consigneRefund') %></span></div>
                <div class="font-black text-slate-900"><%= (consigneChargeCents / 100).toFixed(2).replace('.', ',') %> €</div>
              </div>
            <% } %>
            <% if (typeof vatRC !== 'undefined' && vatRC && vatRC.active) { %>
              <div class="flex items-center justify-between text-indigo-700">
                <div>TVA — autoliquidée <span class="text-slate-400 font-normal">(pro UE)</span></div>
                <div class="font-black">− <%= (vatRC.vatAmountCents / 100).toFixed(2).replace('.', ',') %> €</div>
              </div>
            <% } %>
          </div>

          <% var _rc = (typeof vatRC !== 'undefined' && vatRC && vatRC.active); %>
          <div class="mt-4 pt-4 border-t border-slate-200 flex items-center justify-between">
            <div class="text-slate-600 font-black"><%= _rc ? 'Total HT' : t('checkout.total') %></div>
            <div class="text-primary font-black text-2xl"><%= ((_rc ? vatRC.totalCents : totalCents) / 100).toFixed(2).replace('.', ',') %> €</div>
          </div>
          <% if (_rc) { %>
            <div class="mt-2 flex items-start gap-2 rounded-lg bg-indigo-50 px-3 py-2 text-[12px] leading-snug text-indigo-700">
              <span class="material-symbols-outlined text-[16px] shrink-0">verified</span>
              <span>Autoliquidation de la TVA — n° <strong><%= vatRC.vatNumber %></strong> validé. Montant facturé <strong>HT</strong> (livraison intracommunautaire, art. 262 ter I du CGI).</span>
            </div>
          <% } %>

          <% if (typeof consigneChargeCents !== 'undefined' && consigneChargeCents > 0) { %>
            <div class="mt-2 flex items-start gap-2 rounded-lg bg-emerald-50 px-3 py-2 text-[12px] leading-snug text-emerald-700">
              <span class="material-symbols-outlined text-[16px] shrink-0">savings</span>
              <span><%- t('checkout.consigneNotePayment', { amount: (consigneChargeCents / 100).toFixed(2).replace('.', ',') }) %></span>
            </div>
          <% } %>

          <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-5 space-y-2">
            <div class="flex items-center gap-2 text-xs font-black text-slate-700">
              <span class="material-symbols-outlined text-base text-slate-400">verified</span>
              <%= t('checkout.qualityChecked') %>
            </div>
            <div class="flex items-center gap-2 text-xs font-black text-slate-700">
              <span class="material-symbols-outlined text-base text-slate-400">lock</span>
              <%= t('checkout.securePayProviders') %>
            </div>
            <div class="flex items-center gap-2 text-xs font-black text-slate-700">
              <span class="material-symbols-outlined text-base text-slate-400">autorenew</span>
              <%= t('checkout.easyReturns') %>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</main>

<script>
  (function () {
    var typeInput = document.querySelector('[data-vehicle-type]');
    var panelPlate = document.querySelector('[data-vehicle-panel="plate"]');
    var panelVin = document.querySelector('[data-vehicle-panel="vin"]');
    var switches = document.querySelectorAll('[data-vehicle-switch]');

    if (!typeInput || !panelPlate || !panelVin || !switches || !switches.length) return;

    var plateInput = panelPlate.querySelector('[data-vehicle-input="plate"]');
    var vinInput = panelVin.querySelector('[data-vehicle-input="vin"]');

    function setType(type) {
      var t = type === 'vin' ? 'vin' : 'plate';
      typeInput.value = t;

      if (t === 'vin') {
        panelPlate.classList.add('hidden');
        panelVin.classList.remove('hidden');
        // Le champ caché ne doit PAS être "required" (sinon le navigateur bloque
        // la soumission sur un champ non focusable) — on déplace l'obligation.
        if (plateInput) plateInput.required = false;
        if (vinInput) vinInput.required = true;
      } else {
        panelVin.classList.add('hidden');
        panelPlate.classList.remove('hidden');
        if (vinInput) vinInput.required = false;
        if (plateInput) plateInput.required = true;
      }
    }

    switches.forEach(function (btn) {
      btn.addEventListener('click', function () {
        setType(btn.getAttribute('data-vehicle-switch'));
      });
    });
  })();
</script>

<%- include('../partials/footer') %>
