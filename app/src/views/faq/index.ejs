<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-1 bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 transition-colors duration-300">
  <div class="mx-auto max-w-[1440px] px-4 md:px-10 py-10">

    <div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-12 w-12 rounded-2xl bg-primary/10 flex items-center justify-center">
          <span class="material-symbols-rounded text-primary text-3xl">help</span>
        </div>
        <div>
          <div class="text-xs font-black uppercase tracking-widest text-slate-400"><%= brand.NAME %></div>
          <h1 class="text-2xl sm:text-3xl font-black tracking-tight">Questions fréquentes</h1>
        </div>
      </div>

      <div class="space-y-4">
        <% (typeof faqItems !== 'undefined' && Array.isArray(faqItems) ? faqItems : []).forEach((item) => { %>
          <details class="group rounded-2xl border border-slate-200 bg-white overflow-hidden">
            <summary class="flex items-center justify-between gap-4 cursor-pointer p-5 font-bold text-sm hover:bg-slate-50 transition-colors">
              <span><%= item.question %></span>
              <span class="material-symbols-outlined text-slate-400 transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-slate-600 leading-relaxed">
              <%- item.answer %>
            </div>
          </details>
        <% }) %>
      </div>

      <div class="mt-10 rounded-2xl bg-slate-900 p-6 text-white text-center">
        <div class="font-black">Vous n'avez pas trouvé votre réponse ?</div>
        <div class="mt-2 text-sm text-white/70">Notre équipe est disponible du lundi au vendredi de 8h à 18h.</div>
        <div class="mt-5 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-5 py-3 text-xs font-black uppercase tracking-wider hover:bg-red-700 transition" href="/contact">
            <span class="material-symbols-outlined text-sm">chat_bubble</span>
            Nous contacter
          </a>
          <a class="inline-flex items-center justify-center gap-2 rounded-xl bg-white/10 px-5 py-3 text-xs font-black uppercase tracking-wider hover:bg-white/20 transition" href="tel:<%= brand.PHONE_INTL %>">
            <span class="material-symbols-outlined text-sm">call</span>
            <%= brand.PHONE %>
          </a>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
