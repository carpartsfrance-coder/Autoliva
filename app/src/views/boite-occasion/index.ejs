<p class="text-xs text-center text-gray-400 mt-4 flex justify-center items-center gap-1">
<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            Vos informations sont sécurisées et confidentielles.
          </p>

<script>
(function () {
  var form = document.getElementById('quote-multistep');
  if (!form) return;
  var step1 = form.querySelector('[data-step="1"]');
  var step2 = form.querySelector('[data-step="2"]');
  var nextBtn = form.querySelector('[data-step1-next]');
  var backBtns = form.querySelectorAll('[data-step2-back]');
  var plateInput = form.querySelector('input[name="plate"]');
  var phoneInput = form.querySelector('input[name="phone"]');
  var errMsg = form.querySelector('[data-step1-error]');
  var bar1 = document.querySelector('[data-step-bar="1"]');
  var bar2 = document.querySelector('[data-step-bar="2"]');
  var counter = document.querySelector('[data-step-counter]');
  var subtitle = document.querySelector('[data-step-subtitle]');
  var recap = form.querySelector('[data-step1-recap]');

  // ── Tracking funnel (GTM dataLayer) ──
  window.dataLayer = window.dataLayer || [];
  function track(ev, extra) {
    try { window.dataLayer.push(Object.assign({ event: ev, funnel: '<%= copy.funnelName %>' }, extra || {})); } catch (e) {}
  }
  // form_start : 1er focus sur un champ du formulaire (une seule fois)
  var _formStarted = false;
  form.addEventListener('focusin', function () {
    if (_formStarted) return;
    _formStarted = true;
    track('form_start');
  });

  function goStep(n) {
    if (n === 1) {
      step1.classList.remove('hidden'); step2.classList.add('hidden');
      bar1.classList.add('bg-brand-red'); bar1.classList.remove('bg-gray-200');
      bar2.classList.remove('bg-brand-red'); bar2.classList.add('bg-gray-200');
      if (counter) counter.textContent = '1 / 2';
      if (subtitle) subtitle.textContent = 'Étape 1 — Parlez-nous de votre véhicule';
      setTimeout(function(){ plateInput && plateInput.focus(); }, 50);
    } else {
      step1.classList.add('hidden'); step2.classList.remove('hidden');
      bar1.classList.add('bg-brand-red'); bar1.classList.remove('bg-gray-200');
      bar2.classList.add('bg-brand-red'); bar2.classList.remove('bg-gray-200');
      if (counter) counter.textContent = '2 / 2';
      if (subtitle) subtitle.textContent = 'Étape 2 — Comment vous joindre';
      track('funnel_step2_view');
      // Récap pour rappel + bouton modifier
      var plate = plateInput ? plateInput.value.trim() : '';
      if (recap) recap.textContent = plate || 'Véhicule renseigné';
      setTimeout(function(){ phoneInput && phoneInput.focus(); }, 50);
    }
  }

  nextBtn.addEventListener('click', function () {
    if (!plateInput.value.trim()) {
      errMsg.classList.remove('hidden');
      plateInput.focus();
      return;
    }
    errMsg.classList.add('hidden');
    track('funnel_step1_complete');
    goStep(2);
  });

  backBtns.forEach(function (btn) {
    btn.addEventListener('click', function () { goStep(1); });
  });

  // Submit : si phone vide, retour étape 2 (déjà visible)
  form.addEventListener('submit', function (e) {
    if (!plateInput.value.trim()) {
      e.preventDefault();
      goStep(1);
      errMsg.classList.remove('hidden');
      return;
    }
    if (!phoneInput.value.trim()) {
      e.preventDefault();
      goStep(2);
      phoneInput.focus();
    }
  });

  // Si le serveur a renvoyé une erreur ET qu'on a déjà des coordonnées remplies, aller direct à l'étape 2
  <% if (errorMessage && (form.phone || form.email || form.fullName)) { %>
  goStep(2);
  <% } %>
})();
</script>

<% } %>
</div>
</div>
</div>
