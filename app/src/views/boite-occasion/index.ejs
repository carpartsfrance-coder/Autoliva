<style>
  html { scroll-behavior: smooth; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  /* Anti-zoom iOS Safari : un champ < 16px déclenche un zoom auto au focus.
     On force 16px sur mobile/tablette uniquement (desktop garde le rendu actuel). */
  @media (max-width: 1023px) {
    input:not([type="radio"]):not([type="checkbox"]),
    select,
    textarea {
      font-size: 16px !important;
    }
  }
  /* Bande de logos partenaires : défilement auto en boucle infinie (marquee).
     Les logos sont dupliqués 2× dans le HTML ; on translate de -50% → boucle parfaite. */
  @keyframes brand-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .brand-marquee-track { animation: brand-marquee 28s linear infinite; will-change: transform; }
  .brand-marquee:hover .brand-marquee-track { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) { .brand-marquee-track { animation: none; } }
</style>

