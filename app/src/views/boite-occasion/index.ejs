<script>
  /* Champ « État » → masque « Complet / Nu » quand le moteur est reconditionné
     (un moteur reconditionné est toujours complet). Self-guarding : ne fait rien
     si le champ État n'est pas présent (landing /moteurs-reconditionnes). */
  (function () {
    var etatInputs = document.querySelectorAll('[data-etat-input]');
    var etBlock = document.querySelector('[data-enginetype-block]');
    if (!etatInputs.length) return;
    var hint = document.querySelector('[data-etat-hint]');
    var defaultHint = hint ? hint.textContent : '';
    function setHint(txt) { if (hint) hint.textContent = txt || defaultHint; }
    function selectedDesc() {
      var sel = document.querySelector('[data-etat-input]:checked');
      return sel ? sel.getAttribute('data-etat-desc') : '';
    }
    function sync() {
      var sel = document.querySelector('[data-etat-input]:checked');
      var isRecond = !!(sel && sel.value === 'reconditionne');
      if (etBlock) {
        etBlock.classList.toggle('hidden', isRecond);
        if (isRecond) document.querySelectorAll('[data-enginetype-input]').forEach(function (r) { r.checked = false; });
      }
      setHint(selectedDesc());
    }
    etatInputs.forEach(function (r) {
      r.addEventListener('change', sync);
      var lbl = r.closest('label');
      if (lbl) {
        // Aperçu au survol (desktop) : on montre le détail sans avoir à cliquer.
        lbl.addEventListener('mouseenter', function () { setHint(r.getAttribute('data-etat-desc')); });
        lbl.addEventListener('mouseleave', function () { setHint(selectedDesc()); });
      }
    });
    sync();
  })();
</script>

