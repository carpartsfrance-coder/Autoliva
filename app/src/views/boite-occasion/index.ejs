<!-- Sticky CTA — apparaît après le scroll au-delà du hero -->
<% if (!successMessage) { %>
<div id="sticky-cta" class="opacity-0 pointer-events-none transition-opacity duration-300">
<!-- Mobile : barre pleine largeur en bas -->
<div class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-white border-t border-gray-200 px-4 py-3 shadow-[0_-4px_20px_rgba(0,0,0,0.08)]">
<div class="flex gap-2">
<a href="#quote-form" data-cta="sticky-mobile" class="flex-1 inline-flex items-center justify-center gap-2 bg-brand-red text-white font-bold py-3 rounded-full text-sm">
Demander mon devis gratuit
</a>
<a href="tel:<%= brand.PHONE_MOTEUR_INTL %>" class="inline-flex items-center justify-center w-12 shrink-0 border-2 border-gray-300 text-brand-red rounded-full" aria-label="Appeler">
<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11 11 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path></svg>
</a>
</div>
</div>
<!-- Desktop : bouton flottant coin bas-droite -->
<a href="#quote-form" data-cta="sticky-desktop" class="hidden lg:inline-flex fixed bottom-6 right-6 z-40 items-center gap-2 bg-brand-red hover:bg-brand-redhover text-white font-bold py-4 px-7 rounded-full shadow-xl shadow-brand-red/30 transition">
<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path></svg>
Demander mon devis gratuit
</a>
</div>
<script>
(function () {
  var sticky = document.getElementById('sticky-cta');
  var form = document.getElementById('quote-form');
  if (!sticky || !form) return;
  function onScroll() {
    // Affiche le CTA dès qu'on a scrollé au-delà du hero/formulaire
    var heroBottom = form.getBoundingClientRect().bottom;
    var show = heroBottom < 0; // le formulaire du hero est passé au-dessus du viewport
    sticky.classList.toggle('opacity-0', !show);
    sticky.classList.toggle('pointer-events-none', !show);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>

<!-- Tracking clics CTA (quel emplacement convertit le mieux) -->
<script>
(function () {
  window.dataLayer = window.dataLayer || [];
  document.addEventListener('click', function (e) {
    var a = e.target && e.target.closest ? e.target.closest('a[data-cta]') : null;
    if (!a) return;
    try {
      window.dataLayer.push({
        event: 'cta_click',
        funnel: '<%= copy.funnelName %>',
        cta_location: a.getAttribute('data-cta') || 'unknown'
      });
    } catch (err) {}
  }, true);
})();
</script>
<% } %>

<!-- Footer du site (même que la home) -->

<!-- Confirmation lead : dataLayer (GTM) + conversion Google Ads (gtag, avec suivi avancé) -->
<% if (successMessage) { %>
<script>
(function () {
  var c = <%- JSON.stringify(typeof conversion !== 'undefined' && conversion ? conversion : null).replace(/</g, '\\u003c') %>;
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: 'lead_submitted',
    lead_source: '<%= copy.funnelName %>',
    lead_category: 'boite',
    lead_ref: (c && c.ref) || '',
    page_path: window.location.pathname
  });
  // Conversion Google Ads "Envoi form" — UNIQUEMENT pour un vrai lead (c.ref présent),
  // jamais pour le honeypot (faux succès bot). Suivi avancé : email + téléphone (E.164).
  if (c && c.ref && typeof gtag === 'function') {
    if (c.email || c.phone) {
      gtag('set', 'user_data', {
        email: c.email || undefined,
        phone_number: c.phone || undefined
      });
    }
    gtag('event', 'conversion', {
      send_to: 'AW-16778404215/kK_sCIiYu70bEPfCyMA-',
      value: c.value || 1.0,
      currency: 'EUR',
      transaction_id: c.ref
    });
  }
})();
</script>
<% } %>

<%- include('../partials/footer') %>
