<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'cart-activity' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Leads à relancer'}] }) %>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Leads à relancer</div>
        <div class="mt-1 text-sm text-slate-500">Visiteurs avec activité panier ou demande de devis, prêts à être recontactés.</div>
      </div>
    </div>

    <!-- KPIs (30 derniers jours) -->
    <div class="mt-8 grid grid-cols-2 lg:grid-cols-5 gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase tracking-widest text-slate-400 font-semibold">Leads (30j)</div>
        <div class="mt-1 text-2xl font-bold text-slate-900"><%= kpis.total %></div>
      </div>
      <div class="rounded-2xl border border-red-100 bg-red-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-red-500 font-semibold">À contacter</div>
        <div class="mt-1 text-2xl font-bold text-red-700"><%= kpis.uncontacted %></div>
      </div>
      <div class="rounded-2xl border border-blue-100 bg-blue-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-blue-500 font-semibold">Contactés</div>
        <div class="mt-1 text-2xl font-bold text-blue-700"><%= kpis.contacted %></div>
      </div>
      <div class="rounded-2xl border border-green-100 bg-green-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-green-500 font-semibold">Convertis</div>
        <div class="mt-1 text-2xl font-bold text-green-700"><%= kpis.converted %> <span class="text-sm font-medium text-green-600">(<%= kpis.recoveryRate %>%)</span></div>
      </div>
      <div class="rounded-2xl border border-amber-100 bg-amber-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-amber-600 font-semibold">€ en attente</div>
        <div class="mt-1 text-2xl font-bold text-amber-700"><%= kpis.pendingValue || '0,00 €' %></div>
      </div>
    </div>

    <!-- Onglets : file de travail vs historique complet -->
    <div class="mt-6 flex items-center gap-2">
      <a href="<%= tabs.todoUrl %>" class="inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold border <%= view === 'todo' ? 'bg-slate-900 text-white border-slate-900' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50' %>">
        À traiter
        <span class="inline-flex items-center justify-center rounded-full px-2 py-0.5 text-[11px] font-bold <%= view === 'todo' ? 'bg-white/20 text-white' : 'bg-red-50 text-red-700' %>"><%= tabs.todoCount %></span>
      </a>
      <a href="<%= tabs.allUrl %>" class="inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold border <%= view === 'all' ? 'bg-slate-900 text-white border-slate-900' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50' %>">
        Tous
        <span class="inline-flex items-center justify-center rounded-full px-2 py-0.5 text-[11px] font-bold <%= view === 'all' ? 'bg-white/20 text-white' : 'bg-slate-100 text-slate-600' %>"><%= tabs.allCount %></span>
      </a>
      <div class="ml-2 text-xs text-slate-400 hidden md:block">
        <% if (view === 'todo') { %>Jamais contactés, cycle en cours — hors devis moteur/boîte (gérés dans « Devis moteurs &amp; boîtes »).<% } else { %>Historique complet, y compris contactés, convertis, perdus et leads devis.<% } %>
      </div>
      <button type="button" id="leads-help-btn" class="ml-auto inline-flex items-center gap-1.5 rounded-xl px-3 py-2 text-xs font-semibold border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 flex-shrink-0">
        <span class="material-symbols-outlined text-base text-primary">school</span>Comprendre cette page
      </button>
    </div>

    <!-- Filtres -->
    <form action="/admin/activite-panier" class="mt-4 bg-white rounded-2xl border border-slate-200 p-4 shadow-sm" method="GET">
      <input type="hidden" name="view" value="<%= view %>" />
      <div class="grid grid-cols-2 lg:grid-cols-7 gap-3">

        <input type="text" name="q" value="<%= filters.q || '' %>" placeholder="Email, nom, tél…"
          class="col-span-2 lg:col-span-2 rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20" />

        <select name="manual" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white">
          <option value="">Statut manuel: tous</option>
          <option value="none" <%= filters.manualStatus === 'none' ? 'selected' : '' %>>Non contacté</option>
          <option value="contacted" <%= filters.manualStatus === 'contacted' ? 'selected' : '' %>>Contacté</option>
          <option value="converted" <%= filters.manualStatus === 'converted' ? 'selected' : '' %>>Converti</option>
          <option value="lost" <%= filters.manualStatus === 'lost' ? 'selected' : '' %>>Perdu</option>
        </select>

        <select name="source" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white">
          <option value="">Source: toutes</option>
          <option value="user" <%= filters.captureSource === 'user' ? 'selected' : '' %>>Compte client</option>
          <option value="guest_checkout" <%= filters.captureSource === 'guest_checkout' ? 'selected' : '' %>>Guest checkout</option>
          <option value="devis" <%= filters.captureSource === 'devis' ? 'selected' : '' %>>Demande devis</option>
          <option value="landing_moteurs" <%= filters.captureSource === 'landing_moteurs' ? 'selected' : '' %>>Landing Moteurs occasion</option>
          <option value="landing_boites" <%= filters.captureSource === 'landing_boites' ? 'selected' : '' %>>Landing Boîtes occasion</option>
          <option value="contact" <%= filters.captureSource === 'contact' ? 'selected' : '' %>>Contact</option>
          <option value="newsletter" <%= filters.captureSource === 'newsletter' ? 'selected' : '' %>>Newsletter</option>
          <option value="cart_activity" <%= filters.captureSource === 'cart_activity' ? 'selected' : '' %>>Panier</option>
          <option value="blog_cta" <%= filters.captureSource === 'blog_cta' ? 'selected' : '' %>>Article blog</option>
        </select>

        <select name="channel" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white">
          <option value="">Canal: tous</option>
          <option value="email" <%= filters.channel === 'email' ? 'selected' : '' %>>Email dispo</option>
          <option value="phone" <%= filters.channel === 'phone' ? 'selected' : '' %>>Tél dispo</option>
          <option value="both" <%= filters.channel === 'both' ? 'selected' : '' %>>Email + Tél</option>
        </select>

        <select name="period" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white">
          <option value="7d" <%= filters.period === '7d' ? 'selected' : '' %>>7 jours</option>
          <option value="30d" <%= !filters.period || filters.period === '30d' ? 'selected' : '' %>>30 jours</option>
          <option value="90d" <%= filters.period === '90d' ? 'selected' : '' %>>90 jours</option>
        </select>

        <select name="sort" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white">
          <option value="recent" <%= !filters.sort || filters.sort === 'recent' ? 'selected' : '' %>>Récent ↓</option>
          <option value="amount" <%= filters.sort === 'amount' ? 'selected' : '' %>>Montant ↓</option>
          <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Ancien ↑</option>
        </select>

      </div>
      <div class="mt-3 flex items-center gap-2">
        <button class="btn btn-primary text-sm" type="submit">Appliquer</button>
        <a href="/admin/activite-panier" class="btn btn-ghost text-sm">Réinitialiser</a>
      </div>
    </form>

    <!-- Liste de leads -->
    <div class="mt-6 bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-5 py-3 bg-slate-50 border-b border-slate-100 flex items-center justify-between">
        <div class="font-semibold text-slate-900 text-sm"><%= pagination.totalItems %> lead<%= pagination.totalItems > 1 ? 's' : '' %></div>
        <% if (pagination.totalItems > 0) { %>
          <div class="text-xs text-slate-500"><%= pagination.from %>–<%= pagination.to %></div>
        <% } %>
      </div>

      <% if (leads && leads.length) { %>
        <ul class="divide-y divide-slate-100">
          <% leads.forEach((c) => { %>
            <%# Bordure gauche = priorité : rouge à appeler, bleu en cours, vert gagné, gris perdu, ambre relances auto seules %>
            <% var _prioBorder = { call: 'border-l-red-500', inprogress: 'border-l-blue-400', won: 'border-l-green-500', lost: 'border-l-slate-300', auto: 'border-l-amber-400' }[c.priority] || 'border-l-slate-200'; %>
            <li class="lead-row p-5 hover:bg-slate-50/60 transition border-l-4 <%= _prioBorder %>" data-lead-id="<%= c.id %>">
              <div class="flex flex-col lg:flex-row lg:items-start gap-4">

                <!-- Avatar / icône selon source -->
                <div class="flex-shrink-0">
                  <% if (c.showRequestAsPrimary) { %>
                    <div class="w-14 h-14 rounded-xl bg-teal-50 border border-teal-200 flex items-center justify-center" title="Demande explicite (devis/contact)">
                      <span class="material-symbols-outlined text-teal-600">request_quote</span>
                    </div>
                  <% } else if (c.firstItemImage) { %>
                    <img src="<%= c.firstItemImage %>" alt="" class="w-14 h-14 rounded-xl object-cover border border-slate-200" />
                  <% } else { %>
                    <div class="w-14 h-14 rounded-xl bg-slate-100 flex items-center justify-center">
                      <span class="material-symbols-outlined text-slate-400">person</span>
                    </div>
                  <% } %>
                </div>

                <!-- Infos client -->
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-2">
                    <div class="text-[15px] font-bold text-slate-900">
                      <%= c.fullName || c.email || c.phone || 'Anonyme' %>
                    </div>
                    <% if (c.priority === 'call') { %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-red-600 text-white px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider">À appeler</span>
                    <% } %>
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider <%= c.statusBadge.className %>">
                      <%= c.statusBadge.label %>
                    </span>
                    <% if (c.captureSource) { %>
                      <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium <%= c.captureBadge.className %>">
                        <%= c.captureBadge.label %>
                      </span>
                    <% } %>
                    <% if (c.engineQuoteUrl) { %>
                      <a href="<%= c.engineQuoteUrl %>" class="inline-flex items-center gap-0.5 text-[11px] font-semibold text-primary hover:underline">Dossier devis <span class="material-symbols-outlined text-xs">arrow_forward</span></a>
                    <% } %>
                    <% if (c.totalAmountCents > 0) { %>
                      <span class="ml-auto text-base font-extrabold text-slate-900 whitespace-nowrap"><%= c.totalAmount %></span>
                    <% } %>
                  </div>

                  <div class="mt-1.5 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
                    <% if (c.phone) { %>
                      <button type="button" data-copy-phone="<%= c.phone %>" class="font-bold text-slate-900 hover:text-primary inline-flex items-center gap-1.5 cursor-pointer" title="Cliquer pour copier le numéro (à coller dans votre logiciel d'appel)">
                        <span class="material-symbols-outlined text-base text-emerald-600">call</span><%= c.phone %>
                        <% if (!c.phoneCallable) { %>
                          <span class="text-xs font-normal text-amber-600">(format ?)</span>
                        <% } %>
                        <span class="material-symbols-outlined text-[13px] text-slate-300">content_copy</span>
                      </button>
                    <% } %>
                    <% if (c.email) { %>
                      <a href="mailto:<%= c.email %>" class="text-slate-600 hover:text-primary inline-flex items-center gap-1">
                        <span class="material-symbols-outlined text-base text-slate-400">mail</span><%= c.email %>
                      </a>
                    <% } %>
                    <span class="text-slate-400 text-xs cursor-help border-b border-dotted border-slate-300" title="« Reçu » = quand le client a laissé sa demande / abandonné son panier. « Dernier signe » = sa dernière action sur le site (nouveau passage, formulaire) — <%= c.lastActivityAbsolute %>. Plus c'est récent, plus il est chaud !">Reçu <%= c.receivedRel %><% if (c.lastActivityRel !== c.receivedRel) { %> · dernier signe du client <%= c.lastActivityRel %><% } %></span>
                  </div>

                  <% if (c.showRequestAsPrimary) { %>
                    <!-- Demande explicite (devis/contact) en bandeau principal -->
                    <div class="mt-2 rounded-lg bg-teal-50/60 border border-teal-100 px-3 py-2">
                      <div class="text-[10px] uppercase tracking-wider text-teal-700 font-semibold">Demande</div>
                      <div class="mt-0.5 text-sm font-medium text-slate-900">
                        <% if (c.requestSummary) { %>
                          <%= c.requestSummary %>
                        <% } else { %>
                          <span class="text-slate-500 italic">Demande sans détails produit</span>
                        <% } %>
                      </div>
                      <% if (c.requested.message) { %>
                        <div class="mt-1 text-xs text-slate-600 italic line-clamp-2">"<%= c.requested.message.slice(0, 180) %><%= c.requested.message.length > 180 ? '…' : '' %>"</div>
                      <% } %>
                    </div>
                    <% if (c.itemCount > 0) { %>
                      <div class="mt-1.5 text-xs text-slate-400">
                        🛒 Avait aussi en panier : <%= c.itemsSummary %> · <%= c.totalAmount %>
                        <span class="text-amber-600 font-medium ml-1">(panier ≠ demande)</span>
                      </div>
                    <% } %>
                  <% } else { %>
                    <!-- Lead "panier" classique -->
                    <% if (c.itemCount > 0) { %>
                    <div class="mt-2 text-sm text-slate-600 truncate" title="<%= c.itemsSummary %>">
                      <span class="font-medium text-slate-900"><%= c.totalAmount %></span>
                      <span class="text-slate-400">·</span>
                      <%= c.itemsSummary %>
                      <span class="text-slate-400 text-xs">(<%= c.itemCount %> art.)</span>
                    </div>
                    <% } %>
                  <% } %>

                  <!-- ═ Suivi : relances AUTO + actions du commercial + dernière note ═ -->
                  <div class="mt-2.5 flex flex-wrap items-center gap-1.5 text-[11.5px] leading-none">

                    <%# Relances automatiques (cycle email panier) : R1 R2 R3 %>
                    <% if (c.autoReminders.applicable) { %>
                      <span class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-slate-50 px-2 py-[5px] font-medium text-slate-600" title="Emails de relance AUTOMATIQUES du cycle panier abandonné (1h / +24h / +72h)<%= c.autoReminders.lastRel ? ' — dernier envoyé ' + c.autoReminders.lastRel : ' — aucun parti pour l\'instant' %>">
                        <span class="material-symbols-outlined text-[13px] text-slate-400">schedule_send</span>
                        Auto
                        <% for (var _r = 1; _r <= 3; _r++) { %>
                          <span class="inline-flex items-center justify-center min-w-[19px] h-[17px] px-0.5 rounded text-[9px] font-bold <%= _r <= c.autoReminders.sent ? 'bg-emerald-500 text-white' : 'bg-slate-200 text-slate-500' %>" title="Email de relance n°<%= _r %><%= _r <= c.autoReminders.sent ? ' : ENVOYÉ' : ' : pas encore parti' %>">R<%= _r %></span>
                        <% } %>
                        <% if (c.autoReminders.sent > 0 && c.autoReminders.lastRel) { %><span class="text-slate-400 font-normal">dern. <%= c.autoReminders.lastRel %></span><% } %>
                        <% if (c.autoReminders.cycleDone) { %><span class="text-slate-400 font-normal">· cycle terminé</span><% } %>
                      </span>
                    <% } %>

                    <%# Suivi commercial : jamais contacté (alerte) OU récap emails/SMS/statut.
                        L'alerte rouge n'a pas de sens sur un lead gagné/perdu. %>
                    <% if (c.neverTouched && c.priority !== 'won' && c.priority !== 'lost') { %>
                      <span class="inline-flex items-center gap-1 rounded-lg border border-red-200 bg-red-50 px-2 py-[5px] font-bold text-red-700">
                        <span class="material-symbols-outlined text-[13px]">priority_high</span>Jamais contacté par le commercial
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1.5 rounded-lg border border-blue-200 bg-blue-50 px-2 py-[5px] font-medium text-blue-800" title="Actions manuelles du commercial sur ce lead">
                        <span class="material-symbols-outlined text-[13px]">support_agent</span>
                        <% if (c.manualEmailsSent) { %><%= c.manualEmailsSent %> email<%= c.manualEmailsSent > 1 ? 's' : '' %><% } %>
                        <% if (c.manualEmailsSent && c.manualSmsSent) { %>·<% } %>
                        <% if (c.manualSmsSent) { %><%= c.manualSmsSent %> SMS<% } %>
                        <% if (!c.manualEmailsSent && !c.manualSmsSent) { %>Suivi<% } %>
                        <% if (c.lastManualContactRel) { %><span class="font-normal text-blue-600">· dern. <%= c.lastManualContactRel %></span><% } %>
                      </span>
                      <% if (c.manualStatus) { %>
                        <% var _msLabel = { contacted: 'Contacté', converted: 'Converti', lost: 'Perdu' }[c.manualStatus] || c.manualStatus; %>
                        <span class="text-slate-500">→ <strong><%= _msLabel %></strong><%= c.manualStatusByName ? ' par ' + c.manualStatusByName : '' %><%= c.manualStatusAtRel ? ' · ' + c.manualStatusAtRel : '' %></span>
                      <% } %>
                    <% } %>

                    <%# Commande rapprochée : ce lead est devenu un CLIENT %>
                    <% if (c.recoveredOrderBadge) { %>
                      <a href="<%= c.recoveredOrderBadge.url %>" class="inline-flex items-center gap-1 rounded-lg border border-green-300 bg-green-50 px-2 py-[5px] font-bold text-green-800 hover:bg-green-100 transition" title="Ce client a passé commande — cliquer pour ouvrir la commande. On ne le relance plus, mais on le garde : c'est un client pour le réachat.">
                        <span class="material-symbols-outlined text-[13px]">shopping_bag</span>
                        A commandé<%= c.recoveredOrderBadge.number ? ' — n°' + c.recoveredOrderBadge.number : '' %><%= c.recoveredOrderBadge.totalEuro ? ' · ' + c.recoveredOrderBadge.totalEuro : '' %><%= c.recoveredOrderBadge.atRel ? ' · ' + c.recoveredOrderBadge.atRel : '' %>
                      </a>
                    <% } %>
                    <% if (c.repurchaseSentRel) { %>
                      <span class="inline-flex items-center gap-1 text-slate-500" title="Email automatique « besoin d'autre chose ? » envoyé ~3 mois après son achat">
                        <span class="material-symbols-outlined text-[13px] text-slate-400">autorenew</span>Relance réachat envoyée <%= c.repurchaseSentRel %>
                      </span>
                    <% } %>

                    <%# 360° client : a-t-il DÉJÀ commandé chez nous ? A-t-il un SAV ? %>
                    <% if (c.clientHistory) { %>
                      <a href="<%= c.clientHistory.lastUrl %>" class="inline-flex items-center gap-1 rounded-lg border border-indigo-200 bg-indigo-50 px-2 py-[5px] font-bold text-indigo-800 hover:bg-indigo-100 transition" title="<%= c.clientHistory.title %>">
                        <span class="material-symbols-outlined text-[13px]">loyalty</span>
                        Déjà client · <%= c.clientHistory.count %> commande<%= c.clientHistory.count > 1 ? 's' : '' %> · dern. <%= c.clientHistory.lastRel %>
                      </a>
                    <% } %>
                    <% if (c.savHistory) { %>
                      <a href="<%= c.savHistory.url %>" class="inline-flex items-center gap-1 rounded-lg border px-2 py-[5px] font-bold transition <%= c.savHistory.openCount ? 'border-amber-300 bg-amber-50 text-amber-800 hover:bg-amber-100' : 'border-slate-200 bg-slate-50 text-slate-600 hover:bg-slate-100' %>" title="<%= c.savHistory.title %>">
                        <span class="material-symbols-outlined text-[13px]">build_circle</span>
                        <% if (c.savHistory.openCount) { %>SAV en cours (<%= c.savHistory.openCount %>) · <%= c.savHistory.lastStatut %><% } else { %>SAV : <%= c.savHistory.count %> clos<% } %>
                      </a>
                    <% } %>

                    <%# Dernière note interne (l'historique complet est dans Détail) %>
                    <% if (c.lastNote) { %>
                      <span class="inline-flex items-center gap-1 text-slate-500 min-w-0">
                        <span class="material-symbols-outlined text-[13px] text-slate-400 flex-shrink-0">sticky_note_2</span>
                        <span class="truncate max-w-[360px]">« <%= c.lastNote.text %> » — <%= c.lastNote.by %><%= c.lastNote.atRel ? ', ' + c.lastNote.atRel : '' %></span>
                      </span>
                    <% } %>
                  </div>
                </div>

                <!-- Actions commerciales -->
                <div class="flex flex-wrap items-center gap-1.5 lg:flex-col lg:items-stretch lg:w-[230px] lg:flex-shrink-0 lg:border-l lg:border-slate-100 lg:pl-4">
                  <% if (c.phone && c.phoneCallable) { %>
                    <button type="button" data-copy-phone="<%= c.phone %>" class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold px-3 py-2 transition" title="Copie le numéro pour le coller dans votre logiciel d'appel">
                      <span class="material-symbols-outlined text-sm">content_copy</span>Copier le n°
                    </button>
                  <% } %>
                  <div class="flex gap-1.5 w-full lg:w-auto">
                    <% if (c.email) { %>
                      <button type="button" class="btn btn-secondary text-xs flex-1 justify-center lead-action" data-action="email" data-lead-id="<%= c.id %>" data-lead-email="<%= c.email %>" data-lead-name="<%= c.fullName %>">
                        <span class="material-symbols-outlined text-sm mr-1">mail</span>Email
                      </button>
                    <% } %>
                    <% if (c.phone && c.phoneCallable) { %>
                      <button type="button" class="btn btn-secondary text-xs flex-1 justify-center lead-action" data-action="sms" data-lead-id="<%= c.id %>" data-lead-phone="<%= c.phone %>" data-lead-name="<%= c.fullName %>">
                        <span class="material-symbols-outlined text-sm mr-1">sms</span>SMS
                      </button>
                    <% } %>
                  </div>
                  <% if (c.phone && c.phoneCallable) { %>
                    <%# SMS 1 clic : ouvre la fenêtre SMS avec le bon modèle pré-rempli (à relire avant envoi). %>
                    <div class="flex gap-1 w-full lg:w-auto">
                      <button type="button" class="lead-action flex-1 justify-center inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 text-[10.5px] font-semibold px-1.5 py-1 transition" data-action="sms" data-sms-template="sms_compat_ok" data-lead-id="<%= c.id %>" data-lead-phone="<%= c.phone %>" data-lead-name="<%= c.fullName %>" title="SMS « Compatibilité vérifiée » pré-rempli — à relire avant d'envoyer"><span class="material-symbols-outlined text-[13px] mr-0.5">check_circle</span>Compat</button>
                      <button type="button" class="lead-action flex-1 justify-center inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 text-[10.5px] font-semibold px-1.5 py-1 transition" data-action="sms" data-sms-template="sms_tried_to_call" data-lead-id="<%= c.id %>" data-lead-phone="<%= c.phone %>" data-lead-name="<%= c.fullName %>" title="SMS « J'ai essayé de vous joindre » pré-rempli"><span class="material-symbols-outlined text-[13px] mr-0.5">call</span>Rappel</button>
                    </div>
                  <% } %>
                  <% if (c.canRemind) { %>
                    <button type="button" class="lead-remind-btn inline-flex items-center justify-center gap-1 rounded-lg border border-amber-300 bg-amber-50 hover:bg-amber-100 text-amber-800 text-[11px] font-bold px-2 py-1.5 transition" data-lead-id="<%= c.id %>" data-next="<%= c.nextReminderNumber %>" title="Envoie tout de suite l'email de relance automatique n°<%= c.nextReminderNumber %> (au lieu d'attendre le cron)">
                      <span class="material-symbols-outlined text-sm">forward_to_inbox</span>Relance auto n°<%= c.nextReminderNumber %>
                    </button>
                  <% } %>

                  <!-- Statut : le commercial marque où il en est -->
                  <div class="inline-flex items-stretch rounded-lg overflow-hidden border border-slate-200 w-full lg:w-auto">
                    <button type="button" class="lead-status-btn flex-1 px-1 py-1.5 text-[10.5px] <%= c.manualStatus === 'contacted' ? 'bg-blue-100 text-blue-800 font-semibold' : 'bg-white hover:bg-slate-50 text-slate-600' %>" data-lead-id="<%= c.id %>" data-status="contacted" title="Marquer contacté (re-cliquer pour annuler)">📞 Contacté</button>
                    <button type="button" class="lead-status-btn flex-1 px-1 py-1.5 text-[10.5px] border-l border-slate-200 <%= c.manualStatus === 'converted' ? 'bg-green-100 text-green-800 font-semibold' : 'bg-white hover:bg-slate-50 text-slate-600' %>" data-lead-id="<%= c.id %>" data-status="converted" title="Marquer gagné (re-cliquer pour annuler)">✅ Gagné</button>
                    <button type="button" class="lead-status-btn flex-1 px-1 py-1.5 text-[10.5px] border-l border-slate-200 <%= c.manualStatus === 'lost' ? 'bg-slate-200 text-slate-600 font-semibold' : 'bg-white hover:bg-slate-50 text-slate-600' %>" data-lead-id="<%= c.id %>" data-status="lost" title="Marquer perdu (re-cliquer pour annuler)">✖ Perdu</button>
                  </div>

                  <div class="flex items-center gap-1 w-full lg:w-auto">
                    <button type="button" class="btn btn-ghost text-xs flex-1 justify-center lead-detail-btn" data-lead-id="<%= c.id %>">
                      <span class="material-symbols-outlined text-sm mr-1">visibility</span>Détail &amp; notes<% if (c.notesCount) { %> (<%= c.notesCount %>)<% } %>
                    </button>
                    <% if (c.sessionId) { %>
                      <a href="/admin/visiteurs/<%= c.sessionId %>" class="btn btn-ghost text-xs px-2" title="Voir le parcours de navigation du client">
                        <span class="material-symbols-outlined text-sm">play_circle</span>
                      </a>
                    <% } %>
                  </div>
                </div>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <div class="p-12 text-center">
          <span class="material-symbols-outlined text-slate-300" style="font-size:48px">inbox</span>
          <p class="mt-3 text-slate-500">Aucun lead correspondant aux filtres.</p>
          <a href="/admin/activite-panier" class="mt-2 inline-block text-sm text-primary hover:underline">Réinitialiser les filtres</a>
        </div>
      <% } %>

      <!-- Pagination -->
      <% if (pagination.totalPages > 1) { %>
        <div class="px-5 py-3 border-t border-slate-100 flex items-center justify-between bg-slate-50">
          <div class="text-xs text-slate-500">Page <%= pagination.page %> / <%= pagination.totalPages %></div>
          <div class="flex items-center gap-2">
            <% if (pagination.hasPrev) { %>
              <a href="?<%= filtersQS ? filtersQS + '&' : '' %>page=<%= pagination.prevPage %>" class="btn btn-ghost text-xs">← Précédent</a>
            <% } %>
            <% if (pagination.hasNext) { %>
              <a href="?<%= filtersQS ? filtersQS + '&' : '' %>page=<%= pagination.nextPage %>" class="btn btn-ghost text-xs">Suivant →</a>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>

    <% if (!dbConnected) { %>
      <div class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="font-bold">Mode démo</div>
        <div class="mt-1 text-sm">Base de données indisponible.</div>
      </div>
    <% } %>
  </div>
</main>

<!-- Modal: guide « Comprendre cette page » (formation commercial) -->
