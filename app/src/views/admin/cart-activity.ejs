            <span class="inline-flex items-center justify-center min-w-[19px] h-[17px] px-0.5 rounded text-[9px] font-bold bg-emerald-500 text-white">R1</span>
            <span class="inline-flex items-center justify-center min-w-[19px] h-[17px] px-0.5 rounded text-[9px] font-bold bg-emerald-500 text-white">R2</span>
