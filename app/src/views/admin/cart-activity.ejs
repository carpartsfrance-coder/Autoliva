      + '<textarea id="lead-sms-text" name="text" rows="5" required maxlength="480" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" placeholder="Message SMS court…"></textarea>'
      + '<div class="text-xs text-slate-400"><span id="sms-count">0</span>/480 caractères · <span class="text-amber-600">Au-delà de 160 = SMS multipart (coût × n)</span></div>'
      + '<div id="lead-sms-linkwarn" class="hidden rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-xs px-3 py-2">⚠️ Un lien dans un SMS « CarParts » est bloqué par les opérateurs — le client ne le recevra pas. Retire le lien, envoie-le par email.</div>'
      + '<div class="flex items-center gap-2 pt-2">'
      + '  <button type="submit" class="btn btn-primary text-sm">📱 Envoyer SMS</button>'
      + '  <button type="button" onclick="document.getElementById(\'lead-modal\').classList.add(\'hidden\')" class="btn btn-ghost text-sm">Annuler</button>'
      + '</div>'
      + '<div id="lead-sms-result" class="text-sm"></div>'
      + '</form>';

    var form = document.getElementById('lead-sms-form');
    var ta = document.getElementById('lead-sms-text');
    var counter = document.getElementById('sms-count');
    var templateEl = document.getElementById('lead-sms-template');
    var linkWarn = document.getElementById('lead-sms-linkwarn');
    var submitBtn = form.querySelector('button[type="submit"]');

    attachVariableInserters(form);

    function smsHasLink(t) { return /https?:\/\/|www\.[a-z0-9-]+\.[a-z]{2,}|\b[a-z0-9-]{2,}\.(?:fr|com|net|org|eu|io|co|shop|store)\b/i.test(t || ''); }
    function updateCount() {
      counter.textContent = ta.value.length;
      var bad = smsHasLink(ta.value);
      if (linkWarn) linkWarn.classList.toggle('hidden', !bad);
      if (submitBtn) { submitBtn.disabled = bad; submitBtn.style.opacity = bad ? '0.4' : ''; submitBtn.style.cursor = bad ? 'not-allowed' : ''; }
    }
    ta.addEventListener('input', updateCount);

    function applyTemplate(tpl) {
      if (!tpl) return;
      ta.value = tpl.body || '';
      updateCount();
    }

    var presetSms = presetTemplateKey ? SMS_TEMPLATES.find(function (t) { return t.key === presetTemplateKey; }) : null;
    var defaultSms = presetSms || SMS_TEMPLATES.find(function (t) {
      return t.forSource && t.forSource.indexOf(c.captureSource) >= 0;
    }) || SMS_TEMPLATES.find(function (t) { return t.key === 'sms_tried_to_call'; });
    if (defaultSms) { templateEl.value = defaultSms.key; applyTemplate(defaultSms); }

    templateEl.addEventListener('change', function () {
      var tpl = SMS_TEMPLATES.find(function (t) { return t.key === templateEl.value; });
      if (tpl) applyTemplate(tpl);
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var resultEl = document.getElementById('lead-sms-result');
      resultEl.textContent = 'Envoi…';
      fetch('/admin/api/leads/' + leadId + '/sms', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: ta.value, templateKey: templateEl.value || '' }),
      })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d && d.ok) {
            var canEmail = !!c.email;
            var extra = canEmail ? ' · <button type="button" id="sms-then-email" class="underline font-semibold text-blue-700">＋ enchaîner un email (lien / devis)</button>' : '';
            resultEl.innerHTML = '<span class="text-green-700 font-semibold">✓ SMS envoyé à ' + escapeHtml(d.sentTo) + '</span>' + extra;
            var reloadTimer = setTimeout(refresh, canEmail ? 6000 : 1200);
            var thenBtn = document.getElementById('sms-then-email');
            if (thenBtn) thenBtn.addEventListener('click', function () { clearTimeout(reloadTimer); openEmailModal(leadId, c); });
          }
          else resultEl.innerHTML = '<span class="text-red-700">Erreur : ' + escapeHtml(d && d.error ? d.error : '?') + '</span>';
        })
        .catch(function () { resultEl.innerHTML = '<span class="text-red-700">Erreur réseau</span>'; });
    });
  }

  // ─ Action: email ou sms ─
  document.querySelectorAll('.lead-action').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var action = btn.dataset.action;
      var leadId = btn.dataset.leadId;
      openModal('Chargement…');
      content.innerHTML = '<div class="text-sm text-slate-500">Chargement du lead…</div>';

      fetchLeadDetail(leadId)
        .then(function (data) {
          if (!data || !data.ok || !data.cart) {
            content.innerHTML = '<div class="text-sm text-red-500">Erreur : impossible de charger le lead.</div>';
            return;
          }
          if (action === 'email') openEmailModal(leadId, data.cart);
          else if (action === 'sms') openSmsModal(leadId, data.cart, btn.dataset.smsTemplate || '');
        })
        .catch(function () {
          content.innerHTML = '<div class="text-sm text-red-500">Erreur réseau.</div>';
        });
    });
  });
})();
</script>

<%- include('./partials/footer') %>
