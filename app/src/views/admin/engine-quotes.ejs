<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'engine-quotes' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Devis moteurs & boîtes'}] }) %>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Devis moteurs &amp; boîtes</div>
        <div class="mt-1 text-sm text-slate-500">Workflow commercial dédié — identification, sourcing, tarification, photos.</div>
      </div>
      <div class="flex flex-wrap items-center gap-3 shrink-0">
        <a href="/admin/devis-moteurs/nouveau" class="inline-flex items-center gap-2 rounded-xl bg-red-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-red-700">
          <span class="material-symbols-outlined" style="font-size:18px">add</span>
          Nouveau devis
        </a>
        <a href="/admin/devis-moteurs/conversion" class="inline-flex items-center gap-2 rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-800">
          <span class="material-symbols-outlined" style="font-size:18px">monitoring</span>
          Tableau de conversion
        </a>
      </div>
    </div>

    <!-- KPIs -->
    <div class="mt-8 grid grid-cols-2 lg:grid-cols-8 gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase tracking-widest text-slate-400 font-semibold">Total</div>
        <div class="mt-1 text-2xl font-bold text-slate-900"><%= stats.total %></div>
      </div>
      <div class="rounded-2xl border border-green-100 bg-green-50/40 p-4" title="Leads avec un identifiant de clic Google Ads (gclid). Nécessite l'auto-tagging activé côté Google Ads.">
        <div class="text-xs uppercase tracking-widest text-green-600 font-semibold">Via Google Ads</div>
        <div class="mt-1 text-2xl font-bold text-green-700"><%= stats.fromAds %></div>
      </div>
      <div class="rounded-2xl border border-blue-100 bg-blue-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-blue-500 font-semibold">Nouveau</div>
        <div class="mt-1 text-2xl font-bold text-blue-700"><%= stats.newCount %></div>
      </div>
      <div class="rounded-2xl border border-amber-100 bg-amber-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-amber-500 font-semibold">En analyse</div>
        <div class="mt-1 text-2xl font-bold text-amber-700"><%= stats.analyzing %></div>
      </div>
      <div class="rounded-2xl border border-violet-100 bg-violet-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-violet-500 font-semibold">Devis envoyés</div>
        <div class="mt-1 text-2xl font-bold text-violet-700"><%= stats.quoteSent %></div>
      </div>
      <a href="/admin/devis-moteurs?sourcing=1" title="Auto-devis non envoyé : l'état demandé (occasion/reconditionné) est indisponible au catalogue — à sourcer / rappeler" class="rounded-2xl border <%= filters.sourcing ? 'border-orange-300 ring-2 ring-orange-200' : 'border-orange-100' %> bg-orange-50/50 p-4 block hover:bg-orange-50 transition">
        <div class="text-xs uppercase tracking-widest text-orange-500 font-semibold">À sourcer</div>
        <div class="mt-1 text-2xl font-bold text-orange-700"><%= stats.sourcing %></div>
      </a>
      <div class="rounded-2xl border border-emerald-100 bg-emerald-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-emerald-500 font-semibold">CA en attente</div>
        <div class="mt-1 text-2xl font-bold text-emerald-700"><%= fmt(stats.caExpected) %> €</div>
      </div>
      <div class="rounded-2xl border border-emerald-100 bg-emerald-50/40 p-4">
        <div class="text-xs uppercase tracking-widest text-emerald-500 font-semibold">Marge prévue</div>
        <div class="mt-1 text-2xl font-bold text-emerald-700"><%= fmt(stats.marginExpected) %> €</div>
      </div>
    </div>

    <!-- Toggle Actifs / Archivés -->
    <div class="mt-6 inline-flex rounded-xl border border-slate-200 bg-white p-1">
      <a href="/admin/devis-moteurs<%= filters.status ? ('?status=' + filters.status) : '' %>"
         class="px-4 py-2 rounded-lg text-sm font-semibold transition <%= view === 'active' ? 'bg-slate-900 text-white' : 'text-slate-600 hover:text-slate-900' %>">
        Actifs
      </a>
      <a href="/admin/devis-moteurs?view=archived<%= filters.status ? ('&status=' + filters.status) : '' %>"
         class="px-4 py-2 rounded-lg text-sm font-semibold transition flex items-center gap-1.5 <%= view === 'archived' ? 'bg-slate-900 text-white' : 'text-slate-600 hover:text-slate-900' %>">
        Archivés
        <% if (archivedCount > 0) { %>
          <span class="inline-flex items-center justify-center min-w-[20px] h-5 px-1.5 rounded-full text-[11px] font-bold <%= view === 'archived' ? 'bg-white/20 text-white' : 'bg-slate-100 text-slate-500' %>"><%= archivedCount %></span>
        <% } %>
      </a>
    </div>

    <!-- Filtres -->
    <form action="/admin/devis-moteurs" method="GET" class="mt-4 bg-white rounded-2xl border border-slate-200 p-4 flex flex-col md:flex-row gap-3">
      <% if (view === 'archived') { %><input type="hidden" name="view" value="archived"><% } %>
      <input name="q" value="<%= filters.q || '' %>" placeholder="Recherche : nom, plaque, dossier, pièce…" class="flex-1 rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white focus:ring-2 focus:ring-red-500 focus:border-red-500">
      <select name="status" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white">
        <option value="">Tous statuts</option>
        <% Object.keys(statusLabels).forEach(function(s) { %>
          <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= statusLabels[s].label %></option>
        <% }) %>
      </select>
      <select name="condition" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white">
        <option value="">Toutes conditions</option>
        <option value="reconditionne" <%= filters.condition === 'reconditionne' ? 'selected' : '' %>>Reconditionné</option>
        <option value="occasion" <%= filters.condition === 'occasion' ? 'selected' : '' %>>Occasion</option>
      </select>
      <button type="submit" class="bg-slate-900 hover:bg-slate-800 text-white font-semibold px-5 py-2.5 rounded-xl text-sm">Filtrer</button>
      <% if (filters.q || filters.status || filters.condition) { %>
        <a href="/admin/devis-moteurs<%= view === 'archived' ? '?view=archived' : '' %>" class="px-5 py-2.5 text-sm text-slate-600 hover:text-slate-900">Réinitialiser</a>
      <% } %>
    </form>

    <!-- Tableau -->
    <% if (items.length === 0) { %>
      <div class="mt-8 bg-white rounded-2xl border border-slate-200 p-12 text-center">
        <p class="text-slate-500">Aucun devis ne correspond aux filtres.</p>
      </div>
    <% } else { %>
      <div class="mt-6 bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200">
              <tr>
                <th class="text-left px-4 py-3 font-semibold">Dossier</th>
                <th class="text-left px-4 py-3 font-semibold">Client</th>
                <th class="text-left px-4 py-3 font-semibold">Véhicule / Pièce</th>
                <th class="text-left px-4 py-3 font-semibold">Statut</th>
                <th class="text-left px-4 py-3 font-semibold">Stock</th>
                <th class="text-right px-4 py-3 font-semibold">Vente HT</th>
                <th class="text-right px-4 py-3 font-semibold">Marge</th>
                <th class="text-center px-4 py-3 font-semibold">Photos</th>
                <th class="text-right px-4 py-3 font-semibold"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% items.forEach(function(it) { %>
                <tr class="hover:bg-slate-50 transition">
                  <td class="px-4 py-3 align-top">
                    <div class="flex items-center gap-2">
                      <div class="font-mono text-xs font-semibold text-slate-900"><%= it.ref || '—' %></div>
                      <% if (it.priority === 'hot') { %>
                        <span title="Lead chaud : nouveau, complet, moins de 24h" class="inline-flex items-center text-xs font-bold text-orange-600">🔥</span>
                      <% } else if (it.priority === 'cold') { %>
                        <span title="Lead froid : pas de suivi depuis 7+ jours" class="inline-flex items-center text-xs">🥶</span>
                      <% } %>
                    </div>
                    <div class="text-xs text-slate-400 mt-1"><%= new Date(it.receivedAt).toLocaleDateString('fr-FR', {day:'2-digit',month:'short',year:'numeric'}) %></div>
                    <% if (it.sentQuoteCount > 0) { %>
                      <div class="text-[10px] text-violet-600 mt-0.5">Envoyé il y a <%= Math.floor((Date.now() - new Date(it.lastSentAt).getTime()) / (24*60*60*1000)) %>j</div>
                      <div class="flex items-center gap-1 mt-1 flex-wrap">
                        <% if (it.lastSentPayClicked) { %>
                          <span class="inline-flex items-center text-[10px] font-semibold text-amber-800 bg-amber-100 px-1.5 py-0.5 rounded-full" title="A cliqué sur le bouton de paiement">💳 Paiement cliqué</span>
                        <% } else if (it.lastSentPdfViewed) { %>
                          <span class="inline-flex items-center text-[10px] font-semibold text-blue-700 bg-blue-50 px-1.5 py-0.5 rounded-full" title="A consulté le PDF en ligne">📄 PDF vu</span>
                        <% } else if (it.lastSentOpened) { %>
                          <span class="inline-flex items-center text-[10px] font-semibold text-emerald-700 bg-emerald-50 px-1.5 py-0.5 rounded-full" title="Email ouvert <%= it.lastSentOpenCount || 1 %> fois">👁 Ouvert<%= (it.lastSentOpenCount > 1) ? ' ×' + it.lastSentOpenCount : '' %></span>
                        <% } else { %>
                          <span class="inline-flex items-center text-[10px] font-medium text-slate-400 bg-slate-50 px-1.5 py-0.5 rounded-full" title="Devis envoyé — suivi via vue PDF / clic paiement">Envoyé</span>
                        <% } %>
                      </div>
                    <% } %>
                  </td>
                  <td class="px-4 py-3 align-top">
                    <div class="font-medium text-slate-900"><%= it.displayName %></div>
                    <div class="text-xs text-slate-500 mt-0.5"><%= it.phone %></div>
                    <% if (it.email) { %><div class="text-xs text-slate-400"><%= it.email %></div><% } %>
                    <% if (it.source) { %>
                      <span class="inline-flex items-center mt-1 px-2 py-0.5 rounded-full text-[10px] font-semibold <%= it.source.isAds ? 'bg-green-100 text-green-700' : (it.source.kind === 'seo' ? 'bg-sky-100 text-sky-700' : 'bg-slate-100 text-slate-500') %>"<% if (it.source.campaign) { %> title="Campagne : <%= it.source.campaign %>"<% } %>><%= it.source.label %></span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3 align-top">
                    <div class="font-mono text-xs text-slate-700"><%= it.plate || '—' %></div>
                    <% if (it.isBoite) { %>
                      <span class="inline-flex items-center mt-1 mr-1 px-2 py-0.5 rounded-full text-[10px] font-bold bg-indigo-100 text-indigo-700">⚙️ Boîte</span>
                    <% } else if (it.isPont) { %>
                      <span class="inline-flex items-center mt-1 mr-1 px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-700">🔩 Pont/Transfert</span>
                    <% } %>
                    <% if (it.conditionBadge) { %>
                      <span class="inline-flex items-center mt-1 px-2 py-0.5 rounded-full text-[10px] font-bold <%= it.conditionBadge.className %>"><%= it.conditionBadge.label %></span>
                    <% } %>
                    <% if (it.identifiedEngineModel || it.identifiedEngineCode) { %>
                      <div class="text-xs text-slate-500 mt-0.5">
                        <%= it.identifiedEngineModel %>
                        <% if (it.identifiedEngineCode) { %><span class="font-mono">· <%= it.identifiedEngineCode %></span><% } %>
                      </div>
                    <% } else { %>
                      <div class="text-xs text-amber-600 mt-0.5">À identifier</div>
                    <% } %>
                  </td>
                  <td class="px-4 py-3 align-top">
                    <div class="flex flex-col items-start gap-1">
                      <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold <%= it.statusBadge.className %>"><%= it.statusBadge.label %></span>
                      <% if (it.needsSourcing) { %>
                        <span title="État demandé indisponible au catalogue — à sourcer / rappeler" class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-orange-100 text-orange-700 border border-orange-200">À sourcer<%= it.sourcingRequested ? ' · ' + (it.sourcingRequested === 'reconditionne' ? 'reconditionné' : it.sourcingRequested) : '' %></span>
                      <% } %>
                    </div>
                  </td>
                  <td class="px-4 py-3 align-top">
                    <% if (it.stockLabel) { %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= it.stockClass %>"><%= it.stockLabel %></span>
                    <% } else { %>
                      <span class="text-xs text-slate-300">—</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3 align-top text-right font-mono text-sm">
                    <% if (it.sellPrice > 0) { %><%= fmt(it.sellPrice) %> €<% } else { %><span class="text-slate-300">—</span><% } %>
                  </td>
                  <td class="px-4 py-3 align-top text-right font-mono text-sm">
                    <% if (it.marginEur !== 0) { %>
                      <div class="font-bold <%= it.marginColor %>"><%= fmt(it.marginEur) %> €</div>
                      <div class="text-xs <%= it.marginColor %>"><%= it.marginPct.toFixed(1) %>%</div>
                    <% } else { %><span class="text-slate-300">—</span><% } %>
                  </td>
                  <td class="px-4 py-3 align-top text-center">
                    <% if (it.photoCount > 0) { %>
                      <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-600 bg-slate-100 px-2 py-0.5 rounded">
                        <span class="material-symbols-outlined text-sm" style="font-size:14px">photo_camera</span>
                        <%= it.photoCount %>
                      </span>
                    <% } else { %><span class="text-slate-300 text-xs">—</span><% } %>
                  </td>
                  <td class="px-4 py-3 align-top text-right">
                    <div class="flex items-center justify-end gap-1.5">
                      <a href="/admin/devis-moteurs/<%= it.id %>" class="text-red-600 hover:text-red-700 font-semibold text-sm whitespace-nowrap">Ouvrir →</a>
                      <% if (view === 'archived') { %>
                        <form action="/admin/devis-moteurs/<%= it.id %>/archive" method="POST" class="inline">
                          <input type="hidden" name="archived" value="0">
                          <input type="hidden" name="returnTo" value="/admin/devis-moteurs?view=archived">
                          <button type="submit" title="Désarchiver" class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 transition">
                            <span class="material-symbols-outlined" style="font-size:18px">unarchive</span>
                          </button>
                        </form>
                      <% } else { %>
                        <form action="/admin/devis-moteurs/<%= it.id %>/archive" method="POST" class="inline">
                          <input type="hidden" name="archived" value="1">
                          <input type="hidden" name="returnTo" value="/admin/devis-moteurs">
                          <button type="submit" title="Archiver (sortir de la liste active)" class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition">
                            <span class="material-symbols-outlined" style="font-size:18px">archive</span>
                          </button>
                        </form>
                      <% } %>
                      <form action="/admin/devis-moteurs/<%= it.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Supprimer définitivement ce dossier ?\n\nIrréversible : le lead, ses photos et PDF seront effacés.');">
                        <button type="submit" title="Supprimer définitivement" class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-slate-400 hover:text-rose-600 hover:bg-rose-50 transition">
                          <span class="material-symbols-outlined" style="font-size:18px">delete</span>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</main>

<%- include('./partials/footer') %>
