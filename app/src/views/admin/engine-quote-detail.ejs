<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'engine-quotes' }) %>

<%
function dt(v) {
  if (!v) return '—';
  return new Date(v).toLocaleString('fr-FR', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
}
%>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8 max-w-7xl mx-auto">

    <!-- Breadcrumb + retour -->
    <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Devis moteurs & boîtes', url: '/admin/devis-moteurs'}, {label: cart.ref || cart.displayName}] }) %>

    <!-- Header -->
    <div class="mt-4 flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
      <div>
        <div class="flex items-center gap-3">
          <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 font-mono"><%= cart.ref || 'Sans référence' %></h1>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold <%= engineQuote.statusBadge.className %>"><%= engineQuote.statusBadge.label %></span>
        </div>
        <p class="mt-1 text-sm text-slate-500">Reçu le <%= dt(cart.receivedAt) %><% if (engineQuote.updatedAt) { %> · Modifié par <%= engineQuote.updatedByName %> le <%= dt(engineQuote.updatedAt) %><% } %></p>
      </div>

      <div class="flex flex-col items-stretch lg:items-end gap-3">
        <!-- Changement de statut -->
        <form action="/admin/devis-moteurs/<%= cart.id %>/status" method="POST" data-autosave class="flex items-center gap-3">
          <select name="status" class="rounded-xl border border-slate-200 px-3 py-2 text-sm font-semibold">
            <% Object.keys(statusLabels).forEach(function(s) { %>
              <option value="<%= s %>" <%= engineQuote.status === s ? 'selected' : '' %>><%= statusLabels[s].label %></option>
            <% }) %>
          </select>
          <span data-save-indicator class="text-xs text-slate-400 transition-opacity opacity-0">Enregistré ✓</span>
        </form>

        <!-- Archiver / Supprimer -->
        <div class="flex items-center gap-2">
          <% if (cart.archived) { %>
            <form action="/admin/devis-moteurs/<%= cart.id %>/archive" method="POST">
              <input type="hidden" name="archived" value="0">
              <input type="hidden" name="returnTo" value="/admin/devis-moteurs/<%= cart.id %>">
              <button type="submit" class="inline-flex items-center gap-1.5 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 px-3 py-2 text-sm font-semibold transition">
                <span class="material-symbols-outlined" style="font-size:18px">unarchive</span>
                Désarchiver
              </button>
            </form>
          <% } else { %>
            <form action="/admin/devis-moteurs/<%= cart.id %>/archive" method="POST">
              <input type="hidden" name="archived" value="1">
              <input type="hidden" name="returnTo" value="/admin/devis-moteurs/<%= cart.id %>">
              <button type="submit" class="inline-flex items-center gap-1.5 rounded-xl border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 hover:text-slate-900 px-3 py-2 text-sm font-semibold transition">
                <span class="material-symbols-outlined" style="font-size:18px">archive</span>
                Archiver
              </button>
            </form>
          <% } %>
          <form action="/admin/devis-moteurs/<%= cart.id %>/delete" method="POST" onsubmit="return confirm('Supprimer définitivement ce dossier ?\n\nIrréversible : le lead, ses photos et PDF seront effacés.');">
            <button type="submit" class="inline-flex items-center gap-1.5 rounded-xl border border-rose-200 bg-white text-rose-600 hover:bg-rose-50 px-3 py-2 text-sm font-semibold transition">
              <span class="material-symbols-outlined" style="font-size:18px">delete</span>
              Supprimer
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Bandeau ARCHIVÉ -->
    <% if (cart.archived) { %>
      <div class="mt-6 rounded-2xl bg-slate-100 border border-slate-300 p-4 flex items-center gap-3">
        <span class="material-symbols-outlined text-slate-500" style="font-size:24px">inventory_2</span>
        <div class="text-sm text-slate-600">
          <span class="font-semibold text-slate-800">Dossier archivé</span>
          <% if (cart.archivedByName) { %> par <%= cart.archivedByName %><% } %>
          <% if (cart.archivedAt) { %> le <%= dt(cart.archivedAt) %><% } %>
          — il n'apparaît plus dans la liste active.
        </div>
      </div>
    <% } %>

    <!-- Bandeau ACOMPTE REÇU (paiement Mollie validé) -->
    <% if (engineQuote.payment && engineQuote.payment.status === 'paid') { %>
      <div class="mt-6 rounded-2xl bg-emerald-50 border-2 border-emerald-300 p-4 flex items-center gap-3">
        <span class="material-symbols-outlined text-emerald-600" style="font-size:28px">paid</span>
        <div>
          <p class="font-bold text-emerald-900">Acompte payé — <%= lex.noun %> <%= lex.reserve %></p>
          <p class="text-sm text-emerald-800">
            <%= fmt((engineQuote.payment.amountCents || 0) / 100) %> € reçu
            <% if (engineQuote.payment.paidAt) { %> le <%= new Date(engineQuote.payment.paidAt).toLocaleString('fr-FR', {day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %><% } %>
            · lance la préparation et l'expédition.
          </p>
        </div>
      </div>
    <% } %>

    <!-- EXPÉDITION & SUIVI -->
    <section id="expedition" class="mt-6 bg-white rounded-2xl border border-slate-200 p-6">
      <div class="flex items-center gap-2 mb-1">
        <span class="material-symbols-outlined text-slate-500" style="font-size:20px">local_shipping</span>
        <h2 class="text-lg font-semibold text-slate-900">Expédition &amp; suivi</h2>
      </div>
      <p class="text-xs text-slate-500 mb-4">Marque <%= lex.leNoun %> <%= lex.expedie %> et envoie au client l'email + SMS de suivi (tient la promesse de la confirmation d'acompte).</p>

      <% if (engineQuote.shipment) { %>
        <div class="rounded-xl bg-emerald-50 border border-emerald-200 p-4">
          <p class="font-semibold text-emerald-900">📦 Expédié<% if (engineQuote.shipment.shippedAt) { %> le <%= new Date(engineQuote.shipment.shippedAt).toLocaleString('fr-FR',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %><% } %><% if (engineQuote.shipment.shippedByName) { %> par <%= engineQuote.shipment.shippedByName %><% } %></p>
          <p class="text-sm text-emerald-800 mt-1">Transporteur : <strong><%= engineQuote.shipment.carrier || '—' %></strong><% if (engineQuote.shipment.trackingNumber) { %> · Suivi : <strong class="font-mono"><%= engineQuote.shipment.trackingNumber %></strong><% } %></p>
          <% if (engineQuote.shipment.trackingUrl) { %><p class="text-sm mt-1"><a href="<%= engineQuote.shipment.trackingUrl %>" target="_blank" rel="noopener" class="text-blue-600 hover:underline">Lien de suivi →</a></p><% } %>
          <p class="text-xs text-emerald-700 mt-2"><%= engineQuote.shipment.emailSentAt ? '✓ Email de suivi envoyé au client' : 'Email non envoyé (pas d’email client)' %></p>
        </div>
      <% } %>

      <form action="/admin/devis-moteurs/<%= cart.id %>/expedition" method="POST" class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-3" onsubmit="return confirm('Envoyer l\'email + SMS d\'expédition au client ?');">
        <div>
          <label class="block text-xs font-semibold text-slate-500 mb-1">Transporteur</label>
          <input name="carrier" value="<%= engineQuote.shipment ? engineQuote.shipment.carrier : '' %>" list="carriers-list" placeholder="DPD, Chronopost, palette…" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500">
          <datalist id="carriers-list"><option value="DPD"></option><option value="Chronopost"></option><option value="Colissimo"></option><option value="GLS"></option><option value="UPS"></option><option value="Affrètement palette"></option></datalist>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 mb-1">N° de suivi</label>
          <input name="trackingNumber" value="<%= engineQuote.shipment ? engineQuote.shipment.trackingNumber : '' %>" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 mb-1">Lien de suivi (URL)</label>
          <input name="trackingUrl" type="url" value="<%= engineQuote.shipment ? engineQuote.shipment.trackingUrl : '' %>" placeholder="https://…" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500">
        </div>
        <div class="md:col-span-3 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
          <p class="text-xs text-slate-400">Email + SMS de suivi envoyés au client<% if (!cart.email) { %> (pas d'email : SMS seul)<% } %>.</p>
          <button type="submit" class="bg-slate-900 hover:bg-slate-800 text-white font-semibold px-5 py-2.5 rounded-xl text-sm inline-flex items-center justify-center gap-2">
            <span class="material-symbols-outlined" style="font-size:16px">local_shipping</span>
            <%= engineQuote.shipment ? 'Mettre à jour + renvoyer' : 'Marquer expédié + envoyer' %>
          </button>
        </div>
      </form>
    </section>

    <!-- APERÇU DES MAILS AUTOMATIQUES -->
    <section class="mt-6 bg-white rounded-2xl border border-slate-200 p-6">
      <div class="flex items-center gap-2 mb-1">
        <span class="material-symbols-outlined text-slate-500" style="font-size:20px">drafts</span>
        <h2 class="text-lg font-semibold text-slate-900">Aperçu des mails automatiques</h2>
      </div>
      <p class="text-xs text-slate-500 mb-4">Visualise ce que reçoit le client pour ce dossier (relances incluses). S'ouvre dans un nouvel onglet — <strong>rien n'est envoyé</strong>.</p>
      <div class="flex flex-wrap gap-2">
        <% [
          { t: 'ack', l: 'Accusé de réception' },
          { t: 'j3', l: 'Relance J+3' },
          { t: 'j7', l: 'Relance J+7' },
          { t: 'j14', l: 'Relance J+14' },
          { t: 'winback', l: 'Win-back J+30' },
          { t: 'acompte', l: 'Confirmation acompte' },
          { t: 'expedition', l: 'Expédition' }
        ].forEach(function(m) { %>
          <a href="/admin/devis-moteurs/<%= cart.id %>/preview-mail/<%= m.t %>" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-700 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-lg px-3 py-2 transition">
            <span class="material-symbols-outlined" style="font-size:15px">open_in_new</span>
            <%= m.l %>
          </a>
        <% }) %>
      </div>
    </section>

    <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- ─── COLONNE GAUCHE (2/3) ─── -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Bloc IDENTIFICATION de la pièce -->
        <form action="/admin/devis-moteurs/<%= cart.id %>/engine" method="POST" data-autosave class="bg-white rounded-2xl border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Identification <%= lex.noun %></h2>
              <p class="text-xs text-slate-500 mt-0.5">Renseigne <%= lex.leNoun %> exact<%= cart.isBoite ? 'e' : '' %> après analyse du dossier</p>
            </div>
            <span data-save-indicator class="text-xs text-slate-400 transition-opacity opacity-0">Enregistré ✓</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Code moteur</label>
              <input name="code" value="<%= engineQuote.identifiedEngine.code || '' %>" placeholder="ex: M48.50" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Année / Plage</label>
              <input name="year" value="<%= engineQuote.identifiedEngine.year || '' %>" placeholder="ex: 2002-2006" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500">
            </div>
            <div class="md:col-span-2">
              <label class="block text-xs font-semibold text-slate-500 mb-1">Désignation <%= lex.noun %></label>
              <input name="model" value="<%= engineQuote.identifiedEngine.model || '' %>" placeholder="ex: Porsche Cayenne Turbo 4.5 V8 — 955 Turbo" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500">
              <p class="text-xs text-slate-400 mt-1">Modèle complet + finition libre — affiché tel quel sur le devis</p>
            </div>
            <div class="md:col-span-2">
              <label class="block text-xs font-semibold text-slate-500 mb-1">Kilométrage certifié</label>
              <input type="number" name="mileage" min="0" step="1000" value="<%= engineQuote.identifiedEngine.mileage || '' %>" placeholder="ex: 128 000" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500">
              <p class="text-xs text-slate-400 mt-1">Affiché sur le devis client</p>
            </div>
            <div class="md:col-span-2">
              <label class="block text-xs font-semibold text-slate-500 mb-2">État <%= lex.duNoun %> (affiché sur le devis)</label>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                <% Object.keys(conditionLabels).forEach(function(key) { if (!key) return; %>
                  <label class="cursor-pointer border-2 border-slate-200 hover:border-slate-300 has-[:checked]:border-red-500 has-[:checked]:bg-red-50 rounded-lg p-2.5 text-center transition block">
                    <input type="radio" name="condition" value="<%= key %>" <%= engineQuote.identifiedEngine.condition === key ? 'checked' : '' %> class="sr-only peer">
                    <span class="block text-xs font-bold text-slate-700 peer-checked:text-red-700 leading-tight"><%= conditionLabels[key].admin %></span>
                  </label>
                <% }) %>
              </div>
              <p class="text-xs text-slate-400 mt-1.5">Reconditionné<%= cart.isBoite ? 'e' : '' %> = badge premium visible sur le PDF et l'email</p>
            </div>
          </div>
        </form>

        <!-- Bloc STOCK -->
        <form action="/admin/devis-moteurs/<%= cart.id %>/stock" method="POST" data-autosave class="bg-white rounded-2xl border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Stock & sourcing</h2>
              <p class="text-xs text-slate-500 mt-0.5">Provenance <%= lex.duNoun %> et délai estimé</p>
            </div>
            <span data-save-indicator class="text-xs text-slate-400 transition-opacity opacity-0">Enregistré ✓</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4">
            <% [['atelier', 'En stock atelier'], ['sourcing', 'Sourcing réseau'], ['indisponible', 'Indisponible']].forEach(function(opt) { %>
              <label class="cursor-pointer border-2 border-slate-200 hover:border-slate-300 has-[:checked]:border-red-500 has-[:checked]:bg-red-50 rounded-xl p-3 text-center transition block">
                <input type="radio" name="location" value="<%= opt[0] %>" <%= engineQuote.stock.location === opt[0] ? 'checked' : '' %> class="sr-only peer">
                <span class="block text-sm font-semibold text-slate-700 peer-checked:text-red-700"><%= opt[1] %></span>
              </label>
            <% }) %>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-500 mb-1">Délai estimé</label>
            <!-- Boutons rapides : remplissent le champ + déclenchent l'auto-save -->
            <div class="flex flex-wrap gap-2 mb-2" data-delay-chips>
              <% const delayPresets = ['48-72h', '5-7 jours', '7-10 jours', '10-15 jours']; %>
              <% delayPresets.forEach(function(preset) { %>
                <button type="button" data-delay-preset="<%= preset %>" class="px-3 py-1.5 rounded-full border text-xs font-semibold transition <%= engineQuote.stock.estimatedDelay === preset ? 'border-red-500 bg-red-50 text-red-700' : 'border-slate-200 text-slate-600 hover:border-slate-300' %>"><%= preset %></button>
              <% }) %>
            </div>
            <input name="estimatedDelay" data-delay-input value="<%= engineQuote.stock.estimatedDelay || '' %>" placeholder="ou saisis un délai sur mesure…" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500">
            <p class="text-xs text-slate-400 mt-1">Pour info fournisseur, utilise les notes internes en bas de page</p>
          </div>
        </form>

        <!-- Bloc TARIFICATION & MARGE -->
        <form action="/admin/devis-moteurs/<%= cart.id %>/pricing" method="POST" data-autosave class="bg-white rounded-2xl border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Tarification &amp; marge</h2>
              <p class="text-xs text-slate-500 mt-0.5">La marge se calcule automatiquement en temps réel</p>
            </div>
            <span data-save-indicator class="text-xs text-slate-400 transition-opacity opacity-0">Enregistré ✓</span>
          </div>

          <%
            // Reconditionné : régime normal IMPÉRATIF (TVA 20%). Occasion : régime
            // enregistré ('normal' explicite) sinon TVA sur marge par défaut.
            var _stored = engineQuote.pricing && engineQuote.pricing.vatScheme;
            var _scheme = isReconditionne ? 'normal' : (_stored === 'normal' ? 'normal' : 'margin');
          %>
          <input type="hidden" name="vatScheme" value="<%= _scheme %>" data-vat-scheme data-margin-input>
          <% if (isReconditionne) { %>
          <div class="mb-5 flex flex-wrap items-center gap-2">
            <span class="text-xs font-semibold text-slate-500">Régime TVA :</span>
            <span class="inline-flex items-center rounded-lg bg-slate-900 text-white px-3 py-1.5 text-xs font-semibold">Régime normal · TVA 20 %</span>
            <span class="text-[11px] text-slate-400"><%= lex.nounCap %> reconditionné<%= cart.isBoite ? 'e' : '' %> — non éligible à la TVA sur marge. Prix saisi en HT, TVA 20 % ajoutée.</span>
          </div>
          <% } else { %>
          <div class="mb-5 flex flex-wrap items-center gap-2">
            <span class="text-xs font-semibold text-slate-500">Régime TVA :</span>
            <div class="inline-flex rounded-xl bg-slate-100 p-1 text-xs">
              <button type="button" data-scheme-btn="margin" class="px-3 py-1.5 rounded-lg font-semibold transition">TVA sur marge</button>
              <button type="button" data-scheme-btn="normal" class="px-3 py-1.5 rounded-lg font-semibold transition">Régime normal</button>
            </div>
            <span data-scheme-hint class="text-[11px] text-slate-400"></span>
          </div>
          <% } %>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Prix d'achat HT (€)</label>
              <input type="number" step="0.01" min="0" name="purchasePrice" value="<%= engineQuote.pricing.purchasePrice || '' %>" data-margin-input data-cost class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Frais annexes HT (€)</label>
              <input type="number" step="0.01" min="0" name="additionalFees" value="<%= engineQuote.pricing.additionalFees || '' %>" data-margin-input data-cost placeholder="port, palette…" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1"><span data-sell-label>Prix de vente HT (€)</span></label>
              <input type="number" step="0.01" min="0" name="sellPrice" value="<%= engineQuote.pricing.sellPrice || '' %>" data-margin-input data-sell class="w-full rounded-lg border-2 border-slate-300 px-3 py-2 text-sm font-mono font-bold focus:ring-2 focus:ring-red-500 focus:border-red-500">
            </div>
          </div>

          <% if (isReconditionne) { %>
          <!-- Reconditionné : pas de banc d'essai → aucun coût de contrôle déduit.
               Inputs cachés à 0 pour que le calcul de marge live reste cohérent. -->
          <input type="hidden" data-ctrl-port value="0">
          <input type="hidden" data-ctrl-rate value="0">
          <input type="hidden" data-ctrl-hours value="0">
          <div class="mb-4 p-3 rounded-xl border border-dashed border-slate-200 bg-slate-50/60">
            <p class="text-[11px] text-slate-500"><strong><%= lex.nounCap %> reconditionné<%= cart.isBoite ? 'e' : '' %></strong> — aucun coût de <%= cart.isBoite ? 'contrôle' : 'banc d\'essai' %> déduit de la marge (la remise à neuf est intégrée au prix d'achat). Régime <strong>TVA normale 20 %</strong> (HT + TVA), marge cible <strong>25 %</strong>.</p>
          </div>
          <% } else { %>
          <!-- Coûts de contrôle (port de test + MO de test) — TOUJOURS inclus dans la marge -->
          <div class="flex flex-wrap items-end gap-3 mb-4 p-3 rounded-xl border border-dashed border-emerald-300 bg-emerald-50/40">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Port de test (€)</label>
              <input type="number" step="1" min="0" data-ctrl-port value="<%= controlCostDefaults.portTest %>" class="w-24 rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Taux atelier (€/h)</label>
              <input type="number" step="1" min="0" data-ctrl-rate value="<%= controlCostDefaults.hourlyRate %>" class="w-24 rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Temps test (h)</label>
              <input type="number" step="0.5" min="0" data-ctrl-hours value="<%= controlCostDefaults.testHours %>" class="w-20 rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
            </div>
            <div class="pb-2">
              <div class="text-[11px] font-semibold uppercase tracking-wide text-emerald-700">Coûts de contrôle inclus</div>
              <div class="text-lg font-bold font-mono text-emerald-700"><span data-ctrl-total>—</span> €</div>
            </div>
            <p class="basis-full text-[11px] text-slate-400"><strong>Toujours déduits de ta marge</strong> (port fournisseur→atelier + ta main-d'œuvre de test) → la marge affichée est ta <strong>vraie</strong> marge, sans rien cliquer. Modifiable ici pour un dossier particulier. La livraison client (refacturée) n'est pas comptée.</p>
          </div>
          <% } %>

          <!-- Aide au calcul du prix de vente depuis une marge cible -->
          <div class="flex flex-wrap items-end gap-3 mb-4 p-3 rounded-xl border border-dashed border-slate-300 bg-slate-50/60">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Calcul auto · marge cible</label>
              <div class="flex items-center gap-1">
                <input type="number" step="1" min="0" max="95" value="<%= isReconditionne ? 25 : 30 %>" data-target-margin class="w-20 rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500">
                <span class="text-sm font-semibold text-slate-500">%</span>
              </div>
            </div>
            <button type="button" data-calc-sell class="bg-slate-900 hover:bg-slate-800 text-white font-semibold px-4 py-2 rounded-lg text-sm inline-flex items-center gap-1.5">
              <span class="material-symbols-outlined" style="font-size:16px">calculate</span>
              Calculer le prix de vente
            </button>
            <div class="flex items-center gap-1">
              <% [25, 30, 35, 40].forEach(function(m) { %>
                <button type="button" data-margin-chip="<%= m %>" class="text-xs font-semibold text-slate-600 border border-slate-200 hover:border-slate-400 hover:bg-white rounded-full px-2.5 py-1 transition"><%= m %>%</button>
              <% }) %>
            </div>
            <p class="basis-full text-[11px] text-slate-400">Remplit le prix de vente HT pour atteindre cette marge (calculée sur le prix de vente). Renseigne d'abord le prix d'achat. Tu peux toujours ajuster ensuite.</p>
          </div>

          <!-- Marge calculée live -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 bg-slate-50 rounded-xl p-4">
            <div>
              <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider">Coût total</div>
              <div data-margin-cost class="mt-1 text-lg font-bold font-mono text-slate-900">—</div>
            </div>
            <div>
              <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider" data-label-eur>Marge nette</div>
              <div data-margin-eur class="mt-1 text-lg font-bold font-mono text-slate-900">—</div>
            </div>
            <div>
              <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider">% marge</div>
              <div data-margin-pct class="mt-1 text-lg font-bold font-mono text-slate-900">—</div>
            </div>
            <div>
              <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider" data-label-ttc>TVA sur marge</div>
              <div data-margin-ttc class="mt-1 text-lg font-bold font-mono text-slate-900">—</div>
            </div>
          </div>

          <input type="hidden" name="vatRate" value="<%= engineQuote.pricing.vatRate || 20 %>">
          <p class="mt-3 text-xs text-slate-400">TVA appliquée : <%= engineQuote.pricing.vatRate || 20 %>% · Seuil orange &lt; 25% · Seuil rouge &lt; 15%</p>
        </form>

        <!-- Bloc PHOTOS -->
        <section id="photos" class="bg-white rounded-2xl border border-slate-200 p-6">
          <div class="mb-4">
            <h2 class="text-lg font-semibold text-slate-900">Photos du dossier</h2>
            <p class="text-xs text-slate-500 mt-0.5">Photos jointes au devis envoyé au client</p>
          </div>

          <% const photoCategories = [
            { key: 'engine',    label: cart.isBoite ? 'Photos boîte' : 'Photos moteur', hint: cart.isBoite ? 'Carter, mécatronique, étiquettes, n° de série' : 'Bloc moteur, accessoires, étiquettes, banc d\'essai' },
            { key: 'kmReading', label: 'Relevé kilométrique', hint: 'Photo du compteur du véhicule donneur' },
          ]; %>

          <% photoCategories.forEach(function(cat) { %>
            <div class="mb-6 last:mb-0">
              <div class="flex items-center justify-between mb-2">
                <div>
                  <h3 class="text-sm font-semibold text-slate-700"><%= cat.label %></h3>
                  <p class="text-xs text-slate-400"><%= cat.hint %></p>
                </div>
                <form action="/admin/devis-moteurs/<%= cart.id %>/photo/<%= cat.key %>" method="POST" enctype="multipart/form-data" class="flex items-center gap-2">
                  <label class="cursor-pointer text-xs font-semibold text-red-600 hover:text-red-700">
                    + Ajouter (1 ou plusieurs)
                    <input type="file" name="photo" accept="image/jpeg,image/png,image/webp,image/heic" multiple class="hidden" onchange="this.form.submit()">
                  </label>
                </form>
              </div>
              <% const photos = (engineQuote.photos[cat.key] || []); %>
              <% if (photos.length === 0) { %>
                <div class="border-2 border-dashed border-slate-200 rounded-xl p-6 text-center text-xs text-slate-400">
                  Aucune photo
                </div>
              <% } else { %>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                  <% photos.forEach(function(p) { %>
                    <div class="relative group rounded-xl overflow-hidden border border-slate-200 bg-slate-50">
                      <a href="<%= p.url %>" target="_blank">
                        <img src="<%= p.url %>" alt="<%= p.filename %>" class="w-full h-32 object-cover">
                      </a>
                      <form action="/admin/devis-moteurs/<%= cart.id %>/photo/<%= cat.key %>/<%= p.id %>/delete" method="POST" class="absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition" onsubmit="return confirm('Supprimer cette photo ?')">
                        <button type="submit" class="bg-red-600 hover:bg-red-700 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs">×</button>
                      </form>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        </section>

<!-- Bloc ENVOI DU DEVIS -->
        <section id="send-quote" class="bg-white rounded-2xl border-2 border-red-200 p-6 bg-gradient-to-br from-red-50/30 to-transparent">
          <div class="mb-4 flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
                <span class="material-symbols-outlined text-red-600">send</span>
                Envoyer le devis au client
              </h2>
              <p class="text-xs text-slate-500 mt-0.5">Génère un PDF brandé + envoie au client par email</p>
            </div>
          </div>

          <% // Calcul initial — sera actualisé en temps réel par le JS au bas de la page
             const initialCanSend = cart.email && engineQuote.pricing.sellPrice > 0;
             const noEmail = !cart.email;
             // Modification d'un devis déjà envoyé : on renvoie une RÉVISION.
             const sentCount = (engineQuote.sentQuotes && engineQuote.sentQuotes.length) || 0;
             const alreadySent = sentCount > 0;
             const nextVersion = sentCount + 1;
             const sendConfirmMsg = alreadySent
               ? ('Renvoyer une version mise a jour (revision v' + nextVersion + ') du devis au client ' + cart.email + ' ? Les anciens liens (SMS/email) pointeront vers cette nouvelle version.')
               : ('Envoyer le devis au client ' + cart.email + ' ?');
          %>
          <!-- Warning email manquant : permanent si le client n'a pas d'email -->
          <% if (noEmail) { %>
            <div class="rounded-lg bg-amber-50 border border-amber-200 p-3 text-sm text-amber-800 mb-4">
              ⚠️ Le client n'a pas fourni d'email — devis non envoyable.
            </div>
          <% } %>

          <!-- Warning prix vente manquant — mis à jour en JS via data-warn-price -->
          <div data-warn-price class="rounded-lg bg-amber-50 border border-amber-200 p-3 text-sm text-amber-800 mb-4 <%= (noEmail || engineQuote.pricing.sellPrice > 0) ? 'hidden' : '' %>">
            ⚠️ Renseigne d'abord le prix de vente HT dans le bloc Tarification ci-dessus.
          </div>

          <!-- Warning champs essentiels vides — mis à jour en JS via data-warn-missing -->
          <div data-warn-missing class="rounded-lg bg-orange-50 border-2 border-orange-300 p-3 mb-4 text-sm hidden">
            <p class="font-bold text-orange-900 mb-1">⚠️ Champs essentiels vides — le PDF sera incomplet</p>
            <p class="text-orange-800">Renseigne avant d'envoyer :</p>
            <ul data-warn-missing-list class="text-orange-800 mt-1 ml-4 list-disc"></ul>
            <p class="text-xs text-orange-700 mt-2">L'envoi reste possible, mais le devis manquera de détails (zones vides sur le PDF).</p>
          </div>
          <% { %>
            <% // Template commercial pré-rempli — le commercial peut éditer avant envoi.
              // Accordé au genre selon la catégorie du lead (boîte fém. / moteur masc.).
              const b = !!cart.isBoite;
              const tplFirstName = (cart.firstName && cart.lastName) ? cart.firstName : '';
              const tplPlate = cart.plate || 'votre véhicule';
              const tplModel = engineQuote.identifiedEngine.model || (b ? 'la boîte demandée' : 'le moteur demandé');
              const tplCode = engineQuote.identifiedEngine.code ? ' (' + engineQuote.identifiedEngine.code + ')' : '';
              const tplMileage = engineQuote.identifiedEngine.mileage > 0
                ? new Intl.NumberFormat('fr-FR').format(engineQuote.identifiedEngine.mileage) + ' km certifiés au compteur'
                : '';
              const tplCondition = engineQuote.identifiedEngine.condition;
              const tplIsRecond = tplCondition === 'reconditionne_complet' || tplCondition === 'reconditionne_chemise_fonte';
              const tplConditionLine = tplCondition === 'reconditionne_chemise_fonte'
                ? (b
                    ? 'Il s\'agit d\'une boîte reconditionnée haut de gamme dans notre atelier — la solution premium pour fiabiliser durablement votre transmission.'
                    : 'Il s\'agit d\'un moteur reconditionné avec chemisage fonte — la solution premium pour fiabiliser durablement votre bloc moteur.')
                : tplCondition === 'reconditionne_complet'
                  ? (b
                      ? 'Il s\'agit d\'une boîte entièrement reconditionnée dans notre atelier.'
                      : 'Il s\'agit d\'un moteur entièrement reconditionné dans notre atelier.')
                  : tplCondition === 'occasion'
                    ? (b
                        ? 'Boîte de vitesse d\'occasion intégralement contrôlée à l\'atelier avant expédition.'
                        : 'Moteur d\'occasion intégralement testé sur banc d\'essai avant expédition.')
                    : '';
              // Garantie selon l'état (cohérent avec le devis PDF/email) : reconditionné 12 mois, occasion 6 mois
              const tplWarranty = (tplCondition === 'reconditionne_chemise_fonte' || tplCondition === 'reconditionne_complet') ? 12 : 6;
              const tplStock = engineQuote.stock.location === 'atelier'
                ? (tplIsRecond
                    ? (b
                        ? 'La boîte est reconditionnée dans notre atelier (remplacement des pièces d\'usure, mécatronique contrôlée).'
                        : 'Le moteur est reconditionné dans notre atelier (rectification + remplacement des pièces d\'usure).')
                    : (b
                        ? 'La boîte est actuellement dans notre atelier, déjà contrôlée.'
                        : 'Le moteur est actuellement dans notre atelier, déjà passé sur banc d\'essai.'))
                : engineQuote.stock.location === 'sourcing'
                  ? (tplIsRecond
                      ? (b
                          ? 'La boîte est reconditionnée à la commande dans notre atelier (remplacement des pièces d\'usure, mécatronique contrôlée), puis contrôlée avant expédition.'
                          : 'Le moteur est reconditionné à la commande dans notre atelier (rectification + remplacement des pièces d\'usure), puis contrôlé avant expédition.')
                      : (b
                          ? 'La boîte est sur commande sur notre réseau professionnel. Elle sera obligatoirement contrôlée à l\'atelier avant expédition.'
                          : 'Le moteur est sur commande sur notre réseau professionnel. Il passera obligatoirement sur banc d\'essai à l\'atelier avant expédition.'))
                  : '';
              const tplDelay = engineQuote.stock.estimatedDelay ? ' Délai estimé : ' + engineQuote.stock.estimatedDelay + '.' : '';
              // Bullet "expédition" adapté au scénario stock (pas de 48-72h si c'est sur commande)
              const tplShippingBullet = engineQuote.stock.location === 'atelier'
                ? '• Expédition Europe en 48-72h après accord'
                : engineQuote.stock.location === 'sourcing'
                  ? (tplIsRecond
                      ? (b
                          ? '• Expédition Europe sous 48-72h une fois la boîte reconditionnée et contrôlée'
                          : '• Expédition Europe sous 48-72h une fois le moteur reconditionné et contrôlé')
                      : (b
                          ? '• Expédition Europe sous 48-72h une fois la boîte validée à l\'atelier'
                          : '• Expédition Europe sous 48-72h une fois le moteur validé sur notre banc d\'essai'))
                  : '• Expédition sécurisée Europe (palette, scellés, attestation)';
              // Contrôle au banc — vocabulaire spécifique (compression/endoscopie pour
              // un moteur ; passage des rapports/mécatronique pour une boîte).
              const tplBenchObligatoire = b
                ? '• Contrôle obligatoire (passage des rapports, étanchéité, mécatronique)'
                : '• Banc d\'essai obligatoire (compression, étanchéité, endoscopie)';
              const tplBenchRecond = b
                ? '• Banc d\'essai (passage des rapports, étanchéité, mécatronique)'
                : '• Banc d\'essai (compression, étanchéité, endoscopie)';
              const defaultMessage = [
                tplFirstName ? `Bonjour ${tplFirstName},` : 'Bonjour,',
                ``,
                `Suite à votre demande pour ${tplPlate}, voici notre devis personnalisé pour ${tplModel}${tplCode}.`,
                tplConditionLine ? `\n${tplConditionLine}` : '',
                tplMileage ? `\nKilométrage : ${tplMileage}.` : '',
                tplStock ? `\n${tplStock}${tplDelay}` : '',
                ``,
                `Vous trouverez en pièces jointes le devis détaillé au format PDF et les photos ${b ? 'de la boîte' : 'du moteur'}.`,
                ``,
                `Pour rappel, nos engagements :`,
                tplIsRecond ? `• Reconditionnement complet en atelier (pièces d'usure remplacées)` : tplBenchObligatoire,
                tplIsRecond ? tplBenchRecond : `• Kilométrage certifié et photo du compteur transmise`,
                `• Garantie ${tplWarranty} mois sans franchise kilométrique`,
                tplShippingBullet,
                ``,
                `À votre disposition pour toute question.`,
                ``,
                `L'équipe technique Autoliva`,
              ].filter(s => s !== null).join('\n').replace(/\n{3,}/g, '\n\n').trim();
            %>
            <form action="/admin/devis-moteurs/<%= cart.id %>/send-quote" method="POST" class="space-y-4">
              <div>
                <div class="flex items-center justify-between mb-1">
                  <label class="text-xs font-semibold text-slate-500">Message commercial (modifiable)</label>
                  <button type="button" onclick="document.querySelector('[name=customMessage]').value=this.dataset.tpl" data-tpl="<%= defaultMessage.replace(/&/g,'&amp;').replace(/"/g,'&quot;') %>" class="text-xs text-slate-400 hover:text-slate-600">↻ Recharger le template</button>
                </div>
                <textarea name="customMessage" rows="10" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 font-sans"><%= defaultMessage %></textarea>
              </div>

              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-2">Mode de paiement proposé au client</label>
                <div class="grid grid-cols-3 md:grid-cols-4 gap-2">
                  <% [
                    { val: 0,   lbl: 'Aucun', hint: 'Pas de paiement' },
                    { val: 10,  lbl: '10 %',  hint: 'Acompte' },
                    { val: 15,  lbl: '15 %',  hint: 'Acompte' },
                    { val: 20,  lbl: '20 %',  hint: 'Acompte' },
                    { val: 30,  lbl: '30 %',  hint: 'Réservation' },
                    { val: 50,  lbl: '50 %',  hint: 'Engagement fort' },
                    { val: 100, lbl: '100 %', hint: 'Intégral' },
                  ].forEach(function(opt) { %>
                    <label class="cursor-pointer border-2 border-slate-200 hover:border-slate-300 has-[:checked]:border-red-500 has-[:checked]:bg-red-50 rounded-lg p-2.5 text-center transition block">
                      <input type="radio" name="depositPct" value="<%= opt.val %>" <%= (opt.val === 30 ? 'checked' : '') %> class="sr-only peer" data-deposit-radio>
                      <span class="block text-sm font-bold text-slate-700 peer-checked:text-red-700"><%= opt.lbl %></span>
                      <span class="block text-[10px] text-slate-400 mt-0.5"><%= opt.hint %></span>
                    </label>
                  <% }) %>
                </div>
                <div class="mt-2 flex items-center gap-2">
                  <label for="depositPctCustom" class="text-xs font-semibold text-slate-500 whitespace-nowrap">Autre %</label>
                  <input type="number" id="depositPctCustom" name="depositPctCustom" min="1" max="100" step="1" placeholder="ex : 22" class="w-24 rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500" data-deposit-custom>
                  <span class="text-[11px] text-slate-400">prioritaire sur les boutons si renseigné</span>
                </div>
                <script>
                  (function () {
                    var custom = document.querySelector('[data-deposit-custom]');
                    var radios = document.querySelectorAll('[data-deposit-radio]');
                    if (!custom || !radios.length) return;
                    // Saisie d'un % libre → on décoche les presets (une seule sélection visible)
                    custom.addEventListener('input', function () {
                      if (custom.value !== '') {
                        radios.forEach(function (r) { r.checked = false; });
                      }
                    });
                    // Clic sur un preset → on vide le champ libre
                    radios.forEach(function (r) {
                      r.addEventListener('change', function () {
                        if (r.checked) custom.value = '';
                      });
                    });
                  })();
                </script>
              </div>

              <div>
                <label class="flex items-center gap-2 text-sm <%= mollieEnabled ? 'text-slate-700 cursor-pointer' : 'text-slate-400' %>">
                  <input type="checkbox" name="createMollie" <%= mollieEnabled ? 'checked' : 'disabled' %>>
                  <span>Inclure le bouton de paiement cliquable Mollie dans le PDF et l'email<% if (!mollieEnabled) { %> <em class="text-xs">(désactivé — défini ENGINE_QUOTE_MOLLIE_ENABLED=true)</em><% } %></span>
                </label>
              </div>

              <div class="bg-slate-50 border border-slate-200 rounded-lg p-3 text-xs space-y-1">
                <div class="text-slate-700">📧 Email vers <strong><%= cart.email %></strong></div>
                <div class="text-slate-700">📎 PDF en pièce jointe (<%= cart.ref %>)</div>
                <div class="text-slate-700">🏷️ Statut passera à <strong>"Devis envoyé"</strong> + relances auto J+3 / J+7 activées</div>
                <% if (alreadySent) { %>
                  <div class="text-violet-700 font-semibold">🔁 Révision <strong>v<%= nextVersion %></strong> — remplace la version précédente. Les liens déjà envoyés (SMS/email) pointeront vers cette nouvelle version.</div>
                <% } %>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-2 pt-1">
                <button type="submit" formaction="/admin/devis-moteurs/<%= cart.id %>/preview-email" formtarget="_blank" formnovalidate onclick="return true" class="bg-white border-2 border-slate-300 hover:border-slate-400 text-slate-700 font-semibold py-2.5 rounded-xl text-sm flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined" style="font-size:16px">visibility</span>
                  Aperçu email
                </button>
                <button type="submit" formaction="/admin/devis-moteurs/<%= cart.id %>/preview-pdf" formtarget="_blank" formnovalidate onclick="return true" class="bg-white border-2 border-slate-300 hover:border-slate-400 text-slate-700 font-semibold py-2.5 rounded-xl text-sm flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined" style="font-size:16px">picture_as_pdf</span>
                  Aperçu PDF
                </button>
                <button type="submit" data-send-btn onclick="return confirm('<%= sendConfirmMsg %>')" <%= initialCanSend ? '' : 'disabled' %> class="bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 rounded-xl text-sm flex items-center justify-center gap-2 disabled:bg-slate-300 disabled:cursor-not-allowed disabled:hover:bg-slate-300">
                  <span class="material-symbols-outlined" style="font-size:16px"><%= alreadySent ? 'autorenew' : 'send' %></span>
                  <%= alreadySent ? ('Renvoyer le devis modifié (v' + nextVersion + ')') : 'Envoyer' %>
                </button>
              </div>
              <p class="text-xs text-slate-400 text-center">Les 2 aperçus s'ouvrent dans un nouvel onglet · l'envoi reste à confirmer</p>
            </form>
          <% } %>
        </section>

        <!-- Bloc HISTORIQUE -->
        <% if (engineQuote.sentQuotes && engineQuote.sentQuotes.length > 0) { %>
        <section id="history" class="bg-white rounded-2xl border border-slate-200 p-6">
          <h2 class="text-lg font-semibold text-slate-900 mb-4">Historique des envois</h2>
          <div class="space-y-3">
            <% engineQuote.sentQuotes.forEach(function(sq, _idx) { %>
              <div class="border border-slate-200 rounded-xl p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                      <span class="text-sm font-semibold text-slate-900"><%= sq.version ? ('Devis v' + sq.version) : 'Devis envoyé' %></span>
                      <% if (_idx === 0 && engineQuote.sentQuotes.length > 1) { %>
                        <span class="inline-flex items-center text-xs font-semibold text-violet-700 bg-violet-50 px-2 py-0.5 rounded-full">Version actuelle</span>
                      <% } %>
                      <span class="text-xs text-slate-400">par <%= sq.sentByName || 'Admin' %></span>
                      <% if (sq.sms && sq.sms.status === 'sent') { %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full" title="SMS du devis envoyé au <%= sq.sms.phone || '' %>">
                          <span class="material-symbols-outlined" style="font-size:13px">sms</span> SMS envoyé
                        </span>
                      <% } else if (sq.sms && sq.sms.status === 'failed') { %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-red-700 bg-red-50 px-2 py-0.5 rounded-full" title="<%= sq.sms.message || sq.sms.reason || '' %>">
                          <span class="material-symbols-outlined" style="font-size:13px">sms_failed</span> SMS échec<%= sq.sms.message ? ' — ' + sq.sms.message : (sq.sms.reason ? ' (' + sq.sms.reason + ')' : '') %>
                        </span>
                      <% } else if (sq.sms && sq.sms.status === 'disabled') { %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full" title="Le template SMS « devis » est désactivé">
                          <span class="material-symbols-outlined" style="font-size:13px">sms</span> SMS désactivé
                        </span>
                      <% } %>
                      <% if (sq.openedAt) { %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full" title="Email ouvert <%= sq.openCount || 1 %> fois">
                          <span class="material-symbols-outlined" style="font-size:13px">visibility</span>
                          Ouvert<%= (sq.openCount && sq.openCount > 1) ? ' ×' + sq.openCount : '' %>
                        </span>
                      <% } %>
                      <% if (sq.pdfViewedAt) { %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-blue-700 bg-blue-50 px-2 py-0.5 rounded-full" title="PDF consulté en ligne <%= sq.pdfViewCount || 1 %> fois">
                          <span class="material-symbols-outlined" style="font-size:13px">picture_as_pdf</span>
                          PDF vu<%= (sq.pdfViewCount && sq.pdfViewCount > 1) ? ' ×' + sq.pdfViewCount : '' %>
                        </span>
                      <% } %>
                      <% if (sq.payClickedAt) { %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-amber-800 bg-amber-100 px-2 py-0.5 rounded-full" title="A cliqué sur le bouton de paiement <%= sq.payClickCount || 1 %> fois">
                          <span class="material-symbols-outlined" style="font-size:13px">credit_card</span>
                          Paiement cliqué<%= (sq.payClickCount && sq.payClickCount > 1) ? ' ×' + sq.payClickCount : '' %>
                        </span>
                      <% } %>
                    </div>
                    <div class="text-xs text-slate-500">
                      <%= new Date(sq.sentAt).toLocaleString('fr-FR', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                      · TTC <strong class="text-slate-700 font-mono"><%= fmt(sq.sellPriceTtc) %> €</strong>
                      <% if (sq.depositCents) { %> · Acompte <strong class="text-slate-700 font-mono"><%= fmt(sq.depositCents / 100) %> €</strong><% } %>
                      <% if (sq.openedAt) { %> · ouvert le <%= new Date(sq.openedAt).toLocaleString('fr-FR', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %><% } %>
                      <% if (sq.pdfViewedAt) { %> · PDF vu le <%= new Date(sq.pdfViewedAt).toLocaleString('fr-FR', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %><% } %>
                      <% if (sq.payClickedAt) { %> · paiement cliqué le <%= new Date(sq.payClickedAt).toLocaleString('fr-FR', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %><% } %>
                    </div>
                    <% if (sq.mollieUrl) { %><div class="text-xs text-blue-600 mt-1 truncate"><a href="<%= sq.mollieUrl %>" target="_blank">Lien Mollie →</a></div><% } %>
                  </div>
                  <% if (sq.pdfUrl) { %>
                    <a href="<%= sq.pdfUrl %>" target="_blank" class="text-xs font-semibold text-red-600 hover:text-red-700 whitespace-nowrap shrink-0">📄 PDF →</a>
                  <% } %>
                </div>

                <% if (sq.attachedPhotos && sq.attachedPhotos.length > 0) { %>
                  <div class="mt-3 pt-3 border-t border-slate-100">
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"><%= sq.attachedPhotos.length %> photo<%= sq.attachedPhotos.length > 1 ? 's' : '' %> jointe<%= sq.attachedPhotos.length > 1 ? 's' : '' %> au devis</p>
                    <div class="grid grid-cols-3 md:grid-cols-6 gap-2">
                      <% sq.attachedPhotos.forEach(function(p) { %>
                        <a href="<%= p.url %>" target="_blank" class="block rounded-lg overflow-hidden border border-slate-200 bg-slate-50 hover:border-red-300 transition" title="<%= p.filename %> · <%= p.category %>">
                          <img src="<%= p.url %>" alt="<%= p.filename %>" class="w-full h-16 object-cover">
                        </a>
                      <% }) %>
                    </div>
                  </div>
                <% } %>

                <% if (sq.customMessage) { %>
                  <div class="mt-3 pt-3 border-t border-slate-100">
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Message envoyé</p>
                    <p class="text-xs text-slate-600 whitespace-pre-wrap line-clamp-3"><%= sq.customMessage %></p>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>

          <% if (engineQuote.remindersSent && engineQuote.remindersSent.length > 0) { %>
            <div class="mt-4 pt-4 border-t border-slate-100">
              <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Relances auto</p>
              <div class="flex flex-wrap gap-2">
                <% engineQuote.remindersSent.forEach(function(r) { %>
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold <%= r.type === 'j14_lost' ? 'bg-rose-50 text-rose-700' : 'bg-amber-50 text-amber-700' %>">
                    <%= r.type === 'j3' ? 'J+3' : r.type === 'j7' ? 'J+7' : 'Auto-perdu J+14' %> · <%= new Date(r.sentAt).toLocaleDateString('fr-FR') %>
                  </span>
                <% }) %>
              </div>
            </div>
          <% } %>
        </section>
        <% } %>

        <!-- Bloc NOTES -->
        <section id="notes" class="bg-white rounded-2xl border border-slate-200 p-6">
          <h2 class="text-lg font-semibold text-slate-900 mb-4">Notes internes</h2>

          <form action="/admin/devis-moteurs/<%= cart.id %>/note" method="POST" class="mb-4">
            <textarea name="text" rows="3" placeholder="Ajouter une note (visible uniquement par l'équipe)…" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500" required></textarea>
            <button type="submit" class="mt-2 bg-slate-900 hover:bg-slate-800 text-white text-sm font-semibold px-4 py-2 rounded-lg">Ajouter la note</button>
          </form>

          <% if (cart.notes.length === 0) { %>
            <p class="text-xs text-slate-400">Aucune note.</p>
          <% } else { %>
            <div class="space-y-3">
              <% cart.notes.forEach(function(n) { %>
                <div class="border-l-2 border-slate-200 pl-3 py-1">
                  <div class="text-xs text-slate-500"><strong class="text-slate-700"><%= n.addedByName || 'Admin' %></strong> · <%= dt(n.addedAt) %></div>
                  <div class="text-sm text-slate-800 mt-1 whitespace-pre-wrap"><%= n.text %></div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

      </div>

      <!-- ─── COLONNE DROITE (1/3) ─── -->
      <aside class="space-y-6">

        <!-- Coordonnées client -->
        <section class="bg-white rounded-2xl border border-slate-200 p-6">
          <h2 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-4">Demandeur</h2>
          <div class="space-y-3">
            <div>
              <div class="text-xs text-slate-400">Nom</div>
              <div class="font-medium text-slate-900"><%= cart.displayName %></div>
            </div>
            <% if (cart.phone) { %>
              <div>
                <div class="text-xs text-slate-400">Téléphone</div>
                <a href="tel:<%= cart.phone %>" class="font-medium text-red-600 hover:underline"><%= cart.phone %></a>
              </div>
            <% } %>
            <% if (engineQuote.ackSms && engineQuote.ackSms.status) { %>
              <div>
                <div class="text-xs text-slate-400">Accusé SMS (à la demande)</div>
                <% if (engineQuote.ackSms.status === 'sent') { %>
                  <span class="inline-flex items-center gap-1 text-xs font-semibold text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full"><span class="material-symbols-outlined" style="font-size:13px">sms</span> Envoyé</span>
                <% } else if (engineQuote.ackSms.status === 'failed') { %>
                  <span class="inline-flex items-center gap-1 text-xs font-semibold text-red-700 bg-red-50 px-2 py-0.5 rounded-full" title="<%= engineQuote.ackSms.message || engineQuote.ackSms.reason || '' %>"><span class="material-symbols-outlined" style="font-size:13px">sms_failed</span> Échec<%= engineQuote.ackSms.message ? ' — ' + engineQuote.ackSms.message : (engineQuote.ackSms.reason ? ' (' + engineQuote.ackSms.reason + ')' : '') %></span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full"><span class="material-symbols-outlined" style="font-size:13px">sms</span> Désactivé</span>
                <% } %>
              </div>
            <% } %>
            <% if (cart.email) { %>
              <div>
                <div class="text-xs text-slate-400">Email</div>
                <a href="mailto:<%= cart.email %>" class="font-medium text-red-600 hover:underline break-all"><%= cart.email %></a>
              </div>
            <% } %>
          </div>
        </section>

        <!-- Demande initiale -->
        <section class="bg-white rounded-2xl border border-slate-200 p-6">
          <h2 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-4">Demande initiale</h2>
          <div class="space-y-3">
            <div>
              <div class="text-xs text-slate-400">Plaque / châssis / code</div>
              <div class="font-mono font-semibold text-slate-900"><%= cart.plate || '—' %></div>
            </div>
            <div>
              <div class="text-xs text-slate-400">Type demandé</div>
              <div class="text-sm text-slate-700"><%= cart.vehicle || '—' %></div>
            </div>
            <% if (cart.message) { %>
              <div>
                <div class="text-xs text-slate-400">Message</div>
                <div class="text-sm text-slate-700 italic">"<%= cart.message %>"</div>
              </div>
            <% } %>
          </div>
        </section>

        <!-- Attribution -->
        <% if (cart.attribution && (cart.attribution.source || cart.attribution.campaign)) { %>
          <section class="bg-white rounded-2xl border border-slate-200 p-6">
            <h2 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-4">Source du lead</h2>
            <div class="space-y-2 text-sm text-slate-700">
              <% if (cart.attribution.source) { %><div><span class="text-xs text-slate-400">Source :</span> <%= cart.attribution.source %></div><% } %>
              <% if (cart.attribution.medium) { %><div><span class="text-xs text-slate-400">Medium :</span> <%= cart.attribution.medium %></div><% } %>
              <% if (cart.attribution.campaign) { %><div><span class="text-xs text-slate-400">Campagne :</span> <%= cart.attribution.campaign %></div><% } %>
              <% if (cart.attribution.gclid) { %><div class="text-xs text-slate-400 font-mono break-all"><%= cart.attribution.gclid %></div><% } %>
            </div>
          </section>
        <% } %>

      </aside>
    </div>

  </div>
</main>

<script>
// ─── Boutons rapides "Délai estimé" ───
(function () {
  const input = document.querySelector('[data-delay-input]');
  const chips = document.querySelectorAll('[data-delay-preset]');
  if (!input || !chips.length) return;

  function syncChips() {
    chips.forEach(c => {
      const active = c.dataset.delayPreset === input.value.trim();
      c.classList.toggle('border-red-500', active);
      c.classList.toggle('bg-red-50', active);
      c.classList.toggle('text-red-700', active);
      c.classList.toggle('border-slate-200', !active);
      c.classList.toggle('text-slate-600', !active);
    });
  }

  chips.forEach(chip => {
    chip.addEventListener('click', function () {
      // Re-cliquer un chip actif le désélectionne (vide le champ)
      input.value = (input.value.trim() === chip.dataset.delayPreset) ? '' : chip.dataset.delayPreset;
      // Déclenche l'auto-save du formulaire Stock
      input.dispatchEvent(new Event('input', { bubbles: true }));
      input.dispatchEvent(new Event('change', { bubbles: true }));
      syncChips();
    });
  });

  // Si l'utilisateur tape en manuel, garde les chips synchros
  input.addEventListener('input', syncChips);
})();

// ─── Auto-save : tout form avec data-autosave envoie en AJAX au change/blur ───
(function () {
  const forms = document.querySelectorAll('form[data-autosave]');
  forms.forEach(form => {
    const indicator = form.querySelector('[data-save-indicator]');
    let timer = null;
    let lastPayload = '';

    function showStatus(state) {
      if (!indicator) return;
      if (state === 'saving') {
        indicator.textContent = 'Enregistrement…';
        indicator.classList.remove('text-emerald-600', 'text-rose-600');
        indicator.classList.add('text-slate-400');
        indicator.style.opacity = 1;
      } else if (state === 'saved') {
        indicator.textContent = 'Enregistré ✓';
        indicator.classList.remove('text-slate-400', 'text-rose-600');
        indicator.classList.add('text-emerald-600');
        indicator.style.opacity = 1;
        setTimeout(() => { indicator.style.opacity = 0; }, 1800);
      } else if (state === 'error') {
        indicator.textContent = '⚠ Erreur enregistrement';
        indicator.classList.remove('text-slate-400', 'text-emerald-600');
        indicator.classList.add('text-rose-600');
        indicator.style.opacity = 1;
      }
    }

    async function save() {
      // IMPORTANT : on envoie en application/x-www-form-urlencoded (PAS FormData
      // multipart) car le serveur parse uniquement urlencoded sur ces routes.
      // FormData → multipart → req.body vide → champs non persistés.
      const fd = new FormData(form);
      const params = new URLSearchParams();
      for (const [k, v] of fd.entries()) params.append(k, v);
      const payloadStr = params.toString();
      if (payloadStr === lastPayload) return; // pas de changement réel
      lastPayload = payloadStr;
      showStatus('saving');
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: params,
          credentials: 'same-origin',
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        showStatus('saved');
      } catch (err) {
        console.error('Autosave failed:', err);
        showStatus('error');
      }
    }

    // Debounced save (300ms après changement)
    function scheduleSave() {
      clearTimeout(timer);
      timer = setTimeout(save, 300);
    }

    // Initial snapshot (pour ne pas spammer au load)
    lastPayload = new URLSearchParams(new FormData(form)).toString();

    form.addEventListener('change', scheduleSave);        // radio, select, checkbox
    form.addEventListener('input', scheduleSave);         // text, number, textarea
    form.addEventListener('blur', save, true);            // blur immédiat (capture phase)
    form.addEventListener('submit', e => { e.preventDefault(); save(); });
  });
})();

// ─── Live update du bloc "Envoyer le devis" selon les autres formulaires ───
// Surveille les changements dans les blocs Identification / Stock / Tarification
// et met à jour les warnings + le bouton Envoyer en temps réel.
(function () {
  const noEmail = <%= noEmail ? 'true' : 'false' %>;
  const warnPrice = document.querySelector('[data-warn-price]');
  const warnMissing = document.querySelector('[data-warn-missing]');
  const warnMissingList = document.querySelector('[data-warn-missing-list]');
  const sendBtn = document.querySelector('[data-send-btn]');
  if (!warnPrice || !warnMissing || !sendBtn) return;

  function val(name, formAction) {
    const form = document.querySelector('form[action$="' + formAction + '"]');
    if (!form) return '';
    const el = form.elements.namedItem(name);
    if (!el) return '';
    if (el.type === 'radio' || el.length) {
      // RadioNodeList ou node radio unique
      if (el.value !== undefined && el.checked !== undefined) return el.checked ? el.value : '';
      const checked = Array.from(el).find(x => x.checked);
      return checked ? checked.value : '';
    }
    return el.value || '';
  }

  function compute() {
    const sellPrice = Number(val('sellPrice', '/pricing')) || 0;
    const code = val('code', '/engine').trim();
    const model = val('model', '/engine').trim();
    const mileage = Number(val('mileage', '/engine')) || 0;
    const condition = val('condition', '/engine');
    const stock = val('location', '/stock');

    const canSend = !noEmail && sellPrice > 0;

    // Warning prix
    warnPrice.classList.toggle('hidden', noEmail || sellPrice > 0);

    // Warning champs essentiels
    const missing = [];
    if (!code && !model) missing.push('identification <%= lex.noun %> (code et modèle vides)');
    if (!mileage) missing.push('kilométrage');
    if (!condition) missing.push('état <%= lex.duNoun %> (occasion / reconditionné<%= cart.isBoite ? "e" : "" %>)');
    if (!stock) missing.push('stock (atelier / sourcing)');

    if (canSend && missing.length > 0) {
      warnMissing.classList.remove('hidden');
      warnMissingList.innerHTML = missing.map(m => '<li>' + m + '</li>').join('');
    } else {
      warnMissing.classList.add('hidden');
    }

    // Bouton Envoyer activé/désactivé
    sendBtn.disabled = !canSend;
  }

  // Écoute tous les inputs des 3 formulaires pertinents
  ['/engine', '/stock', '/pricing'].forEach(action => {
    const form = document.querySelector('form[action$="' + action + '"]');
    if (form) {
      form.addEventListener('input', compute);
      form.addEventListener('change', compute);
    }
  });
  compute();
})();

// Calcul de marge live
(function () {
  const root = document.querySelector('form[action*="/pricing"]');
  if (!root) return;
  const vat = <%= engineQuote.pricing.vatRate || 20 %>;
  const inputs = root.querySelectorAll('[data-margin-input]');
  const out = {
    cost: root.querySelector('[data-margin-cost]'),
    eur:  root.querySelector('[data-margin-eur]'),
    pct:  root.querySelector('[data-margin-pct]'),
    ttc:  root.querySelector('[data-margin-ttc]'),
  };
  function num(el) { return Number(String(el.value).replace(',', '.')) || 0; }
  function fmtEur(n) { return new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' €'; }
  function color(pct) {
    if (pct >= 25) return 'text-emerald-700';
    if (pct >= 15) return 'text-amber-700';
    return 'text-rose-700';
  }
  // Coûts de contrôle (port test + MO) — TOUJOURS inclus dès qu'un dossier est
  // chiffré. Lit les champs via querySelector (pas de const → pas de souci
  // d'ordre d'initialisation).
  function controlCost(purchase) {
    if (!(purchase > 0)) return 0;
    const port = num(root.querySelector('[data-ctrl-port]'));
    const rate = num(root.querySelector('[data-ctrl-rate]'));
    const hours = num(root.querySelector('[data-ctrl-hours]'));
    return port + rate * hours;
  }
  const schemeInput = root.querySelector('[data-vat-scheme]');
  function isMargin() { return !schemeInput || schemeInput.value !== 'normal'; }
  function recompute() {
    const purchase = num(root.querySelector('[name=purchasePrice]'));
    const fees = num(root.querySelector('[name=additionalFees]'));
    const sell = num(root.querySelector('[name=sellPrice]'));
    const cost = purchase + fees + controlCost(purchase);
    let marginEur, fourth;
    if (isMargin()) {
      // TVA sur marge = (vente − achat) × taux/(100+taux), si marge positive.
      const tvaMarge = sell > purchase ? (sell - purchase) * vat / (100 + vat) : 0;
      marginEur = sell - cost - tvaMarge;
      fourth = tvaMarge;                  // 4e carte = TVA sur marge
    } else {
      marginEur = sell - cost;
      fourth = sell * (1 + vat / 100);    // 4e carte = Vente TTC
    }
    const marginPct = sell > 0 ? (marginEur / sell) * 100 : 0;

    out.cost.textContent = sell || cost ? fmtEur(cost) : '—';
    out.eur.textContent  = sell || cost ? fmtEur(marginEur) : '—';
    out.pct.textContent  = sell > 0 ? marginPct.toFixed(1) + ' %' : '—';
    out.ttc.textContent  = sell > 0 ? fmtEur(fourth) : '—';

    // Couleurs
    ['text-emerald-700','text-amber-700','text-rose-700','text-slate-900'].forEach(c => {
      out.eur.classList.remove(c); out.pct.classList.remove(c);
    });
    if (sell > 0) {
      const cls = color(marginPct);
      out.eur.classList.add(cls);
      out.pct.classList.add(cls);
    } else {
      out.eur.classList.add('text-slate-900');
      out.pct.classList.add('text-slate-900');
    }
  }

  // ─── Toggle régime TVA (marge / normal) ───
  const labelTtc = root.querySelector('[data-label-ttc]');
  const labelSell = root.querySelector('[data-sell-label]');
  const schemeHint = root.querySelector('[data-scheme-hint]');
  const schemeBtns = root.querySelectorAll('[data-scheme-btn]');
  function syncSchemeUI() {
    const margin = isMargin();
    if (labelTtc) labelTtc.textContent = margin ? 'TVA sur marge' : 'Vente TTC';
    if (labelSell) labelSell.textContent = margin ? 'Prix de vente — tout compris (€)' : 'Prix de vente HT (€)';
    if (schemeHint) schemeHint.textContent = margin
      ? 'Prix tout compris · TVA sur (vente − achat) · art. 297 A CGI'
      : 'TVA 20% ajoutée au prix HT';
    schemeBtns.forEach(function (b) {
      const active = b.getAttribute('data-scheme-btn') === (margin ? 'margin' : 'normal');
      b.classList.toggle('bg-white', active);
      b.classList.toggle('shadow-sm', active);
      b.classList.toggle('text-slate-900', active);
      b.classList.toggle('text-slate-500', !active);
    });
  }
  schemeBtns.forEach(function (b) {
    b.addEventListener('click', function () {
      if (schemeInput) schemeInput.value = b.getAttribute('data-scheme-btn');
      syncSchemeUI();
      recompute();
      if (schemeInput) schemeInput.dispatchEvent(new Event('input', { bubbles: true })); // autosave
    });
  });

  inputs.forEach(el => el.addEventListener('input', recompute));
  syncSchemeUI();
  recompute();

  // ─── Coûts de contrôle (port de test + MO de test) — affichage + live ───
  const ctrlPort = root.querySelector('[data-ctrl-port]');
  const ctrlRate = root.querySelector('[data-ctrl-rate]');
  const ctrlHours = root.querySelector('[data-ctrl-hours]');
  const ctrlTotalEl = root.querySelector('[data-ctrl-total]');
  function refreshCtrlTotal() {
    const raw = num(ctrlPort) + num(ctrlRate) * num(ctrlHours);
    if (ctrlTotalEl) ctrlTotalEl.textContent = new Intl.NumberFormat('fr-FR', { maximumFractionDigits: 0 }).format(raw);
  }
  [ctrlPort, ctrlRate, ctrlHours].forEach(function (el) {
    if (el) el.addEventListener('input', function () { refreshCtrlTotal(); recompute(); });
  });
  refreshCtrlTotal();

  // ─── Calcul auto du prix de vente depuis une marge cible ───
  // Marge = taux de marque (sur le prix de vente) → vente = coût / (1 - m/100),
  // cohérent avec l'affichage "% marge" ci-dessus.
  const sellInput = root.querySelector('[name=sellPrice]');
  const targetInput = root.querySelector('[data-target-margin]');
  const calcBtn = root.querySelector('[data-calc-sell]');
  function computeSellFromMargin() {
    const purchase = num(root.querySelector('[name=purchasePrice]'));
    const fees = num(root.querySelector('[name=additionalFees]'));
    if (purchase <= 0) { alert('Renseigne d\'abord le prix d\'achat.'); return; }
    const cost = purchase + fees + controlCost(purchase); // marge cible calculée sur le coût RÉEL (contrôle inclus)
    let m = Number(String(targetInput.value).replace(',', '.')) || 0;
    m = Math.max(0, Math.min(95, m)); // borne : évite la division par ~0 à 100%
    const sell = cost / (1 - m / 100);
    sellInput.value = (Math.round(sell * 100) / 100).toFixed(2);
    // Déclenche le recalcul de marge ET l'autosave (form écoute 'input')
    sellInput.dispatchEvent(new Event('input', { bubbles: true }));
  }
  if (calcBtn) calcBtn.addEventListener('click', computeSellFromMargin);
  root.querySelectorAll('[data-margin-chip]').forEach(function (chip) {
    chip.addEventListener('click', function () {
      targetInput.value = chip.getAttribute('data-margin-chip');
      computeSellFromMargin();
    });
  });
})();
</script>

