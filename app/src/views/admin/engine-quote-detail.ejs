              <div class="flex flex-wrap gap-2">
                <% engineQuote.remindersSent.forEach(function(r) { %>
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold <%= r.type === 'j14_lost' ? 'bg-rose-50 text-rose-700' : 'bg-amber-50 text-amber-700' %>">
                    <%= r.type === 'j3' ? 'J+3' : r.type === 'j7' ? 'J+7' : 'Auto-perdu J+14' %> · <%= new Date(r.sentAt).toLocaleDateString('fr-FR') %>
