<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'settings' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8 max-w-5xl">

    <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Paramètres', url: '/admin/parametres'}, {label: 'SMS automatiques'}] }) %>
    <div class="text-2xl md:text-3xl font-semibold text-slate-900">SMS automatiques</div>
    <div class="mt-1 text-sm text-slate-500"><%= total %> SMS au total. Active/désactive, personnalise le texte, teste avant d'envoyer. Rien n'est envoyé tant que tu ne cliques pas « Test ».</div>

    <% if (successMessage) { %>
      <div class="mt-6 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 text-sm font-medium"><%= successMessage %></div>
    <% } %>

    <!-- Numéro de test partagé -->
    <div class="mt-6 flex flex-col sm:flex-row sm:items-center gap-3 bg-white rounded-2xl border border-slate-200 p-4">
      <label for="sms-test-phone" class="text-sm font-semibold text-slate-600 whitespace-nowrap">Numéro pour les tests</label>
      <input id="sms-test-phone" type="tel" value="<%= smsTestTo %>" placeholder="06 12 34 56 78" class="w-full sm:w-56 rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500">
      <span class="text-xs text-slate-400">Le bouton « Test » de chaque SMS envoie un vrai SMS à ce numéro (avec des données d'exemple).</span>
    </div>

    <form method="POST" action="/admin/parametres/sms" class="mt-6">
      <% categories.forEach(function(cat) { %>
        <h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mt-8 mb-3"><%= cat %> · <%= groups[cat].length %></h2>
        <div class="space-y-4">
          <% groups[cat].forEach(function(it) {
               var effective = it.template && it.template.trim() ? it.template : it.defaultTemplate;
          %>
            <div class="bg-white rounded-2xl border border-slate-200 p-5" data-sms-card data-key="<%= it.key %>" data-default="<%= JSON.stringify(it.defaultTemplate) %>" data-example="<%= JSON.stringify(it.example) %>">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="font-semibold text-slate-900"><%= it.label %></div>
                  <div class="text-[11px] font-mono text-slate-400 mt-0.5"><%= it.key %></div>
                </div>
                <label class="inline-flex items-center gap-2 cursor-pointer shrink-0">
                  <input type="checkbox" name="enabled_<%= it.key %>" <%= it.enabled ? 'checked' : '' %> data-enable class="sr-only peer">
                  <span class="relative w-10 h-6 bg-slate-200 rounded-full peer-checked:bg-emerald-500 transition after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-5 after:h-5 after:bg-white after:rounded-full after:transition peer-checked:after:translate-x-4"></span>
                  <span class="text-xs font-semibold text-slate-500 peer-checked:text-emerald-600" data-enable-label><%= it.enabled ? 'Activé' : 'Désactivé' %></span>
                </label>
              </div>

              <textarea name="template_<%= it.key %>" rows="4" data-tpl class="mt-3 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm font-mono leading-relaxed focus:ring-2 focus:ring-red-500 focus:border-red-500"><%= effective %></textarea>

              <div class="mt-2 flex flex-wrap items-center gap-1.5">
                <span class="text-[11px] text-slate-400 mr-1">Variables :</span>
                <% it.vars.forEach(function(v) { %>
                  <button type="button" data-var="<%= v[0] %>" title="<%= v[1] %>" class="text-[11px] font-mono text-slate-600 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded px-1.5 py-0.5">{<%= v[0] %>}</button>
                <% }) %>
              </div>

              <div class="mt-3 rounded-lg bg-slate-50 border border-slate-100 p-3">
                <div class="text-[11px] font-semibold uppercase tracking-wider text-slate-400 mb-1">Aperçu (données d'exemple)</div>
                <div data-preview class="text-sm text-slate-700 whitespace-pre-line"></div>
              </div>

              <div class="mt-3 flex flex-wrap items-center justify-between gap-2">
                <div class="text-[11px] text-slate-400"><span data-count>0</span> caractères · <span data-seg>0</span> SMS</div>
                <div class="flex items-center gap-2">
                  <span data-test-status class="text-[11px] font-medium"></span>
                  <button type="button" data-reset class="text-xs font-semibold text-slate-500 hover:text-slate-800">↻ Réinitialiser</button>
                  <button type="button" data-test class="text-xs font-semibold text-white bg-slate-900 hover:bg-slate-800 rounded-lg px-3 py-1.5 inline-flex items-center gap-1">
                    <span class="material-symbols-outlined" style="font-size:14px">sms</span> Test
                  </button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% }) %>

      <div class="sticky bottom-0 mt-8 -mx-6 lg:-mx-10 px-6 lg:px-10 py-4 bg-white/90 backdrop-blur border-t border-slate-200 flex items-center justify-end gap-3">
        <span class="text-xs text-slate-400">Les modifications s'appliquent à tous les envois automatiques.</span>
        <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold px-6 py-2.5 rounded-xl text-sm">Enregistrer</button>
      </div>
    </form>
  </div>
</main>

<script>
(function () {
  function render(tpl, vars) {
    return String(tpl || '').replace(/\{(\w+)\}/g, function (m, k) { return (vars && vars[k] != null) ? vars[k] : m; });
  }
  function segInfo(text) {
    // GSM-7 (160/153) ; bascule Unicode (70/67) si caractere hors latin-1 (emoji...).
    var unicode = /[^\r\n€ -ÿ]/.test(text);
    var single = unicode ? 70 : 160, multi = unicode ? 67 : 153;
    var len = text.length;
    var seg = len === 0 ? 0 : (len <= single ? 1 : Math.ceil(len / multi));
    return { len: len, seg: seg };
  }
  function setStatus(el, msg, kind) {
    if (!el) return;
    el.textContent = msg;
    el.style.color = kind === 'ok' ? '#059669' : (kind === 'err' ? '#e11d48' : '#64748b');
  }

  var phoneInput = document.getElementById('sms-test-phone');

  document.querySelectorAll('[data-sms-card]').forEach(function (card) {
    try {
      var tpl = card.querySelector('[data-tpl]');
      var preview = card.querySelector('[data-preview]');
      var count = card.querySelector('[data-count]');
      var seg = card.querySelector('[data-seg]');
      var enable = card.querySelector('[data-enable]');
      var enableLabel = card.querySelector('[data-enable-label]');
      var statusEl = card.querySelector('[data-test-status]');
      var example = {};
      try { example = JSON.parse(card.getAttribute('data-example')) || {}; } catch (e) {}
      var def = card.getAttribute('data-default') || '';

      function refresh() {
        var rendered = render(tpl.value, example);
        preview.textContent = rendered;
        var info = segInfo(rendered);
        count.textContent = info.len;
        seg.textContent = info.seg;
        card.style.opacity = enable.checked ? '1' : '0.55';
        if (enableLabel) enableLabel.textContent = enable.checked ? 'Activé' : 'Désactivé';
      }
      tpl.addEventListener('input', refresh);
      enable.addEventListener('change', refresh);

      // Insérer une variable au curseur
      card.querySelectorAll('[data-var]').forEach(function (b) {
        b.addEventListener('click', function () {
          var token = '{' + b.getAttribute('data-var') + '}';
          var s = tpl.selectionStart, e = tpl.selectionEnd;
          if (s == null) { s = e = tpl.value.length; }
          tpl.value = tpl.value.slice(0, s) + token + tpl.value.slice(e);
          tpl.focus(); tpl.selectionStart = tpl.selectionEnd = s + token.length;
          refresh();
        });
      });

      var resetBtn = card.querySelector('[data-reset]');
      if (resetBtn) resetBtn.addEventListener('click', function () { tpl.value = def; refresh(); });

      var testBtn = card.querySelector('[data-test]');
      if (testBtn) testBtn.addEventListener('click', function () {
        var phone = ((phoneInput && phoneInput.value) || '').trim();
        if (!phone) { setStatus(statusEl, 'Renseigne le numéro plus haut', 'err'); if (phoneInput) phoneInput.focus(); return; }
        testBtn.disabled = true;
        setStatus(statusEl, 'Envoi...', 'info');
        // Envoi form-encoded same-origin (même pattern que l'autosave, prouvé).
        var body = new URLSearchParams({ key: card.getAttribute('data-key'), phone: phone, template: tpl.value });
        fetch('/admin/parametres/sms/test', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
          body: body,
          credentials: 'same-origin'
        }).then(function (r) {
          return r.json().catch(function () { return { ok: false, error: 'HTTP ' + r.status }; });
        }).then(function (d) {
          if (d && d.ok) setStatus(statusEl, 'Envoyé à ' + phone + ' ✓', 'ok');
          else setStatus(statusEl, 'Échec : ' + ((d && d.error) || 'inconnu'), 'err');
        }).catch(function () {
          setStatus(statusEl, 'Erreur réseau', 'err');
        }).then(function () { testBtn.disabled = false; });
      });

      refresh();
    } catch (err) {
      if (window.console) console.error('[sms-settings] init card error:', err);
    }
  });
})();
</script>

<%- include('./partials/footer') %>
