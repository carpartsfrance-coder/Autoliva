<%- include('./partials/head', { title }) %>
<%- include('./partials/sidebar', { active: 'finance', currentAdmin: typeof currentAdminSession !== 'undefined' ? currentAdminSession : null }) %>

<main class="p-4 sm:p-6 lg:p-10 max-w-7xl mx-auto">

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Finance — pilotage</h1>
      <p class="text-sm text-slate-500 mt-1">
        Tes vrais KPI : CA, marge brute, ticket moyen, top produits.
        À ne pas confondre avec l'espace comptable (déclaratif).
      </p>
    </div>
    <% if (period) { %>
      <div class="flex items-center gap-2 bg-white rounded-xl border border-slate-200 p-1">
        <a href="?period=<%= period.prevPeriod %>" class="px-3 py-2 text-sm rounded-lg hover:bg-slate-100 transition" title="Mois précédent">
          <span class="material-symbols-outlined text-base align-middle">chevron_left</span>
        </a>
        <div class="px-3 py-2 text-sm font-semibold text-slate-900 capitalize"><%= period.currentLabel %></div>
        <a href="?period=<%= period.nextPeriod %>" class="px-3 py-2 text-sm rounded-lg hover:bg-slate-100 transition" title="Mois suivant">
          <span class="material-symbols-outlined text-base align-middle">chevron_right</span>
        </a>
      </div>
    <% } %>
  </div>

  <% if (!dbConnected) { %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800">
      Base de données indisponible.
    </div>
  <% } else if (summary) { %>

    <!-- Alerte couverture coût -->
    <% if (summary.margin.coveragePct < 1) { %>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800 mb-6 flex items-start gap-3">
        <span class="material-symbols-outlined text-amber-600">info</span>
        <div>
          <div class="font-semibold">Marge brute partielle</div>
          <div class="text-xs mt-1">
            <%= Math.round(summary.margin.coveragePct * 100) %> % du CA a un prix d'achat renseigné.
            Pour avoir la marge précise sur tout le CA, complète le champ <strong>Prix d'achat HT</strong> sur les fiches produit (Catalogue → fiche produit).
          </div>
        </div>
      </div>
    <% } %>

    <%
      /* Helper de delta vs mois précédent. Retourne un objet
       *   { pct: nombre signé en %, sign: '+|-|±', class: 'emerald|rose|slate' }
       * Si le mois précédent est 0, on retourne null (pas de comparaison). */
      function delta(current, prev) {
        if (!prev || prev === 0) return null;
        const pct = ((current - prev) / Math.abs(prev)) * 100;
        const sign = pct > 0 ? '+' : (pct < 0 ? '' : '±');
        let cls = 'text-slate-400';
        if (pct >= 5) cls = 'text-emerald-600';
        else if (pct <= -5) cls = 'text-rose-600';
        return { pct, sign, class: cls };
      }
      const dCA = delta(summary.revenue.ttc, prevSummary && prevSummary.revenue.ttc);
      const dProfit = delta(summary.profit.netCents, prevSummary && prevSummary.profit.netCents);
      const dMargin = delta(summary.margin.gross, prevSummary && prevSummary.margin.gross);
      const dAvg = delta(summary.avgBasket, prevSummary && prevSummary.avgBasket);
    %>

    <!-- KPI cards : 4 chiffres clés avec comparaison N-1 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

      <!-- CA TTC -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs uppercase tracking-wider text-slate-500 font-semibold">CA TTC</div>
          <span class="material-symbols-outlined text-slate-400">attach_money</span>
        </div>
        <div class="text-3xl font-bold text-slate-900"><%= (summary.revenue.ttc / 100).toFixed(2) %> €</div>
        <div class="text-sm text-slate-500 mt-1">HT : <%= (summary.revenue.ht / 100).toFixed(2) %> €</div>
        <div class="text-xs mt-2 flex items-center gap-1">
          <% if (dCA) { %>
            <span class="<%= dCA.class %> font-semibold tabular-nums"><%= dCA.sign %><%= dCA.pct.toFixed(1) %> %</span>
            <span class="text-slate-400">vs mois précédent</span>
          <% } else { %>
            <span class="text-slate-400"><%= summary.ordersWithSoldItems %> commande(s)</span>
          <% } %>
        </div>
      </div>

      <!-- Bénéfice net — la KPI star -->
      <div class="bg-slate-900 text-white rounded-2xl p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs uppercase tracking-wider text-white/70 font-semibold">Bénéfice net</div>
          <span class="material-symbols-outlined text-white/60">savings</span>
        </div>
        <% if (summary.margin.itemsCountWithCost > 0 || summary.expenses.total > 0) { %>
          <div class="text-3xl font-bold <%= summary.profit.netCents >= 0 ? 'text-emerald-300' : 'text-rose-300' %>">
            <%= summary.profit.netCents >= 0 ? '+' : '' %><%= (summary.profit.netCents / 100).toFixed(2) %> €
          </div>
          <div class="text-sm text-white/70 mt-1">
            <% if (summary.net.ttc > 0) { %>
              <%= (summary.profit.netPct * 100).toFixed(1) %> % du CA net
            <% } else { %>
              Marge brute − charges
            <% } %>
          </div>
          <div class="text-xs mt-2 flex items-center gap-1">
            <% if (dProfit) { %>
              <span class="font-semibold tabular-nums <%= dProfit.pct >= 0 ? 'text-emerald-300' : 'text-rose-300' %>"><%= dProfit.sign %><%= dProfit.pct.toFixed(1) %> %</span>
              <span class="text-white/60">vs mois précédent</span>
            <% } else { %>
              <span class="text-white/50">Premier mois de suivi</span>
            <% } %>
          </div>
          <% if (summary.profit.incompleteMargin) { %>
            <div class="text-[10px] text-amber-300 mt-2">⚠ Marge calculée sur <%= Math.round(summary.margin.coveragePct * 100) %> % du CA seulement</div>
          <% } %>
        <% } else { %>
          <div class="text-3xl font-bold text-white/30">—</div>
          <div class="text-sm text-white/70 mt-1">Saisis tes coûts produits + charges pour activer</div>
        <% } %>
      </div>

      <!-- Marge brute -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Marge brute</div>
          <span class="material-symbols-outlined text-slate-400">trending_up</span>
        </div>
        <% if (summary.margin.itemsCountWithCost > 0) { %>
          <div class="text-3xl font-bold text-emerald-700"><%= (summary.margin.gross / 100).toFixed(2) %> €</div>
          <div class="text-sm text-slate-500 mt-1">
            <%= (summary.margin.pct * 100).toFixed(1) %> % · COGS <%= (summary.margin.cogsKnown / 100).toFixed(0) %> €
          </div>
          <div class="text-xs mt-2 flex items-center gap-1">
            <% if (dMargin) { %>
              <span class="<%= dMargin.class %> font-semibold tabular-nums"><%= dMargin.sign %><%= dMargin.pct.toFixed(1) %> %</span>
              <span class="text-slate-400">vs mois précédent</span>
            <% } else { %>
              <span class="text-slate-400">CA Net : <%= (summary.net.ttc / 100).toFixed(0) %> €</span>
            <% } %>
          </div>
        <% } else { %>
          <div class="text-3xl font-bold text-slate-300">—</div>
          <div class="text-sm text-slate-500 mt-1">Aucun produit avec prix d'achat renseigné</div>
        <% } %>
      </div>

      <!-- Ticket moyen -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Ticket moyen</div>
          <span class="material-symbols-outlined text-slate-400">shopping_cart</span>
        </div>
        <div class="text-3xl font-bold text-slate-900"><%= (summary.avgBasket / 100).toFixed(2) %> €</div>
        <div class="text-sm text-slate-500 mt-1"><%= summary.ordersWithSoldItems %> commandes</div>
        <div class="text-xs mt-2 flex items-center gap-1">
          <% if (dAvg) { %>
            <span class="<%= dAvg.class %> font-semibold tabular-nums"><%= dAvg.sign %><%= dAvg.pct.toFixed(1) %> %</span>
            <span class="text-slate-400">vs mois précédent</span>
          <% } else { %>
            <span class="<%= summary.refunds.rate > 0.05 ? 'text-rose-600' : 'text-slate-400' %>">
              Refunds : <%= (summary.refunds.rate * 100).toFixed(1) %> %
            </span>
          <% } %>
        </div>
      </div>

    </div>

    <!-- Compte de résultat — la vraie nouveauté du Sprint A -->
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-6">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
        <div>
          <div class="text-lg font-semibold text-slate-900">Compte de résultat — <%= period.currentLabel %></div>
          <div class="text-sm text-slate-500 mt-1">Du CA brut au bénéfice net, étape par étape.</div>
        </div>
        <a href="/admin/charges?period=<%= period.currentPeriod %>" class="text-sm text-amber-600 hover:underline inline-flex items-center gap-1">
          <span class="material-symbols-outlined text-base">edit</span>
          Gérer les charges
        </a>
      </div>
      <div class="p-6 space-y-2 text-sm">
        <div class="flex items-center justify-between py-1">
          <div class="text-slate-700">CA TTC brut</div>
          <div class="font-semibold text-slate-900 tabular-nums"><%= (summary.revenue.ttc / 100).toFixed(2) %> €</div>
        </div>
        <div class="flex items-center justify-between py-1">
          <div class="text-slate-700">− Remboursements</div>
          <div class="font-semibold text-rose-600 tabular-nums">-<%= (summary.refunds.total / 100).toFixed(2) %> €</div>
        </div>
        <div class="flex items-center justify-between py-1 border-t border-slate-100 pt-2">
          <div class="font-semibold text-slate-900">CA Net</div>
          <div class="font-bold text-slate-900 tabular-nums"><%= (summary.net.ttc / 100).toFixed(2) %> €</div>
        </div>
        <% if (summary.margin.itemsCountWithCost > 0) { %>
          <div class="flex items-center justify-between py-1 mt-3">
            <div class="text-slate-700">
              − COGS (achats produits vendus)
              <% if (summary.profit.incompleteMargin) { %>
                <span class="text-xs text-amber-600 ml-1">⚠ sur <%= Math.round(summary.margin.coveragePct * 100) %> % du CA</span>
              <% } %>
            </div>
            <div class="font-semibold text-rose-600 tabular-nums">-<%= (summary.margin.cogsKnown / 100).toFixed(2) %> €</div>
          </div>
          <div class="flex items-center justify-between py-1 border-t border-slate-100 pt-2">
            <div class="font-semibold text-slate-900">= Marge brute</div>
            <div class="font-bold text-emerald-700 tabular-nums"><%= (summary.margin.gross / 100).toFixed(2) %> € (<%= (summary.margin.pct * 100).toFixed(1) %> %)</div>
          </div>
        <% } else { %>
          <div class="flex items-center justify-between py-1 mt-3 italic">
            <div class="text-slate-400">− COGS : indisponible (saisis le prix d'achat sur tes fiches produit)</div>
            <div class="text-slate-300 tabular-nums">—</div>
          </div>
        <% } %>
        <div class="mt-3 space-y-1">
          <% if (summary.expenses.paymentFeesAuto > 0) { %>
            <div class="flex items-center justify-between py-1">
              <div class="text-slate-700">
                − Frais paiement Mollie
                <span class="text-xs text-emerald-600 ml-1">(auto)</span>
              </div>
              <div class="font-semibold text-rose-600 tabular-nums">-<%= (summary.expenses.paymentFeesAuto / 100).toFixed(2) %> €</div>
            </div>
          <% } %>
          <% Object.keys(summary.expenses.byCategory).sort(function (a, b) { return summary.expenses.byCategory[b] - summary.expenses.byCategory[a]; }).forEach(function (cat) { %>
            <div class="flex items-center justify-between py-1">
              <div class="text-slate-700">− <%= expensesCategoryLabels[cat] || cat %></div>
              <div class="font-semibold text-rose-600 tabular-nums">-<%= (summary.expenses.byCategory[cat] / 100).toFixed(2) %> €</div>
            </div>
          <% }) %>
          <% if (summary.expenses.total === 0 && summary.expenses.paymentFeesAuto === 0) { %>
            <div class="flex items-center justify-between py-1 italic">
              <div class="text-slate-400">Aucune charge saisie sur ce mois — <a href="/admin/charges/nouvelle" class="text-amber-600 hover:underline not-italic">ajouter une charge</a></div>
              <div class="text-slate-300 tabular-nums">—</div>
            </div>
          <% } %>
        </div>
        <div class="flex items-center justify-between py-3 border-t-2 border-slate-900 mt-3">
          <div class="text-lg font-bold text-slate-900">= Bénéfice net</div>
          <div class="text-xl font-bold tabular-nums <%= summary.profit.netCents >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
            <%= summary.profit.netCents >= 0 ? '+' : '' %><%= (summary.profit.netCents / 100).toFixed(2) %> €
            <% if (summary.net.ttc > 0) { %>
              <span class="text-sm font-normal text-slate-500">(<%= (summary.profit.netPct * 100).toFixed(1) %> %)</span>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Tendance 12 mois -->
    <div class="bg-white rounded-2xl border border-slate-200 p-6 mb-6">
      <div class="mb-4">
        <div class="text-lg font-semibold text-slate-900">Tendance — 12 derniers mois</div>
        <div class="text-sm text-slate-500 mt-1 flex flex-wrap gap-3">
          <span><span class="inline-block w-3 h-3 rounded bg-slate-900 mr-1 align-middle"></span> CA TTC</span>
          <span><span class="inline-block w-3 h-3 rounded bg-emerald-500 mr-1 align-middle"></span> Marge brute</span>
          <span><span class="inline-block w-3 h-3 rounded bg-amber-500 mr-1 align-middle"></span> Bénéfice net</span>
        </div>
      </div>
      <% const maxRev = Math.max.apply(null, trend.map(function(t){return t.revenueTtc}).concat([1])); %>
      <div class="flex items-end gap-2 h-48">
        <% trend.forEach(function (t) {
             const revPct = maxRev > 0 ? (t.revenueTtc / maxRev) * 100 : 0;
             const margPct = maxRev > 0 ? (t.marginGross / maxRev) * 100 : 0;
             const profitPct = maxRev > 0 && t.profit > 0 ? (t.profit / maxRev) * 100 : 0;
             const profitNegPct = maxRev > 0 && t.profit < 0 ? (Math.abs(t.profit) / maxRev) * 100 : 0;
             const isCurrent = t.year === summary.year && t.month === summary.month; %>
          <div class="flex-1 flex flex-col items-center gap-1 min-w-0">
            <div class="text-[10px] text-slate-500 tabular-nums whitespace-nowrap"><%= (t.revenueTtc / 100).toFixed(0) %>€</div>
            <div class="w-full relative" style="height: 80%">
              <div class="absolute bottom-0 left-0 right-0 <%= isCurrent ? 'bg-slate-900' : 'bg-slate-300' %> rounded-t" style="height: <%= Math.max(2, revPct) %>%; opacity: 0.9"></div>
              <% if (t.marginGross > 0) { %>
                <div class="absolute bottom-0 left-1/4 right-1/4 bg-emerald-500 rounded-t" style="height: <%= Math.max(2, margPct) %>%; opacity: 0.85"></div>
              <% } %>
              <% if (profitPct > 0) { %>
                <div class="absolute bottom-0 left-[40%] right-[40%] bg-amber-500 rounded-t" style="height: <%= Math.max(2, profitPct) %>%; opacity: 0.95" title="Bénéfice net : <%= (t.profit/100).toFixed(0) %>€"></div>
              <% } else if (profitNegPct > 0) { %>
                <div class="absolute top-0 left-[40%] right-[40%] bg-rose-500 rounded-b" style="height: <%= Math.max(2, profitNegPct * 0.3) %>%; opacity: 0.7" title="Perte : <%= (t.profit/100).toFixed(0) %>€"></div>
              <% } %>
            </div>
            <div class="text-[10px] text-slate-500 capitalize"><%= t.label %></div>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Top produits par CA + par marge -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Top par CA -->
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
          <div class="text-lg font-semibold text-slate-900">Top 10 produits — CA</div>
          <div class="text-sm text-slate-500 mt-1">Sur le mois en cours</div>
        </div>
        <% if (summary.topByRevenue.length === 0) { %>
          <div class="p-8 text-center text-slate-500 text-sm">Aucune vente sur la période.</div>
        <% } else { %>
          <ul class="divide-y divide-slate-100">
            <% summary.topByRevenue.forEach(function (p, i) { %>
              <li class="px-6 py-3 flex items-center gap-4">
                <div class="w-6 text-center text-xs font-bold text-slate-400 tabular-nums"><%= i + 1 %></div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-slate-900 truncate" title="<%= p.name %>"><%= p.name %></div>
                  <div class="text-xs text-slate-500"><%= p.qtySold %> vendu(s) · SKU <%= p.sku || '—' %></div>
                </div>
                <div class="text-right">
                  <div class="font-semibold text-slate-900 tabular-nums"><%= (p.revenueTtc / 100).toFixed(2) %> €</div>
                  <% if (p.costKnown) { %>
                    <div class="text-xs text-emerald-600">+<%= (p.margin / 100).toFixed(2) %> € (<%= p.marginPct.toFixed(1) %> %)</div>
                  <% } else { %>
                    <div class="text-xs text-slate-300">marge ?</div>
                  <% } %>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

      <!-- Top par marge -->
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
          <div class="text-lg font-semibold text-slate-900">Top 10 produits — Marge €</div>
          <div class="text-sm text-slate-500 mt-1">Uniquement les produits avec un prix d'achat renseigné</div>
        </div>
        <% if (summary.topByMargin.length === 0) { %>
          <div class="p-8 text-center text-slate-500 text-sm">
            <p>Aucun produit avec prix d'achat renseigné n'a généré de vente ce mois-ci.</p>
            <p class="text-xs mt-2">Ajoute le <strong>Prix d'achat HT</strong> sur les fiches produit pour activer ce classement.</p>
          </div>
        <% } else { %>
          <ul class="divide-y divide-slate-100">
            <% summary.topByMargin.forEach(function (p, i) { %>
              <li class="px-6 py-3 flex items-center gap-4">
                <div class="w-6 text-center text-xs font-bold text-emerald-500 tabular-nums"><%= i + 1 %></div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-slate-900 truncate" title="<%= p.name %>"><%= p.name %></div>
                  <div class="text-xs text-slate-500"><%= p.qtySold %> vendu(s) · SKU <%= p.sku || '—' %></div>
                </div>
                <div class="text-right">
                  <div class="font-semibold text-emerald-700 tabular-nums">+<%= (p.margin / 100).toFixed(2) %> €</div>
                  <div class="text-xs text-slate-500"><%= p.marginPct.toFixed(1) %> % · CA <%= (p.revenueTtc / 100).toFixed(0) %> €</div>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

    </div>

    <!-- Tous les produits vendus du mois — table complète avec tri + recherche -->
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden mt-6" id="all-products-block">
      <div class="px-6 py-4 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <div class="text-lg font-semibold text-slate-900">Tous les produits vendus — <%= period.currentLabel %></div>
          <div class="text-sm text-slate-500 mt-1">
            <%= summary.allProductsSold.length %> produit(s) distinct(s) · clique sur une colonne pour trier
          </div>
        </div>
        <div class="flex items-center gap-2">
          <input type="text" id="all-products-search" placeholder="Rechercher nom ou SKU…"
                 class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm w-64 focus:ring-amber-500 focus:border-amber-500" />
        </div>
      </div>

      <% if (summary.allProductsSold.length === 0) { %>
        <div class="p-12 text-center text-slate-500">
          <span class="material-symbols-outlined text-4xl text-slate-300">inventory_2</span>
          <p class="mt-2">Aucun produit vendu sur ce mois.</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" id="all-products-table">
            <thead class="bg-slate-50 text-xs uppercase tracking-wider text-slate-500 sticky top-0">
              <tr>
                <th class="px-4 py-3 text-left font-semibold cursor-pointer hover:bg-slate-100" data-sort="name">Produit <span class="sort-icon"></span></th>
                <th class="px-4 py-3 text-left font-semibold cursor-pointer hover:bg-slate-100" data-sort="sku">SKU <span class="sort-icon"></span></th>
                <th class="px-4 py-3 text-right font-semibold cursor-pointer hover:bg-slate-100" data-sort="qtySold">Qté vendue <span class="sort-icon"></span></th>
                <th class="px-4 py-3 text-right font-semibold cursor-pointer hover:bg-slate-100" data-sort="revenueTtc">CA TTC <span class="sort-icon">▼</span></th>
                <th class="px-4 py-3 text-right font-semibold cursor-pointer hover:bg-slate-100" data-sort="revenueHt">CA HT <span class="sort-icon"></span></th>
                <th class="px-4 py-3 text-right font-semibold cursor-pointer hover:bg-slate-100" data-sort="costCents" title="Prix d'achat HT unitaire — éditable">Prix achat HT <span class="sort-icon"></span></th>
                <th class="px-4 py-3 text-right font-semibold cursor-pointer hover:bg-slate-100" data-sort="margin">Marge € <span class="sort-icon"></span></th>
                <th class="px-4 py-3 text-right font-semibold cursor-pointer hover:bg-slate-100" data-sort="marginPct">Marge % <span class="sort-icon"></span></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100" id="all-products-tbody">
              <% summary.allProductsSold.forEach(function (p) { %>
                <tr class="hover:bg-slate-50"
                    data-productid="<%= p.productId %>"
                    data-name="<%= (p.name || '').toLowerCase() %>"
                    data-sku="<%= (p.sku || '').toLowerCase() %>"
                    data-qtysold="<%= p.qtySold %>"
                    data-revenuettc="<%= p.revenueTtc %>"
                    data-revenueht="<%= p.revenueHt %>"
                    data-costcents="<%= p.costCentsPerUnit != null ? p.costCentsPerUnit : -1 %>"
                    data-margin="<%= p.costKnown ? p.margin : -1 %>"
                    data-marginpct="<%= p.costKnown && p.marginPct != null ? p.marginPct : -1 %>">
                  <td class="px-4 py-3 text-slate-900 max-w-md truncate" title="<%= p.name %>"><%= p.name %></td>
                  <td class="px-4 py-3 font-mono text-xs text-slate-500"><%= p.sku || '—' %></td>
                  <td class="px-4 py-3 text-right tabular-nums text-slate-700"><%= p.qtySold %></td>
                  <td class="px-4 py-3 text-right tabular-nums font-semibold text-slate-900"><%= (p.revenueTtc / 100).toFixed(2) %> €</td>
                  <td class="px-4 py-3 text-right tabular-nums text-slate-500"><%= (p.revenueHt / 100).toFixed(2) %> €</td>
                  <td class="px-4 py-3 text-right tabular-nums">
                    <div class="inline-flex items-center justify-end gap-1">
                      <input type="text"
                             class="cost-inline-input w-24 rounded-md border border-slate-200 bg-white px-2 py-1 text-right text-sm tabular-nums focus:ring-2 focus:ring-amber-400 focus:border-amber-400 focus:outline-none"
                             value="<%= p.costCentsPerUnit != null ? (p.costCentsPerUnit / 100).toFixed(2).replace('.', ',') : '' %>"
                             placeholder="—"
                             inputmode="decimal"
                             data-cost-input
                             aria-label="Prix d'achat HT pour <%= p.name %>" />
                      <span class="text-slate-400 text-xs">€</span>
                      <span class="cost-inline-status w-4 text-xs" data-cost-status aria-live="polite"></span>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-right tabular-nums" data-margin-cell>
                    <% if (p.costKnown) { %>
                      <span class="<%= p.margin >= 0 ? 'text-emerald-700 font-semibold' : 'text-rose-700 font-semibold' %>">
                        <%= p.margin >= 0 ? '+' : '' %><%= (p.margin / 100).toFixed(2) %> €
                      </span>
                    <% } else { %>
                      <span class="text-slate-300" title="Renseigne le prix d'achat sur cette ligne pour calculer la marge">—</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3 text-right tabular-nums" data-marginpct-cell>
                    <% if (p.costKnown && p.marginPct != null) { %>
                      <span class="<%= p.marginPct >= 30 ? 'text-emerald-600' : (p.marginPct >= 10 ? 'text-amber-600' : 'text-rose-600') %>">
                        <%= p.marginPct.toFixed(1) %> %
                      </span>
                    <% } else { %>
                      <span class="text-slate-300">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot class="bg-slate-50 border-t-2 border-slate-200">
              <tr class="text-sm font-semibold text-slate-900">
                <td class="px-4 py-3" colspan="2">Total <span id="all-products-count"><%= summary.allProductsSold.length %></span> produit(s)</td>
                <td class="px-4 py-3 text-right tabular-nums" id="all-products-qty-total">
                  <%= summary.allProductsSold.reduce(function (s, p) { return s + p.qtySold; }, 0) %>
                </td>
                <td class="px-4 py-3 text-right tabular-nums" id="all-products-revenuettc-total">
                  <%= (summary.allProductsSold.reduce(function (s, p) { return s + p.revenueTtc; }, 0) / 100).toFixed(2) %> €
                </td>
                <td class="px-4 py-3 text-right tabular-nums text-slate-500" id="all-products-revenueht-total">
                  <%= (summary.allProductsSold.reduce(function (s, p) { return s + p.revenueHt; }, 0) / 100).toFixed(2) %> €
                </td>
                <td class="px-4 py-3"></td>
                <td class="px-4 py-3 text-right tabular-nums text-emerald-700" id="all-products-margin-total">
                  +<%= (summary.allProductsSold.filter(function (p) { return p.costKnown; }).reduce(function (s, p) { return s + p.margin; }, 0) / 100).toFixed(2) %> €
                </td>
                <td class="px-4 py-3 text-right text-xs text-slate-500" colspan="1">
                  <span id="all-products-cost-count"><%= summary.allProductsSold.filter(function (p) { return p.costKnown; }).length %></span>/<%= summary.allProductsSold.length %> avec cost
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% } %>
    </div>

    <!-- JS pour tri + recherche + édition inline du prix d'achat -->
    <script>
      (function () {
        var tbody = document.getElementById('all-products-tbody');
        if (!tbody) return;
        var rows = Array.from(tbody.querySelectorAll('tr'));
        var search = document.getElementById('all-products-search');
        var costCountEl = document.getElementById('all-products-cost-count');

        /* Re-calcule les totaux du footer en fonction des lignes visibles */
        function recomputeTotals() {
          var visibleRows = rows.filter(function (r) { return r.style.display !== 'none'; });
          document.getElementById('all-products-count').textContent = visibleRows.length;
          var qty = 0, ttc = 0, ht = 0, margin = 0, withCost = 0;
          visibleRows.forEach(function (r) {
            qty += Number(r.dataset.qtysold) || 0;
            ttc += Number(r.dataset.revenuettc) || 0;
            ht += Number(r.dataset.revenueht) || 0;
            if (Number(r.dataset.margin) >= 0) {
              margin += Number(r.dataset.margin);
              withCost++;
            }
          });
          document.getElementById('all-products-qty-total').textContent = qty;
          document.getElementById('all-products-revenuettc-total').textContent = (ttc / 100).toFixed(2) + ' €';
          document.getElementById('all-products-revenueht-total').textContent = (ht / 100).toFixed(2) + ' €';
          document.getElementById('all-products-margin-total').textContent = '+' + (margin / 100).toFixed(2) + ' €';
          if (costCountEl) costCountEl.textContent = withCost;
        }

        /* ── Édition inline du prix d'achat HT ────────────────────────
         * Au blur ou Enter sur l'input, POST /admin/api/produits/:id/cost.
         * Mise à jour locale des cellules Marge / Marge % et du footer
         * sans recharger la page. */
        function parseCostInput(raw) {
          if (typeof raw !== 'string') return { ok: false };
          var trimmed = raw.trim();
          if (!trimmed) return { ok: true, cents: null }; // vide = effacer
          var normalized = trimmed.replace(/€/g, '').replace(/\s+/g, '').replace(',', '.');
          var num = Number(normalized);
          if (!isFinite(num) || num < 0) return { ok: false };
          return { ok: true, cents: Math.round(num * 100) };
        }

        function formatCents(cents) {
          return (cents / 100).toFixed(2).replace('.', ',');
        }

        function applyRowRecompute(row, costCents) {
          var qty = Number(row.dataset.qtysold) || 0;
          var ht = Number(row.dataset.revenueht) || 0;
          var marginCell = row.querySelector('[data-margin-cell]');
          var marginPctCell = row.querySelector('[data-marginpct-cell]');

          if (costCents == null) {
            row.dataset.costcents = -1;
            row.dataset.margin = -1;
            row.dataset.marginpct = -1;
            if (marginCell) marginCell.innerHTML = '<span class="text-slate-300" title="Renseigne le prix d\'achat sur cette ligne pour calculer la marge">—</span>';
            if (marginPctCell) marginPctCell.innerHTML = '<span class="text-slate-300">—</span>';
            return;
          }

          var cogs = qty * costCents;
          var margin = ht - cogs;
          var marginPct = ht > 0 ? (margin / ht) * 100 : null;

          row.dataset.costcents = costCents;
          row.dataset.margin = margin;
          row.dataset.marginpct = marginPct == null ? -1 : marginPct;

          if (marginCell) {
            var marginCls = margin >= 0 ? 'text-emerald-700 font-semibold' : 'text-rose-700 font-semibold';
            marginCell.innerHTML = '<span class="' + marginCls + '">' + (margin >= 0 ? '+' : '') + (margin / 100).toFixed(2) + ' €</span>';
          }
          if (marginPctCell) {
            if (marginPct == null) {
              marginPctCell.innerHTML = '<span class="text-slate-300">—</span>';
            } else {
              var pctCls = marginPct >= 30 ? 'text-emerald-600' : (marginPct >= 10 ? 'text-amber-600' : 'text-rose-600');
              marginPctCell.innerHTML = '<span class="' + pctCls + '">' + marginPct.toFixed(1) + ' %</span>';
            }
          }
        }

        function setStatus(statusEl, kind) {
          if (!statusEl) return;
          if (kind === 'saving') {
            statusEl.textContent = '⋯';
            statusEl.className = 'cost-inline-status w-4 text-xs text-slate-400';
          } else if (kind === 'ok') {
            statusEl.textContent = '✓';
            statusEl.className = 'cost-inline-status w-4 text-xs text-emerald-600';
            setTimeout(function () { statusEl.textContent = ''; }, 1500);
          } else if (kind === 'error') {
            statusEl.textContent = '✕';
            statusEl.className = 'cost-inline-status w-4 text-xs text-rose-600';
          } else {
            statusEl.textContent = '';
            statusEl.className = 'cost-inline-status w-4 text-xs';
          }
        }

        function saveCost(input) {
          var row = input.closest('tr');
          if (!row) return;
          var productId = row.dataset.productid;
          if (!productId) return;
          var statusEl = row.querySelector('[data-cost-status]');

          var parsed = parseCostInput(input.value);
          if (!parsed.ok) {
            setStatus(statusEl, 'error');
            input.title = 'Format invalide. Ex : 89,00';
            return;
          }
          input.title = '';

          // Si pas de changement vs valeur stockée, ne rien faire
          var currentStored = Number(row.dataset.costcents);
          var nextCents = parsed.cents == null ? -1 : parsed.cents;
          if (currentStored === nextCents) {
            setStatus(statusEl, null);
            return;
          }

          setStatus(statusEl, 'saving');

          var body = 'cost=' + encodeURIComponent(parsed.cents == null ? '' : formatCents(parsed.cents));
          fetch('/admin/api/produits/' + encodeURIComponent(productId) + '/cost', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded',
              'X-Requested-With': 'XMLHttpRequest',
              'Accept': 'application/json',
            },
            credentials: 'same-origin',
            body: body,
          })
            .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
            .then(function (r) {
              if (!r.ok || !r.data || r.data.ok !== true) {
                throw new Error((r.data && r.data.error) || 'Erreur ' + (r.data && r.data.status || ''));
              }
              applyRowRecompute(row, r.data.costCents);
              if (r.data.costFormatted) {
                input.value = r.data.costFormatted;
              } else if (r.data.costCents == null) {
                input.value = '';
              }
              setStatus(statusEl, 'ok');
              recomputeTotals();
            })
            .catch(function (err) {
              setStatus(statusEl, 'error');
              input.title = (err && err.message) || 'Erreur réseau';
            });
        }

        tbody.querySelectorAll('[data-cost-input]').forEach(function (input) {
          input.addEventListener('blur', function () { saveCost(input); });
          input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
              e.preventDefault();
              input.blur();
            } else if (e.key === 'Escape') {
              // Revenir à la valeur stockée
              var row = input.closest('tr');
              var stored = Number(row && row.dataset.costcents);
              input.value = stored >= 0 ? formatCents(stored) : '';
              setStatus(row && row.querySelector('[data-cost-status]'), null);
              input.blur();
            }
          });
        });

        /* Recherche : filtre name + sku */
        if (search) {
          search.addEventListener('input', function () {
            var q = search.value.toLowerCase().trim();
            rows.forEach(function (r) {
              var match = !q || r.dataset.name.indexOf(q) !== -1 || r.dataset.sku.indexOf(q) !== -1;
              r.style.display = match ? '' : 'none';
            });
            recomputeTotals();
          });
        }

        /* Tri sur clic colonne */
        var currentSort = { key: 'revenuettc', dir: 'desc' };
        var headers = document.querySelectorAll('#all-products-table th[data-sort]');
        headers.forEach(function (th) {
          th.addEventListener('click', function () {
            var key = th.dataset.sort.toLowerCase();
            var dir = (currentSort.key === key && currentSort.dir === 'desc') ? 'asc' : 'desc';
            currentSort = { key: key, dir: dir };

            /* Met à jour les flèches */
            headers.forEach(function (h) { var i = h.querySelector('.sort-icon'); if (i) i.textContent = ''; });
            var icon = th.querySelector('.sort-icon');
            if (icon) icon.textContent = dir === 'desc' ? '▼' : '▲';

            var dataKey = 'data' + key.replace(/[a-z]/i, function (c) { return c.toLowerCase(); });
            var dataAttr = key; // dataset names are camelCase in JS but we use lowercase attrs
            var sortedRows = rows.slice().sort(function (a, b) {
              var va = a.dataset[dataAttr];
              var vb = b.dataset[dataAttr];
              var na = parseFloat(va);
              var nb = parseFloat(vb);
              var isNum = !isNaN(na) && !isNaN(nb);
              var cmp = isNum ? (na - nb) : String(va).localeCompare(String(vb));
              return dir === 'desc' ? -cmp : cmp;
            });
            sortedRows.forEach(function (r) { tbody.appendChild(r); });
          });
        });
      })();
    </script>

  <% } %>

</main>

<%- include('./partials/footer') %>
