<%- include('./partials/head', { title }) %>
<%- include('./partials/sidebar', { active: 'finance', currentAdmin: typeof currentAdminSession !== 'undefined' ? currentAdminSession : null }) %>

<main class="p-4 sm:p-6 lg:p-10 max-w-7xl mx-auto">

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Finance — pilotage</h1>
      <p class="text-sm text-slate-500 mt-1">
        Tes vrais KPI : CA, marge brute, ticket moyen, top produits.
        À ne pas confondre avec l'espace comptable (déclaratif).
      </p>
    </div>
    <% if (period) { %>
      <div class="flex items-center gap-2 bg-white rounded-xl border border-slate-200 p-1">
        <a href="?period=<%= period.prevPeriod %>" class="px-3 py-2 text-sm rounded-lg hover:bg-slate-100 transition" title="Mois précédent">
          <span class="material-symbols-outlined text-base align-middle">chevron_left</span>
        </a>
        <div class="px-3 py-2 text-sm font-semibold text-slate-900 capitalize"><%= period.currentLabel %></div>
        <a href="?period=<%= period.nextPeriod %>" class="px-3 py-2 text-sm rounded-lg hover:bg-slate-100 transition" title="Mois suivant">
          <span class="material-symbols-outlined text-base align-middle">chevron_right</span>
        </a>
      </div>
    <% } %>
  </div>

  <% if (!dbConnected) { %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800">
      Base de données indisponible.
    </div>
  <% } else if (summary) { %>

    <!-- Alerte couverture coût -->
    <% if (summary.margin.coveragePct < 1) { %>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800 mb-6 flex items-start gap-3">
        <span class="material-symbols-outlined text-amber-600">info</span>
        <div>
          <div class="font-semibold">Marge brute partielle</div>
          <div class="text-xs mt-1">
            <%= Math.round(summary.margin.coveragePct * 100) %> % du CA a un prix d'achat renseigné.
            Pour avoir la marge précise sur tout le CA, complète le champ <strong>Prix d'achat HT</strong> sur les fiches produit (Catalogue → fiche produit).
          </div>
        </div>
      </div>
    <% } %>

    <!-- KPI cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

      <!-- CA TTC -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Chiffre d'affaires TTC</div>
          <span class="material-symbols-outlined text-slate-400">attach_money</span>
        </div>
        <div class="text-3xl font-bold text-slate-900"><%= (summary.revenue.ttc / 100).toFixed(2) %> €</div>
        <div class="text-sm text-slate-500 mt-1">HT : <%= (summary.revenue.ht / 100).toFixed(2) %> €</div>
        <div class="text-xs text-slate-400 mt-2"><%= summary.ordersWithSoldItems %> commande(s)</div>
      </div>

      <!-- Net (après refunds) -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs uppercase tracking-wider text-slate-500 font-semibold">CA Net</div>
          <span class="material-symbols-outlined text-slate-400">payments</span>
        </div>
        <div class="text-3xl font-bold text-slate-900"><%= (summary.net.ttc / 100).toFixed(2) %> €</div>
        <div class="text-sm text-slate-500 mt-1">après <%= (summary.refunds.total / 100).toFixed(2) %> € de remboursements</div>
        <div class="text-xs <%= summary.refunds.rate > 0.05 ? 'text-rose-600' : 'text-slate-400' %> mt-2">
          Taux de remboursement : <%= (summary.refunds.rate * 100).toFixed(2) %> %
        </div>
      </div>

      <!-- Marge brute -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Marge brute</div>
          <span class="material-symbols-outlined text-slate-400">trending_up</span>
        </div>
        <% if (summary.margin.itemsCountWithCost > 0) { %>
          <div class="text-3xl font-bold text-emerald-700"><%= (summary.margin.gross / 100).toFixed(2) %> €</div>
          <div class="text-sm text-slate-500 mt-1">
            <%= (summary.margin.pct * 100).toFixed(1) %> % de marge sur les items au cost connu
          </div>
          <div class="text-xs text-slate-400 mt-2">
            COGS : <%= (summary.margin.cogsKnown / 100).toFixed(2) %> €
          </div>
        <% } else { %>
          <div class="text-3xl font-bold text-slate-300">—</div>
          <div class="text-sm text-slate-500 mt-1">Aucun produit avec prix d'achat renseigné</div>
        <% } %>
      </div>

      <!-- Ticket moyen -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Ticket moyen</div>
          <span class="material-symbols-outlined text-slate-400">shopping_cart</span>
        </div>
        <div class="text-3xl font-bold text-slate-900"><%= (summary.avgBasket / 100).toFixed(2) %> €</div>
        <div class="text-sm text-slate-500 mt-1">par commande</div>
        <div class="text-xs text-slate-400 mt-2"><%= summary.ordersWithSoldItems %> commandes</div>
      </div>

    </div>

    <!-- Tendance 12 mois -->
    <div class="bg-white rounded-2xl border border-slate-200 p-6 mb-6">
      <div class="mb-4">
        <div class="text-lg font-semibold text-slate-900">Tendance — 12 derniers mois</div>
        <div class="text-sm text-slate-500 mt-1">
          <span class="inline-block w-3 h-3 rounded bg-slate-900 mr-1 align-middle"></span> CA TTC ·
          <span class="inline-block w-3 h-3 rounded bg-emerald-500 mr-1 align-middle"></span> Marge brute
        </div>
      </div>
      <% const maxRev = Math.max.apply(null, trend.map(function(t){return t.revenueTtc}).concat([1])); %>
      <div class="flex items-end gap-2 h-48">
        <% trend.forEach(function (t) {
             const revPct = maxRev > 0 ? (t.revenueTtc / maxRev) * 100 : 0;
             const margPct = maxRev > 0 ? (t.marginGross / maxRev) * 100 : 0;
             const isCurrent = t.year === summary.year && t.month === summary.month; %>
          <div class="flex-1 flex flex-col items-center gap-1 min-w-0">
            <div class="text-[10px] text-slate-500 tabular-nums whitespace-nowrap"><%= (t.revenueTtc / 100).toFixed(0) %>€</div>
            <div class="w-full relative" style="height: 80%">
              <div class="absolute bottom-0 left-0 right-0 <%= isCurrent ? 'bg-slate-900' : 'bg-slate-300' %> rounded-t" style="height: <%= Math.max(2, revPct) %>%; opacity: 0.9"></div>
              <% if (t.marginGross > 0) { %>
                <div class="absolute bottom-0 left-1/4 right-1/4 bg-emerald-500 rounded-t" style="height: <%= Math.max(2, margPct) %>%; opacity: 0.85"></div>
              <% } %>
            </div>
            <div class="text-[10px] text-slate-500 capitalize"><%= t.label %></div>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Top produits par CA + par marge -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Top par CA -->
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
          <div class="text-lg font-semibold text-slate-900">Top 10 produits — CA</div>
          <div class="text-sm text-slate-500 mt-1">Sur le mois en cours</div>
        </div>
        <% if (summary.topByRevenue.length === 0) { %>
          <div class="p-8 text-center text-slate-500 text-sm">Aucune vente sur la période.</div>
        <% } else { %>
          <ul class="divide-y divide-slate-100">
            <% summary.topByRevenue.forEach(function (p, i) { %>
              <li class="px-6 py-3 flex items-center gap-4">
                <div class="w-6 text-center text-xs font-bold text-slate-400 tabular-nums"><%= i + 1 %></div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-slate-900 truncate" title="<%= p.name %>"><%= p.name %></div>
                  <div class="text-xs text-slate-500"><%= p.qtySold %> vendu(s) · SKU <%= p.sku || '—' %></div>
                </div>
                <div class="text-right">
                  <div class="font-semibold text-slate-900 tabular-nums"><%= (p.revenueTtc / 100).toFixed(2) %> €</div>
                  <% if (p.costKnown) { %>
                    <div class="text-xs text-emerald-600">+<%= (p.margin / 100).toFixed(2) %> € (<%= p.marginPct.toFixed(1) %> %)</div>
                  <% } else { %>
                    <div class="text-xs text-slate-300">marge ?</div>
                  <% } %>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

      <!-- Top par marge -->
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
          <div class="text-lg font-semibold text-slate-900">Top 10 produits — Marge €</div>
          <div class="text-sm text-slate-500 mt-1">Uniquement les produits avec un prix d'achat renseigné</div>
        </div>
        <% if (summary.topByMargin.length === 0) { %>
          <div class="p-8 text-center text-slate-500 text-sm">
            <p>Aucun produit avec prix d'achat renseigné n'a généré de vente ce mois-ci.</p>
            <p class="text-xs mt-2">Ajoute le <strong>Prix d'achat HT</strong> sur les fiches produit pour activer ce classement.</p>
          </div>
        <% } else { %>
          <ul class="divide-y divide-slate-100">
            <% summary.topByMargin.forEach(function (p, i) { %>
              <li class="px-6 py-3 flex items-center gap-4">
                <div class="w-6 text-center text-xs font-bold text-emerald-500 tabular-nums"><%= i + 1 %></div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-slate-900 truncate" title="<%= p.name %>"><%= p.name %></div>
                  <div class="text-xs text-slate-500"><%= p.qtySold %> vendu(s) · SKU <%= p.sku || '—' %></div>
                </div>
                <div class="text-right">
                  <div class="font-semibold text-emerald-700 tabular-nums">+<%= (p.margin / 100).toFixed(2) %> €</div>
                  <div class="text-xs text-slate-500"><%= p.marginPct.toFixed(1) %> % · CA <%= (p.revenueTtc / 100).toFixed(0) %> €</div>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

    </div>

  <% } %>

</main>

<%- include('./partials/footer') %>
