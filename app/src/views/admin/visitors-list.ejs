<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'visitors' }) %>

<main class="flex-1 relative">
  <div class="px-6 lg:px-10 py-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Visiteurs'}] }) %>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Visiteurs en direct</div>
        <div class="mt-1 text-sm text-slate-500">Liste des dernières sessions avec leur source et leur activité.</div>
      </div>
    </div>

    <%
      function fmtRelative(date) {
        if (!date) return '—';
        var diff = Date.now() - new Date(date).getTime();
        if (diff < 60000) return 'à l\'instant';
        if (diff < 3600000) return Math.round(diff / 60000) + ' min';
        if (diff < 86400000) return Math.round(diff / 3600000) + ' h';
        return Math.round(diff / 86400000) + ' j';
      }
      var _badgeColors = {
        amber: 'bg-amber-50 text-amber-700 border-amber-200',
        blue: 'bg-blue-50 text-blue-700 border-blue-200',
        sky: 'bg-sky-50 text-sky-700 border-sky-200',
        emerald: 'bg-emerald-50 text-emerald-700 border-emerald-200',
        purple: 'bg-purple-50 text-purple-700 border-purple-200',
        slate: 'bg-slate-100 text-slate-600 border-slate-200',
      };
    %>

    <%/* Filtres */%>
    <form action="/admin/visiteurs" class="mt-6 bg-white rounded-2xl border border-slate-200 p-4 shadow-sm" method="GET">
      <div class="flex flex-col md:flex-row md:items-end gap-3 flex-wrap">
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-1">Période</label>
          <select class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-900" name="period">
            <option value="1h" <%= filters.period === '1h' ? 'selected' : '' %>>1 heure</option>
            <option value="24h" <%= filters.period === '24h' ? 'selected' : '' %>>24 heures</option>
            <option value="7d" <%= filters.period === '7d' ? 'selected' : '' %>>7 jours</option>
            <option value="30d" <%= filters.period === '30d' ? 'selected' : '' %>>30 jours</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-1">Conversion</label>
          <select class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-900" name="converted">
            <option value="" <%= !filters.converted ? 'selected' : '' %>>Tous</option>
            <option value="converted" <%= filters.converted === 'converted' ? 'selected' : '' %>>Acheteurs</option>
            <option value="not_converted" <%= filters.converted === 'not_converted' ? 'selected' : '' %>>Non-acheteurs</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-1">Source</label>
          <input type="text" name="source" value="<%= filters.source %>" placeholder="ex : google" class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-900 w-32" />
        </div>
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-1">Campagne</label>
          <input type="text" name="campaign" value="<%= filters.campaign %>" placeholder="ex : mecatro_dq381" class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-900 w-40" />
        </div>
        <div class="flex-1 min-w-[200px]">
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-1">Recherche libre</label>
          <input type="text" name="q" value="<%= filters.search %>" placeholder="produit, n° commande, mot recherché..." class="w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-900" />
        </div>
        <button class="btn btn-secondary" type="submit">Filtrer</button>
        <a href="/admin/visiteurs" class="text-sm text-slate-500 hover:text-slate-700 font-semibold py-2.5">Réinitialiser</a>
      </div>
    </form>

    <%/* Tableau */%>
    <div class="mt-6 bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
        <div class="font-semibold text-slate-900">
          <%= sessions.length %> session<%= sessions.length > 1 ? 's' : '' %>
          <% if (sessions.length === 100) { %><span class="ml-1 text-xs text-slate-500 font-normal">(limité aux 100 plus récentes)</span><% } %>
        </div>
        <div class="text-xs text-slate-500" id="visitors-auto-refresh">Rafraîchissement auto toutes les 30s</div>
      </div>

      <% if (!dbConnected) { %>
        <div class="p-6 text-sm text-amber-700 bg-amber-50 border-t border-amber-200">
          <strong>Mode démo :</strong> base de données indisponible.
        </div>
      <% } else if (!sessions.length) { %>
        <div class="p-12 text-center text-sm text-slate-500">
          <span class="material-symbols-outlined text-4xl text-slate-300">visibility</span>
          <div class="mt-3 font-semibold text-slate-700">Aucune session pour cette période</div>
          <div class="mt-1">Dès qu'un visiteur arrive, il apparaîtra ici.</div>
        </div>
      <% } else { %>
        <%/* ── Mobile : cards stack ───────────────────────────────────── */%>
        <ul class="md:hidden divide-y divide-slate-100">
          <% sessions.forEach(function(s) {
               var sid = s._id || '';
               var sourceLabel = s.source ? s.source : (s.gclid ? 'Google Ads' : 'Direct / SEO');
               var sourceColor = s.gclid ? 'amber' : (s.source === 'facebook' ? 'blue' : (s.source === 'google' ? 'sky' : 'slate'));
               var pillCls = _badgeColors[sourceColor] || _badgeColors.slate;
               var converted = !!s.orderId;
          %>
            <li>
              <a href="/admin/visiteurs/<%= encodeURIComponent(sid) %>" class="block px-5 py-4 hover:bg-slate-50 active:bg-slate-100 transition">
                <%/* Ligne 1 : Source badge + temps relatif + chevron */%>
                <div class="flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 min-w-0 flex-1">
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[11px] font-bold <%= pillCls %> shrink-0">
                      <%= sourceLabel %>
                    </span>
                    <% if (converted) { %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-50 text-green-700 border border-green-200 text-[11px] font-bold shrink-0">
                        ✓ <%= s.orderTotalCents ? formatEuro(s.orderTotalCents) : 'OK' %>
                      </span>
                    <% } else if (s.addToCartCount > 0) { %>
                      <span class="text-[11px] text-amber-600 font-bold shrink-0">⚠ panier abandon</span>
                    <% } %>
                  </div>
                  <div class="text-[11px] text-slate-400 shrink-0">il y a <%= fmtRelative(s.lastSeenAt) %></div>
                </div>

                <%/* Ligne 2 : Campagne ou page */%>
                <% if (s.campaign) { %>
                  <div class="mt-1.5 text-sm font-semibold text-slate-900 truncate"><%= s.campaign %></div>
                <% } %>
                <div class="mt-0.5 text-xs text-slate-500 truncate"><%= (s.lastPage || '/').slice(0, 80) %></div>

                <%/* Ligne 3 : Compteurs en chips */%>
                <div class="mt-2 flex items-center gap-2 flex-wrap text-[11px] text-slate-600">
                  <span class="inline-flex items-center gap-0.5">
                    <span class="material-symbols-outlined" style="font-size:13px"><%= s.deviceType === 'mobile' ? 'smartphone' : (s.deviceType === 'tablet' ? 'tablet' : 'computer') %></span>
                    <%= s.pageviewCount || 0 %> page<%= (s.pageviewCount || 0) > 1 ? 's' : '' %>
                  </span>
                  <% if (s.addToCartCount > 0) { %>
                    <span class="inline-flex items-center gap-0.5 text-emerald-700 font-semibold">
                      <span class="material-symbols-outlined" style="font-size:13px">add_shopping_cart</span>
                      <%= s.addToCartCount %>
                    </span>
                  <% } %>
                  <% if (s.clickPhoneCount > 0) { %><span class="inline-flex items-center text-blue-600 font-semibold">📞 <%= s.clickPhoneCount %></span><% } %>
                  <% if (s.clickEmailCount > 0) { %><span class="inline-flex items-center text-blue-600 font-semibold">✉ <%= s.clickEmailCount %></span><% } %>
                  <% if (s.clickWhatsappCount > 0) { %><span class="inline-flex items-center text-green-600 font-semibold">💬 <%= s.clickWhatsappCount %></span><% } %>
                  <span class="ml-auto text-[10px] text-slate-400 font-mono"><%= sid.slice(0, 8) %>…</span>
                </div>
              </a>
            </li>
          <% }); %>
        </ul>

        <%/* ── Desktop : tableau classique ─────────────────────────── */%>
        <div class="overflow-x-auto hidden md:block">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-white border-b border-slate-200 text-left text-[10px] font-bold uppercase tracking-widest text-slate-400">
                <th class="px-6 py-3">Visiteur</th>
                <th class="px-6 py-3">Source</th>
                <th class="px-6 py-3">Page</th>
                <th class="px-6 py-3 text-center">Pages</th>
                <th class="px-6 py-3 text-center">Panier</th>
                <th class="px-6 py-3 text-center">Contact</th>
                <th class="px-6 py-3 text-center">Conversion</th>
                <th class="px-6 py-3">Activité</th>
                <th class="px-6 py-3 text-right"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% sessions.forEach(function(s) {
                   var sid = s._id || '';
                   var sourceLabel = s.source ? s.source : (s.gclid ? 'Google Ads' : 'Direct / SEO');
                   var sourceColor = s.gclid ? 'amber' : (s.source === 'facebook' ? 'blue' : (s.source === 'google' ? 'sky' : 'slate'));
                   var pillCls = _badgeColors[sourceColor] || _badgeColors.slate;
                   var converted = !!s.orderId;
              %>
                <tr class="hover:bg-slate-50">
                  <td class="px-6 py-4">
                    <div class="font-mono text-xs text-slate-700"><%= sid.slice(0, 12) %><%= sid.length > 12 ? '…' : '' %></div>
                    <div class="mt-0.5 text-[11px] text-slate-400">
                      <span class="material-symbols-outlined" style="font-size:13px;vertical-align:-2px"><%= s.deviceType === 'mobile' ? 'smartphone' : (s.deviceType === 'tablet' ? 'tablet' : 'computer') %></span>
                      <%= s.deviceType || 'desktop' %>
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[11px] font-bold <%= pillCls %>">
                      <%= sourceLabel %>
                    </span>
                    <% if (s.campaign) { %>
                      <div class="mt-1 text-xs text-slate-700 font-medium"><%= s.campaign %></div>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-xs text-slate-600 max-w-xs truncate"><%= (s.lastPage || '').slice(0, 60) %></td>
                  <td class="px-6 py-4 text-center text-sm tabular-nums"><%= s.pageviewCount || 0 %></td>
                  <td class="px-6 py-4 text-center">
                    <% if (s.addToCartCount > 0) { %>
                      <span class="inline-flex items-center gap-1 text-emerald-700 font-semibold text-xs">
                        <span class="material-symbols-outlined" style="font-size:14px">add_shopping_cart</span>
                        <%= s.addToCartCount %>
                      </span>
                    <% } else { %>
                      <span class="text-slate-300">—</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-center">
                    <% if (s.clickPhoneCount > 0 || s.clickEmailCount > 0 || s.clickWhatsappCount > 0) { %>
                      <div class="inline-flex items-center gap-1.5">
                        <% if (s.clickPhoneCount > 0) { %><span class="material-symbols-outlined text-blue-600" style="font-size:16px" title="<%= s.clickPhoneCount %> clic(s) téléphone">call</span><% } %>
                        <% if (s.clickEmailCount > 0) { %><span class="material-symbols-outlined text-blue-600" style="font-size:16px" title="<%= s.clickEmailCount %> clic(s) email">mail</span><% } %>
                        <% if (s.clickWhatsappCount > 0) { %><span class="material-symbols-outlined text-green-600" style="font-size:16px" title="<%= s.clickWhatsappCount %> clic(s) whatsapp">chat</span><% } %>
                      </div>
                    <% } else { %>
                      <span class="text-slate-300">—</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-center">
                    <% if (converted) { %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-50 text-green-700 border border-green-200 text-[11px] font-bold">
                        <span class="material-symbols-outlined" style="font-size:13px">check_circle</span>
                        <%= s.orderTotalCents ? formatEuro(s.orderTotalCents) : 'OK' %>
                      </span>
                    <% } else if (s.addToCartCount > 0) { %>
                      <span class="text-xs text-amber-600 font-semibold">Panier abandon</span>
                    <% } else { %>
                      <span class="text-xs text-slate-400">—</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4">
                    <div class="text-xs text-slate-700 font-semibold">il y a <%= fmtRelative(s.lastSeenAt) %></div>
                    <div class="text-[11px] text-slate-400"><%= s.eventCount || 0 %> events</div>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <a href="/admin/visiteurs/<%= encodeURIComponent(sid) %>" class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 hover:text-indigo-800">
                      Timeline
                      <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
                    </a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div class="mt-4 text-xs text-slate-400">
      <strong>Note :</strong> chaque visiteur est identifié par un cookie de session (sessionId). Les visiteurs connectés sont aussi liés par leur compte (cross-device). Données conservées 90 jours.
    </div>
  </div>
</main>

<script>
  // Refresh auto toutes les 30s pour ne pas surcharger
  setTimeout(function() { window.location.reload(); }, 30000);
</script>

<%- include('./partials/footer') %>
