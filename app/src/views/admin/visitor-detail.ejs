<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'visitors' }) %>

<%
  // Métadonnées par type d'event : icône + couleur + libellé humain
  var EVENT_META = {
    pageview: { icon: 'visibility', color: 'slate', label: 'Visite page' },
    page_exit: { icon: 'exit_to_app', color: 'slate', label: 'Sortie page' },
    product_view: { icon: 'inventory_2', color: 'sky', label: 'Vue produit' },
    product_interaction: { icon: 'pan_tool', color: 'sky', label: 'Interaction produit' },
    add_to_cart: { icon: 'add_shopping_cart', color: 'emerald', label: 'Ajout au panier' },
    remove_from_cart: { icon: 'remove_shopping_cart', color: 'amber', label: 'Retrait panier' },
    update_qty: { icon: 'edit', color: 'amber', label: 'Modif quantité' },
    checkout_start: { icon: 'shopping_cart_checkout', color: 'indigo', label: 'Début checkout' },
    funnel_step: { icon: 'route', color: 'indigo', label: 'Étape funnel' },
    order_placed: { icon: 'celebration', color: 'green', label: 'COMMANDE 🎉' },
    click_phone: { icon: 'call', color: 'blue', label: 'Clic téléphone' },
    click_email: { icon: 'mail', color: 'blue', label: 'Clic email' },
    click_whatsapp: { icon: 'chat', color: 'green', label: 'Clic WhatsApp' },
    click_social_share: { icon: 'share', color: 'purple', label: 'Partage social' },
    contact_submit: { icon: 'contact_mail', color: 'purple', label: 'Formulaire contact' },
    quote_request: { icon: 'request_quote', color: 'purple', label: 'Demande de devis' },
    newsletter_signup: { icon: 'subscriptions', color: 'purple', label: 'Inscription newsletter' },
    account_create: { icon: 'person_add', color: 'green', label: 'Création de compte' },
    login: { icon: 'login', color: 'slate', label: 'Connexion' },
    search: { icon: 'search', color: 'sky', label: 'Recherche' },
    filter_applied: { icon: 'filter_list', color: 'slate', label: 'Filtre appliqué' },
  };
  function metaFor(t) { return EVENT_META[t] || { icon: 'circle', color: 'slate', label: t }; }
  var COLOR_CLASSES = {
    slate: { bg: 'bg-slate-100', text: 'text-slate-600', border: 'border-slate-200' },
    sky: { bg: 'bg-sky-100', text: 'text-sky-600', border: 'border-sky-200' },
    emerald: { bg: 'bg-emerald-100', text: 'text-emerald-700', border: 'border-emerald-200' },
    amber: { bg: 'bg-amber-100', text: 'text-amber-700', border: 'border-amber-200' },
    indigo: { bg: 'bg-indigo-100', text: 'text-indigo-700', border: 'border-indigo-200' },
    green: { bg: 'bg-green-100', text: 'text-green-700', border: 'border-green-200' },
    blue: { bg: 'bg-blue-100', text: 'text-blue-700', border: 'border-blue-200' },
    purple: { bg: 'bg-purple-100', text: 'text-purple-700', border: 'border-purple-200' },
  };
  function fmtTime(d) {
    if (!d) return '';
    var dt = new Date(d);
    return dt.toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  function fmtDuration(ms) {
    if (!ms || ms < 0) return '';
    if (ms < 1000) return ms + ' ms';
    if (ms < 60000) return Math.round(ms / 1000) + ' s';
    return Math.round(ms / 60000) + ' min';
  }

  // Extrait un nom lisible depuis un slug d'URL produit.
  // /product/mecatronique-dsg7-dq381-0de-...  →  "Mécatronique DSG7 DQ381"
  function readableFromSlug(path) {
    if (!path) return '';
    var m = path.match(/\/product[s]?\/([^\/?#]+)/);
    if (!m) return '';
    var slug = decodeURIComponent(m[1] || '');
    // Coupe les bouts de hash (UUID-like) à la fin
    slug = slug.replace(/-(\d+[a-z]+|[a-f0-9]{8,}).*/i, '');
    var words = slug.split('-').filter(Boolean);
    return words.map(function(w) {
      // Garde DQ381, VW, etc. en majuscules
      if (/^(dq|dsg|tcu|vin|vw|bmw|gp|spi)\d*$/i.test(w)) return w.toUpperCase();
      return w.charAt(0).toUpperCase() + w.slice(1);
    }).join(' ');
  }

  // Dédoublonnage : on n'affiche qu'UN event par couple pageview/funnel_step
  // émis dans la même seconde sur la même page (sinon on a 2 events identiques).
  function dedupeEvents(events) {
    var out = [];
    var i = 0;
    while (i < events.length) {
      var ev = events[i];
      var next = events[i + 1];
      if (next
          && ev.type === 'pageview'
          && next.type === 'funnel_step'
          && Math.abs(new Date(next.createdAt).getTime() - new Date(ev.createdAt).getTime()) < 2000
          && (ev.page === next.page || !next.page)) {
        // On garde le pageview + on annote son funnelStep depuis le suivant
        ev.funnelStep = next.funnelStep || ev.funnelStep;
        out.push(ev);
        i += 2;
      } else {
        out.push(ev);
        i += 1;
      }
    }
    return out;
  }

  var displayEvents = dedupeEvents(data.events);
%>

<main class="flex-1 relative">
  <div class="px-6 lg:px-10 py-8">
    <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Visiteurs', url: '/admin/visiteurs'}, {label: 'Timeline'}] }) %>

    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6 mt-2">
      <div>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Timeline visiteur</div>
        <div class="mt-1 text-xs text-slate-500 font-mono"><%= data.sessionId %></div>
        <% if (data.relatedSessions.length > 1) { %>
          <div class="mt-1 text-xs text-indigo-600">
            🔗 <%= data.relatedSessions.length %> sessions liées (cross-device via compte)
          </div>
        <% } %>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full bg-green-50 text-green-700 border border-green-200 text-xs font-bold">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Rafraîchissement live (5 s)
        </span>
      </div>
    </div>

    <%/* Carte d'identité du visiteur */%>
    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Identité</div>
        <% if (data.user) { %>
          <div class="mt-2 font-semibold text-slate-900"><%= [data.user.firstName, data.user.lastName].filter(Boolean).join(' ') || data.user.email %></div>
          <div class="text-xs text-slate-500"><%= data.user.email %></div>
          <div class="mt-1 text-[11px] text-slate-400"><%= data.user.accountType === 'pro' ? 'Pro' : 'Particulier' %><% if (data.user.companyName) { %> · <%= data.user.companyName %><% } %></div>
        <% } else { %>
          <div class="mt-2 text-slate-400 italic">Visiteur anonyme</div>
        <% } %>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Source</div>
        <div class="mt-2 font-semibold text-slate-900">
          <% if (data.source.gclid) { %>
            <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-amber-600" style="font-size:18px">ads_click</span> Google Ads</span>
          <% } else if (data.source.source) { %>
            <%= data.source.source %><% if (data.source.medium) { %> · <%= data.source.medium %><% } %>
          <% } else { %>
            Direct / SEO
          <% } %>
        </div>
        <% if (data.source.campaign) { %>
          <div class="text-xs text-slate-700 font-medium mt-1">Campagne : <%= data.source.campaign %></div>
        <% } %>
        <% if (data.source.referrer) { %>
          <div class="text-[11px] text-slate-400 mt-1 truncate" title="<%= data.source.referrer %>">↩ <%= data.source.referrer %></div>
        <% } %>
        <div class="mt-1 text-[11px] text-slate-400"><%= data.source.deviceType || 'desktop' %></div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Activité</div>
        <div class="mt-2 grid grid-cols-2 gap-x-3 gap-y-1 text-xs">
          <span class="text-slate-500">Pages vues</span><span class="font-semibold text-slate-900"><%= data.summary.pageviewCount %></span>
          <span class="text-slate-500">Ajouts panier</span><span class="font-semibold text-slate-900"><%= data.summary.addToCartCount %></span>
          <span class="text-slate-500">Retraits panier</span><span class="font-semibold text-slate-900"><%= data.summary.removeFromCartCount %></span>
          <span class="text-slate-500">Clics tél / mail / WA</span><span class="font-semibold text-slate-900"><%= data.summary.clickPhoneCount %> / <%= data.summary.clickEmailCount %> / <%= data.summary.clickWhatsappCount %></span>
          <span class="text-slate-500">Total events</span><span class="font-semibold text-slate-900"><%= data.summary.eventsCount %></span>
        </div>
        <% if (data.summary.converted) { %>
          <div class="mt-3 inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-50 text-green-700 border border-green-200 text-[11px] font-bold">
            <span class="material-symbols-outlined" style="font-size:13px">paid</span>
            <%= formatEuro(data.summary.revenueCents) %> commandé
          </div>
        <% } else if (data.summary.addToCartCount > 0) { %>
          <div class="mt-3 inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 border border-amber-200 text-[11px] font-bold">
            Panier abandonné
          </div>
        <% } %>
      </div>
    </div>

    <%/* Timeline */%>
    <div class="mt-6 bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
        <div class="font-semibold text-slate-900">Timeline (<span id="timeline-count"><%= displayEvents.length %></span> action<%= displayEvents.length > 1 ? 's' : '' %>)</div>
        <% if (data.orders.length) { %>
          <div class="flex gap-2">
            <%
              var _paidStatuses = ['paid', 'processing', 'label_created', 'shipped', 'delivered', 'completed'];
              var _statusLabels = { cancelled: 'Annulée', refunded: 'Remboursée', pending_payment: 'En attente de paiement', draft: 'Brouillon' };
            %>
            <% data.orders.forEach(function(o) {
                 var _isPaid = _paidStatuses.indexOf(o.status) >= 0;
                 var _statusLabel = _statusLabels[o.status] || o.status;
            %>
              <a href="/admin/commandes/<%= o._id %>" class="inline-flex items-center gap-1 px-3 py-1 rounded-lg border text-xs font-bold <%= _isPaid ? 'bg-green-50 text-green-700 border-green-200 hover:bg-green-100' : 'bg-rose-50 text-rose-700 border-rose-200 hover:bg-rose-100' %>">
                <span class="material-symbols-outlined" style="font-size:14px">receipt_long</span>
                Commande <%= o.number %><% if (!_isPaid) { %> · <%= _statusLabel %><% } %>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>

      <div id="timeline-container">
        <% if (!displayEvents.length) { %>
          <div class="text-center text-sm text-slate-500 py-12">Aucun événement pour cette session.</div>
        <% } else { %>
          <ul class="divide-y divide-slate-100">
            <% displayEvents.forEach(function(ev, idx) {
                 var m = metaFor(ev.type);
                 var c = COLOR_CLASSES[m.color] || COLOR_CLASSES.slate;
                 var productLabel = ev.productName || readableFromSlug(ev.page) || '';
            %>
              <li class="px-6 py-4 flex items-start gap-4 hover:bg-slate-50/60 transition">
                <%/* Numéro d'étape + icône — toujours alignés à gauche */%>
                <div class="flex-shrink-0 flex flex-col items-center" style="width:48px">
                  <span class="text-[10px] font-bold text-slate-300 mb-1"><%= String(idx + 1).padStart(2, '0') %></span>
                  <span class="flex items-center justify-center w-9 h-9 rounded-full <%= c.bg %> <%= c.text %>">
                    <span class="material-symbols-outlined" style="font-size:18px;line-height:1"><%= m.icon %></span>
                  </span>
                </div>

                <%/* Contenu principal */%>
                <div class="flex-1 min-w-0">
                  <div class="flex items-baseline gap-2 flex-wrap">
                    <span class="font-semibold text-slate-900 text-sm"><%= m.label %></span>
                    <span class="text-[11px] text-slate-400 font-mono"><%= fmtTime(ev.createdAt) %></span>
                    <% if (ev.durationMs > 0) { %>
                      <span class="text-[11px] text-slate-500">· resté <%= fmtDuration(ev.durationMs) %></span>
                    <% } %>
                  </div>
                  <div class="mt-1 text-sm text-slate-700">
                    <% if (ev.type === 'pageview' || ev.type === 'page_exit') { %>
                      <% if (productLabel) { %>
                        <div class="font-semibold text-slate-900"><%= productLabel %></div>
                      <% } %>
                      <code class="text-[11px] text-slate-500 break-all"><%= (ev.page || '').slice(0, 120) %></code>
                    <% } else if (ev.type === 'add_to_cart' || ev.type === 'remove_from_cart' || ev.type === 'update_qty') { %>
                      <% if (productLabel) { %>
                        <span class="font-semibold text-slate-900"><%= productLabel %></span>
                      <% } %>
                      <% if (ev.cart && ev.cart.qtyChange) { %>
                        <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full <%= ev.cart.qtyChange > 0 ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %> text-[11px] font-bold">
                          <%= ev.cart.qtyChange > 0 ? '+' : '' %><%= ev.cart.qtyChange %>
                        </span>
                      <% } %>
                      <% if (ev.productPriceCents) { %><span class="ml-2 text-xs text-slate-500"><%= formatEuro(ev.productPriceCents) %></span><% } %>
                    <% } else if (ev.type === 'click_phone') { %>
                      <span class="font-semibold text-blue-700">📞 <%= ev.target %></span>
                    <% } else if (ev.type === 'click_email') { %>
                      <span class="font-semibold text-blue-700">✉️ <%= ev.target %></span>
                    <% } else if (ev.type === 'click_whatsapp') { %>
                      <span class="font-semibold text-green-700">💬 WhatsApp</span>
                      <span class="ml-2 text-xs text-slate-500"><%= (ev.target || '').slice(0, 80) %></span>
                    <% } else if (ev.type === 'order_placed') { %>
                      <span class="font-bold text-green-700 text-base">Commande <%= ev.orderNumber %></span>
                      <span class="ml-2 px-2 py-0.5 rounded-full bg-green-100 text-green-800 text-xs font-bold"><%= formatEuro(ev.orderTotalCents) %></span>
                    <% } else if (ev.type === 'product_interaction') { %>
                      <span class="text-slate-700"><%= ev.interaction || '' %></span>
                      <% if (productLabel) { %><span class="ml-2 font-semibold text-slate-900"><%= productLabel %></span><% } %>
                    <% } else if (ev.type === 'search') { %>
                      Recherche : <span class="font-semibold text-slate-900">« <%= ev.searchQuery %> »</span>
                      <span class="ml-2 text-xs text-slate-500"><%= ev.searchResultCount %> résultats</span>
                    <% } else if (ev.type === 'newsletter_signup') { %>
                      <span class="font-semibold text-purple-700">Inscription newsletter</span>
                    <% } else if (ev.type === 'contact_submit') { %>
                      <span class="font-semibold text-purple-700">Formulaire contact envoyé</span>
                    <% } else if (ev.type === 'quote_request') { %>
                      <span class="font-semibold text-purple-700">Demande de devis envoyée</span>
                    <% } else if (ev.type === 'account_create') { %>
                      <span class="font-semibold text-green-700">Création de compte</span>
                      <span class="ml-2 text-xs text-slate-500">(<%= ev.meta && ev.meta.accountType ? ev.meta.accountType : 'particulier' %>)</span>
                    <% } else if (ev.type === 'login') { %>
                      <span class="font-semibold text-slate-700">Connexion à son compte</span>
                    <% } else if (ev.type === 'filter_applied') { %>
                      <% if (ev.meta && typeof ev.meta === 'object') { %>
                        <% Object.keys(ev.meta).forEach(function(k) { %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-slate-100 text-slate-700 text-[11px] font-semibold mr-1"><%= k %> = <%= ev.meta[k] %></span>
                        <% }); %>
                      <% } %>
                    <% } else if (ev.type === 'funnel_step') { %>
                      <span class="text-slate-700"><%= ev.funnelStep %></span>
                      <% if (productLabel) { %><span class="ml-2 font-semibold text-slate-900"><%= productLabel %></span><% } %>
                    <% } else { %>
                      <%= ev.type %>
                      <% if (ev.target) { %><span class="ml-2 text-slate-500"><%= ev.target %></span><% } %>
                    <% } %>
                  </div>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    </div>

    <div class="mt-4 text-xs text-slate-400">
      Rafraîchissement automatique toutes les 5 secondes. Tu peux fermer la page à tout moment.
    </div>
  </div>
</main>

<script>
(function() {
  var sessionId = <%- JSON.stringify(data.sessionId) %>;
  var lastCount = <%= data.events.length %>; // raw count (avant dédup) — fiable

  function poll() {
    fetch('/admin/visiteurs/' + encodeURIComponent(sessionId) + '/events', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data || !data.ok) return;
        if (data.eventsCount > lastCount) {
          // Nouveau(x) event(s) → on recharge la page pour afficher proprement
          window.location.reload();
        }
      })
      .catch(function() {});
  }

  setInterval(poll, 5000);
})();
</script>

<%- include('./partials/footer') %>
