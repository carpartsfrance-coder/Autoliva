<div class="prep-card rounded-2xl border border-slate-200 bg-white p-4 shadow-sm" data-order="<%= o.id %>" data-state="<%= o.prepState %>">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <a href="/admin/commandes/<%= o.id %>" class="font-bold text-slate-900 hover:underline"><%= o.number %></a>
        <% if (o.isExchange) { %><span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">Échange · consigne</span><% } %>
        <% if (o.hasLabel) { %><span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">Étiquette créée</span><% } %>
      </div>
      <div class="text-sm text-slate-600 mt-0.5 truncate"><%= o.customerName || '—' %><% if (o.city) { %> · <%= o.city %><% } %></div>
    </div>
    <span class="shrink-0 text-xs font-bold px-2 py-1 rounded-lg <%= o.ageDays >= 2 ? 'bg-rose-100 text-rose-700' : 'bg-slate-100 text-slate-600' %>" title="Commande payée il y a <%= o.ageDays %> jour(s)">
      <% if (o.ageDays >= 2) { %><span class="material-symbols-outlined text-sm align-middle">priority_high</span><% } %><%= o.ageDays === 0 ? "auj." : o.ageDays + ' j' %>
    </span>
  </div>

  <div class="mt-3 space-y-2">
    <% (o.items || []).forEach(function(it){ %>
      <div class="flex items-center gap-3 rounded-xl bg-slate-50 p-2">
        <% if (it.image) { %>
          <img src="<%= it.image %>" alt="" loading="lazy" class="w-12 h-12 rounded-lg object-cover bg-white border border-slate-200 shrink-0" />
        <% } else { %>
          <div class="w-12 h-12 rounded-lg bg-slate-200 flex items-center justify-center shrink-0"><span class="material-symbols-outlined text-slate-400">build</span></div>
        <% } %>
        <div class="min-w-0 flex-1">
          <div class="text-sm font-semibold text-slate-900 truncate"><%= it.name %></div>
          <div class="text-xs text-slate-500">
            <% if (it.ref) { %>Réf. <span class="font-mono font-semibold text-slate-700"><%= it.ref %></span><% } %><% if (it.category) { %> · <%= it.category %><% } %>
            <% if (it.inStock === false) { %> · <span class="text-rose-600 font-semibold">marqué épuisé</span><% } %>
          </div>
        </div>
        <span class="shrink-0 text-sm font-bold text-slate-900 bg-white border border-slate-200 rounded-lg px-2.5 py-1">×<%= it.quantity %></span>
      </div>
    <% }) %>
  </div>

  <% if (o.prepNote) { %><div class="mt-2 text-xs text-rose-600">⚠ <%= o.prepNote %></div><% } %>

  <div class="mt-3 grid grid-cols-3 gap-2">
    <button type="button" data-state-btn="todo" onclick="prepSetState('<%= o.id %>','todo')" class="prep-state-btn rounded-lg border px-2 py-2 text-xs font-bold <%= o.prepState==='todo'?'is-active':'' %>">À préparer</button>
    <button type="button" data-state-btn="ready" onclick="prepSetState('<%= o.id %>','ready')" class="prep-state-btn prep-ready rounded-lg border px-2 py-2 text-xs font-bold <%= o.prepState==='ready'?'is-active':'' %>">✅&nbsp;Prête</button>
    <button type="button" data-state-btn="blocked" onclick="prepSetState('<%= o.id %>','blocked')" class="prep-state-btn prep-blocked rounded-lg border px-2 py-2 text-xs font-bold <%= o.prepState==='blocked'?'is-active':'' %>">🚫&nbsp;Rupture</button>
  </div>

  <a href="/admin/commandes/<%= o.id %>" class="mt-2 flex items-center justify-center gap-1.5 w-full rounded-lg bg-slate-900 text-white px-3 py-2.5 text-sm font-bold hover:bg-slate-800 transition">
    <span class="material-symbols-outlined text-base">local_shipping</span> Étiquette &amp; expédition
  </a>
</div>
