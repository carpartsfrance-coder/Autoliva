<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'marketing' }) %>

<main class="flex-1 relative">
  <div class="px-6 lg:px-10 py-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Marketing'}] }) %>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Marketing &mdash; performance par campagne</div>
        <div class="mt-1 text-sm text-slate-500">Visites, ventes, CA et taux de conversion par campagne marketing.</div>
      </div>
    </div>

    <%
      // Helpers d'affichage
      function pct(rate) {
        if (!isFinite(rate) || rate <= 0) return '—';
        return (rate * 100).toFixed(rate < 0.001 ? 3 : (rate < 0.01 ? 2 : 1)) + ' %';
      }
      var _badgeColors = {
        amber: 'bg-amber-50 text-amber-700 border-amber-200',
        blue: 'bg-blue-50 text-blue-700 border-blue-200',
        sky: 'bg-sky-50 text-sky-700 border-sky-200',
        emerald: 'bg-emerald-50 text-emerald-700 border-emerald-200',
        purple: 'bg-purple-50 text-purple-700 border-purple-200',
        slate: 'bg-slate-100 text-slate-600 border-slate-200',
      };

      // Construit l'URL d'un en-tête cliquable pour le tri
      function sortUrl(field) {
        var nextDir = (filters.sort === field && filters.order === 'desc') ? 'asc' : 'desc';
        var qs = 'sort=' + encodeURIComponent(field) + '&order=' + encodeURIComponent(nextDir)
          + '&period=' + encodeURIComponent(filters.period)
          + '&model=' + encodeURIComponent(filters.model);
        return '/admin/marketing?' + qs;
      }
      function sortIcon(field) {
        if (filters.sort !== field) return '<span class="material-symbols-outlined text-[14px] text-slate-300">unfold_more</span>';
        return '<span class="material-symbols-outlined text-[14px] text-slate-700">' + (filters.order === 'asc' ? 'arrow_upward' : 'arrow_downward') + '</span>';
      }
    %>

    <%/* ── Filtres ───────────────────────────────────────────────────── */%>
    <form action="/admin/marketing" class="mt-6 bg-white rounded-2xl border border-slate-200 p-4 shadow-sm" method="GET">
      <div class="flex flex-col md:flex-row md:items-end gap-4">
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-1">Période</label>
          <select class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-900" name="period">
            <option value="7d" <%= filters.period === '7d' ? 'selected' : '' %>>7 derniers jours</option>
            <option value="30d" <%= filters.period === '30d' ? 'selected' : '' %>>30 derniers jours</option>
            <option value="90d" <%= filters.period === '90d' ? 'selected' : '' %>>90 derniers jours</option>
            <option value="365d" <%= filters.period === '365d' ? 'selected' : '' %>>12 derniers mois</option>
            <option value="all" <%= filters.period === 'all' ? 'selected' : '' %>>Tout l'historique</option>
          </select>
        </div>

        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-1">Modèle d'attribution</label>
          <select class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-900" name="model">
            <option value="last" <%= filters.model === 'last' ? 'selected' : '' %>>Dernier clic (qui a converti)</option>
            <option value="first" <%= filters.model === 'first' ? 'selected' : '' %>>Premier clic (qui a découvert)</option>
          </select>
        </div>

        <input type="hidden" name="sort" value="<%= filters.sort %>">
        <input type="hidden" name="order" value="<%= filters.order %>">

        <button class="btn btn-secondary" type="submit">Appliquer</button>

        <div class="ml-auto text-xs text-slate-500 max-w-md">
          <strong class="text-slate-700">Astuce :</strong> le modèle « dernier clic » crédite la pub qui a directement déclenché l'achat ; « premier clic » crédite celle qui a fait découvrir Autoliva. Le total des deux ne se compare donc pas.
        </div>
      </div>
    </form>

    <%/* ── KPIs globaux ──────────────────────────────────────────────── */%>
    <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Visites trackées</div>
        <div class="mt-2 text-2xl font-bold text-slate-900"><%= totals.visits.toLocaleString('fr-FR') %></div>
        <div class="mt-1 text-xs text-slate-500">Sessions avec UTM ou gclid</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Commandes</div>
        <div class="mt-2 text-2xl font-bold text-slate-900"><%= totals.orders.toLocaleString('fr-FR') %></div>
        <div class="mt-1 text-xs text-slate-500">Statut payée / livrée</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">CA TTC</div>
        <div class="mt-2 text-2xl font-bold text-slate-900"><%= formatEuro(totals.revenueCents) %></div>
        <div class="mt-1 text-xs text-slate-500">Panier moyen : <%= formatEuro(totals.aovCents) %></div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Taux conv. global</div>
        <div class="mt-2 text-2xl font-bold text-slate-900"><%- pct(totals.conversionRate) %></div>
        <div class="mt-1 text-xs text-slate-500">Commandes / visites</div>
      </div>
    </div>

    <%/* ── Tableau campagnes ────────────────────────────────────────── */%>
    <div class="mt-6 bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
        <div class="font-semibold text-slate-900">Détail par campagne</div>
        <div class="text-xs text-slate-500"><%= rows.length %> ligne<%= rows.length > 1 ? 's' : '' %></div>
      </div>

      <% if (!dbConnected) { %>
        <div class="p-6 text-sm text-amber-700 bg-amber-50 border-t border-amber-200">
          <strong>Mode démo :</strong> base de données indisponible.
        </div>
      <% } else if (!rows.length) { %>
        <div class="p-12 text-center text-sm text-slate-500">
          <span class="material-symbols-outlined text-4xl text-slate-300">analytics</span>
          <div class="mt-3 font-semibold text-slate-700">Aucune donnée pour cette période</div>
          <div class="mt-1">Dès qu'un visiteur arrivera avec un UTM ou un gclid, il apparaîtra ici.</div>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-white border-b border-slate-200 text-left text-[10px] font-bold uppercase tracking-widest text-slate-400">
                <th class="px-6 py-3">
                  <a class="inline-flex items-center gap-1 hover:text-slate-700" href="<%= sortUrl('campaign') %>">Campagne <%- sortIcon('campaign') %></a>
                </th>
                <th class="px-6 py-3">Source</th>
                <th class="px-6 py-3 text-right">
                  <a class="inline-flex items-center gap-1 hover:text-slate-700" href="<%= sortUrl('visits') %>">Visites <%- sortIcon('visits') %></a>
                </th>
                <th class="px-6 py-3 text-right">
                  <a class="inline-flex items-center gap-1 hover:text-slate-700" href="<%= sortUrl('orders') %>">Commandes <%- sortIcon('orders') %></a>
                </th>
                <th class="px-6 py-3 text-right">
                  <a class="inline-flex items-center gap-1 hover:text-slate-700" href="<%= sortUrl('revenue') %>">CA TTC <%- sortIcon('revenue') %></a>
                </th>
                <th class="px-6 py-3 text-right">
                  <a class="inline-flex items-center gap-1 hover:text-slate-700" href="<%= sortUrl('aov') %>">Panier moyen <%- sortIcon('aov') %></a>
                </th>
                <th class="px-6 py-3 text-right">
                  <a class="inline-flex items-center gap-1 hover:text-slate-700" href="<%= sortUrl('conversionRate') %>">Taux conv. <%- sortIcon('conversionRate') %></a>
                </th>
                <th class="px-6 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% rows.forEach(function(r) {
                   var trClass = r.isVirtual ? 'bg-slate-50/60 text-slate-600' : '';
                   var pillCls = _badgeColors[r.displayBadge] || _badgeColors.slate;
                   var drillUrl = '';
                   if (r.isCampaign) {
                     var qsParts = [];
                     if (r.campaign) qsParts.push('utmCampaign=' + encodeURIComponent(r.campaign));
                     if (r.source) qsParts.push('utmSource=' + encodeURIComponent(r.source));
                     if (filters.period && filters.period !== 'all') qsParts.push('period=' + encodeURIComponent(filters.period));
                     drillUrl = '/admin/commandes' + (qsParts.length ? '?' + qsParts.join('&') : '');
                   }
              %>
                <tr class="<%= trClass %>">
                  <td class="px-6 py-4">
                    <% if (r.campaign) { %>
                      <div class="font-semibold text-slate-900"><%= r.campaign %></div>
                      <% if (r.medium) { %>
                        <div class="mt-0.5 text-xs text-slate-400"><%= r.medium %></div>
                      <% } %>
                    <% } else { %>
                      <div class="font-semibold italic"><%= r.displayLabel %></div>
                    <% } %>
                  </td>
                  <td class="px-6 py-4">
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[11px] font-bold <%= pillCls %>">
                      <span class="material-symbols-outlined" style="font-size:13px"><%= r.displayIcon %></span>
                      <%= r.displaySource %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-right tabular-nums"><%= r.visits ? r.visits.toLocaleString('fr-FR') : '—' %></td>
                  <td class="px-6 py-4 text-right tabular-nums font-semibold text-slate-900"><%= r.orders ? r.orders.toLocaleString('fr-FR') : '—' %></td>
                  <td class="px-6 py-4 text-right tabular-nums font-semibold text-slate-900"><%= r.revenueCents ? formatEuro(r.revenueCents) : '—' %></td>
                  <td class="px-6 py-4 text-right tabular-nums"><%= r.aovCents ? formatEuro(r.aovCents) : '—' %></td>
                  <td class="px-6 py-4 text-right tabular-nums"><%- pct(r.conversionRate) %></td>
                  <td class="px-6 py-4 text-right">
                    <% if (drillUrl) { %>
                      <a href="<%= drillUrl %>" class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 hover:text-indigo-800">
                        Voir commandes
                        <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
                      </a>
                    <% } else { %>
                      <span class="text-xs text-slate-300">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
            <tfoot>
              <tr class="bg-slate-50 border-t-2 border-slate-200 font-bold text-slate-900">
                <td class="px-6 py-3" colspan="2">Total (hors pré-tracking)</td>
                <td class="px-6 py-3 text-right tabular-nums"><%= totals.visits.toLocaleString('fr-FR') %></td>
                <td class="px-6 py-3 text-right tabular-nums"><%= totals.orders.toLocaleString('fr-FR') %></td>
                <td class="px-6 py-3 text-right tabular-nums"><%= formatEuro(totals.revenueCents) %></td>
                <td class="px-6 py-3 text-right tabular-nums"><%= formatEuro(totals.aovCents) %></td>
                <td class="px-6 py-3 text-right tabular-nums"><%- pct(totals.conversionRate) %></td>
                <td class="px-6 py-3"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% } %>
    </div>

    <div class="mt-4 text-xs text-slate-400">
      <strong>Note :</strong> les visites proviennent de la collection <code>attributiontouches</code> (TTL 180 jours). Les commandes proviennent de <code>orders.attribution.<%= filters.model === 'first' ? 'firstTouch' : 'lastTouch' %></code>. Une commande sans aucune trace UTM/gclid est rangée dans <em>Direct / SEO</em>. Les commandes d'avant la mise en place du tracking sont dans <em>Pré-tracking</em>.
    </div>
  </div>
</main>

<%- include('./partials/footer') %>
