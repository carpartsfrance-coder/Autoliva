<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'settings' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Produits vedette (page d'accueil)</div>
        <div class="mt-1 text-sm text-slate-500">Choisis les <%= limit %> produits affichés dans la section "Découvrez Nos Pièces", et leur ordre. Glisse-déposer pour réordonner.</div>
      </div>
      <a class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700" href="/admin/parametres">
        <span class="material-symbols-outlined text-base">arrow_back</span> Retour Paramètres
      </a>
    </div>

    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
      <div class="mt-8 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900">
        <div class="font-bold">OK</div>
        <div class="mt-1 text-sm"><%= successMessage %></div>
      </div>
    <% } %>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="mt-8 rounded-xl border border-red-200 bg-red-50 p-4 text-red-900">
        <div class="font-bold">Erreur</div>
        <div class="mt-1 text-sm"><%= errorMessage %></div>
      </div>
    <% } %>

    <form id="featured-form" action="/admin/parametres/produits-vedette" method="POST" class="mt-8 space-y-4">
      <div id="featured-slots-container" class="space-y-3">
        <% (slots || []).forEach(function(slot, idx) { %>
          <div class="featured-slot bg-white rounded-2xl border border-slate-200 p-4 transition-shadow"
               data-slot-index="<%= idx %>"
               draggable="true">
            <div class="flex items-stretch gap-3">

              <!-- Drag handle + position -->
              <div class="flex flex-col items-center justify-center px-2 cursor-move text-slate-400 hover:text-slate-600 select-none" title="Glisser pour réordonner">
                <span class="material-symbols-outlined text-base">drag_indicator</span>
                <span class="mt-1 inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary/10 text-primary font-bold text-xs slot-position-label"><%= idx + 1 %></span>
              </div>

              <!-- Hidden input — la valeur est l'id du produit choisi (ou vide) -->
              <input type="hidden" name="productIds" class="featured-slot-input" value="<%= slot.productId || '' %>" />

              <!-- État rempli (visible si un produit est choisi) -->
              <div class="featured-slot-filled flex-1 flex items-center gap-3 <%= slot.product ? '' : 'hidden' %>">
                <div class="featured-slot-thumb h-14 w-14 rounded-lg bg-slate-100 overflow-hidden flex-shrink-0 flex items-center justify-center">
                  <% if (slot.product && slot.product.imageUrl) { %>
                    <img src="<%= slot.product.imageUrl %>" alt="<%= slot.product.name %>" class="w-full h-full object-cover" />
                  <% } else { %>
                    <span class="material-symbols-outlined text-slate-400 text-base">image</span>
                  <% } %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="featured-slot-name text-sm font-semibold text-slate-900 truncate"><%= slot.product ? slot.product.name : '' %></div>
                  <div class="featured-slot-meta text-xs text-slate-500 truncate">
                    <% if (slot.product) { %>
                      <% if (slot.product.brand) { %><span><%= slot.product.brand %></span><% } %>
                      <% if (slot.product.brand && slot.product.sku) { %> · <% } %>
                      <% if (slot.product.sku) { %><span>Réf <%= slot.product.sku %></span><% } %>
                    <% } %>
                  </div>
                </div>
                <button type="button" class="featured-slot-change inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700">
                  <span class="material-symbols-outlined text-sm">swap_horiz</span> Changer
                </button>
                <button type="button" class="featured-slot-clear inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white hover:bg-red-50 hover:text-red-600 hover:border-red-200 p-2 text-slate-500" title="Vider ce slot">
                  <span class="material-symbols-outlined text-sm">close</span>
                </button>
              </div>

              <!-- État vide (recherche) -->
              <div class="featured-slot-empty flex-1 relative <%= slot.product ? 'hidden' : '' %>">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-slate-400 absolute left-3 top-1/2 -translate-y-1/2 text-base pointer-events-none">search</span>
                  <input type="text"
                         class="featured-slot-search w-full rounded-xl border border-slate-200 bg-slate-50 pl-10 pr-4 py-3 text-sm focus:ring-primary focus:border-primary"
                         placeholder="Rechercher un produit (nom, marque, SKU)…"
                         autocomplete="off" />
                </div>
                <!-- Dropdown des résultats -->
                <div class="featured-slot-results hidden absolute z-20 left-0 right-0 mt-2 bg-white rounded-xl border border-slate-200 shadow-lg max-h-72 overflow-y-auto"></div>
              </div>

            </div>
          </div>
        <% }); %>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end pt-4">
        <a class="btn btn-secondary" href="/admin/parametres">Retour</a>
        <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-primary hover:bg-red-700 text-white px-6 py-3 text-sm font-bold">
          <span class="material-symbols-outlined">save</span> Enregistrer
        </button>
      </div>

      <div class="text-xs text-slate-500 pt-2">
        Astuce : si tu sélectionnes moins de <%= limit %> produits, les positions vides sont automatiquement remplies par les produits récemment mis à jour.
      </div>
    </form>
  </div>
</main>

<script id="featured-products-data" type="application/json"><%- JSON.stringify(productOptions || []) %></script>

<script>
(function() {
  var container = document.getElementById('featured-slots-container');
  if (!container) return;

  var dataEl = document.getElementById('featured-products-data');
  var products = [];
  try { products = JSON.parse(dataEl.textContent || '[]'); } catch (_e) { products = []; }

  // ── Normalisation des chaînes pour la recherche (insensible à la casse + accents)
  function norm(s) {
    return String(s || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[̀-ͯ]/g, '');
  }

  // Pré-calcul des champs normalisés pour rapidité
  products.forEach(function(p) {
    p._search = norm(p.name) + ' ' + norm(p.brand) + ' ' + norm(p.sku);
  });

  // ── État courant : ids déjà sélectionnés (pour les exclure des résultats)
  function getSelectedIds() {
    var ids = [];
    container.querySelectorAll('.featured-slot-input').forEach(function(inp) {
      if (inp.value) ids.push(inp.value);
    });
    return ids;
  }

  // ── Recherche
  function search(query, excludeIds) {
    var q = norm(query);
    var excludeSet = new Set(excludeIds || []);
    var results = [];
    for (var i = 0; i < products.length; i += 1) {
      var p = products[i];
      if (excludeSet.has(p.id)) continue;
      if (q && p._search.indexOf(q) === -1) continue;
      results.push(p);
      if (results.length >= 50) break;
    }
    return results;
  }

  function escapeHtml(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderResults(slot, list) {
    var box = slot.querySelector('.featured-slot-results');
    if (!box) return;
    if (!list.length) {
      box.innerHTML = '<div class="px-4 py-3 text-sm text-slate-500">Aucun résultat</div>';
      box.classList.remove('hidden');
      return;
    }
    var html = list.map(function(p) {
      var meta = [];
      if (p.brand) meta.push(escapeHtml(p.brand));
      if (p.sku) meta.push('Réf ' + escapeHtml(p.sku));
      var img = p.imageUrl
        ? '<img src="' + escapeHtml(p.imageUrl) + '" alt="" class="w-10 h-10 object-cover rounded-md flex-shrink-0" />'
        : '<div class="w-10 h-10 rounded-md bg-slate-100 flex items-center justify-center flex-shrink-0"><span class="material-symbols-outlined text-slate-400 text-base">image</span></div>';
      return ''
        + '<button type="button" class="featured-slot-result w-full flex items-center gap-3 px-3 py-2 text-left hover:bg-slate-50 border-b border-slate-100 last:border-b-0"'
        + ' data-id="' + escapeHtml(p.id) + '"'
        + ' data-name="' + escapeHtml(p.name) + '"'
        + ' data-brand="' + escapeHtml(p.brand) + '"'
        + ' data-sku="' + escapeHtml(p.sku) + '"'
        + ' data-image="' + escapeHtml(p.imageUrl) + '">'
        + img
        + '<div class="flex-1 min-w-0">'
        +   '<div class="text-sm font-semibold text-slate-900 truncate">' + escapeHtml(p.name) + '</div>'
        +   '<div class="text-xs text-slate-500 truncate">' + meta.join(' · ') + '</div>'
        + '</div>'
        + '</button>';
    }).join('');
    box.innerHTML = html;
    box.classList.remove('hidden');
  }

  function fillSlot(slot, p) {
    var input = slot.querySelector('.featured-slot-input');
    var filled = slot.querySelector('.featured-slot-filled');
    var empty = slot.querySelector('.featured-slot-empty');
    var thumb = slot.querySelector('.featured-slot-thumb');
    var name = slot.querySelector('.featured-slot-name');
    var meta = slot.querySelector('.featured-slot-meta');
    var results = slot.querySelector('.featured-slot-results');
    var searchInput = slot.querySelector('.featured-slot-search');

    input.value = p.id;
    if (thumb) {
      if (p.imageUrl || p.image) {
        var url = p.imageUrl || p.image;
        thumb.innerHTML = '<img src="' + escapeHtml(url) + '" alt="" class="w-full h-full object-cover" />';
      } else {
        thumb.innerHTML = '<span class="material-symbols-outlined text-slate-400 text-base">image</span>';
      }
    }
    if (name) name.textContent = p.name || '';
    if (meta) {
      var parts = [];
      if (p.brand) parts.push(p.brand);
      if (p.sku) parts.push('Réf ' + p.sku);
      meta.textContent = parts.join(' · ');
    }
    if (results) { results.classList.add('hidden'); results.innerHTML = ''; }
    if (searchInput) searchInput.value = '';
    if (filled) filled.classList.remove('hidden');
    if (empty) empty.classList.add('hidden');
  }

  function clearSlot(slot) {
    var input = slot.querySelector('.featured-slot-input');
    var filled = slot.querySelector('.featured-slot-filled');
    var empty = slot.querySelector('.featured-slot-empty');
    var searchInput = slot.querySelector('.featured-slot-search');

    input.value = '';
    if (filled) filled.classList.add('hidden');
    if (empty) empty.classList.remove('hidden');
    if (searchInput) { searchInput.value = ''; searchInput.focus(); }
  }

  function refreshLabels() {
    var slots = container.querySelectorAll('.featured-slot');
    slots.forEach(function(s, idx) {
      s.dataset.slotIndex = String(idx);
      var label = s.querySelector('.slot-position-label');
      if (label) label.textContent = String(idx + 1);
    });
  }

  // ── Wiring par slot
  container.querySelectorAll('.featured-slot').forEach(bindSlot);

  function bindSlot(slot) {
    var searchInput = slot.querySelector('.featured-slot-search');
    var resultsBox = slot.querySelector('.featured-slot-results');
    var changeBtn = slot.querySelector('.featured-slot-change');
    var clearBtn = slot.querySelector('.featured-slot-clear');

    if (searchInput) {
      searchInput.addEventListener('input', function() {
        var list = search(searchInput.value, getSelectedIds());
        renderResults(slot, list);
      });
      searchInput.addEventListener('focus', function() {
        var list = search(searchInput.value, getSelectedIds());
        renderResults(slot, list);
      });
      searchInput.addEventListener('blur', function() {
        // Délai pour permettre le clic sur un résultat avant de fermer
        setTimeout(function() {
          if (resultsBox) resultsBox.classList.add('hidden');
        }, 150);
      });
    }

    if (resultsBox) {
      resultsBox.addEventListener('mousedown', function(e) {
        var btn = e.target.closest('.featured-slot-result');
        if (!btn) return;
        e.preventDefault();
        var p = {
          id: btn.dataset.id,
          name: btn.dataset.name,
          brand: btn.dataset.brand,
          sku: btn.dataset.sku,
          imageUrl: btn.dataset.image,
        };
        fillSlot(slot, p);
      });
    }

    if (changeBtn) {
      changeBtn.addEventListener('click', function() { clearSlot(slot); });
    }
    if (clearBtn) {
      clearBtn.addEventListener('click', function() { clearSlot(slot); });
    }

    // Drag & drop
    slot.addEventListener('dragstart', function(e) {
      slot.classList.add('opacity-50');
      e.dataTransfer.effectAllowed = 'move';
      try { e.dataTransfer.setData('text/plain', slot.dataset.slotIndex || ''); } catch(_e) {}
    });
    slot.addEventListener('dragend', function() {
      slot.classList.remove('opacity-50');
      container.querySelectorAll('.featured-slot').forEach(function(s) {
        s.classList.remove('ring-2', 'ring-primary', 'ring-offset-2');
      });
    });
    slot.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      slot.classList.add('ring-2', 'ring-primary', 'ring-offset-2');
    });
    slot.addEventListener('dragleave', function() {
      slot.classList.remove('ring-2', 'ring-primary', 'ring-offset-2');
    });
    slot.addEventListener('drop', function(e) {
      e.preventDefault();
      slot.classList.remove('ring-2', 'ring-primary', 'ring-offset-2');
      var dragging = container.querySelector('.featured-slot.opacity-50');
      if (!dragging || dragging === slot) return;
      // Insère dragging avant slot si dragging était après, sinon après
      var rect = slot.getBoundingClientRect();
      var halfway = rect.top + rect.height / 2;
      if (e.clientY < halfway) {
        container.insertBefore(dragging, slot);
      } else {
        container.insertBefore(dragging, slot.nextSibling);
      }
      refreshLabels();
    });
  }
})();
</script>

<%- include('./partials/footer') %>
