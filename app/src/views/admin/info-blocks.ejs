<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'catalog' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8 space-y-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Produits', url: '/admin/catalogue'}, {label: "Blocs d'information"}] }) %>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Blocs d'information</div>
        <div class="mt-1 text-sm text-slate-500">Créez des blocs réutilisables (conditions, garanties, consigne...) puis attachez-les aux fiches produit. Une modification du bloc se répercute sur toutes les fiches qui l'utilisent.</div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <a class="btn btn-secondary" href="/admin/catalogue">
          <span class="material-symbols-outlined mr-2 text-base">arrow_back</span>
          Retour catalogue
        </a>
      </div>
    </div>

    <% if (successMessage) { %>
      <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900">
        <div class="font-bold"><%= successMessage %></div>
      </div>
    <% } %>

    <% if (errorMessage) { %>
      <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="font-bold"><%= errorMessage %></div>
      </div>
    <% } %>

    <section class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
        <div class="font-semibold text-slate-900">Nouveau bloc d'information</div>
        <div class="mt-1 text-sm text-slate-500">Exemple : « Conditions — Moteurs reconditionnés », « Consigne &amp; retour »...</div>
      </div>

      <form action="/admin/catalogue/blocs" class="p-6 grid grid-cols-1 lg:grid-cols-2 gap-6" method="POST">
        <div>
          <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500" for="title">Titre</label>
          <input class="mt-2 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold" id="title" name="title" placeholder="Ex : Conditions — Moteurs reconditionnés" type="text" required />
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500" for="slug">Slug (identifiant pour l'import)</label>
          <input class="mt-2 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold" id="slug" name="slug" placeholder="Laisse vide = généré depuis le titre" type="text" />
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500" for="position">Position d'affichage</label>
          <select class="mt-2 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold" id="position" name="position">
            <% positions.forEach((p) => { %>
              <option value="<%= p.value %>"><%= p.label %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500" for="autoCategories">Pré-sélection auto (catégories)</label>
          <input class="mt-2 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold" id="autoCategories" name="autoCategories" placeholder="Ex : moteur, bloc moteur" type="text" />
          <div class="mt-2 text-xs text-slate-500">Mots-clés séparés par des virgules. Le bloc sera pré-coché sur les fiches dont la catégorie contient un de ces mots (modifiable par fiche).</div>
        </div>

        <div class="lg:col-span-2">
          <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500" for="content">Contenu (markdown simple)</label>
          <textarea class="mt-2 w-full min-h-[220px] rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-mono" id="content" name="content" placeholder="Texte du bloc. Markdown simple supporté : **gras**, listes avec - , titres ## ..."></textarea>
        </div>

        <div class="lg:col-span-2 flex justify-end">
          <button class="btn btn-primary" type="submit">
            <span class="material-symbols-outlined mr-2 text-base">save</span>
            Enregistrer le bloc
          </button>
        </div>
      </form>
    </section>

    <section class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
        <div class="font-semibold text-slate-900">Bibliothèque</div>
        <div class="mt-1 text-sm text-slate-500"><%= blocks && blocks.length ? blocks.length : 0 %> bloc(s) enregistré(s)</div>
      </div>

      <% if (blocks && blocks.length) { %>
        <div class="divide-y divide-slate-100">
          <% blocks.forEach((block) => { %>
            <div class="p-6 space-y-5">
              <div class="flex flex-col xl:flex-row xl:items-start xl:justify-between gap-4">
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-2">
                    <div class="text-lg font-semibold text-slate-900"><%= block.title %></div>
                    <span class="inline-flex items-center rounded-full bg-violet-50 px-3 py-1 text-[10px] font-semibold uppercase tracking-widest text-violet-700"><%= block.positionLabel %></span>
                    <span class="badge <%= block.isActive ? 'badge-actif' : 'badge-neutral' %>"><%= block.isActive ? 'Actif' : 'Inactif' %></span>
                  </div>
                  <div class="mt-2 text-sm text-slate-500">Slug : <span class="font-semibold text-slate-900"><%= block.slug %></span></div>
                  <% if (block.autoCategoriesText) { %>
                    <div class="mt-1 text-sm text-slate-500">Pré-sélection auto : <span class="font-semibold text-slate-900"><%= block.autoCategoriesText %></span></div>
                  <% } %>
                  <% if (block.content) { %>
                    <div class="mt-3 max-w-2xl whitespace-pre-line rounded-xl bg-slate-50 border border-slate-100 p-3 text-xs text-slate-600"><%= block.content.length > 280 ? block.content.slice(0, 280) + '…' : block.content %></div>
                  <% } %>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                  <form action="/admin/catalogue/blocs/<%= block.id %>/toggle" method="POST" data-ajax="true">
                    <button class="inline-flex items-center justify-center rounded-xl px-4 py-2 text-xs font-semibold uppercase tracking-wider transition <%= block.isActive ? 'bg-slate-100 text-slate-500 hover:bg-slate-200' : 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100' %>" type="submit">
                      <%= block.isActive ? 'Désactiver' : 'Réactiver' %>
                    </button>
                  </form>
                  <form action="/admin/catalogue/blocs/<%= block.id %>/supprimer" method="POST" data-ajax="true" data-confirm="Supprimer ce bloc ? Il sera détaché de toutes les fiches.">
                    <button class="inline-flex items-center justify-center rounded-xl px-4 py-2 text-xs font-semibold uppercase tracking-wider bg-red-50 text-red-700 hover:bg-red-100 transition" type="submit">Supprimer</button>
                  </form>
                </div>
              </div>

              <details class="rounded-2xl border border-slate-200 bg-slate-50">
                <summary class="cursor-pointer list-none px-5 py-4 font-semibold text-slate-900">Modifier ce bloc</summary>
                <form action="/admin/catalogue/blocs/<%= block.id %>" class="border-t border-slate-200 p-5 grid grid-cols-1 lg:grid-cols-2 gap-5" method="POST">
                  <div>
                    <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500">Titre</label>
                    <input class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" name="title" type="text" value="<%= block.title %>" />
                  </div>

                  <div>
                    <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500">Slug</label>
                    <input class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" name="slug" type="text" value="<%= block.slug %>" />
                  </div>

                  <div>
                    <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500">Position d'affichage</label>
                    <select class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" name="position">
                      <% positions.forEach((p) => { %>
                        <option value="<%= p.value %>" <%= block.position === p.value ? 'selected' : '' %>><%= p.label %></option>
                      <% }) %>
                    </select>
                  </div>

                  <div>
                    <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500">Pré-sélection auto (catégories)</label>
                    <input class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" name="autoCategories" type="text" value="<%= block.autoCategoriesText %>" />
                  </div>

                  <div class="lg:col-span-2">
                    <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500">Contenu (markdown simple)</label>
                    <textarea class="mt-2 w-full min-h-[220px] rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-mono" name="content"><%= block.content %></textarea>
                  </div>

                  <div class="lg:col-span-2 flex justify-end">
                    <button class="btn btn-primary" type="submit">
                      <span class="material-symbols-outlined mr-2 text-base">save</span>
                      Enregistrer les modifications
                    </button>
                  </div>
                </form>
              </details>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="p-6 text-sm text-slate-500">Aucun bloc d'information pour le moment.</div>
      <% } %>
    </section>
  </div>
</main>

<%- include('./partials/footer') %>
