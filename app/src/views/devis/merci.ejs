<%- include('../partials/head') %>
<% if (typeof refreshUrl !== 'undefined' && refreshUrl) { %>
<meta http-equiv="refresh" content="8;url=<%= refreshUrl %>">
<% } %>
<%- include('../partials/header') %>

<main class="flex-1 container mx-auto px-4 lg:px-8 py-10 sm:py-16">
  <div class="max-w-xl mx-auto">

    <% if (paid) { %>
      <%/* ───────── Acompte confirmé ───────── */%>
      <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="bg-emerald-50 px-6 sm:px-10 py-8 text-center border-b border-emerald-100">
          <div class="mx-auto w-16 h-16 rounded-full bg-emerald-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-[40px] text-emerald-600">check_circle</span>
          </div>
          <h1 class="mt-4 text-2xl sm:text-3xl font-display font-black text-slate-900">Acompte bien reçu&nbsp;!</h1>
          <p class="mt-2 text-sm text-emerald-700 font-semibold">Votre moteur est officiellement réservé.</p>
          <% if (ref) { %><p class="mt-1 text-xs text-slate-400">Dossier <%= ref %></p><% } %>
        </div>
        <div class="px-6 sm:px-10 py-8">
          <p class="text-sm font-bold text-slate-700 mb-4">Et maintenant&nbsp;?</p>
          <ol class="space-y-4">
            <li class="flex gap-3">
              <span class="shrink-0 w-7 h-7 rounded-full bg-slate-100 text-slate-700 text-sm font-black flex items-center justify-center">1</span>
              <div class="text-sm text-slate-600"><strong class="text-slate-900">Préparation &amp; banc d'essai</strong><br>Aucun moteur n'est expédié sans passer par notre banc d'essai.</div>
            </li>
            <li class="flex gap-3">
              <span class="shrink-0 w-7 h-7 rounded-full bg-slate-100 text-slate-700 text-sm font-black flex items-center justify-center">2</span>
              <div class="text-sm text-slate-600"><strong class="text-slate-900">Email d'expédition</strong><br>Vous recevrez le suivi transporteur dès l'envoi.</div>
            </li>
            <li class="flex gap-3">
              <span class="shrink-0 w-7 h-7 rounded-full bg-slate-100 text-slate-700 text-sm font-black flex items-center justify-center">3</span>
              <div class="text-sm text-slate-600"><strong class="text-slate-900">Solde à régler</strong><br>Une fois le moteur testé et déclaré conforme.</div>
            </li>
          </ol>
          <p class="mt-6 text-xs text-slate-400">Un email de confirmation vous a été envoyé. Une question&nbsp;?
            <% if (brandPhone) { %><a href="tel:<%= brandPhoneIntl || brandPhone %>" class="text-primary font-semibold whitespace-nowrap"><%= brandPhone %></a><% } %>
          </p>
        </div>
      </div>

    <% } else { %>
      <%/* ───────── Retour Mollie sans confirmation de paiement (en cours,
              annulé, ou lien expiré) — TOUJOURS rassurant, jamais une erreur ───────── */%>
      <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 sm:px-10 py-8 text-center border-b border-slate-100">
          <div class="mx-auto w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-[38px] text-slate-500">hourglass_top</span>
          </div>
          <h1 class="mt-4 text-2xl sm:text-3xl font-display font-black text-slate-900">Merci&nbsp;!</h1>
          <p class="mt-2 text-sm text-slate-500">Votre demande est bien prise en compte.</p>
          <% if (ref) { %><p class="mt-1 text-xs text-slate-400">Dossier <%= ref %></p><% } %>
        </div>
        <div class="px-6 sm:px-10 py-8 space-y-5">
          <div class="flex gap-3 rounded-xl bg-emerald-50 p-4">
            <span class="material-symbols-outlined text-[20px] text-emerald-600 shrink-0">mark_email_read</span>
            <p class="text-sm text-emerald-800">Si vous venez de <strong>régler l'acompte</strong>, votre confirmation arrive par <strong>email</strong> d'ici quelques minutes — cette page se met à jour automatiquement.</p>
          </div>
          <div class="flex gap-3 rounded-xl bg-amber-50 p-4">
            <span class="material-symbols-outlined text-[20px] text-amber-600 shrink-0">help</span>
            <p class="text-sm text-amber-900">Le <strong>paiement n'a pas abouti</strong> ou le <strong>lien a expiré</strong>&nbsp;? Pas d'inquiétude, rien n'est perdu&nbsp;: on vous renvoie un lien valide en un instant.</p>
          </div>
          <% if (brandPhone) { %>
            <a href="tel:<%= brandPhoneIntl || brandPhone %>" class="flex items-center justify-center gap-2 w-full rounded-xl bg-primary text-white py-3.5 font-black text-sm hover:bg-red-700 transition">
              <span class="material-symbols-outlined text-[20px]">call</span>
              Nous appeler — <%= brandPhone %>
            </a>
          <% } %>
          <a href="/" class="block text-center text-sm font-semibold text-slate-500 hover:text-slate-800">Retour à l'accueil</a>
        </div>
      </div>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
